@* 員工照片 Tab - 單張大頭照，結構與 CompanyLogoTab 一致 *@
@inject IEmployeeService EmployeeService
@inject INotificationService NotificationService
@inject IWebHostEnvironment Environment
@inject IStringLocalizer<SharedResource> L

@if (!EmployeeId.HasValue || EmployeeId.Value <= 0)
{
    <div class="text-center text-muted py-4">
        <i class="bi bi-person-circle fs-1 d-block mb-2"></i>
        <span>@L["EmployeePhoto.SaveFirst"]</span>
    </div>
}
else
{
    <div class="business-card-tab">

        @* Header *@
        <div class="d-flex align-items-center justify-content-between mb-3">
            <span class="fw-semibold">@L["Tab.EmployeePhoto"]</span>
            <label class="btn btn-sm btn-outline-primary" style="cursor:pointer; margin-bottom:0;">
                <i class="bi bi-upload me-1"></i>
                @(string.IsNullOrEmpty(currentPhotoPath) ? L["EmployeePhoto.Upload"] : L["EmployeePhoto.Change"])
                <InputFile OnChange="@HandleFileSelected" accept=".jpg,.jpeg,.png" class="d-none" />
            </label>
        </div>

        @if (!string.IsNullOrEmpty(uploadError))
        {
            <div class="alert alert-danger py-2 mb-2">@uploadError</div>
        }

        @if (isUploading)
        {
            <div class="text-center text-muted py-3">
                <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                @L["Label.PleaseWait"]
            </div>
        }

        @* 空狀態 *@
        @if (string.IsNullOrEmpty(currentPhotoPath))
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-person-circle fs-1 d-block mb-2"></i>
                <span>@L["EmployeePhoto.NoPhoto"]</span>
            </div>
        }
        else
        {
            <div class="business-card-grid">
                <div class="business-card-item">
                    <div class="business-card-photo-wrapper">
                        <img src="@currentPhotoPath" alt="Employee Photo"
                             class="business-card-photo employee-photo"
                             @onclick="OpenPreview" />
                    </div>
                    <div class="business-card-info px-2 py-1">
                        <span class="fw-semibold small">@L["Entity.Employee"]</span>
                        <span class="text-muted small d-block">@L["EmployeePhoto.Hint"]</span>
                    </div>
                    <div class="business-card-actions px-2 pb-2 d-flex gap-1">
                        <button class="btn btn-xs btn-outline-secondary flex-fill"
                                title="@L["Button.Preview"]"
                                type="button"
                                @onclick="OpenPreview">
                            <i class="bi bi-eye"></i>
                        </button>
                        <button class="btn btn-xs btn-outline-danger flex-fill"
                                title="@L["Button.Delete"]"
                                type="button"
                                @onclick="RequestDelete">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* 刪除確認 Modal *@
<GenericConfirmModalComponent IsVisible="@showDeleteModal"
                              IsVisibleChanged="@((bool v) => showDeleteModal = v)"
                              Title="@L["EmployeePhoto.Delete"]"
                              Icon="bi-trash"
                              Message="@L["EmployeePhoto.DeleteMessage"]"
                              ConfirmButtonText="@L["Button.ConfirmDelete"]"
                              CancelButtonText="@L["Button.Cancel"]"
                              ConfirmButtonVariant="ButtonVariant.Red"
                              HeaderColor="BaseModalComponent.HeaderVariant.Danger"
                              OnConfirm="@ConfirmDeleteAsync"
                              OnCancel="@(() => showDeleteModal = false)" />

@* 預覽 Modal *@
@if (showPreview)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.7);" @onclick="ClosePreview">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@L["Tab.EmployeePhoto"]</h5>
                    <button type="button" class="btn-close" @onclick="ClosePreview"></button>
                </div>
                <div class="modal-body text-center p-2">
                    <img src="@currentPhotoPath" class="img-fluid" alt="Employee Photo" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? EmployeeId { get; set; }
    [Parameter] public string? InitialPhotoPath { get; set; }

    private string? currentPhotoPath;
    private bool isUploading = false;
    private string? uploadError = null;
    private bool showDeleteModal = false;
    private bool showPreview = false;
    private int? _loadedEmployeeId;

    protected override void OnParametersSet()
    {
        if (EmployeeId != _loadedEmployeeId)
        {
            _loadedEmployeeId = EmployeeId;
            currentPhotoPath = InitialPhotoPath;
            uploadError = null;
        }
    }

    // ===== 公開方法（供主組件透過 @ref 呼叫） =====

    public void Load(int employeeId, string? photoPath)
    {
        currentPhotoPath = photoPath;
        uploadError = null;
        StateHasChanged();
    }

    public void Clear()
    {
        currentPhotoPath = null;
        uploadError = null;
        StateHasChanged();
    }

    // ===== 上傳 =====

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        if (!EmployeeId.HasValue || EmployeeId.Value <= 0) return;

        uploadError = null;
        isUploading = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            var (success, message, filePath) = await FileUploadHelper.UploadImageAsync(
                file, "employee-photos", Environment, currentPhotoPath);

            if (!success)
            {
                uploadError = message;
                return;
            }

            var result = await EmployeeService.UpdatePhotoPathAsync(EmployeeId.Value, filePath!);
            if (result.IsSuccess)
            {
                currentPhotoPath = filePath;
                await NotificationService.ShowSuccessAsync(L["EmployeePhoto.UploadSuccess"]);
            }
            else
            {
                uploadError = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            uploadError = $"上傳失敗：{ex.Message}";
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    // ===== 刪除 =====

    private void RequestDelete()
    {
        showDeleteModal = true;
        StateHasChanged();
    }

    private async Task ConfirmDeleteAsync()
    {
        if (string.IsNullOrEmpty(currentPhotoPath)) return;

        try
        {
            FileUploadHelper.DeleteFile(currentPhotoPath, Environment);
            var result = await EmployeeService.ClearPhotoAsync(EmployeeId!.Value);
            if (result.IsSuccess)
            {
                currentPhotoPath = null;
                await NotificationService.ShowSuccessAsync(L["EmployeePhoto.DeleteSuccess"]);
            }
            else
            {
                await NotificationService.ShowErrorAsync(result.ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"刪除失敗：{ex.Message}");
        }
        finally
        {
            showDeleteModal = false;
            StateHasChanged();
        }
    }

    // ===== 預覽 =====

    private void OpenPreview()
    {
        showPreview = true;
        StateHasChanged();
    }

    private void ClosePreview()
    {
        showPreview = false;
        StateHasChanged();
    }
}
