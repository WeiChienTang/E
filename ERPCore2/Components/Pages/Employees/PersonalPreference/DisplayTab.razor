@* 顯示設定 Tab — 主題顏色 + 字型縮放 *@
@inject IStringLocalizer<SharedResource> L

<div class="p-2">
    <div class="display-sections-container">

        @* 主題顏色 *@
        <div class="display-section-column">
            <div class="section-header mb-3">
                <span class="section-title">@L["Preference.Theme"]</span>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var option in _themeOptions)
                {
                    var isSelected = (Model ?? _fallback).Theme == option.Value;
                    <button type="button"
                            class="btn @(isSelected ? "btn-primary" : "btn-outline-secondary") theme-option-btn"
                            title="@option.Label"
                            @onclick="() => SelectTheme(option.Value)">
                        <i class="bi @option.Icon theme-icon"></i>
                        <span class="theme-label">@option.Label</span>
                    </button>
                }
            </div>
        </div>

        @* 字型縮放 *@
        <div class="display-section-column">
            <div class="section-header mb-3">
                <span class="section-title">@L["Preference.FontSize"]</span>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var option in _zoomOptions)
                {
                    var isSelected = (Model ?? _fallback).Zoom == option.Value;
                    <button type="button"
                            class="btn @(isSelected ? "btn-primary" : "btn-outline-secondary") zoom-option-btn"
                            title="@option.Label"
                            @onclick="() => SelectZoom(option.Value)">
                        <span class="zoom-preview" style="font-size: @option.PreviewSize;">Aa</span>
                        <span class="zoom-label">@option.Label</span>
                    </button>
                }
            </div>
        </div>

        @* 導覽列顯示設定 *@
        <div class="display-section-column">
            <div class="section-header mb-3">
                <span class="section-title">@L["Preference.NavDisplay"]</span>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var option in _navDisplayOptions)
                {
                    var isSelected = (Model ?? _fallback).ShowDisabledModules == option.Value;
                    <button type="button"
                            class="btn @(isSelected ? "btn-primary" : "btn-outline-secondary") theme-option-btn"
                            title="@option.Label"
                            @onclick="() => SelectNavDisplay(option.Value)">
                        <i class="bi @option.Icon theme-icon"></i>
                        <span class="theme-label">@option.Label</span>
                    </button>
                }
            </div>
        </div>

        @* 每頁顯示筆數 *@
        <div class="display-section-column">
            <div class="section-header mb-3">
                <span class="section-title">@L["Preference.PageSize"]</span>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var size in _pageSizeOptions)
                {
                    var isSelected = (Model ?? _fallback).DefaultPageSize == size;
                    <button type="button"
                            class="btn @(isSelected ? "btn-primary" : "btn-outline-secondary") zoom-option-btn"
                            title="@size"
                            @onclick="() => SelectPageSize(size)">
                        <span class="zoom-preview" style="font-size: 1rem;">@size</span>
                        <span class="zoom-label">@L["Preference.PageSizeUnit"]</span>
                    </button>
                }
            </div>
        </div>

        @* 操作偏好 *@
        <div class="display-section-column">
            <div class="section-header mb-3">
                <span class="section-title">@L["Preference.OperationBehavior"]</span>
            </div>
            <div class="mb-2">
                <div class="small text-muted mb-2">@L["Preference.UnsavedChangesWarning"]</div>
                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var option in _unsavedWarningOptions)
                    {
                        var isSelected = (Model ?? _fallback).ShowUnsavedChangesWarning == option.Value;
                        <button type="button"
                                class="btn @(isSelected ? "btn-primary" : "btn-outline-secondary") theme-option-btn"
                                title="@option.Label"
                                @onclick="() => SelectUnsavedChangesWarning(option.Value)">
                            <i class="bi @option.Icon theme-icon"></i>
                            <span class="theme-label">@option.Label</span>
                        </button>
                    }
                </div>
            </div>
            @if (!(Model ?? _fallback).ShowUnsavedChangesWarning)
            {
                <div class="alert alert-warning d-flex align-items-start gap-2 py-2 px-3 mt-2 mb-0" style="font-size: 0.82rem;">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
                    <span>@L["Preference.UnsavedChangesWarningDesc"]</span>
                </div>
            }
        </div>

    </div>
</div>

@code {
    [Parameter]
    public EmployeePreference? Model { get; set; }

    private readonly EmployeePreference _fallback = new();

    private record ThemeOption(AppTheme Value, string Label, string Icon);
    private record ZoomOption(ContentZoom Value, string Label, string PreviewSize);
    private record NavDisplayOption(bool Value, string Label, string Icon);
    private record BoolOption(bool Value, string Label, string Icon);

    private List<ThemeOption> _themeOptions = new();
    private List<NavDisplayOption> _navDisplayOptions = new();
    private List<BoolOption> _unsavedWarningOptions = new();

    private static readonly List<int> _pageSizeOptions = new() { 10, 20, 50, 100 };

    private static readonly List<ZoomOption> _zoomOptions = new()
    {
        new(ContentZoom.XSmall,  "75%",  "0.75rem"),
        new(ContentZoom.Small,   "90%",  "0.9rem"),
        new(ContentZoom.Medium,  "100%", "1rem"),
        new(ContentZoom.Large,   "110%", "1.1rem"),
        new(ContentZoom.XLarge,  "125%", "1.25rem"),
        new(ContentZoom.XXLarge, "150%", "1.5rem"),
    };

    protected override void OnInitialized()
    {
        _themeOptions = new List<ThemeOption>
        {
            new(AppTheme.Light, L["Preference.ThemeLight"], "bi-sun"),
            new(AppTheme.Dark,  L["Preference.ThemeDark"],  "bi-moon-stars"),
        };

        _navDisplayOptions = new List<NavDisplayOption>
        {
            new(false, L["Preference.HideDisabledModules"], "bi-eye-slash"),
            new(true,  L["Preference.ShowDisabledModules"], "bi-lock"),
        };

        _unsavedWarningOptions = new List<BoolOption>
        {
            new(true,  L["Preference.UnsavedChangesWarningOn"],  "bi-question-circle"),
            new(false, L["Preference.UnsavedChangesWarningOff"], "bi-box-arrow-right"),
        };
    }

    private void SelectTheme(AppTheme value)
    {
        (Model ?? _fallback).Theme = value;
        StateHasChanged();
    }

    private void SelectZoom(ContentZoom value)
    {
        (Model ?? _fallback).Zoom = value;
        StateHasChanged();
    }

    private void SelectNavDisplay(bool value)
    {
        (Model ?? _fallback).ShowDisabledModules = value;
        StateHasChanged();
    }

    private void SelectPageSize(int value)
    {
        (Model ?? _fallback).DefaultPageSize = value;
        StateHasChanged();
    }

    private void SelectUnsavedChangesWarning(bool value)
    {
        (Model ?? _fallback).ShowUnsavedChangesWarning = value;
        StateHasChanged();
    }
}
