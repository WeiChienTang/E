@* 個人化設定 Modal *@
@using Microsoft.AspNetCore.Components.Authorization
@inject IEmployeePreferenceService EmployeePreferenceService
@inject IEmployeeService EmployeeService
@inject INotificationService NotificationService
@inject INavigationPermissionService NavigationPermissionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> L

<BaseModalComponent IsVisible="@IsVisible"
                   IsVisibleChanged="@IsVisibleChanged"
                   Title="@L["Preference.Title"]"
                   Icon="bi bi-person-gear"
                   HeaderColor="BaseModalComponent.HeaderVariant.ProjectPrimary"
                   IsLoading="@isLoading"
                   LoadingMessage="@L["Preference.LoadingMessage"]"
                   OnClose="@HandleClose"
                   DebugComponentName="@DebugName">

    <HeaderButtons>
        <div class="d-flex gap-2 align-items-center">
            <GenericButtonComponent Variant="ButtonVariant.Green"
                                  Size="ButtonSize.Small"
                                  Text="@L["Button.Save"]"
                                  Icon="bi bi-check-lg"
                                  OnClick="HandleSave"
                                  IsDisabled="@isLoading"
                                  Title="@L["Preference.SaveTooltip"]" />
        </div>
    </HeaderButtons>

    <BodyContent>
        <GenericFormComponent TModel="EmployeePreference"
                              Model="@employeePreference"
                              FieldDefinitions="@allFields"
                              FieldSections="@fieldSections"
                              TabDefinitions="@tabDefinitions"
                              OnTabChanged="@HandleTabChanged" />
    </BodyContent>

</BaseModalComponent>

@code {
    // ===== 參數 =====

    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    [Parameter]
    public EventCallback OnSaved { get; set; }

    // ===== 私有欄位 =====

    private bool isLoading = false;
    private int? currentEmployeeId = null;

    // SuperAdmin 狀態（載入後確認，決定是否顯示 Debug Tab）
    private bool _isSuperAdmin = false;

    // 語言偏好 + 字型縮放 + 主題 + 快捷鍵
    private EmployeePreference employeePreference = new();
    private UILanguage _originalLanguage = UILanguage.ZhTW;   // 記錄載入時的語言，用於判斷是否需要 reload
    private ContentZoom _originalZoom = ContentZoom.Medium;    // 記錄載入時的縮放，用於判斷是否需要套用
    private AppTheme _originalTheme = AppTheme.Light;         // 記錄載入時的主題，用於判斷是否需要套用
    private bool _originalShowDisabledModules = false;         // 記錄載入時的導覽列顯示設定，用於判斷是否需要 reload
    private int _originalDefaultPageSize = 20;                 // 記錄載入時的每頁筆數，用於判斷是否需要 reload

    // 個人資料
    private Employee? currentEmployee = null;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;

    // Tab 定義
    private readonly List<FormFieldDefinition> allFields = new();
    private readonly Dictionary<string, string> fieldSections = new();
    private List<FormTabDefinition> tabDefinitions = new();

    // Debug Tab 追蹤（僅 SuperAdmin 可見的 Debug Bar 使用）
    private int _activeTabIndex = 0;

    /// <summary>
    /// Debug Bar 顯示名稱：PersonalPreferenceModalComponent 或 PersonalPreferenceModalComponent > TabComponentName
    /// </summary>
    private string DebugName
    {
        get
        {
            if (_activeTabIndex < 0 || _activeTabIndex >= tabDefinitions.Count)
                return "PersonalPreferenceModalComponent";
            var tabDebugName = tabDefinitions[_activeTabIndex].DebugComponentName;
            return string.IsNullOrEmpty(tabDebugName)
                ? "PersonalPreferenceModalComponent"
                : $"PersonalPreferenceModalComponent > {tabDebugName}";
        }
    }

    private void HandleTabChanged(int index)
    {
        _activeTabIndex = index;
        StateHasChanged();
    }

    // ===== Tab RenderFragment =====

    private RenderFragment CreatePersonalDataTabContent() => __builder =>
    {
        <PersonalDataTab Model="@currentEmployee"
                         NewPassword="@newPassword"
                         NewPasswordChanged="@((pwd) => { newPassword = pwd; StateHasChanged(); })"
                         ConfirmPassword="@confirmPassword"
                         ConfirmPasswordChanged="@((pwd) => { confirmPassword = pwd; StateHasChanged(); })" />
    };

    private RenderFragment CreateLanguageRegionTabContent() => __builder =>
    {
        <LanguageRegionTab Model="@employeePreference" />
    };

    private RenderFragment CreateDisplayTabContent() => __builder =>
    {
        <DisplayTab Model="@employeePreference" />
    };

    private RenderFragment CreateShortcutKeysTabContent() => __builder =>
    {
        <ShortcutKeysTab Model="@employeePreference" />
    };

    private RenderFragment CreateNotificationTabContent() => __builder =>
    {
        <NotificationSettingsTab Model="@employeePreference" />
    };

    private RenderFragment CreateSuperAdminDebugTabContent() => __builder =>
    {
        <SuperAdminDebugTab />
    };

    // ===== 生命週期 =====

    protected override void OnInitialized()
    {
        RebuildTabDefinitions(isSuperAdmin: false);
    }

    /// <summary>
    /// 重新建構 Tab 清單。在 OnInitialized 時以 isSuperAdmin=false 呼叫，
    /// 資料載入後以實際狀態呼叫一次，確保 SuperAdmin Debug Tab 正確顯示。
    /// </summary>
    private void RebuildTabDefinitions(bool isSuperAdmin)
    {
        _activeTabIndex = 0;
        tabDefinitions = new List<FormTabDefinition>
        {
            new() { Label = L["Preference.PersonalData"],   Icon = "bi bi-person",    SectionNames = new(), CustomContent = CreatePersonalDataTabContent(),     DebugComponentName = "PersonalDataTab" },
            new() { Label = L["Preference.LanguageRegion"], Icon = "bi bi-translate",  SectionNames = new(), CustomContent = CreateLanguageRegionTabContent(),   DebugComponentName = "LanguageRegionTab" },
            new() { Label = L["Preference.Display"],        Icon = "bi bi-type",       SectionNames = new(), CustomContent = CreateDisplayTabContent(),          DebugComponentName = "DisplayTab" },
            new() { Label = L["Preference.ShortcutKeys"],   Icon = "bi bi-keyboard",   SectionNames = new(), CustomContent = CreateShortcutKeysTabContent(),     DebugComponentName = "ShortcutKeysTab" },
            new() { Label = L["Preference.Notifications"],  Icon = "bi bi-bell",       SectionNames = new(), CustomContent = CreateNotificationTabContent(),     DebugComponentName = "NotificationSettingsTab" }
        };

        if (isSuperAdmin)
        {
            tabDefinitions.Add(new()
            {
                Label = "Debug",
                Icon = "bi bi-bug",
                SectionNames = new(),
                CustomContent = CreateSuperAdminDebugTabContent(),
                DebugComponentName = "SuperAdminDebugTab"
            });
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !isLoading && currentEmployeeId == null)
        {
            await LoadDataAsync();
        }
    }

    // ===== 資料載入 =====

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            currentEmployeeId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);

            if (currentEmployeeId.HasValue)
            {
                // 載入語言偏好，並記錄原始值供儲存後比對
                employeePreference = await EmployeePreferenceService.GetByEmployeeIdAsync(currentEmployeeId.Value);
                _originalLanguage = employeePreference.Language;
                _originalZoom = employeePreference.Zoom;
                _originalTheme = employeePreference.Theme;
                _originalShowDisabledModules = employeePreference.ShowDisabledModules;
                _originalDefaultPageSize = employeePreference.DefaultPageSize;

                // 載入員工個人資料
                currentEmployee = await EmployeeService.GetByIdAsync(currentEmployeeId.Value);

                // 確認 SuperAdmin 狀態，若為 SuperAdmin 則加入 Debug Tab
                _isSuperAdmin = await NavigationPermissionService.IsCurrentEmployeeSuperAdminAsync();
                RebuildTabDefinitions(_isSuperAdmin);
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync(L["Error.LoadFailed", ex.Message]);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // ===== 事件處理 =====

    private async Task HandleSave()
    {
        if (!currentEmployeeId.HasValue)
        {
            await NotificationService.ShowErrorAsync(L["Error.UnknownUser"]);
            return;
        }

        // 密碼確認驗證
        if (!string.IsNullOrEmpty(newPassword) && newPassword != confirmPassword)
        {
            await NotificationService.ShowErrorAsync(L["Error.PasswordMismatch"]);
            return;
        }

        try
        {
            isLoading = true;
            StateHasChanged();

            // 1. 儲存語言偏好
            var preferenceResult = await EmployeePreferenceService.SavePreferenceAsync(currentEmployeeId.Value, employeePreference);

            if (!preferenceResult.IsSuccess)
            {
                await NotificationService.ShowErrorAsync(L["Error.SavePreferenceFailed", preferenceResult.ErrorMessage ?? ""]);
                return;
            }

            // 2. 儲存個人資料
            if (currentEmployee != null)
            {
                var profileResult = await EmployeeService.UpdateSelfProfileAsync(
                    currentEmployeeId.Value,
                    currentEmployee.Name ?? string.Empty,
                    currentEmployee.Mobile,
                    currentEmployee.Email,
                    string.IsNullOrWhiteSpace(newPassword) ? null : newPassword
                );

                if (!profileResult.IsSuccess)
                {
                    await NotificationService.ShowErrorAsync(L["Error.SaveProfileFailed", profileResult.ErrorMessage ?? ""]);
                    return;
                }
            }

            await NotificationService.ShowSuccessAsync(L["Preference.SaveSuccess"]);

            if (OnSaved.HasDelegate)
                await OnSaved.InvokeAsync();

            // 快捷鍵：立即套用（不需 reload）
            var shortcutConfig = new Dictionary<string, string>
            {
                ["pageSearch"]   = employeePreference.ShortcutPageSearch   ?? ShortcutDefaults.PageSearch,
                ["reportSearch"] = employeePreference.ShortcutReportSearch  ?? ShortcutDefaults.ReportSearch,
                ["stickyNotes"]  = employeePreference.ShortcutStickyNotes   ?? ShortcutDefaults.StickyNotes,
                ["calendar"]     = employeePreference.ShortcutCalendar      ?? ShortcutDefaults.Calendar,
                ["quickAction"]  = employeePreference.ShortcutQuickAction   ?? ShortcutDefaults.QuickAction
            };
            await JSRuntime.InvokeVoidAsync("KeyboardShortcuts.configure", shortcutConfig);

            // 字型縮放若有變更，即時套用（寫 cookie + 更新 CSS variable，不需 reload）
            if (employeePreference.Zoom != _originalZoom)
            {
                await JSRuntime.InvokeVoidAsync("setContentZoom", (int)employeePreference.Zoom);
                _originalZoom = employeePreference.Zoom;
            }

            // 主題若有變更，即時套用（寫 cookie + 更新 data-bs-theme，不需 reload）
            if (employeePreference.Theme != _originalTheme)
            {
                await JSRuntime.InvokeVoidAsync("setAppTheme", (int)employeePreference.Theme);
                _originalTheme = employeePreference.Theme;
            }

            // 即時套用 Toast 訊息顯示時長
            await JSRuntime.InvokeVoidAsync("setToastDelays", new
            {
                success = employeePreference.ToastSuccessDurationMs,
                error   = employeePreference.ToastErrorDurationMs,
                warning = employeePreference.ToastWarningDurationMs,
                info    = employeePreference.ToastInfoDurationMs
            });

            // 判斷是否需要重新載入頁面
            // 以下三類設定無法透過 JS 或 Blazor 即時套用，必須 forceLoad 才能生效：
            //
            // 1. 語言：需寫入 culture cookie，由 ASP.NET Core RequestLocalization middleware 在下次
            //    請求時重新套用，所有 IStringLocalizer 資源字串都必須重新解析，無法在現有 circuit 中更新。
            //
            // 2. 導覽列顯示（ShowDisabledModules）：NavMenu 在 OnInitializedAsync 讀取一次後
            //    靜止不動，沒有訂閱任何變更通知。與主題（直接改 DOM attribute）不同，
            //    導覽列結構需要 Blazor 元件重新初始化才能反映新設定。
            //
            // 3. 每頁顯示筆數（DefaultPageSize）：每個 GenericIndexPageComponent 在初始化時
            //    讀取 UserPreferenceContext 並存入本地 pageSize 變數，之後不再讀取。
            //    由於影響範圍廣（所有列表頁），實作 event 訂閱機制的成本遠大於效益，
            //    統一以 forceLoad 處理，與語言切換行為一致。
            var newCultureCode = ERPCore2.Helpers.CultureHelper.ToCultureCode(employeePreference.Language);
            var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
            bool needsReload = newCultureCode != currentCulture
                || employeePreference.ShowDisabledModules != _originalShowDisabledModules
                || employeePreference.DefaultPageSize != _originalDefaultPageSize;

            if (needsReload)
            {
                if (newCultureCode != currentCulture)
                    await JSRuntime.InvokeVoidAsync("setCultureCookie", newCultureCode);
                NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
                return; // forceLoad 後頁面會重整，不需要繼續執行
            }

            await CloseModalAsync();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync(L["Error.SaveFailed", ex.Message]);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleClose()
    {
        await CloseModalAsync();
    }

    private async Task CloseModalAsync()
    {
        // 關閉時重置狀態，下次開啟時重新載入
        currentEmployeeId = null;
        currentEmployee = null;
        employeePreference = new();
        _originalLanguage = UILanguage.ZhTW;
        _originalZoom = ContentZoom.Medium;
        _originalTheme = AppTheme.Light;
        _originalShowDisabledModules = false;
        _originalDefaultPageSize = 20;
        newPassword = string.Empty;
        confirmPassword = string.Empty;
        _isSuperAdmin = false;
        RebuildTabDefinitions(isSuperAdmin: false);

        if (IsVisibleChanged.HasDelegate)
            await IsVisibleChanged.InvokeAsync(false);
    }
}
