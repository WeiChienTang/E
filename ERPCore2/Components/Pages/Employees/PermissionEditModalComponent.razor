@* 可重用的權限明細檢視組件 - 權限由 PermissionRegistry 統一管理，UI 僅供檢視 *@
@using System.Linq

@inject IPermissionManagementService PermissionService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@using ERPCore2.Models.FeatureGuides.GuideDefinitions

<GenericEditModalComponent TEntity="Permission"
                          TService="IPermissionManagementService"
                          @ref="editModalComponent"
                          IsVisible="@IsVisible"
                          IsVisibleChanged="@IsVisibleChanged"
                          @bind-Id="@PermissionId"
                          Service="@PermissionService"
                          EntityName="@L["Entity.Permission"]"
                          EntityNamePlural="@L["Entity.Permission"]"
                          ModalTitle="@L["Message.EditTitle", L["Entity.Permission"]].ToString()"
                          Size="GenericEditModalComponent<Permission, IPermissionManagementService>.ModalSize.Desktop"
                          UseGenericForm="true"                          
                          FormFields="@formFields"
                          FormSections="@formSections"
                          DataLoader="@LoadPermissionData"
                          UseGenericSave="false"
                          ShowSaveButton="false"
                          RequiredPermission="@PermissionRegistry.Permission.Read"
                          OnCancel="@OnCancel"
                          OnEntityLoaded="@HandleEntityLoaded"
                          ComponentName="PermissionEditModalComponent"
                          FeatureGuide="@PermissionGuide.Create()" />

@code {
    // ===== 必要參數 =====
    [Parameter] public bool IsVisible { get; set; } = false;
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? PermissionId { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    // ===== 內部狀態 =====
    private GenericEditModalComponent<Permission, IPermissionManagementService>? editModalComponent;
    private List<FormFieldDefinition> formFields = new();
    private Dictionary<string, string> formSections = new();

    // ===== 必要方法 =====
    
    /// <summary>
    /// 處理實體載入完成事件（由 GenericEditModalComponent 的導航觸發）
    /// </summary>
    private async Task HandleEntityLoaded(int loadedEntityId)
    {
        try
        {
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入資料時發生錯誤：{ex.Message}");
        }
    }

    private async Task<Permission?> LoadPermissionData()
    {
        try
        {
            if (!PermissionId.HasValue)
                return null;

            return await PermissionService.GetByIdAsync(PermissionId.Value);
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入權限明細資料時發生錯誤：{ex.Message}");
            return null;
        }
    }

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            InitializeFormFields();
        }
    }

    private void InitializeFormFields()
    {
        try
        {
            formFields = new List<FormFieldDefinition>
            {
                new()
                {
                    PropertyName = nameof(Permission.Code),
                    Label = L["Field.PermissionCode"],
                    FieldType = FormFieldType.Text,
                    IsRequired = true,
                    IsReadOnly = true,
                    MaxLength = 50,
                    HelpText = "權限編號（由 PermissionRegistry 統一管理）"
                },
                new()
                {
                    PropertyName = nameof(Permission.Name),
                    Label = L["Field.PermissionName"],
                    FieldType = FormFieldType.Text,
                    IsRequired = true,
                    IsReadOnly = true,
                    MaxLength = 100,
                    HelpText = "權限名稱（由 PermissionRegistry 統一管理）"
                },
                new()
                {
                    PropertyName = nameof(Permission.Level),
                    Label = L["Field.PermissionLevel"],
                    FieldType = FormFieldType.Select,
                    IsRequired = true,
                    IsReadOnly = true,
                    Options = Enum.GetValues<PermissionLevel>()
                        .Select(e => new SelectOption
                        {
                            Value = ((int)e).ToString(),
                            Text = GetPermissionLevelDisplayName(e)
                        }).ToList(),
                    HelpText = "權限等級（由 PermissionRegistry 統一管理）"
                },
                new()
                {
                    PropertyName = nameof(Permission.Remarks),
                    Label = L["Field.Remarks"],
                    FieldType = FormFieldType.TextArea,
                    IsReadOnly = true,
                    MaxLength = 500,
                    HelpText = "權限說明（由 PermissionRegistry 統一管理）"
                }
            };

            formSections = FormSectionHelper<Permission>.Create()
                .AddToSection(FormSectionNames.BasicInfo,
                    p => p.Code,
                    p => p.Name,
                    p => p.Level)
                .AddToSection(FormSectionNames.AdditionalInfo,
                    p => p.Remarks)
                .Build();
        }
        catch (Exception ex)
        {
            _ = ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(InitializeFormFields), GetType(),
                additionalData: "初始化表單欄位失敗"
            );
        }
    }

    private string GetPermissionLevelDisplayName(PermissionLevel level)
    {
        return level switch
        {
            PermissionLevel.Normal => "一般權限",
            PermissionLevel.Sensitive => "敏感權限",
            _ => level.ToString()
        };
    }
}
