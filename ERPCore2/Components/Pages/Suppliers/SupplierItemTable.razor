@* 供應商品項綁定管理組件 - 使用 InteractiveTableComponent *@
@inject INotificationService NotificationService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L
@using ERPCore2.Helpers
@using ERPCore2.Data.Entities

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <GenericInteractiveTableComponent @ref="tableComponent"
                                  TItem="ItemSupplier" 
                                  Items="@Items"
                                  ColumnDefinitions="@GetColumnDefinitions()"
                                  ShowHeader="true"
                                  ShowRowNumbers="true"
                                  IsStriped="true"
                                  IsHoverable="true"
                                  IsBordered="true"
                                  ShowBuiltInActions="true"
                                  ShowBuiltInDeleteButton="true"
                                  DeleteButtonVariant="ButtonVariant.Red"
                                  OnItemDelete="@HandleDeleteItem"
                                  EnableAutoEmptyRow="true"
                                  AllowAddNewRow="true"
                                  ActionsColumnWidth = "60px"
                                  DataLoadCompleted="@DataLoadCompleted"
                                  CreateEmptyItem="@CreateEmptyItem"
                                  EmptyMessage="@EmptyMessage" />
    </div>
    
    <div class="card-footer">
        <div class="d-flex justify-content-end">
            <GenericButtonComponent Text="@L["Button.ClearDetails"]"
                                  Variant="ButtonVariant.Red"
                                  OnClick="ClearAllDetails"
                                  IsDisabled="@(!HasItemItems)"
                                  Title="@(!HasItemItems ? L["Supplier.NoClearTooltip"].ToString() : L["Supplier.ClearDetailsTooltip"].ToString())" />
        </div>
    </div>
</div>

@code {
    // ===== 參數 =====
    [Parameter] public List<ItemSupplier> Items { get; set; } = new();
    [Parameter] public EventCallback<List<ItemSupplier>> ItemsChanged { get; set; }
    [Parameter] public List<Item> AvailableItems { get; set; } = new();
    [Parameter] public int SupplierId { get; set; }
    [Parameter] public bool DataLoadCompleted { get; set; } = true;
    [Parameter] public string EmptyMessage { get; set; } = "尚未設定供應品項";
    [Parameter] public EventCallback<ItemSupplier> OnItemDeleted { get; set; }
    
    // ===== GenericInteractiveTableComponent 參考 =====
    private GenericInteractiveTableComponent<ItemSupplier>? tableComponent;
    
    /// <summary>
    /// 計算屬性：是否有供應品項項目
    /// </summary>
    private bool HasItemItems => Items.Any(item => item.Item != null);

    /// <summary>
    /// 建立供應品項管理的欄位定義
    /// </summary>
    private List<InteractiveColumnDefinition> GetColumnDefinitions()
    {
        return new List<InteractiveColumnDefinition>
        {
            // 品項選擇（必填，SearchableSelect）
            new InteractiveColumnDefinition
            {
                Title = L["Column.Item"],
                PropertyName = nameof(ItemSupplier.SearchText),  //  修正：綁定實際存在的屬性
                EmptyCheckPropertyName = nameof(ItemSupplier.Item),  //  修正：檢查物件屬性（null = 空行）
                ColumnType = InteractiveColumnType.SearchableSelect,
                Width = "300px",
                Placeholder = "請輸入品項編號或名稱",
                TriggerEmptyRowOnFilled = true,
                SearchValuePropertyName = nameof(ItemSupplier.SearchText),
                FilteredItemsPropertyName = "FilteredItems",
                ShowDropdownPropertyName = "ShowItemDropdown",
                SelectedIndexPropertyName = "ItemSelectedIndex",
                ItemDisplayFormatter = (item) =>
                {
                    var product = (Item)item;
                    return $"[{product.Code}] {product.Name}";
                },
                EnableKeyboardNavigation = true,
                GetDropdownItems = (item) => ((ItemSupplier)item).FilteredItems.Cast<object>().ToList(),
                GetSelectedIndex = (item) => ((ItemSupplier)item).ItemSelectedIndex,
                SetSelectedIndex = (item, index) => ((ItemSupplier)item).ItemSelectedIndex = index,
                GetShowDropdown = (item) => ((ItemSupplier)item).ShowItemDropdown,
                SetShowDropdown = (item, show) => ((ItemSupplier)item).ShowItemDropdown = show,
                MaxDisplayItems = 20,
                OnSearchInputChanged = EventCallback.Factory.Create<(object, string?)>(this, (tuple) =>
                {
                    var (item, searchValue) = tuple;
                    OnItemSearchChanged((ItemSupplier)item, searchValue);
                }),
                OnItemSelected = EventCallback.Factory.Create<(object, object?)>(this, async (tuple) =>
                {
                    var (item, selectedItem) = tuple;
                    await OnItemSelected((ItemSupplier)item, (Item?)selectedItem);
                }),
                OnInputFocus = EventCallback.Factory.Create<object>(this, (item) =>
                {
                    OnItemFocus((ItemSupplier)item);
                }),
                OnInputBlur = EventCallback.Factory.Create<object>(this, (item) =>
                {
                    OnItemBlur((ItemSupplier)item);
                })
            },
            
            // 供應商料號
            new InteractiveColumnDefinition
            {
                Title = L["Column.SupplierItemCode"],
                PropertyName = nameof(ItemSupplier.SupplierItemCode),
                ColumnType = InteractiveColumnType.Input,
                Width = "150px",
                Placeholder = "供應商料號",
                Tooltip = "供應商自己的品項編號"
            },
            
            // 備註
            new InteractiveColumnDefinition
            {
                Title = L["Label.Remarks"],
                PropertyName = nameof(ItemSupplier.Remarks),
                ColumnType = InteractiveColumnType.Input,
                Width = "200px",
                Placeholder = "採購注意事項"
            }
        };
    }

    /// <summary>
    /// 創建空的 ItemSupplier
    /// </summary>
    private ItemSupplier CreateEmptyItem()
    {
        return new ItemSupplier
        {
            SupplierId = SupplierId,
            ItemId = 0,
            Item = null,  //  重要：空行判斷依據（Item = null 表示空行）
            IsPreferred = false,
            Priority = 999,
            Status = EntityStatus.Active,
            SearchText = "",
            FilteredItems = new List<Item>(),
            ShowItemDropdown = false,
            ItemSelectedIndex = -1
        };
    }

    /// <summary>
    /// 品項搜尋輸入變更事件
    /// </summary>
    private void OnItemSearchChanged(ItemSupplier productSupplier, string? searchValue)
    {
        productSupplier.SearchText = searchValue ?? "";
        
        if (string.IsNullOrWhiteSpace(searchValue))
        {
            productSupplier.FilteredItems = new List<Item>();
            productSupplier.ShowItemDropdown = false;
        }
        else
        {
            var searchLower = searchValue.Trim().ToLower();
            productSupplier.FilteredItems = AvailableItems
                .Where(p => (p.Code?.ToLower().Contains(searchLower) ?? false) || 
                           (p.Name?.ToLower().Contains(searchLower) ?? false))
                .Take(20)
                .ToList();
            productSupplier.ShowItemDropdown = productSupplier.FilteredItems.Any();
        }
        
        productSupplier.ItemSelectedIndex = -1;
        StateHasChanged();
    }

    /// <summary>
    /// 品項選擇事件
    /// </summary>
    private async Task OnItemSelected(ItemSupplier productSupplier, Item? selectedItem)
    {
        if (selectedItem == null) return;

        // 檢查是否已存在相同品項
        var existingBinding = Items.FirstOrDefault(ps => 
            ps != productSupplier && 
            ps.ItemId == selectedItem.Id);

        if (existingBinding != null)
        {
            await NotificationService.ShowWarningAsync(string.Format(L["Supplier.AlreadyBound"], selectedItem.Name));
            productSupplier.ItemId = 0;
            productSupplier.SearchText = "";
            productSupplier.FilteredItems = new List<Item>();
            productSupplier.ShowItemDropdown = false;
            return;
        }

        productSupplier.ItemId = selectedItem.Id;
        productSupplier.Item = selectedItem;
        productSupplier.SearchText = $"[{selectedItem.Code}] {selectedItem.Name}";
        productSupplier.FilteredItems = new List<Item>();
        productSupplier.ShowItemDropdown = false;
        
        StateHasChanged();
    }

    /// <summary>
    /// 品項輸入框獲得焦點
    /// </summary>
    private void OnItemFocus(ItemSupplier productSupplier)
    {
        if (productSupplier.ItemId > 0)
        {
            // 已選擇品項時，顯示所有品項供重新選擇
            productSupplier.FilteredItems = AvailableItems.Take(20).ToList();
            productSupplier.ShowItemDropdown = true;
        }
        StateHasChanged();
    }

    /// <summary>
    /// 品項輸入框失去焦點
    /// </summary>
    private void OnItemBlur(ItemSupplier productSupplier)
    {
        // 延遲關閉下拉選單，讓點擊事件能正常觸發
        Task.Delay(200).ContinueWith(_ =>
        {
            productSupplier.ShowItemDropdown = false;
            InvokeAsync(StateHasChanged);
        });
    }

    /// <summary>
    /// 刪除供應品項綁定
    /// </summary>
    private async Task HandleDeleteItem(ItemSupplier item)
    {
        Items.Remove(item);
        await ItemsChanged.InvokeAsync(Items);
        await OnItemDeleted.InvokeAsync(item);
        await InvokeAsync(StateHasChanged);
    }
    
    /// <summary>
    /// 清空所有供應品項明細
    /// </summary>
    private async Task ClearAllDetails()
    {
        //  關鍵：在清除前，先收集需要刪除的項目（有 Id 的項目需通知父組件以便從資料庫刪除）
        var itemsToDelete = Items.Where(item => item.Id > 0 && item.Item != null).ToList();
        
        var cleared = await ItemManagementHelper.ClearAllDetailsAsync(
            Items,
            JSRuntime,
            async () =>
            {
                //  通知父組件哪些項目需要從資料庫刪除
                foreach (var item in itemsToDelete)
                {
                    await OnItemDeleted.InvokeAsync(item);
                }
                
                await ItemsChanged.InvokeAsync(Items);
                tableComponent?.RefreshEmptyRow();
            },
            L["Supplier.ConfirmClearAll"]
        );
        
        if (cleared)
        {
            await NotificationService.ShowSuccessAsync(L["Supplier.ClearedAll"]);
        }
    }
}
