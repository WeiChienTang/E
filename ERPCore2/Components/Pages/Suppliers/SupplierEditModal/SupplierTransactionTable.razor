@* 廠商交易紀錄查詢組件 - 顯示進貨單、退貨單（已實現金流的交易） *@
@using ERPCore2.Models
@using ERPCore2.Models.Enums
@using ERPCore2.Helpers
@inject IPurchaseReceivingService PurchaseReceivingService
@inject IPurchaseReturnService PurchaseReturnService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@if (_isLoading)
{
    <div class="text-center py-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">@L["Label.Loading"]</span>
        </div>
    </div>
}
else
{
    @* 篩選列 *@
    <div class="d-flex align-items-center gap-3 mb-2 p-2 rounded border tx-filter-bar">
        <span class="text-muted small fw-semibold me-1">@L["Label.Show"]</span>
        <div class="form-check form-check-inline mb-0">
            <input class="form-check-input" type="checkbox" id="chk-receiving"
                   checked="@_showReceivings"
                   @onchange="@(e => { _showReceivings = (bool)e.Value!; })" />
            <label class="form-check-label small" for="chk-receiving">
                <span class="badge bg-info me-1"><i class="bi bi-box-arrow-in-down"></i></span>@L["Supplier.Receivings"]
            </label>
        </div>
        <div class="form-check form-check-inline mb-0">
            <input class="form-check-input" type="checkbox" id="chk-return"
                   checked="@_showReturns"
                   @onchange="@(e => { _showReturns = (bool)e.Value!; })" />
            <label class="form-check-label small" for="chk-return">
                <span class="badge bg-warning text-dark me-1"><i class="bi bi-arrow-return-left"></i></span>@L["Supplier.Returns"]
            </label>
        </div>
        @if (_allTransactions.Any())
        {
            <span class="ms-auto text-muted small">@string.Format(L["Label.RecordCount"], FilteredTransactions.Count)</span>
        }
    </div>

    <GenericInteractiveTableComponent TItem="RelatedDocumentInfo"
                               Items="@FilteredTransactions"
                               ColumnDefinitions="@_columnDefinitions"
                               IsReadOnly="true"
                               ShowBuiltInActions="false"
                               ShowActions="true"
                               ActionsTemplate="@GetActionsTemplate"
                               ActionsHeader="@L["Label.Actions"]"
                               ActionsColumnWidth="70px"
                               EmptyMessage="@L["Supplier.NoTransactions"]" />

    @* 統計摘要（基於全部資料，不受篩選影響） *@
    @if (_allTransactions.Any())
    {
        <div class="d-flex align-items-stretch gap-0 border rounded mt-2 overflow-hidden tx-stats-bar">

            @* 淨採購額 - 主要指標 *@
            <div class="d-flex flex-column align-items-center justify-content-center px-3 py-2 border-end tx-net-purchase-cell">
                <span class="text-muted">@L["Supplier.NetPurchase"]</span>
                <span class="fw-bold fs-5 @(NetPurchase >= 0 ? "text-success" : "text-danger")">
                    @NumberFormatHelper.FormatSmartTrim(NetPurchase, useThousandsSeparator: true)
                </span>
            </div>

            @* 進貨 *@
            <div class="d-flex flex-column justify-content-center px-3 py-2 border-end">
                <span class="text-muted">@L["Supplier.Receiving"]</span>
                <span>
                    <span class="text-success fw-semibold">@string.Format(L["Label.RecordCount"], ReceivingCount)</span>
                    <span class="text-muted ms-1">@NumberFormatHelper.FormatSmartTrim(ReceivingTotal, useThousandsSeparator: true)</span>
                </span>
            </div>

            @* 退貨 *@
            <div class="d-flex flex-column justify-content-center px-3 py-2 border-end">
                <span class="text-muted">@L["Supplier.Return"]@(ReturnRate.HasValue ? $"（{ReturnRate.Value:F1}%）" : "")</span>
                <span>
                    <span class="text-danger fw-semibold">@string.Format(L["Label.RecordCount"], ReturnCount)</span>
                    <span class="text-muted ms-1">@NumberFormatHelper.FormatSmartTrim(ReturnTotal, useThousandsSeparator: true)</span>
                </span>
            </div>

            @* 最後交易 *@
            @if (LastTxDate.HasValue)
            {
                <div class="d-flex flex-column justify-content-center px-3 py-2 border-end">
                    <span class="text-muted">@L["Supplier.LastTransaction"]</span>
                    <span>
                        <span class="@LastTxRecencyClass fw-semibold">@LastTxDate.Value.ToString("yyyy-MM-dd")</span>
                        <span class="text-muted ms-1">@string.Format(L["Label.DaysAgo"], DaysSinceLastTx)</span>
                    </span>
                </div>
            }

            @* 平均進貨金額（僅當有進貨單時顯示） *@
            @if (AvgReceiving.HasValue)
            {
                <div class="d-flex flex-column justify-content-center px-3 py-2">
                    <span class="text-muted">@L["Supplier.AvgReceiving"]</span>
                    <span class="text-primary fw-semibold">@NumberFormatHelper.FormatSmartTrim(AvgReceiving.Value, useThousandsSeparator: true)</span>
                </div>
            }

        </div>
    }
}

@* 進貨單編輯 Modal *@
@if (_showReceivingModal)
{
    <PurchaseReceivingEditModalComponent @ref="_receivingEditModal"
                                         IsVisible="@_showReceivingModal"
                                         IsVisibleChanged="@((bool v) => _showReceivingModal = v)"
                                         PurchaseReceivingId="@_selectedDocumentId"
                                         OnPurchaseReceivingSaved="@HandleReceivingSaved"
                                         OnCancel="@(() => _showReceivingModal = false)" />
}

@* 退貨單編輯 Modal *@
@if (_showReturnModal)
{
    <PurchaseReturnEditModalComponent @ref="_returnEditModal"
                                      IsVisible="@_showReturnModal"
                                      IsVisibleChanged="@((bool v) => _showReturnModal = v)"
                                      PurchaseReturnId="@_selectedDocumentId"
                                      OnPurchaseReturnSaved="@HandleReturnSaved"
                                      OnCancel="@(() => _showReturnModal = false)" />
}


@code {
    [Parameter] public int? SupplierId { get; set; }

    private List<RelatedDocumentInfo> _allTransactions = new();
    private List<InteractiveColumnDefinition> _columnDefinitions = new();
    private bool _isLoading = false;
    private int? _previousSupplierId = null;

    private bool _showReceivings = true;
    private bool _showReturns    = true;

    // ===== Modal 狀態 =====
    private PurchaseReceivingEditModalComponent? _receivingEditModal;
    private PurchaseReturnEditModalComponent?    _returnEditModal;
    private bool _showReceivingModal = false;
    private bool _showReturnModal    = false;
    private int? _selectedDocumentId = null;

    private List<RelatedDocumentInfo> FilteredTransactions => _allTransactions
        .Where(t => (_showReceivings && t.DocumentType == RelatedDocumentType.ReceivingDocument)
                 || (_showReturns    && t.DocumentType == RelatedDocumentType.ReturnDocument))
        .ToList();

    // ===== 統計屬性（基於全部資料，不受篩選影響） =====

    private int      ReceivingCount  => _allTransactions.Count(t => t.DocumentType == RelatedDocumentType.ReceivingDocument);
    private int      ReturnCount     => _allTransactions.Count(t => t.DocumentType == RelatedDocumentType.ReturnDocument);

    private decimal  ReceivingTotal  => _allTransactions
        .Where(t => t.DocumentType == RelatedDocumentType.ReceivingDocument && t.TotalAmount.HasValue)
        .Sum(t => t.TotalAmount!.Value);

    private decimal  ReturnTotal     => _allTransactions
        .Where(t => t.DocumentType == RelatedDocumentType.ReturnDocument && t.TotalAmount.HasValue)
        .Sum(t => t.TotalAmount!.Value);

    private decimal  NetPurchase     => ReceivingTotal - ReturnTotal;
    private double?  ReturnRate      => ReceivingTotal > 0 ? (double)(ReturnTotal / ReceivingTotal * 100) : null;
    private decimal? AvgReceiving    => ReceivingCount > 0 ? ReceivingTotal / ReceivingCount : null;

    private DateTime? LastTxDate     => _allTransactions.Any() ? _allTransactions.Max(t => t.DocumentDate) : null;
    private int?     DaysSinceLastTx => LastTxDate.HasValue ? (DateTime.Today - LastTxDate.Value.Date).Days : null;

    private string   LastTxRecencyClass => DaysSinceLastTx switch
    {
        null => "text-muted",
        < 30 => "text-success",
        < 90 => "text-warning",
        _    => "text-danger"
    };

    protected override void OnInitialized()
    {
        InitColumnDefinitions();
    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        if (SupplierId != _previousSupplierId)
        {
            _previousSupplierId = SupplierId;
            if (SupplierId.HasValue && SupplierId.Value > 0)
                await LoadTransactionsAsync();
            else
                _allTransactions.Clear();
        }
    }

    private async Task LoadTransactionsAsync()
    {
        if (!SupplierId.HasValue || SupplierId.Value <= 0) return;

        _isLoading = true;
        StateHasChanged();

        try
        {
            var all = new List<RelatedDocumentInfo>();

            // 載入進貨單
            var receivings = await PurchaseReceivingService.GetBySupplierIdAsync(SupplierId.Value);
            all.AddRange(receivings.Select(pr => new RelatedDocumentInfo
            {
                DocumentId = pr.Id,
                DocumentType = RelatedDocumentType.ReceivingDocument,
                DocumentNumber = pr.Code ?? string.Empty,
                DocumentDate = pr.ReceiptDate,
                TotalAmount = pr.PurchaseReceivingTotalAmountIncludingTax,
                Remarks = pr.Remarks
            }));

            // 載入退貨單
            var returns = await PurchaseReturnService.GetBySupplierIdAsync(SupplierId.Value);
            all.AddRange(returns.Select(pr => new RelatedDocumentInfo
            {
                DocumentId = pr.Id,
                DocumentType = RelatedDocumentType.ReturnDocument,
                DocumentNumber = pr.Code ?? string.Empty,
                DocumentDate = pr.ReturnDate,
                TotalAmount = pr.TotalReturnAmountWithTax,
                Remarks = pr.Remarks
            }));

            // 依日期降序排序，存入全量快取
            _allTransactions = all.OrderByDescending(t => t.DocumentDate).ToList();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入交易紀錄時發生錯誤：{ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void InitColumnDefinitions()
    {
        _columnDefinitions = new List<InteractiveColumnDefinition>
        {
            new()
            {
                Title = L["Column.Date"],
                PropertyName = nameof(RelatedDocumentInfo.DocumentDate),
                ColumnType = InteractiveColumnType.Display,
                Width = "100px",
                DisplayFormatter = item =>
                {
                    var doc = (RelatedDocumentInfo)item!;
                    return doc.DocumentDate.ToString("yyyy-MM-dd");
                }
            },
            new()
            {
                Title = L["Column.OrderType"],
                PropertyName = "",
                ColumnType = InteractiveColumnType.Custom,
                Width = "90px",
                CustomTemplate = item =>
                {
                    var doc = (RelatedDocumentInfo)item;
                    return @<span class="badge bg-@doc.BadgeColor @(doc.DocumentType == RelatedDocumentType.ReturnDocument ? "text-dark" : "")">
                        <i class="bi @doc.Icon me-1"></i>@doc.TypeDisplayName
                    </span>;
                }
            },
            new()
            {
                Title = L["Column.OrderNumber"],
                PropertyName = nameof(RelatedDocumentInfo.DocumentNumber),
                ColumnType = InteractiveColumnType.Display,
                Width = "150px"
            },
            new()
            {
                // 金額欄位：進貨單(綠)=支出實現，退貨單(紅)=負向金流
                Title = L["Column.Amount"],
                PropertyName = "",
                ColumnType = InteractiveColumnType.Display,
                Width = "120px",
                TextAlign = "right",
                DisplayFormatter = item =>
                {
                    var doc = (RelatedDocumentInfo)item!;
                    if (!doc.TotalAmount.HasValue || doc.TotalAmount.Value == 0)
                        return "<span class=\"text-muted\">-</span>";

                    var amount = NumberFormatHelper.FormatSmartTrim(doc.TotalAmount.Value, useThousandsSeparator: true);
                    var cssClass = doc.DocumentType switch
                    {
                        RelatedDocumentType.ReceivingDocument => "text-success fw-bold",
                        RelatedDocumentType.ReturnDocument    => "text-danger fw-bold",
                        _                                     => "text-muted"
                    };
                    return $"<span class=\"{cssClass}\">{amount}</span>";
                }
            }
        };
    }

    // ===== 操作欄 =====

    private RenderFragment<RelatedDocumentInfo> GetActionsTemplate => item => __builder =>
    {
        <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                               IconClass="bi bi-pencil-square text-white"
                               Size="ButtonSize.Large"
                               Title="@L["Button.OpenEdit"]"
                               OnClick="() => OpenDocumentModal(item)"
                               StopPropagation="true"
                               CssClass="btn-square" />
    };

    private void OpenDocumentModal(RelatedDocumentInfo doc)
    {
        _selectedDocumentId = doc.DocumentId;
        if (doc.DocumentType == RelatedDocumentType.ReceivingDocument)
            _showReceivingModal = true;
        else if (doc.DocumentType == RelatedDocumentType.ReturnDocument)
            _showReturnModal = true;
    }

    private async Task HandleReceivingSaved(PurchaseReceiving _)
    {
        _showReceivingModal = false;
        await LoadTransactionsAsync();
    }

    private async Task HandleReturnSaved(PurchaseReturn _)
    {
        _showReturnModal = false;
        await LoadTransactionsAsync();
    }
}
