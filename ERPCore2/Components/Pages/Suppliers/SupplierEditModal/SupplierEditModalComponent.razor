@* 可重用的廠商編輯組件 - 可在任何頁面中嵌入 *@
@using ERPCore2.Services.Reports.Interfaces
@using ERPCore2.Models.Reports
@inject ISupplierService SupplierService
@inject IPaymentMethodService PaymentMethodService
@inject INotificationService NotificationService
@inject ISupplierRosterReportService SupplierRosterReportService
@inject ISupplierDetailReportService SupplierDetailReportService
@inject ActionButtonHelper ActionButtonHelper
@inject ContactLinkHelper ContactLinkHelper
@inject ICompanyModuleService CompanyModuleService
@inject INavigationPermissionService NavigationPermissionService
@inject IStringLocalizer<SharedResource> L
@using ERPCore2.Models.FeatureGuides.GuideDefinitions

<GenericEditModalComponent TEntity="Supplier"
                          TService="ISupplierService"
                          @ref="editModalComponent"
                          IsVisible="@IsVisible"
                          IsVisibleChanged="@IsVisibleChanged"
                          @bind-Id="@SupplierId"
                          Service="@SupplierService"
                          EntityName="@L["Entity.Supplier"]"
                          EntityNamePlural="@L["Entity.Supplier"]"
                          ModalTitle="@(SupplierId.HasValue ? L["Message.EditTitle", L["Entity.Supplier"]].ToString() : L["Message.CreateTitle", L["Entity.Supplier"]].ToString())"
                          Size="GenericEditModalComponent<Supplier, ISupplierService>.ModalSize.Desktop"
                          UseGenericForm="true"
                          FormFields="@formFields"
                          FormSections="@formSections"
                          TabDefinitions="@tabDefinitions"
                          AutoCompletePrefillers="@(autoCompleteConfig?.Prefillers)"
                          AutoCompleteCollections="@(autoCompleteConfig?.Collections)"
                          AutoCompleteDisplayProperties="@(autoCompleteConfig?.DisplayProperties)"
                          AutoCompleteValueProperties="@(autoCompleteConfig?.ValueProperties)"
                          ModalManagers="@modalManagers?.AsDictionary()"
                          DataLoader="@LoadSupplierData"
                          SaveHandler="@SaveSupplier"
                          ShowDraftButton="true"
                          DraftSuccessMessage="廠商草稿已儲存，請記得補齊必填資料"
                          OnSaveSuccess="@OnSaveSuccess"
                          RequiredPermission="@PermissionRegistry.Supplier.Read"
                          OnCancel="@OnCancel"
                          OnEntityLoaded="@HandleEntityLoaded"
                          ShowPrintButton="true"
                          PrintButtonText="@L["Button.Print"]"
                          ReportService="@SupplierDetailReportService"
                          ReportId="@ReportIds.SupplierDetail"
                          ReportPreviewTitle="@L["Label.DocumentPreview", L["Entity.Supplier"]]"
                          GetReportDocumentName="@(e => $"廠商-{e.Code}")"
                          CustomModules="@GetCustomModules()"
                          CustomActionButtons="@GetCustomActionButtons()"
                          ComponentName="SupplierEditModalComponent"
                          FeatureGuide="@SupplierGuide.Create()" />

@* 付款方式編輯 Modal *@
<PaymentMethodEditModalComponent @ref="paymentMethodEditModal"
                                IsVisible="@paymentMethodModalManager.IsModalVisible"
                                IsVisibleChanged="@paymentMethodModalManager.HandleModalVisibilityChangedAsync"
                                PaymentMethodId="@paymentMethodModalManager.SelectedEntityId"
                                OnPaymentMethodSaved="@paymentMethodModalManager.OnSavedAsync"
                                OnCancel="@paymentMethodModalManager.HandleModalCancelAsync" />

@* 複製至客戶確認 Modal *@
<GenericConfirmModalComponent IsVisible="@showCopyToCustomerModal"
                              IsVisibleChanged="@((bool v) => showCopyToCustomerModal = v)"
                              Title="@L["Supplier.CopyToCustomerTitle"]"
                              Icon="bi-person-lines-fill"
                              Message="@L["Supplier.CopyToCustomerMessage"]"
                              Conditions="@copyToCustomerConditions"
                              SummaryMessage="@L["Supplier.CopyToCustomerSummary"]"
                              ConfirmButtonText="@L["Button.ConfirmCopy"]"
                              CancelButtonText="@L["Button.Cancel"]"
                              ConfirmButtonVariant="ButtonVariant.Green"
                              SecondaryButtonText="@L["Button.EditAndCreate"]"
                              SecondaryButtonIcon="bi bi-pencil-square"
                              SecondaryButtonVariant="ButtonVariant.Blue"
                              OnSecondaryClick="@HandleCopyToCustomerAndEdit"
                              OnConfirm="@HandleConfirmCopyToCustomer"
                              OnCancel="@(() => showCopyToCustomerModal = false)" />

@* 客戶編輯 Modal（複製後編輯用，條件渲染避免循環引用）*@
@if (showCustomerEditModal)
{
    <CustomerEditModalComponent IsVisible="@showCustomerEditModal"
                                IsVisibleChanged="@((bool v) => showCustomerEditModal = v)"
                                CustomerId="@copiedCustomerId"
                                OnCustomerSaved="@((Customer _) => showCustomerEditModal = false)"
                                OnCancel="@(() => showCustomerEditModal = false)" />
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? SupplierId { get; set; }
    [Parameter] public EventCallback<Supplier> OnSupplierSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public Dictionary<string, object?>? PrefilledValues { get; set; }

    private GenericEditModalComponent<Supplier, ISupplierService>? editModalComponent;
    private List<FormFieldDefinition> formFields = new();
    private Dictionary<string, string> formSections = new();
    private List<FormTabDefinition>? tabDefinitions;

    // AutoComplete 配置
    private AutoCompleteConfig? autoCompleteConfig;

    // 付款方式選項
    private List<PaymentMethod> availablePaymentMethods = new();

    // Modal Manager 集合
    private ModalManagerCollection? modalManagers;

    // 付款方式編輯 Modal 相關變數 - 使用泛型管理器
    private PaymentMethodEditModalComponent? paymentMethodEditModal;
    private RelatedEntityModalManager<PaymentMethod> paymentMethodModalManager = default!;

    // 資料載入狀態標記
    private bool isDataLoaded = false;

    // 複製至客戶
    private bool showCopyToCustomerModal = false;
    private List<string> copyToCustomerConditions = new();
    private bool showCustomerEditModal = false;
    private int? copiedCustomerId;

    // Tab 元件參考（透過 @ref 呼叫公開方法）
    private SupplierVehicleTab? vehicleTab;
    private SupplierBankAccountTab? bankAccountTab;
    private SupplierItemTab? supplierItemTab;
    private GenericAccountingTabComponent? accountingTab;
    private SupplierVisitTab? visitTab;
    private SupplierTransactionTab? transactionTab;
    private BusinessCardTab? businessCardTab;
    private DocumentsTab? documentsTab;

    // ===== Tab 內容 RenderFragment =====

    private RenderFragment CreateVehicleTabContent() => __builder =>
    {
        <SupplierVehicleTab @ref="vehicleTab" SupplierId="@SupplierId" />
    };

    private RenderFragment CreateSupplierItemTabContent() => __builder =>
    {
        <SupplierItemTab @ref="supplierItemTab" SupplierId="@SupplierId" />
    };

    private RenderFragment CreateAccountingTabContent() => __builder =>
    {
        <GenericAccountingTabComponent @ref="accountingTab" EntityType="AccountingEntityType.Supplier" EntityId="@SupplierId" />
    };

    private RenderFragment CreateVisitTabContent() => __builder =>
    {
        <SupplierVisitTab @ref="visitTab" SupplierId="@SupplierId" />
    };

    private RenderFragment CreateTransactionTabContent() => __builder =>
    {
        <SupplierTransactionTab @ref="transactionTab" SupplierId="@SupplierId" />
    };

    private RenderFragment CreateBusinessCardTabContent() => __builder =>
    {
        <BusinessCardTab @ref="businessCardTab" OwnerType="Supplier" OwnerId="@SupplierId" />
    };

    private RenderFragment CreateBankAccountTabContent() => __builder =>
    {
        <SupplierBankAccountTab @ref="bankAccountTab" SupplierId="@SupplierId" />
    };

    private RenderFragment CreateDocumentsTabContent() => __builder =>
    {
        <DocumentsTab @ref="documentsTab" RelatedEntityType="Supplier" EntityId="@SupplierId" />
    };

    // ===== 生命週期 =====

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalManagers = ModalManagerInitHelper.CreateBuilder<Supplier, ISupplierService>(
                    () => editModalComponent,
                    NotificationService,
                    StateHasChanged,
                    LoadAdditionalDataAsync,
                    InitializeFormFieldsAsync)
                .AddManager<PaymentMethod>(nameof(Supplier.PaymentMethodId), "付款方式")
                .Build();

            paymentMethodModalManager = modalManagers.Get<PaymentMethod>(nameof(Supplier.PaymentMethodId));
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync("初始化廠商編輯組件時發生錯誤");
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !isDataLoaded)
        {
            await LoadAdditionalDataAsync();
            await InitializeFormFieldsAsync();
            isDataLoaded = true;
        }
        else if (!IsVisible)
        {
            isDataLoaded = false;
        }
    }

    // ===== 事件處理 =====

    private async Task HandleEntityLoaded(int loadedEntityId)
    {
        try
        {
            if (loadedEntityId > 0)
            {
                if (vehicleTab != null)         await vehicleTab.LoadAsync(loadedEntityId);
                if (bankAccountTab != null)     await bankAccountTab.LoadAsync(loadedEntityId);
                if (supplierItemTab != null) await supplierItemTab.LoadAsync(loadedEntityId);
                if (accountingTab != null)      await accountingTab.LoadAsync(loadedEntityId);
                if (visitTab != null)           await visitTab.LoadAsync(loadedEntityId);
                if (transactionTab != null)     await transactionTab.LoadAsync(loadedEntityId);
                if (businessCardTab != null)    await businessCardTab.LoadAsync(loadedEntityId);
                if (documentsTab != null)       await documentsTab.LoadAsync(loadedEntityId);
            }
            else
            {
                vehicleTab?.Clear();
                bankAccountTab?.Clear();
                supplierItemTab?.Clear();
                accountingTab?.Clear();
                visitTab?.Clear();
                transactionTab?.Clear();
                businessCardTab?.Clear();
                documentsTab?.Clear();
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入資料時發生錯誤：{ex.Message}");
        }
    }

    private async Task OnSaveSuccess()
    {
        try
        {
            if (editModalComponent?.Entity != null)
            {
                await OnSupplierSaved.InvokeAsync(editModalComponent.Entity);
            }
        }
        catch (Exception)
        {
            _ = NotificationService.ShowErrorAsync("儲存成功回調時發生錯誤");
        }
    }

    // ===== 資料載入 =====

    private async Task<Supplier?> LoadSupplierData()
    {
        try
        {
            if (!SupplierId.HasValue)
            {
                vehicleTab?.Clear();
                bankAccountTab?.Clear();
                supplierItemTab?.Clear();
                visitTab?.Clear();
                transactionTab?.Clear();

                var newSupplier = new Supplier
                {
                    Code = await EntityCodeGenerationHelper.GenerateForEntity<Supplier, ISupplierService>(SupplierService, "S"),
                    Status = EntityStatus.Active
                };

                PrefilledValueHelper.ApplyPrefilledValues(newSupplier, PrefilledValues);
                return newSupplier;
            }

            var supplier = await SupplierService.GetByIdAsync(SupplierId.Value);

            if (supplier == null)
            {
                _ = NotificationService.ShowErrorAsync("找不到指定的廠商資料");
                return null;
            }

            return supplier;
        }
        catch (Exception)
        {
            _ = NotificationService.ShowErrorAsync("載入廠商資料時發生錯誤");
            return new Supplier
            {
                Code = "",
                Status = EntityStatus.Active
            };
        }
    }

    private async Task LoadAdditionalDataAsync()
    {
        try
        {
            availablePaymentMethods = await PaymentMethodService.GetAllAsync();

            autoCompleteConfig = new AutoCompleteConfigBuilder<Supplier>()
                .AddField(nameof(Supplier.PaymentMethodId), "Name", availablePaymentMethods)
                .Build();
        }
        catch (Exception)
        {
            _ = NotificationService.ShowErrorAsync("載入廠商編輯相關資料時發生錯誤");
            availablePaymentMethods = new List<PaymentMethod>();
        }
    }

    // ===== 自訂儲存（含車輛緩衝提交） =====

    private async Task<bool> SaveSupplier(Supplier entity)
    {
        try
        {
            if (!entity.IsDraft)
            {
                bool isDraftEligible = editModalComponent?.ShowDraftButton == true &&
                                       (!SupplierId.HasValue || editModalComponent?.WasOriginallyDraft == true);

                var validationResult = await SupplierService.ValidateAsync(entity);
                if (!validationResult.IsSuccess)
                {
                    if (isDraftEligible)
                        editModalComponent!.PendingSaveError = validationResult.ErrorMessage;
                    else
                        _ = NotificationService.ShowErrorAsync(validationResult.ErrorMessage);
                    return false;
                }
            }

            ServiceResult result;

            if (SupplierId.HasValue)
                result = await SupplierService.UpdateAsync(entity);
            else
                result = await SupplierService.CreateAsync(entity);

            if (!result.IsSuccess)
                return false;

            // 車輛 Tab 有緩衝機制，需在主檔儲存後提交
            if (vehicleTab != null)
                await vehicleTab.SavePendingChangesAsync(entity.Id);

            return true;
        }
        catch (Exception)
        {
            _ = NotificationService.ShowErrorAsync("儲存廠商資料時發生錯誤");
            return false;
        }
    }

    // ===== 表單欄位定義 =====

    private async Task InitializeFormFieldsAsync()
    {
        try
        {
            formFields = new List<FormFieldDefinition>
            {
                new()
                {
                    PropertyName = nameof(Supplier.Code),
                    Label = L["Field.SupplierCode"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.SupplierCode"]],
                    IsRequired = true,
                    MaxLength = 20,
                    HelpText = "廠商的唯一識別編號"
                },
                new()
                {
                    PropertyName = nameof(Supplier.CompanyName),
                    Label = L["Field.SupplierName"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.SupplierName"]],
                    IsRequired = false,
                    MaxLength = 100,
                    HelpText = "廠商的正式廠商名稱（廠商名稱、負責人或聯絡人至少需填寫一項）"
                },
                new()
                {
                    PropertyName = nameof(Supplier.ContactPerson),
                    Label = L["Field.ContactPerson"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.ContactPerson"]],
                    IsRequired = false,
                    MaxLength = 50,
                    HelpText = "主要聯絡人姓名（廠商名稱、負責人或聯絡人至少需填寫一項）",
                    ActionButtons = await GetContactPersonActionButtonsAsync()
                },
                new()
                {
                    PropertyName = nameof(Supplier.TaxNumber),
                    Label = L["Field.TaxNumber"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.TaxNumber"]],
                    MaxLength = 8,
                    HelpText = "公司統一編號（8位數字）"
                },
                new()
                {
                    PropertyName = nameof(Supplier.ResponsiblePerson),
                    Label = L["Field.ResponsiblePerson"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.ResponsiblePerson"]],
                    IsRequired = false,
                    MaxLength = 10,
                    HelpText = "公司負責人姓名（廠商名稱、負責人或聯絡人至少需填寫一項）"
                },
                new()
                {
                    PropertyName = nameof(Supplier.JobTitle),
                    Label = L["Field.JobTitle"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.JobTitle"]],
                    IsRequired = false,
                    MaxLength = 10,
                    HelpText = "聯絡人職稱"
                },
                new()
                {
                    PropertyName = nameof(Supplier.ContactPhone),
                    Label = L["Field.ContactPhone"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.ContactPhone"]],
                    IsRequired = false,
                    MaxLength = 20,
                    HelpText = "聯絡人或是公司聯絡電話",
                    ActionButtons = ContactLinkHelper.CreatePhoneButtons(() => editModalComponent?.Entity?.ContactPhone, IsSaved)
                },
                new()
                {
                    PropertyName = nameof(Supplier.MobilePhone),
                    Label = L["Field.MobilePhone"],
                    FieldType = FormFieldType.MobilePhone,
                    Placeholder = "0912-345-678",
                    HelpText = "聯絡人行動電話（10碼，以09開頭）",
                    ActionButtons = ContactLinkHelper.CreatePhoneButtons(() => editModalComponent?.Entity?.MobilePhone, IsSaved)
                },
                new()
                {
                    PropertyName = nameof(Supplier.Fax),
                    Label = L["Field.Fax"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.Fax"]],
                    IsRequired = false,
                    MaxLength = 20,
                    HelpText = "公司傳真號碼",
                    ActionButtons = ContactLinkHelper.CreatePhoneButtons(() => editModalComponent?.Entity?.Fax, IsSaved)
                },
                new()
                {
                    PropertyName = nameof(Supplier.Email),
                    Label = L["Field.Email"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.Email"]],
                    IsRequired = false,
                    MaxLength = 50,
                    HelpText = "聯絡人電子郵件地址",
                    ActionButtons = ContactLinkHelper.CreateEmailButtons(() => editModalComponent?.Entity?.Email, IsSaved)
                },
                new()
                {
                    PropertyName = nameof(Supplier.Website),
                    Label = L["Field.Website"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.Website"]],
                    MaxLength = 50,
                    ContainerCssClass = "col-4",
                    HelpText = "公司官方網站網址",
                    ActionButtons = ContactLinkHelper.CreateWebsiteButtons(() => editModalComponent?.Entity?.Website, IsSaved)
                },
                new()
                {
                    PropertyName = nameof(Supplier.ContactAddress),
                    Label = L["Field.ContactAddress"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.ContactAddress"]],
                    IsRequired = false,
                    MaxLength = 50,
                    HelpText = "公司聯絡地址",
                    ContainerCssClass = "col-4",
                    ActionButtons = ContactLinkHelper.CreateAddressButtons(() => editModalComponent?.Entity?.ContactAddress, IsSaved)
                },
                new()
                {
                    PropertyName = nameof(Supplier.SupplierAddress),
                    Label = L["Field.CompanyAddress"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.CompanyAddress"]],
                    IsRequired = false,
                    MaxLength = 50,
                    HelpText = "公司地址",
                    ContainerCssClass = "col-4",
                    ActionButtons = await GetSupplierAddressActionButtonsAsync()
                },
                new()
                {
                    PropertyName = nameof(Supplier.PaymentMethodId),
                    Label = L["Entity.PaymentMethod"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = L["Placeholder.PleaseInputOrSelect", L["Entity.PaymentMethod"]],
                    IsRequired = false,
                    MinSearchLength = 0,
                    HelpText = "廠商的付款方式（例如：現金、支票、匯款等）",
                    ActionButtons = await GetPaymentMethodActionButtonsAsync()
                },
                new()
                {
                    PropertyName = nameof(Supplier.PaymentTerms),
                    Label = L["Field.PaymentTerms"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.PaymentTerms"]],
                    IsRequired = false,
                    MaxLength = 50,
                    HelpText = "付款條件說明（例如：月結30天、貨到付款等）"
                },
                new FormFieldDefinition()
                {
                    PropertyName = nameof(Supplier.SupplierContactPhone),
                    Label = L["Field.ContactPhone"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.ContactPhone"]],
                    IsRequired = false,
                    MaxLength = 20,
                    HelpText = "負責人或是公司聯絡電話",
                    ActionButtons = ContactLinkHelper.CreatePhoneButtons(() => editModalComponent?.Entity?.SupplierContactPhone, IsSaved)
                },
                new()
                {
                    PropertyName = nameof(Supplier.CurrentPayable),
                    Label = L["Field.CurrentPayable"],
                    FieldType = FormFieldType.Number,
                    IsRequired = false,
                    IsReadOnly = true,
                    HelpText = "目前應付廠商的餘額（系統自動計算，不可手動修改）"
                },
                new()
                {
                    PropertyName = nameof(Supplier.PaymentDay),
                    Label = L["Field.PaymentDay"],
                    FieldType = FormFieldType.Number,
                    Placeholder = L["Placeholder.CollectionDayHint"],
                    IsRequired = false,
                    Min = 0,
                    Max = 30,
                    HelpText = "每月固定付款日期 (1-30)，輸入 0 表示月底付款。例如：15 表示每月15日"
                },
                new()
                {
                    PropertyName = nameof(Supplier.InvoiceTitle),
                    Label = L["Field.InvoiceTitle"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.InvoiceTitle"]],
                    IsRequired = false,
                    MaxLength = 100,
                    HelpText = "廠商開立發票時使用的抬頭名稱"
                },
                new()
                {
                    PropertyName = nameof(Supplier.SupplierStatus),
                    Label = L["Field.SupplierStatus"],
                    FieldType = FormFieldType.Select,
                    IsRequired = true,
                    HelpText = "廠商目前的往來狀態",
                    Options = new List<SelectOption>
                    {
                        new() { Value = ((int)SupplierStatus.Active).ToString(),    Text = L["SupplierStatus.Active"] },
                        new() { Value = ((int)SupplierStatus.Inactive).ToString(),  Text = L["SupplierStatus.Inactive"] },
                        new() { Value = ((int)SupplierStatus.Suspended).ToString(), Text = L["SupplierStatus.Suspended"] }
                    }
                },
                new()
                {
                    PropertyName = nameof(Supplier.SupplierType),
                    Label = L["Field.SupplierType"],
                    FieldType = FormFieldType.Select,
                    IsRequired = false,
                    HelpText = "廠商的類型分類",
                    Options = new List<SelectOption>
                    {
                        new() { Value = "",                                                     Text = L["Label.NotSet"] },
                        new() { Value = ((int)SupplierType.Manufacturer).ToString(),           Text = L["SupplierType.Manufacturer"] },
                        new() { Value = ((int)SupplierType.Trader).ToString(),                 Text = L["SupplierType.Trader"] },
                        new() { Value = ((int)SupplierType.Agent).ToString(),                  Text = L["SupplierType.Agent"] },
                        new() { Value = ((int)SupplierType.ServiceProvider).ToString(),        Text = L["SupplierType.ServiceProvider"] }
                    }
                },
                new()
                {
                    PropertyName = nameof(Supplier.BillingAddress),
                    Label = L["Field.BillingAddress"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.BillingAddress"]],
                    IsRequired = false,
                    MaxLength = 200,
                    HelpText = "發票或帳單郵寄地址（若與聯絡地址相同可留空）"
                },
                FormFieldConfigurationHelper.CreateRemarksField<Supplier>()
            };

            // 模組狀態（停用時隱藏對應 Tab）
            bool? isSuperAdmin = null;
            var isVehiclesEnabled = await CompanyModuleService.IsModuleEnabledAsync("Vehicles");
            if (!isVehiclesEnabled)
            {
                isSuperAdmin ??= await NavigationPermissionService.IsCurrentEmployeeSuperAdminAsync();
                isVehiclesEnabled = isSuperAdmin.Value;
            }
            var isAccountingEnabled = await CompanyModuleService.IsModuleEnabledAsync("Accounting");
            if (!isAccountingEnabled)
            {
                isSuperAdmin ??= await NavigationPermissionService.IsCurrentEmployeeSuperAdminAsync();
                isAccountingEnabled = isSuperAdmin.Value;
            }
            var isDocumentsEnabled = await CompanyModuleService.IsModuleEnabledAsync("Documents");
            if (!isDocumentsEnabled)
            {
                isSuperAdmin ??= await NavigationPermissionService.IsCurrentEmployeeSuperAdminAsync();
                isDocumentsEnabled = isSuperAdmin.Value;
            }

            var builder = FormSectionHelper<Supplier>.Create()
                .AddToSection(FormSectionNames.BasicInfo,
                    s => s.Code,
                    s => s.CompanyName,
                    s => s.ResponsiblePerson,
                    s => s.SupplierContactPhone,
                    s => s.TaxNumber,
                    s => s.Fax,
                    s => s.Website,
                    s => s.ContactAddress,
                    s => s.SupplierAddress)
                .AddToSection(FormSectionNames.ContactPersonInfo,
                    s => s.ContactPerson,
                    s => s.JobTitle,
                    s => s.ContactPhone,
                    s => s.MobilePhone,
                    s => s.Email)
                .AddToSection(FormSectionNames.PaymentInfo,
                    s => s.PaymentMethodId,
                    s => s.PaymentTerms,
                    s => s.PaymentDay,
                    s => s.InvoiceTitle,
                    s => s.CurrentPayable,
                    s => s.BillingAddress)
                .AddToSection(FormSectionNames.OtherInfo,
                    s => s.SupplierStatus,
                    s => s.SupplierType,
                    s => s.Remarks)
                .GroupIntoTab(L["Tab.SupplierData"].ToString(), "bi-shop", FormSectionNames.BasicInfo, FormSectionNames.ContactPersonInfo, FormSectionNames.PaymentInfo, FormSectionNames.OtherInfo);

            if (isVehiclesEnabled)
                builder = builder.GroupIntoCustomTab(L["Tab.VehicleInfo"].ToString(), "bi-truck", CreateVehicleTabContent(), nameof(SupplierVehicleTab));

            if (isAccountingEnabled)
                builder = builder.GroupIntoCustomTab(L["Tab.AccountingInfo"].ToString(), "bi-calculator", CreateAccountingTabContent(), nameof(GenericAccountingTabComponent));

            builder = builder.GroupIntoCustomTab(L["Tab.BankAccounts"].ToString(), "bi-bank", CreateBankAccountTabContent(), nameof(SupplierBankAccountTab));

            builder = builder
                .GroupIntoCustomTab(L["Tab.SupplierItems"].ToString(), "bi-box-seam", CreateSupplierItemTabContent(), nameof(SupplierItemTab))
                .GroupIntoCustomTab(L["Tab.VisitRecords"].ToString(), "bi-journal-text", CreateVisitTabContent(), nameof(SupplierVisitTab))
                .GroupIntoCustomTab(L["Tab.TransactionRecords"].ToString(), "bi-receipt", CreateTransactionTabContent(), nameof(SupplierTransactionTab))
                .GroupIntoCustomTab(L["Tab.BusinessCards"].ToString(), "bi-person-vcard", CreateBusinessCardTabContent(), nameof(BusinessCardTab));

            if (isDocumentsEnabled)
                builder = builder.GroupIntoCustomTab(L["Tab.Documents"].ToString(), "bi-file-earmark-text", CreateDocumentsTabContent(), nameof(DocumentsTab));

            var layout = builder.BuildAll();

            formSections = layout.FieldSections;
            tabDefinitions = layout.TabDefinitions;
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync("初始化表單欄位時發生錯誤");
        }
    }

