@* 廠商拜訪紀錄 Tab - 自包含元件，主組件透過 @ref 協調 *@
@inject ISupplierVisitService SupplierVisitService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@* 拜訪紀錄列表 *@
<SupplierVisitTable Visits="@supplierVisits"
                   OnAddVisit="@HandleAddVisit"
                   OnEditVisit="@HandleEditVisit"
                   OnDeleteVisit="@HandleDeleteVisitRequest" />

@* 拜訪紀錄編輯 Modal *@
<SupplierVisitEditModalComponent IsVisible="@isVisitModalVisible"
                                 IsVisibleChanged="@HandleVisitModalVisibilityChanged"
                                 SupplierVisitId="@editingVisitId"
                                 PrefilledSupplierId="@SupplierId"
                                 OnSupplierVisitSaved="@OnVisitSavedWrapper"
                                 OnCancel="@HandleVisitModalCancel" />

@* 刪除確認 Modal *@
<GenericConfirmModalComponent IsVisible="@showDeleteVisitModal"
                              IsVisibleChanged="@((bool v) => showDeleteVisitModal = v)"
                              Title="@L["Modal.DeleteVisitRecord"]"
                              Icon="bi-trash"
                              Message="@L["Modal.ConfirmDeleteVisitRecord"]"
                              ConfirmButtonText="@L["Button.ConfirmDelete"]"
                              CancelButtonText="@L["Button.Cancel"]"
                              ConfirmButtonVariant="ButtonVariant.Red"
                              OnConfirm="@HandleConfirmDeleteVisit"
                              OnCancel="@(() => showDeleteVisitModal = false)" />

@code {
    /// <summary>目前廠商 ID（供新增拜訪紀錄時預填）</summary>
    [Parameter] public int? SupplierId { get; set; }

    // ===== 內部狀態 =====
    private List<SupplierVisit> supplierVisits = new();
    private bool isVisitModalVisible = false;
    private int? editingVisitId = null;
    private bool showDeleteVisitModal = false;
    private SupplierVisit? deletingVisit = null;
    private int? _loadedSupplierId;

    // ===== 生命週期 =====

    protected override async Task OnParametersSetAsync()
    {
        if (SupplierId != _loadedSupplierId)
        {
            _loadedSupplierId = SupplierId;
            if (SupplierId.HasValue && SupplierId.Value > 0)
                await LoadAsync(SupplierId.Value);
            else
                Clear();
        }
    }

    // ===== 公開方法（供主組件透過 @ref 呼叫） =====

    /// <summary>載入指定廠商的拜訪紀錄</summary>
    public async Task LoadAsync(int supplierId)
    {
        supplierVisits = await SupplierVisitService.GetBySupplierAsync(supplierId);
        StateHasChanged();
    }

    /// <summary>清除拜訪紀錄（切換至新增模式時使用）</summary>
    public void Clear()
    {
        supplierVisits = new();
        StateHasChanged();
    }

    // ===== 拜訪紀錄 Modal 處理 =====

    private void HandleAddVisit()
    {
        editingVisitId = null;
        isVisitModalVisible = true;
        StateHasChanged();
    }

    private void HandleEditVisit(SupplierVisit visit)
    {
        editingVisitId = visit.Id;
        isVisitModalVisible = true;
        StateHasChanged();
    }

    private void HandleDeleteVisitRequest(SupplierVisit visit)
    {
        deletingVisit = visit;
        showDeleteVisitModal = true;
        StateHasChanged();
    }

    private async Task HandleConfirmDeleteVisit()
    {
        if (deletingVisit == null) return;

        try
        {
            var result = await SupplierVisitService.DeleteAsync(deletingVisit.Id);
            if (result.IsSuccess)
            {
                supplierVisits.RemoveAll(v => v.Id == deletingVisit.Id);
                await NotificationService.ShowSuccessAsync(L["Message.VisitDeleted"]);
            }
            else
            {
                await NotificationService.ShowErrorAsync($"刪除失敗：{result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"刪除拜訪紀錄時發生錯誤：{ex.Message}");
        }
        finally
        {
            deletingVisit = null;
            showDeleteVisitModal = false;
            StateHasChanged();
        }
    }

    private void OnVisitSavedWrapper(SupplierVisit savedVisit)
    {
        var existingIndex = supplierVisits.FindIndex(v => v.Id == savedVisit.Id);
        if (existingIndex >= 0)
            supplierVisits[existingIndex] = savedVisit;
        else
            supplierVisits.Insert(0, savedVisit);

        isVisitModalVisible = false;
        StateHasChanged();
    }

    private void HandleVisitModalVisibilityChanged(bool isVisible)
    {
        isVisitModalVisible = isVisible;
        StateHasChanged();
    }

    private void HandleVisitModalCancel()
    {
        isVisitModalVisible = false;
        StateHasChanged();
    }
}
