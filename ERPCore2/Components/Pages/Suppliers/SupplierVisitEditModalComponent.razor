@* 可重用的廠商拜訪紀錄編輯組件 - 用於廠商 EditModal 的 Tab 頁籤中 *@
@inject ISupplierVisitService SupplierVisitService
@inject ISupplierService SupplierService
@inject IEmployeeService EmployeeService
@inject INotificationService NotificationService
@inject ActionButtonHelper ActionButtonHelper
@inject IStringLocalizer<SharedResource> L
@using ERPCore2.Models.FeatureGuides.GuideDefinitions

<GenericEditModalComponent TEntity="SupplierVisit"
                          TService="ISupplierVisitService"
                          @ref="editModalComponent"
                          IsVisible="@IsVisible"
                          IsVisibleChanged="@IsVisibleChanged"
                          @bind-Id="@SupplierVisitId"
                          Service="@SupplierVisitService"
                          EntityName="@L["Entity.SupplierVisit"]"
                          EntityNamePlural="@L["Entity.SupplierVisit"]"
                          ModalTitle="@(SupplierVisitId.HasValue ? L["Message.EditTitle", L["Entity.SupplierVisit"]].ToString() : L["Message.CreateTitle", L["Entity.SupplierVisit"]].ToString())"
                          UseGenericForm="true"
                          FormFields="@formFields"
                          FormSections="@formSections"
                          AutoCompletePrefillers="@autoCompleteConfig?.Prefillers"
                          AutoCompleteCollections="@autoCompleteConfig?.Collections"
                          AutoCompleteDisplayProperties="@autoCompleteConfig?.DisplayProperties"
                          AutoCompleteValueProperties="@autoCompleteConfig?.ValueProperties"
                          ModalManagers="@modalManagers?.AsDictionary()"
                          DataLoader="@LoadVisitData"
                          UseGenericSave="true"
                          SaveSuccessMessage="@(SupplierVisitId.HasValue ? L["Message.UpdateSuccess", L["Entity.SupplierVisit"]].ToString() : L["Message.CreateSuccess", L["Entity.SupplierVisit"]].ToString())"
                          SaveFailureMessage="@L["Message.SaveFailure", L["Entity.SupplierVisit"]]"
                          RequiredPermission="@PermissionRegistry.Supplier.Read"
                          OnEntitySaved="@OnSupplierVisitSaved"
                          OnCancel="@OnCancel"
                          ComponentName="SupplierVisitEditModalComponent"
                          FeatureGuide="@SupplierVisitGuide.Create()" />

@* 廠商編輯 Modal *@
<SupplierEditModalComponent @ref="supplierEditModal"
                           IsVisible="@supplierModalManager.IsModalVisible"
                           IsVisibleChanged="@supplierModalManager.HandleModalVisibilityChangedAsync"
                           SupplierId="@supplierModalManager.SelectedEntityId"
                           OnSupplierSaved="@supplierModalManager.OnSavedAsync"
                           OnCancel="@supplierModalManager.HandleModalCancelAsync" />

@* 員工編輯 Modal *@
<EmployeeEditModalComponent @ref="employeeEditModal"
                           IsVisible="@employeeModalManager.IsModalVisible"
                           IsVisibleChanged="@employeeModalManager.HandleModalVisibilityChangedAsync"
                           EmployeeId="@employeeModalManager.SelectedEntityId"
                           OnEmployeeSaved="@employeeModalManager.OnSavedAsync"
                           OnCancel="@employeeModalManager.HandleModalCancelAsync" />

@code {
    // ===== 必要參數 =====
    [Parameter] public bool IsVisible { get; set; } = false;
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? SupplierVisitId { get; set; }
    [Parameter] public int? PrefilledSupplierId { get; set; }
    [Parameter] public EventCallback<SupplierVisit> OnSupplierVisitSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    // ===== 內部狀態 =====
    private GenericEditModalComponent<SupplierVisit, ISupplierVisitService>? editModalComponent;
    private List<FormFieldDefinition> formFields = new();
    private Dictionary<string, string> formSections = new();

    // AutoComplete 配置
    private AutoCompleteConfig? autoCompleteConfig;

    // 選項資料
    private List<Supplier> availableSuppliers = new();
    private List<Employee> availableEmployees = new();

    // Modal Manager 集合
    private ModalManagerCollection? modalManagers;

    // 廠商編輯 Modal
    private SupplierEditModalComponent? supplierEditModal;
    private RelatedEntityModalManager<Supplier> supplierModalManager = default!;

    // 員工編輯 Modal
    private EmployeeEditModalComponent? employeeEditModal;
    private RelatedEntityModalManager<Employee> employeeModalManager = default!;

    // 資料載入狀態標記
    private bool isDataLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalManagers = ModalManagerInitHelper.CreateBuilder<SupplierVisit, ISupplierVisitService>(
                    () => editModalComponent,
                    NotificationService,
                    StateHasChanged,
                    LoadAdditionalDataAsync,
                    InitializeFormFieldsAsync)
                .AddManager<Supplier>(nameof(SupplierVisit.SupplierId), "廠商")
                .AddManager<Employee>(nameof(SupplierVisit.EmployeeId), "員工")
                .Build();

            supplierModalManager = modalManagers.Get<Supplier>(nameof(SupplierVisit.SupplierId));
            employeeModalManager = modalManagers.Get<Employee>(nameof(SupplierVisit.EmployeeId));
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync("初始化廠商拜訪紀錄編輯組件時發生錯誤");
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !isDataLoaded)
        {
            await LoadAdditionalDataAsync();
            await InitializeFormFieldsAsync();
            isDataLoaded = true;
        }
        else if (!IsVisible)
        {
            isDataLoaded = false;
        }
    }

    private async Task<SupplierVisit?> LoadVisitData()
    {
        try
        {
            if (!SupplierVisitId.HasValue)
            {
                var newVisit = new SupplierVisit
                {
                    VisitDate = DateTime.Today,
                    VisitType = VisitType.Phone,
                    Status = EntityStatus.Active
                };

                if (PrefilledSupplierId.HasValue)
                    newVisit.SupplierId = PrefilledSupplierId.Value;

                return newVisit;
            }

            return await SupplierVisitService.GetByIdAsync(SupplierVisitId.Value);
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入拜訪紀錄資料時發生錯誤：{ex.Message}");
            return null;
        }
    }

    private async Task InitializeFormFieldsAsync()
    {
        try
        {
            formFields = new List<FormFieldDefinition>
            {
                new()
                {
                    PropertyName = nameof(SupplierVisit.SupplierId),
                    Label = L["Entity.Supplier"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = L["Placeholder.PleaseInputOrSelect", L["Entity.Supplier"]],
                    IsRequired = true,
                    MinSearchLength = 0,
                    HelpText = "此次拜訪的廠商",
                    IsVisible = !PrefilledSupplierId.HasValue,
                    ActionButtons = await GetSupplierActionButtonsAsync()
                },
                new()
                {
                    PropertyName = nameof(SupplierVisit.VisitDate),
                    Label = L["Field.VisitDate"],
                    FieldType = FormFieldType.Date,
                    IsRequired = true,
                    HelpText = "進行拜訪或聯繫的日期"
                },
                new()
                {
                    PropertyName = nameof(SupplierVisit.VisitType),
                    Label = L["Field.VisitMethod"],
                    FieldType = FormFieldType.Select,
                    IsRequired = true,
                    HelpText = "此次拜訪或聯繫的方式",
                    Options = Enum.GetValues(typeof(VisitType))
                        .Cast<VisitType>()
                        .Select(e => new SelectOption
                        {
                            Text = e switch
                            {
                                VisitType.Phone => L["VisitType.Phone"],
                                VisitType.OnSite => L["VisitType.OnSite"],
                                VisitType.VideoConference => L["VisitType.VideoConference"],
                                VisitType.Email => L["VisitType.Email"],
                                VisitType.Other => L["VisitType.Other"],
                                _ => e.ToString()
                            },
                            Value = ((int)e).ToString()
                        })
                        .ToList()
                },
                new()
                {
                    PropertyName = nameof(SupplierVisit.EmployeeId),
                    Label = L["Field.SalesPerson"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = L["Placeholder.PleaseInputOrSelect", L["Field.SalesPerson"]],
                    IsRequired = false,
                    MinSearchLength = 0,
                    HelpText = "負責此次拜訪的業務人員",
                    ActionButtons = await GetEmployeeActionButtonsAsync()
                },
                new()
                {
                    PropertyName = nameof(SupplierVisit.Purpose),
                    Label = L["Field.VisitPurpose"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.VisitPurpose"]],
                    IsRequired = false,
                    MaxLength = 100,
                    HelpText = "此次拜訪或聯繫的主要目的"
                },
                new()
                {
                    PropertyName = nameof(SupplierVisit.Content),
                    Label = L["Field.VisitContent"],
                    FieldType = FormFieldType.TextArea,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.VisitContent"]],
                    IsRequired = false,
                    MaxLength = 1000,
                    HelpText = "詳細記錄此次拜訪或聯繫的內容"
                },
                new()
                {
                    PropertyName = nameof(SupplierVisit.NextFollowUpDate),
                    Label = L["Field.NextFollowUpDate"],
                    FieldType = FormFieldType.Date,
                    IsRequired = false,
                    HelpText = "預計下次追蹤或拜訪的日期"
                },
                FormFieldConfigurationHelper.CreateRemarksField<SupplierVisit>()
            };

            formSections = FormSectionHelper<SupplierVisit>.Create()
                .AddToSection(FormSectionNames.BasicInfo,
                    v => v.SupplierId,
                    v => v.VisitDate,
                    v => v.VisitType,
                    v => v.EmployeeId,
                    v => v.Purpose)
                .AddToSection("拜訪詳情",
                    v => v.Content,
                    v => v.NextFollowUpDate)
                .AddToSection(FormSectionNames.OtherInfo,
                    v => v.Remarks)
                .Build();
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync("初始化拜訪紀錄表單欄位時發生錯誤");
        }
    }

    private async Task LoadAdditionalDataAsync()
    {
        try
        {
            availableSuppliers = await SupplierService.GetAllAsync();

            var allEmployees = await EmployeeService.GetAllAsync();
            availableEmployees = allEmployees.Where(e => !e.IsSuperAdmin).ToList();

            autoCompleteConfig = new AutoCompleteConfigBuilder<SupplierVisit>()
                .AddField(nameof(SupplierVisit.SupplierId), "CompanyName", availableSuppliers)
                .AddField(nameof(SupplierVisit.EmployeeId), "Name", availableEmployees)
                .Build();
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync("載入拜訪紀錄編輯相關資料時發生錯誤");
            availableSuppliers = new List<Supplier>();
            availableEmployees = new List<Employee>();
        }
    }

    private async Task<List<FieldActionButton>> GetSupplierActionButtonsAsync()
    {
        return await ActionButtonHelper.GenerateFieldActionButtonsAsync(
            editModalComponent,
            supplierModalManager,
            nameof(SupplierVisit.SupplierId)
        );
    }

    private async Task<List<FieldActionButton>> GetEmployeeActionButtonsAsync()
    {
        return await ActionButtonHelper.GenerateFieldActionButtonsAsync(
            editModalComponent,
            employeeModalManager,
            nameof(SupplierVisit.EmployeeId)
        );
    }
}
