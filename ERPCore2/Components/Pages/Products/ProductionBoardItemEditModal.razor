@* 看板卡片快速編輯 Modal - 點擊卡片後出現，可修改狀態/數量/結案/刪除/開始生產/完成入庫 *@
@using ERPCore2.Models.Schedule
@using ERPCore2.Models.Enums
@inject IProductionScheduleItemService ScheduleItemService
@inject ISalesOrderDetailService SalesOrderDetailService
@inject INotificationService NotificationService

<BaseModalComponent IsVisible="@IsVisible"
                    IsVisibleChanged="@IsVisibleChanged"
                    Title="@(Item?.ProductName ?? "排程項目")"
                    Icon="bi bi-pencil-square"
                    Size="BaseModalComponent.ModalSize.Small"
                    HeaderColor="BaseModalComponent.HeaderVariant.ProjectPrimary"
                    UseWhiteCloseButton="true"
                    OnClose="@HandleCancel"
                    DebugComponentName="ProductionBoardItemEditModal">

    <HeaderButtons>
        @if (showDeleteConfirm)
        {
            <div class="d-flex align-items-center gap-2">
                <span class="text-danger small fw-semibold">確定刪除此項目？</span>
                <GenericButtonComponent Variant="ButtonVariant.Red" Size="ButtonSize.Small"
                    Text="確定" OnClick="HandleDeleteConfirmed" />
                <GenericButtonComponent Variant="ButtonVariant.OutlineGray" Size="ButtonSize.Small"
                    Text="取消" OnClick="@(() => showDeleteConfirm = false)" />
            </div>
        }
        else if (showStartConfirm)
        {
            <div class="d-flex align-items-center gap-2">
                <span class="text-success small fw-semibold">確定開始生產？（將設定開始時間）</span>
                <GenericButtonComponent Variant="ButtonVariant.Green" Size="ButtonSize.Small"
                    Text="確定" OnClick="HandleStartProductionConfirmed" IsDisabled="@isProcessing" />
                <GenericButtonComponent Variant="ButtonVariant.OutlineGray" Size="ButtonSize.Small"
                    Text="取消" OnClick="@(() => showStartConfirm = false)" />
            </div>
        }
        else
        {
            <div class="d-flex gap-2 w-100">
                <GenericButtonComponent Variant="ButtonVariant.OutlineRed" Size="ButtonSize.Small"
                    IconClass="bi bi-trash" Text="刪除"
                    OnClick="@(() => showDeleteConfirm = true)"
                    IsDisabled="@(Item?.CompletedQuantity > 0)"
                    Title="@(Item?.CompletedQuantity > 0 ? "已有完成數量，無法刪除" : "刪除此排程項目")" />
                @if (Item?.ProductionItemStatus == ProductionItemStatus.Pending)
                {
                    <GenericButtonComponent Variant="ButtonVariant.Green" Size="ButtonSize.Small"
                        IconClass="bi bi-play-fill" Text="開始生產"
                        OnClick="@(() => showStartConfirm = true)"
                        Title="開始生產，並記錄實際開始時間" />
                }
                <div class="ms-auto d-flex gap-2">
                    <GenericButtonComponent Variant="ButtonVariant.OutlineGray" Size="ButtonSize.Small"
                        Text="取消" OnClick="HandleCancel" />
                    <GenericButtonComponent Variant="ButtonVariant.DarkBlue" Size="ButtonSize.Small"
                        Text="儲存" OnClick="HandleSave"
                        IsDisabled="@isProcessing" IsLoading="@isProcessing" />
                </div>
            </div>
        }
    </HeaderButtons>

    <BodyContent>
        @if (Item != null)
        {
            @if (!string.IsNullOrEmpty(Item.ProductCode))
            {
                <div class="mb-3 small text-muted">
                    <span class="fw-semibold text-secondary">@Item.ProductCode</span>
                    @if (!string.IsNullOrEmpty(Item.CustomerName) || !string.IsNullOrEmpty(Item.SalesOrderCode))
                    {
                        <span class="ms-2">
                            @Item.CustomerName
                            @if (!string.IsNullOrEmpty(Item.SalesOrderCode))
                            {
                                <span class="ms-1">・@Item.SalesOrderCode</span>
                            }
                        </span>
                    }
                </div>
            }

            <div class="mb-3">
                <label class="form-label small mb-1">生產狀態</label>
                <select class="form-select form-select-sm" @bind="editStatus">
                    <option value="@ProductionItemStatus.Pending">待生產</option>
                    <option value="@ProductionItemStatus.InProgress">生產中</option>
                    <option value="@ProductionItemStatus.Completed">已完成</option>
                    <option value="@ProductionItemStatus.Discontinued">已停產</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label small mb-1">排程數量</label>
                <input type="number" class="form-control form-control-sm"
                       @bind="editQuantity" min="0.001" step="0.001" />
                @if (Item.CompletedQuantity > 0)
                {
                    <div class="form-text">已完成：@NumberFormatHelper.FormatSmart(Item.CompletedQuantity)</div>
                }
            </div>

            @* 完成入庫區塊：只在生產中或等待完成時顯示 *@
            @if (Item.ProductionItemStatus == ProductionItemStatus.InProgress ||
                 Item.ProductionItemStatus == ProductionItemStatus.Pending && Item.CompletedQuantity < Item.ScheduledQuantity)
            {
                <div class="border rounded p-2 mb-3" style="background:var(--bg-secondary, #f8f9fa);">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="small fw-semibold text-success">
                            <i class="bi bi-box-arrow-in-down-right me-1"></i>完成入庫
                        </span>
                        <span class="small text-muted">剩餘：@NumberFormatHelper.FormatSmart(Item.ScheduledQuantity - Item.CompletedQuantity)</span>
                    </div>
                    <div class="d-flex gap-2 align-items-end">
                        <div class="flex-grow-1">
                            <label class="form-label small mb-1">本次完成數量</label>
                            <input type="number" class="form-control form-control-sm"
                                   @bind="completeQty" min="0.001" step="0.001"
                                   placeholder="輸入數量" />
                        </div>
                        <GenericButtonComponent Variant="ButtonVariant.Green" Size="ButtonSize.Small"
                            Text="確認入庫" OnClick="HandleCompleteProduction"
                            IsDisabled="@(isProcessing || completeQty <= 0)"
                            IsLoading="@isProcessing" />
                    </div>
                </div>
            }

            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="editIsClosed" @bind="editIsClosed" />
                <label class="form-check-label small" for="editIsClosed">標記結案（不再追蹤）</label>
            </div>
        }
    </BodyContent>

</BaseModalComponent>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public BoardScheduleItemDto? Item { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnDeleted { get; set; }

    private ProductionItemStatus editStatus;
    private decimal editQuantity;
    private bool editIsClosed;
    private bool isProcessing;
    private bool showDeleteConfirm;
    private bool showStartConfirm;
    private decimal completeQty;

    protected override void OnParametersSet()
    {
        if (Item != null && IsVisible)
        {
            editStatus = Item.ProductionItemStatus;
            editQuantity = Item.ScheduledQuantity;
            editIsClosed = Item.IsClosed;
            showDeleteConfirm = false;
            showStartConfirm = false;
            completeQty = 0;
        }
    }

    private async Task HandleStartProductionConfirmed()
    {
        if (Item == null) return;
        isProcessing = true;
        try
        {
            var result = await ScheduleItemService.StartProductionAsync(Item.Id);
            if (result.IsSuccess)
            {
                await NotificationService.ShowSuccessAsync("已開始生產");
                await IsVisibleChanged.InvokeAsync(false);
                await OnSaved.InvokeAsync();
            }
            else
            {
                await NotificationService.ShowErrorAsync($"開始生產失敗：{result.ErrorMessage}");
                showStartConfirm = false;
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"開始生產失敗：{ex.Message}");
            showStartConfirm = false;
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task HandleCompleteProduction()
    {
        if (Item == null || completeQty <= 0) return;
        isProcessing = true;
        try
        {
            var result = await ScheduleItemService.CompleteProductionAsync(Item.Id, completeQty);
            if (result.IsSuccess)
            {
                await NotificationService.ShowSuccessAsync($"已完成入庫 {NumberFormatHelper.FormatSmart(completeQty)}");
                await IsVisibleChanged.InvokeAsync(false);
                await OnSaved.InvokeAsync();
            }
            else
            {
                await NotificationService.ShowErrorAsync($"完成入庫失敗：{result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"完成入庫失敗：{ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task HandleSave()
    {
        if (Item == null) return;
        isProcessing = true;
        try
        {
            var item = await ScheduleItemService.GetByIdAsync(Item.Id);
            if (item == null)
            {
                await NotificationService.ShowErrorAsync("找不到排程項目");
                return;
            }

            var qtyDelta = editQuantity - item.ScheduledQuantity;
            if (qtyDelta != 0 && item.SalesOrderDetailId.HasValue)
            {
                var detail = await SalesOrderDetailService.GetByIdAsync(item.SalesOrderDetailId.Value);
                if (detail != null)
                {
                    detail.ScheduledQuantity = Math.Max(0, detail.ScheduledQuantity + qtyDelta);
                    await SalesOrderDetailService.UpdateAsync(detail);
                }
            }

            item.ProductionItemStatus = editStatus;
            item.ScheduledQuantity = editQuantity;
            item.IsClosed = editIsClosed;
            await ScheduleItemService.UpdateAsync(item);

            await NotificationService.ShowSuccessAsync("已儲存");
            await IsVisibleChanged.InvokeAsync(false);
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"儲存失敗：{ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task HandleDeleteConfirmed()
    {
        if (Item == null) return;
        try
        {
            var item = await ScheduleItemService.GetByIdAsync(Item.Id);
            if (item?.SalesOrderDetailId.HasValue == true)
            {
                var detail = await SalesOrderDetailService.GetByIdAsync(item.SalesOrderDetailId!.Value);
                if (detail != null)
                {
                    detail.ScheduledQuantity = Math.Max(0, detail.ScheduledQuantity - item.ScheduledQuantity);
                    await SalesOrderDetailService.UpdateAsync(detail);
                }
            }
            await ScheduleItemService.PermanentDeleteAsync(Item.Id);
            await NotificationService.ShowSuccessAsync("已刪除");
            await IsVisibleChanged.InvokeAsync(false);
            await OnDeleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"刪除失敗：{ex.Message}");
        }
    }

    private async Task HandleCancel()
    {
        showDeleteConfirm = false;
        await IsVisibleChanged.InvokeAsync(false);
    }
}
