@* 看板卡片快速編輯 Modal - 狀態自動管理，使用者僅需調整數量與確認入庫 *@
@using ERPCore2.Models.Schedule
@using ERPCore2.Models.Enums
@using ERPCore2.Data.Entities
@inject IProductionScheduleItemService ScheduleItemService
@inject IProductionScheduleDetailService ScheduleDetailService
@inject ISalesOrderDetailService SalesOrderDetailService
@inject INotificationService NotificationService

<BaseModalComponent IsVisible="@IsVisible"
                    IsVisibleChanged="@IsVisibleChanged"
                    Title="@(Item?.ProductName ?? "排程項目")"
                    Size="BaseModalComponent.ModalSize.Small"
                    HeaderColor="BaseModalComponent.HeaderVariant.ProjectPrimary"
                    UseWhiteCloseButton="true"
                    OnClose="@HandleCancel"
                    DebugComponentName="ProductionBoardItemEditModal">

    <HeaderButtons>
        @if (showDeleteConfirm)
        {
            <div class="d-flex align-items-center gap-2">
                <span class="text-danger small fw-semibold">確定刪除此項目？</span>
                <GenericButtonComponent Variant="ButtonVariant.Red" Size="ButtonSize.Small"
                    Text="確定" OnClick="HandleDeleteConfirmed" />
                <GenericButtonComponent Variant="ButtonVariant.OutlineGray" Size="ButtonSize.Small"
                    Text="取消" OnClick="@(() => showDeleteConfirm = false)" />
            </div>
        }
        else
        {
            <div class="d-flex gap-2 w-100 align-items-center justify-content-end">
                <GenericButtonComponent Variant="ButtonVariant.DarkBlue" Size="ButtonSize.Small"
                    Text="儲存" OnClick="HandleSave"
                    IsDisabled="@isProcessing" IsLoading="@isProcessing" />
                @if (hasBom)
                {
                    <GenericButtonComponent Variant="ButtonVariant.Green" Size="ButtonSize.Small"
                        Text="領料" OnClick="HandleIssueMaterial"
                        IsDisabled="@(isProcessing || materialComplete)"
                        IsLoading="@isProcessing" />
                }
                <GenericButtonComponent Variant="ButtonVariant.Red" Size="ButtonSize.Small"
                    Text="刪除"
                    OnClick="@(() => showDeleteConfirm = true)"
                    IsDisabled="@(Item?.CompletedQuantity > 0)"
                    Title="@(Item?.CompletedQuantity > 0 ? "已有完成數量，無法刪除" : "刪除此排程項目")" />
            </div>
        }
    </HeaderButtons>

    <BodyContent>
        @if (Item != null)
        {
            @* 商品與訂單資訊 *@
            @if (!string.IsNullOrEmpty(Item.ProductCode))
            {
                <div class="mb-3 text-muted" style="font-size:0.9rem;">
                    <span class="fw-semibold text-secondary">@Item.ProductCode</span>
                    @if (!string.IsNullOrEmpty(Item.CustomerName) || !string.IsNullOrEmpty(Item.SalesOrderCode))
                    {
                        <span class="ms-2">
                            @Item.CustomerName
                            @if (!string.IsNullOrEmpty(Item.SalesOrderCode))
                            {
                                <span class="ms-1">・@Item.SalesOrderCode</span>
                            }
                        </span>
                    }
                </div>
            }

            @* 狀態 Badge（唯讀） *@
            <div class="mb-3 d-flex align-items-center gap-2">
                <span class="badge @StatusBadgeCss" style="font-size:0.85rem;">@StatusText</span>
                @if (hasBom)
                {
                    <span class="badge @MaterialBadgeCss" style="font-size:0.85rem;">領料：@MaterialStatusText</span>
                }
            </div>

            @* 排程數量 *@
            <div class="mb-3 d-flex align-items-center gap-2">
                <label class="form-label mb-0 text-nowrap">排程數量</label>
                <input type="number" class="form-control form-control-sm"
                       @bind="editQuantity" min="0.001" step="0.001" style="max-width:120px;" />
                @if (Item.CompletedQuantity > 0)
                {
                    <span class="text-muted" style="font-size:0.85rem;white-space:nowrap;">已完成：@NumberFormatHelper.FormatSmart(Item.CompletedQuantity)</span>
                }
            </div>

            @* 確認入庫：只在生產中且尚有剩餘時顯示 *@
            @if (Item.ProductionItemStatus == ProductionItemStatus.InProgress
              && Item.CompletedQuantity < Item.ScheduledQuantity)
            {
                <div class="border rounded p-2 mb-3" style="background:var(--bg-secondary, #f8f9fa);">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="fw-semibold text-success" style="font-size:0.9rem;">
                            <i class="bi bi-box-arrow-in-down-right me-1"></i>確認入庫
                        </span>
                        <span class="text-muted" style="font-size:0.85rem;">剩餘：@NumberFormatHelper.FormatSmart(Item.ScheduledQuantity - Item.CompletedQuantity)</span>
                    </div>
                    <div class="d-flex gap-2 align-items-end">
                        <div class="flex-grow-1">
                            <label class="form-label mb-1" style="font-size:0.85rem;">本次入庫數量</label>
                            <input type="number" class="form-control form-control-sm"
                                   @bind="completeQty" min="0.001" step="0.001"
                                   placeholder="輸入數量" />
                        </div>
                        <GenericButtonComponent Variant="ButtonVariant.Green" Size="ButtonSize.Small"
                            Text="確認入庫" OnClick="HandleCompleteProduction"
                            IsDisabled="@(isProcessing || completeQty <= 0)"
                            IsLoading="@isProcessing" />
                    </div>
                </div>
            }
        }
    </BodyContent>

</BaseModalComponent>

@* 領料單編輯 Modal：由 HandleIssueMaterial 開啟，使用正式領料流程建立領料單記錄 *@
<MaterialIssueEditModalComponent IsVisible="@showMaterialIssueModal"
                                 IsVisibleChanged="@((bool v) => showMaterialIssueModal = v)"
                                 SourceProductionScheduleItemId="@Item?.Id"
                                 SourceProductionScheduleId="@Item?.ProductionScheduleId"
                                 OnMaterialIssueSaved="@HandleMaterialIssued"
                                 OnCancel="@(() => showMaterialIssueModal = false)" />

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public BoardScheduleItemDto? Item { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnDeleted { get; set; }

    private decimal editQuantity;
    private bool isProcessing;
    private bool showDeleteConfirm;
    private decimal completeQty;
    private bool hasBom;
    private bool materialComplete;
    private bool showMaterialIssueModal;

    protected override async Task OnParametersSetAsync()
    {
        if (Item != null && IsVisible)
        {
            editQuantity = decimal.Parse(Item.ScheduledQuantity.ToString("G"));
            showDeleteConfirm = false;
            completeQty = 0;
            await LoadMaterialStatusAsync();
        }
    }

    private async Task LoadMaterialStatusAsync()
    {
        if (Item == null) return;
        var details = await ScheduleDetailService.GetByScheduleItemIdAsync(Item.Id);
        hasBom = details.Count > 0;
        materialComplete = !hasBom || details.All(d => d.IssuedQuantity >= d.RequiredQuantity);
    }

    private string StatusBadgeCss => Item?.ProductionItemStatus switch
    {
        ProductionItemStatus.WaitingMaterial => "bg-warning text-dark",
        ProductionItemStatus.Pending         => "bg-warning text-dark",
        ProductionItemStatus.InProgress      => "bg-primary",
        ProductionItemStatus.Completed       => "bg-success",
        _                                    => "bg-secondary"
    };

    private string StatusText => Item?.ProductionItemStatus switch
    {
        ProductionItemStatus.WaitingMaterial => "等待領料",
        ProductionItemStatus.Pending         => "等待領料",
        ProductionItemStatus.InProgress      => "生產中",
        ProductionItemStatus.Completed       => "已完成",
        _                                    => "未知"
    };

    private string MaterialBadgeCss => materialComplete ? "bg-success" : "bg-warning text-dark";
    private string MaterialStatusText => materialComplete ? "完成" : "尚未";

    private void HandleIssueMaterial()
    {
        if (Item == null || materialComplete) return;
        showMaterialIssueModal = true;
    }

    private async Task HandleMaterialIssued(MaterialIssue savedIssue)
    {
        await LoadMaterialStatusAsync();

        // 若所有組件已領完，將狀態推進至生產中
        if (materialComplete && Item != null)
        {
            var item = await ScheduleItemService.GetByIdAsync(Item.Id);
            if (item != null && item.ProductionItemStatus is
                ProductionItemStatus.Pending or ProductionItemStatus.WaitingMaterial)
            {
                item.ProductionItemStatus = ProductionItemStatus.InProgress;
                item.ActualStartDate ??= DateTime.Now;
                await ScheduleItemService.UpdateAsync(item);
            }
        }

        await OnSaved.InvokeAsync();
    }

    private async Task HandleCompleteProduction()
    {
        if (Item == null || completeQty <= 0) return;
        isProcessing = true;
        try
        {
            var result = await ScheduleItemService.CompleteProductionAsync(Item.Id, completeQty);
            if (result.IsSuccess)
            {
                // 若已全部完成，自動升格為 Completed
                var totalCompleted = Item.CompletedQuantity + completeQty;
                if (totalCompleted >= Item.ScheduledQuantity)
                {
                    var schedItem = await ScheduleItemService.GetByIdAsync(Item.Id);
                    if (schedItem != null)
                    {
                        schedItem.ProductionItemStatus = ProductionItemStatus.Completed;
                        await ScheduleItemService.UpdateAsync(schedItem);
                    }
                }
                await NotificationService.ShowSuccessAsync($"已確認入庫 {NumberFormatHelper.FormatSmart(completeQty)}");
                await IsVisibleChanged.InvokeAsync(false);
                await OnSaved.InvokeAsync();
            }
            else
            {
                await NotificationService.ShowErrorAsync($"確認入庫失敗：{result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"確認入庫失敗：{ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task HandleSave()
    {
        if (Item == null) return;
        isProcessing = true;
        try
        {
            var item = await ScheduleItemService.GetByIdAsync(Item.Id);
            if (item == null)
            {
                await NotificationService.ShowErrorAsync("找不到排程項目");
                return;
            }

            var qtyDelta = editQuantity - item.ScheduledQuantity;
            if (qtyDelta != 0 && item.SalesOrderDetailId.HasValue)
            {
                var detail = await SalesOrderDetailService.GetByIdAsync(item.SalesOrderDetailId.Value);
                if (detail != null)
                {
                    detail.ScheduledQuantity = Math.Max(0, detail.ScheduledQuantity + qtyDelta);
                    await SalesOrderDetailService.UpdateAsync(detail);
                }
            }

            item.ScheduledQuantity = editQuantity;
            await ScheduleItemService.UpdateAsync(item);

            await NotificationService.ShowSuccessAsync("已儲存");
            await IsVisibleChanged.InvokeAsync(false);
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"儲存失敗：{ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task HandleDeleteConfirmed()
    {
        if (Item == null) return;
        try
        {
            var item = await ScheduleItemService.GetByIdAsync(Item.Id);
            if (item?.SalesOrderDetailId.HasValue == true)
            {
                var detail = await SalesOrderDetailService.GetByIdAsync(item.SalesOrderDetailId!.Value);
                if (detail != null)
                {
                    detail.ScheduledQuantity = Math.Max(0, detail.ScheduledQuantity - item.ScheduledQuantity);
                    await SalesOrderDetailService.UpdateAsync(detail);
                }
            }
            await ScheduleItemService.PermanentDeleteAsync(Item.Id);
            await NotificationService.ShowSuccessAsync("已刪除");
            await IsVisibleChanged.InvokeAsync(false);
            await OnDeleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"刪除失敗：{ex.Message}");
        }
    }

    private async Task HandleCancel()
    {
        showDeleteConfirm = false;
        await IsVisibleChanged.InvokeAsync(false);
    }
}
