@* 看板卡片快速編輯 Modal - 狀態自動管理，使用者僅需確認入庫與用料結算 *@
@using ERPCore2.Models.Schedule
@using ERPCore2.Models.Enums
@using ERPCore2.Data.Entities
@inject IProductionScheduleItemService ScheduleItemService
@inject IProductionScheduleDetailService ScheduleDetailService
@inject IWarehouseService WarehouseService
@inject IWarehouseLocationService WarehouseLocationService
@inject INotificationService NotificationService

<BaseModalComponent IsVisible="@IsVisible"
                    IsVisibleChanged="@IsVisibleChanged"
                    Title="@(Item?.ProductName ?? "排程項目")"
                    Size="BaseModalComponent.ModalSize.Large"
                    HeaderColor="BaseModalComponent.HeaderVariant.ProjectPrimary"
                    UseWhiteCloseButton="true"
                    CloseOnBackdropClick="false"
                    OnClose="@HandleCancel"
                    DebugComponentName="ProductionBoardItemEditModal">

    <HeaderButtons>
        @if (showReturnConfirm)
        {
            <div class="d-flex align-items-center gap-2">
                <span class="text-warning fw-semibold">確定退回至待排清單？</span>
                <GenericButtonComponent Variant="ButtonVariant.Orange" Size="ButtonSize.Small"
                    Text="確定退回" OnClick="HandleReturnConfirmed" />
                <GenericButtonComponent Variant="ButtonVariant.OutlineGray" Size="ButtonSize.Small"
                    Text="取消" OnClick="@(() => showReturnConfirm = false)" />
            </div>
        }
        else if (showForceStartConfirm)
        {
            <div class="d-flex align-items-center gap-2">
                <span class="text-warning fw-semibold">材料未齊，確定強制開始生產？</span>
                <GenericButtonComponent Variant="ButtonVariant.Orange" Size="ButtonSize.Small"
                    Text="確定開始" OnClick="HandleStartProduction" IsLoading="@isProcessing" />
                <GenericButtonComponent Variant="ButtonVariant.OutlineGray" Size="ButtonSize.Small"
                    Text="取消" OnClick="@(() => showForceStartConfirm = false)" />
            </div>
        }
        else if (showAbortConfirm)
        {
            <div class="d-flex align-items-center gap-2">
                <span class="text-danger fw-semibold">確定停止生產並結案？</span>
                <GenericButtonComponent Variant="ButtonVariant.Red" Size="ButtonSize.Small"
                    Text="確定停產" OnClick="HandleAbortProduction" IsLoading="@isProcessing" />
                <GenericButtonComponent Variant="ButtonVariant.OutlineGray" Size="ButtonSize.Small"
                    Text="取消" OnClick="@(() => showAbortConfirm = false)" />
            </div>
        }
        else
        {
            <div class="d-flex gap-2 w-100 align-items-center justify-content-end">
                @if (hasBom)
                {
                    <GenericButtonComponent Variant="ButtonVariant.Green" Size="ButtonSize.Small"
                        Text="領料" OnClick="HandleIssueMaterial"
                        IsDisabled="@(isProcessing || materialComplete)"
                        IsLoading="@isProcessing" />
                }
                @if (Item?.ProductionItemStatus is ProductionItemStatus.WaitingMaterial or ProductionItemStatus.Pending)
                {
                    @if (!hasBom || materialComplete)
                    {
                        <GenericButtonComponent Variant="ButtonVariant.Green" Size="ButtonSize.Small"
                            Text="開始生產" OnClick="HandleStartProduction"
                            IsDisabled="@isProcessing" IsLoading="@isProcessing"
                            Title="材料已備齊，開始生產" />
                    }
                    else
                    {
                        <GenericButtonComponent Variant="ButtonVariant.Orange" Size="ButtonSize.Small"
                            Text="強制開始" OnClick="@(() => showForceStartConfirm = true)"
                            IsDisabled="@isProcessing"
                            Title="材料尚未領齊，點擊確認強制開始生產" />
                    }
                }
                @if (Item?.ProductionItemStatus == ProductionItemStatus.InProgress && Item.CompletedQuantity > 0)
                {
                    <GenericButtonComponent Variant="ButtonVariant.Red" Size="ButtonSize.Small"
                        Text="停產"
                        OnClick="HandleAbortRequest"
                        IsDisabled="@isProcessing"
                        Title="停止生產並結案，不再繼續製作" />
                }
                <GenericButtonComponent Variant="ButtonVariant.Orange" Size="ButtonSize.Small"
                    Text="退回"
                    OnClick="@(() => showReturnConfirm = true)"
                    IsDisabled="@(Item?.CompletedQuantity > 0)"
                    Title="@(Item?.CompletedQuantity > 0 ? "已有完成數量，無法退回" : "退回至待排清單，還原訂單排程數量")" />
            </div>
        }
    </HeaderButtons>

    <BodyContent>
        @if (Item != null)
        {
            @* 商品與訂單資訊 *@
            @if (!string.IsNullOrEmpty(Item.ProductCode))
            {
                <div class="mb-3 text-muted">
                    <span class="fw-semibold text-secondary">@Item.ProductCode</span>
                    @if (!string.IsNullOrEmpty(Item.CustomerName) || !string.IsNullOrEmpty(Item.SalesOrderCode))
                    {
                        <span class="ms-2">
                            @Item.CustomerName
                            @if (!string.IsNullOrEmpty(Item.SalesOrderCode))
                            {
                                <span class="ms-1">・@Item.SalesOrderCode</span>
                            }
                        </span>
                    }
                </div>
            }

            @* 狀態 Badge（唯讀） *@
            <div class="mb-3 d-flex align-items-center gap-2">
                <span class="badge @StatusBadgeCss">@StatusText</span>
                @if (hasBom)
                {
                    <span class="badge @MaterialBadgeCss">領料：@MaterialStatusText</span>
                }
            </div>

            @* 強制開始警告訊息 *@
            @if (Item.ProductionItemStatus is ProductionItemStatus.WaitingMaterial or ProductionItemStatus.Pending
                && hasBom && !materialComplete)
            {
                <div class="alert alert-warning py-2 px-3 mb-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>尚有組件未領齊，建議先完成領料再開始生產
                </div>
            }

            @* A. 三欄統計列：排程 / 已完成 / 剩餘 *@
            <div class="mb-3 stats-row">
                <div class="stat-item">
                    <span class="stat-label">排程</span>
                    <span class="stat-value">@NumberFormatHelper.FormatSmart(Item.ScheduledQuantity)</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-label">已完成</span>
                    <span class="stat-value stat-done">@NumberFormatHelper.FormatSmart(Item.CompletedQuantity)</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-label">剩餘</span>
                    <span class="stat-value stat-remaining">@NumberFormatHelper.FormatSmart(Item.ScheduledQuantity - Item.CompletedQuantity)</span>
                </div>
            </div>

            @* B. 進度條 *@
            @if (Item.ScheduledQuantity > 0 && Item.CompletedQuantity > 0)
            {
                <div class="modal-progress mb-3">
                    <div class="modal-progress-bar" style="width: @(ProgressPercent)%"></div>
                </div>
            }

            @* 確認入庫：只在生產中且尚有剩餘時顯示 *@
            @if (Item.ProductionItemStatus == ProductionItemStatus.InProgress
              && Item.CompletedQuantity < Item.ScheduledQuantity)
            {
                <div class="border rounded p-2 mb-3 complete-section">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="fw-semibold text-success">
                            <i class="bi bi-box-arrow-in-down-right me-1"></i>確認入庫
                        </span>
                    </div>
                    <div class="d-flex gap-2 align-items-end flex-wrap mb-2">
                        <div>
                            <label class="form-label mb-1">本次入庫數量</label>
                            <input type="number" class="form-control form-control-sm input-qty"
                                   @bind="completeQty" @bind:after="OnCompleteQtyChanged"
                                   min="0.001" step="0.001"
                                   placeholder="輸入數量" />
                        </div>
                        <div>
                            <label class="form-label mb-1">入庫倉庫</label>
                            <select class="form-select form-select-sm select-warehouse"
                                    @bind="selectedWarehouseId" @bind:after="LoadLocationsAsync">
                                <option value="">請選擇</option>
                                @foreach (var wh in warehouses)
                                {
                                    <option value="@wh.Id">@wh.Name</option>
                                }
                            </select>
                        </div>
                        <div class="@(locations.Any() ? "" : "d-none")">
                            <label class="form-label mb-1">庫位</label>
                            <select class="form-select form-select-sm select-location"
                                    @bind="selectedLocationId">
                                <option value="">不指定</option>
                                @foreach (var loc in locations)
                                {
                                    <option value="@loc.Id">@loc.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    @* C. 用料結算（可收合） *@
                    @if (isLastCompletion && settlementRows.Any())
                    {
                        <div class="border-top pt-2 mt-2">
                            <button class="btn btn-sm btn-link p-0 text-decoration-none fw-semibold mb-2"
                                    type="button"
                                    @onclick="@(() => showSettlement = !showSettlement)">
                                <i class="bi bi-clipboard-check me-1"></i>用料結算
                                <i class="bi @(showSettlement ? "bi-chevron-up" : "bi-chevron-down") ms-1"></i>
                                <span class="text-muted fw-normal ms-1">（實際用量 + 退料量 + 損耗量 = 已領量）</span>
                            </button>
                            @if (showSettlement)
                            {
                                @foreach (var row in settlementRows)
                                {
                                    <div class="border rounded p-2 mb-2">
                                        <div class="fw-semibold mb-1">@row.ComponentName</div>
                                        <div class="text-muted mb-1">已領量：@NumberFormatHelper.FormatSmart(row.IssuedQty)</div>
                                        <div class="d-flex gap-2 flex-wrap">
                                            <div>
                                                <label class="form-label mb-0">實際用量</label>
                                                <input type="number" class="form-control form-control-sm settlement-input"
                                                       @bind="row.Settlement.ActualUsedQty" min="0" step="0.001" />
                                            </div>
                                            <div>
                                                <label class="form-label mb-0">退料量</label>
                                                <input type="number" class="form-control form-control-sm settlement-input"
                                                       @bind="row.Settlement.ReturnQty" min="0" step="0.001" />
                                            </div>
                                            @* E. 退料倉庫：CSS visibility，不做 Razor 條件渲染 *@
                                            <div style="visibility: @(row.Settlement.ReturnQty > 0 ? "visible" : "hidden")">
                                                <label class="form-label mb-0">退料倉庫</label>
                                                <select class="form-select form-select-sm select-location"
                                                        @bind="row.Settlement.ReturnWarehouseId">
                                                    <option value="">請選擇</option>
                                                    @foreach (var wh in warehouses)
                                                    {
                                                        <option value="@wh.Id">@wh.Name</option>
                                                    }
                                                </select>
                                            </div>
                                            <div>
                                                <label class="form-label mb-0">損耗量</label>
                                                <input type="number" class="form-control form-control-sm settlement-input"
                                                       @bind="row.Settlement.ScrapQty" min="0" step="0.001" />
                                            </div>
                                            <div style="visibility: @(row.Settlement.ScrapQty > 0 ? "visible" : "hidden")">
                                                <label class="form-label mb-0">損耗備註</label>
                                                <input type="text" class="form-control form-control-sm settlement-reason"
                                                       @bind="row.Settlement.ScrapReason" placeholder="原因說明" />
                                            </div>
                                        </div>
                                        @if (SettlementRowHasError(row))
                                        {
                                            <div class="text-danger mt-1">
                                                <i class="bi bi-exclamation-circle me-1"></i>實際用量 + 退料量 + 損耗量 ≠ 已領量（@NumberFormatHelper.FormatSmart(row.IssuedQty)）
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    }

                    @if (isLastCompletion && settlementRows.Any(r => SettlementRowHasError(r)))
                    {
                        <div class="alert alert-danger py-1 px-2 mb-2 mt-2">
                            <i class="bi bi-exclamation-circle me-1"></i>
                            有 @settlementRows.Count(r => SettlementRowHasError(r)) 筆用料結算數量不符，請確認後再入庫
                        </div>
                    }

                    @* D. 確認入庫按鈕 *@
                    <div class="mt-2 text-end confirm-btn-row">
                        <GenericButtonComponent Variant="ButtonVariant.Green" Size="ButtonSize.Small"
                            Text="確認入庫" OnClick="HandleCompleteProduction"
                            IsDisabled="@(isProcessing || completeQty is null or <= 0 || !selectedWarehouseId.HasValue)"
                            IsLoading="@isProcessing" />
                    </div>
                </div>
            }

            @* 停產時的結算區塊（InProgress && CompletedQuantity > 0，且已點「停產」） *@
            @if (Item.ProductionItemStatus == ProductionItemStatus.InProgress
              && Item.CompletedQuantity > 0
              && showAbortSettlement
              && settlementRows.Any())
            {
                <div class="border border-danger rounded p-2 mb-3">
                    <div class="fw-semibold text-danger mb-2">
                        <i class="bi bi-clipboard-check me-1"></i>停產用料結算
                        <span class="text-muted fw-normal ms-1">（實際用量 + 退料量 + 損耗量 = 已領量）</span>
                    </div>
                    @foreach (var row in settlementRows)
                    {
                        <div class="border rounded p-2 mb-2">
                            <div class="fw-semibold mb-1">@row.ComponentName</div>
                            <div class="text-muted mb-1">已領量：@NumberFormatHelper.FormatSmart(row.IssuedQty)</div>
                            <div class="d-flex gap-2 flex-wrap">
                                <div>
                                    <label class="form-label mb-0">實際用量</label>
                                    <input type="number" class="form-control form-control-sm settlement-input"
                                           @bind="row.Settlement.ActualUsedQty" min="0" step="0.001" />
                                </div>
                                <div>
                                    <label class="form-label mb-0">退料量</label>
                                    <input type="number" class="form-control form-control-sm settlement-input"
                                           @bind="row.Settlement.ReturnQty" min="0" step="0.001" />
                                </div>
                                <div style="visibility: @(row.Settlement.ReturnQty > 0 ? "visible" : "hidden")">
                                    <label class="form-label mb-0">退料倉庫</label>
                                    <select class="form-select form-select-sm select-location"
                                            @bind="row.Settlement.ReturnWarehouseId">
                                        <option value="">請選擇</option>
                                        @foreach (var wh in warehouses)
                                        {
                                            <option value="@wh.Id">@wh.Name</option>
                                        }
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label mb-0">損耗量</label>
                                    <input type="number" class="form-control form-control-sm settlement-input"
                                           @bind="row.Settlement.ScrapQty" min="0" step="0.001" />
                                </div>
                                <div style="visibility: @(row.Settlement.ScrapQty > 0 ? "visible" : "hidden")">
                                    <label class="form-label mb-0">損耗備註</label>
                                    <input type="text" class="form-control form-control-sm settlement-reason"
                                           @bind="row.Settlement.ScrapReason" placeholder="原因說明" />
                                </div>
                            </div>
                            @if (SettlementRowHasError(row))
                            {
                                <div class="text-danger mt-1">
                                    <i class="bi bi-exclamation-circle me-1"></i>實際用量 + 退料量 + 損耗量 ≠ 已領量（@NumberFormatHelper.FormatSmart(row.IssuedQty)）
                                </div>
                            }
                        </div>
                    }
                    @if (settlementRows.Any(r => SettlementRowHasError(r)))
                    {
                        <div class="alert alert-danger py-1 px-2 mb-2">
                            <i class="bi bi-exclamation-circle me-1"></i>
                            有 @settlementRows.Count(r => SettlementRowHasError(r)) 筆用料結算數量不符，請確認後再停產
                        </div>
                    }
                </div>
            }
        }
    </BodyContent>

</BaseModalComponent>

@* 領料單編輯 Modal：由 HandleIssueMaterial 開啟，使用正式領料流程建立領料單記錄 *@
<MaterialIssueEditModalComponent IsVisible="@showMaterialIssueModal"
                                 IsVisibleChanged="@((bool v) => showMaterialIssueModal = v)"
                                 SourceProductionScheduleItemId="@Item?.Id"
                                 SourceProductionScheduleId="@Item?.ProductionScheduleId"
                                 OnMaterialIssueSaved="@HandleMaterialIssued"
                                 OnCancel="@(() => showMaterialIssueModal = false)" />

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public BoardScheduleItemDto? Item { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnDeleted { get; set; }

    private bool isProcessing;
    private bool showReturnConfirm;
    private bool showForceStartConfirm;
    private bool showAbortConfirm;
    private bool showAbortSettlement;
    private bool showSettlement = true;
    private decimal? completeQty;
    private bool hasBom;
    private bool materialComplete;
    private bool showMaterialIssueModal;
    private bool isLastCompletion;

    // 倉庫/庫位選擇
    private List<Warehouse> warehouses = new();
    private List<WarehouseLocation> locations = new();
    private int? selectedWarehouseId;
    private int? selectedLocationId;

    // 用料結算
    private List<SettlementEditRow> settlementRows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Item != null && IsVisible)
        {
            showReturnConfirm = false;
            showForceStartConfirm = false;
            showAbortConfirm = false;
            showAbortSettlement = false;
            showSettlement = true;
            completeQty = null;
            selectedWarehouseId = null;
            selectedLocationId = null;
            locations = new();
            settlementRows = new();
            isLastCompletion = false;

            await LoadMaterialStatusAsync();
            await LoadWarehousesAsync();

            // 預填剩餘數量
            if (Item.ProductionItemStatus == ProductionItemStatus.InProgress
                && Item.CompletedQuantity < Item.ScheduledQuantity)
            {
                completeQty = Math.Round(Item.ScheduledQuantity - Item.CompletedQuantity, 3);
                OnCompleteQtyChanged();
            }
        }
    }

    private async Task LoadWarehousesAsync()
    {
        warehouses = await WarehouseService.GetAllAsync();

        // 預填上次同商品入庫位置
        if (Item != null)
        {
            var (wId, lId) = await ScheduleItemService.GetLastCompletionWarehouseAsync(Item.ProductId);
            if (wId.HasValue)
            {
                selectedWarehouseId = wId;
                await LoadLocationsAsync();
                selectedLocationId = lId;
            }
        }
    }

    private async Task LoadLocationsAsync()
    {
        if (!selectedWarehouseId.HasValue)
        {
            locations = new();
            selectedLocationId = null;
            return;
        }
        var result = await WarehouseLocationService.GetByWarehouseIdAsync(selectedWarehouseId.Value);
        locations = result.IsSuccess ? result.Data?.ToList() ?? new() : new();
        if (!locations.Any(l => l.Id == selectedLocationId))
            selectedLocationId = null;
    }

    private async Task LoadMaterialStatusAsync()
    {
        if (Item == null) return;
        var details = await ScheduleDetailService.GetByScheduleItemIdAsync(Item.Id);
        hasBom = details.Count > 0;
        materialComplete = !hasBom || details.All(d => d.IssuedQuantity >= d.RequiredQuantity);

        // 預建用料結算列（含已領量）
        settlementRows = details
            .Where(d => d.IssuedQuantity > 0)
            .Select(d => new SettlementEditRow
            {
                ComponentName = d.ComponentProduct?.Name ?? $"ID:{d.ComponentProductId}",
                IssuedQty = d.IssuedQuantity,
                Settlement = new MaterialSettlementDto
                {
                    ProductionScheduleDetailId = d.Id,
                    ActualUsedQty = d.IssuedQuantity,
                    ReturnQty = null,
                    ScrapQty = null
                }
            })
            .ToList();
    }

    private void OnCompleteQtyChanged()
    {
        if (Item == null) return;
        isLastCompletion = (Item.CompletedQuantity + (completeQty ?? 0)) >= Item.ScheduledQuantity;
    }

    private bool SettlementRowHasError(SettlementEditRow row)
    {
        if (row.IssuedQty == 0) return false;
        var sum = row.Settlement.ActualUsedQty + (row.Settlement.ReturnQty ?? 0) + (row.Settlement.ScrapQty ?? 0);
        return Math.Abs(sum - row.IssuedQty) > 0.0001m;
    }

    private string StatusBadgeCss => Item?.ProductionItemStatus switch
    {
        ProductionItemStatus.WaitingMaterial => "bg-warning text-dark",
        ProductionItemStatus.Pending         => "bg-warning text-dark",
        ProductionItemStatus.InProgress      => "bg-primary",
        ProductionItemStatus.Completed       => "bg-success",
        _                                    => "bg-secondary"
    };

    private string StatusText => Item?.ProductionItemStatus switch
    {
        ProductionItemStatus.WaitingMaterial => "等待領料",
        ProductionItemStatus.Pending         => "等待領料",
        ProductionItemStatus.InProgress      => "生產中",
        ProductionItemStatus.Completed       => "已完成",
        _                                    => "未知"
    };

    private string MaterialBadgeCss => materialComplete ? "bg-success" : "bg-warning text-dark";
    private string MaterialStatusText => materialComplete ? "完成" : "尚未";

    private string ProgressPercent => Item != null && Item.ScheduledQuantity > 0
        ? Math.Min(100, (double)Item.CompletedQuantity / (double)Item.ScheduledQuantity * 100).ToString("F0")
        : "0";

    private void HandleIssueMaterial()
    {
        if (Item == null || materialComplete) return;
        showMaterialIssueModal = true;
    }

    private async Task HandleMaterialIssued(MaterialIssue savedIssue)
    {
        await LoadMaterialStatusAsync();

        // 材料全部領齊且有 BOM → 自動呼叫 StartProductionAsync（§3.2）
        if (materialComplete && hasBom && Item != null)
        {
            var startResult = await ScheduleItemService.StartProductionAsync(Item.Id);
            if (!startResult.IsSuccess)
                await NotificationService.ShowWarningAsync($"自動升格生產中失敗：{startResult.ErrorMessage}");
        }

        await OnSaved.InvokeAsync();
    }

    private async Task HandleStartProduction()
    {
        if (Item == null) return;
        isProcessing = true;
        try
        {
            var result = await ScheduleItemService.StartProductionAsync(Item.Id);
            if (result.IsSuccess)
            {
                await NotificationService.ShowSuccessAsync("已開始生產");
                await IsVisibleChanged.InvokeAsync(false);
                await OnSaved.InvokeAsync();
            }
            else
            {
                await NotificationService.ShowErrorAsync($"開始生產失敗：{result.ErrorMessage}");
            }
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void HandleAbortRequest()
    {
        // 若有已領料，展開結算區塊讓使用者填寫後再按標題確認
        if (settlementRows.Any())
            showAbortSettlement = true;
        showAbortConfirm = true;
    }

    private async Task HandleAbortProduction()
    {
        if (Item == null) return;

        // 若有結算資料，驗證
        if (showAbortSettlement && settlementRows.Any(r => SettlementRowHasError(r)))
        {
            await NotificationService.ShowWarningAsync("用料結算數量不符，請確認實際用量 + 退料量 + 損耗量 = 已領量");
            showAbortConfirm = false;
            return;
        }

        isProcessing = true;
        try
        {
            List<MaterialSettlementDto>? settlements = null;
            if (showAbortSettlement && settlementRows.Any())
                settlements = settlementRows.Select(r => r.Settlement).ToList();

            var result = await ScheduleItemService.AbortProductionAsync(Item.Id, settlements);
            if (result.IsSuccess)
            {
                await NotificationService.ShowSuccessAsync("已停產結案");
                await IsVisibleChanged.InvokeAsync(false);
                await OnSaved.InvokeAsync();
            }
            else
            {
                await NotificationService.ShowErrorAsync($"停產失敗：{result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"停產失敗：{ex.Message}");
        }
        finally
        {
            isProcessing = false;
            showAbortConfirm = false;
        }
    }

    private async Task HandleCompleteProduction()
    {
        if (Item == null || completeQty is null or <= 0) return;
        if (!selectedWarehouseId.HasValue)
        {
            await NotificationService.ShowWarningAsync("請選擇入庫倉庫");
            return;
        }

        // 驗證結算（最後一次完工才驗證）
        if (isLastCompletion && settlementRows.Any(r => SettlementRowHasError(r)))
        {
            await NotificationService.ShowWarningAsync("用料結算數量不符，請確認實際用量 + 退料量 + 損耗量 = 已領量");
            return;
        }

        isProcessing = true;
        try
        {
            List<MaterialSettlementDto>? settlements = null;
            if (isLastCompletion && settlementRows.Any())
                settlements = settlementRows.Select(r => r.Settlement).ToList();

            var result = await ScheduleItemService.CompleteProductionAsync(
                Item.Id, completeQty.Value,
                selectedWarehouseId, selectedLocationId,
                settlements);

            if (result.IsSuccess)
            {
                await NotificationService.ShowSuccessAsync($"已確認入庫 {NumberFormatHelper.FormatSmart(completeQty.Value)}");
                await IsVisibleChanged.InvokeAsync(false);
                await OnSaved.InvokeAsync();
            }
            else
            {
                await NotificationService.ShowErrorAsync($"確認入庫失敗：{result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"確認入庫失敗：{ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task HandleReturnConfirmed()
    {
        if (Item == null) return;
        try
        {
            var result = await ScheduleItemService.ReturnToSidebarAsync(Item.Id);
            if (!result.IsSuccess)
            {
                await NotificationService.ShowErrorAsync($"退回失敗：{result.ErrorMessage}");
                return;
            }

            var msg = result.Data
                ? "已退回待排清單（注意：此項目有領料記錄，請手動確認庫存是否需要沖銷）"
                : "已退回待排清單，訂單排程數量已還原";
            await NotificationService.ShowSuccessAsync(msg);
            await IsVisibleChanged.InvokeAsync(false);
            await OnDeleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"退回失敗：{ex.Message}");
        }
    }

    private async Task HandleCancel()
    {
        showReturnConfirm = false;
        showAbortConfirm = false;
        await IsVisibleChanged.InvokeAsync(false);
    }

    private class SettlementEditRow
    {
        public string ComponentName { get; set; } = string.Empty;
        public decimal IssuedQty { get; set; }
        public MaterialSettlementDto Settlement { get; set; } = new();
    }
}
