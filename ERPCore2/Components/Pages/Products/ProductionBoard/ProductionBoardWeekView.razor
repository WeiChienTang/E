    private void HandlePrintScheduleAsync()
    {
        printInitialCriteria = new ProductionScheduleCriteria
        {
            StartDate = ViewStart,
            EndDate   = ViewEnd
        };
        showPrintModal = true;
    }

    private void HandleMaterialRequirementsAsync()
