@using ERPCore2.Models.Schedule
@using ERPCore2.Models.Enums
@using ERPCore2.Models.Reports
@using ERPCore2.Models.Reports.FilterCriteria
@using ERPCore2.Data.Entities
@inject IProductionScheduleItemService ScheduleItemService
@inject IProductionScheduleService ScheduleService
@inject IProductionScheduleDetailService ScheduleDetailService
@inject ISalesOrderService SalesOrderService
@inject ISalesOrderDetailService SalesOrderDetailService
@inject IProductCompositionService ProductCompositionService
@inject ISalesOrderCompositionDetailService SalesOrderCompositionDetailService
@inject IInventoryStockService InventoryStockService
@inject INotificationService NotificationService
@inject INavigationPermissionService NavigationPermissionService

<div class="board-week-view">

    @* 工具列：週導航 + 篩選 + 批次完工 + 預警 *@
    <div class="board-toolbar">

        @* Row 1：導航 + 右側工具 *@
        <div class="toolbar-row-1">
            <GenericButtonComponent Variant="ButtonVariant.OutlineGray" Size="ButtonSize.Small"
                IconClass="bi bi-chevron-left" OnClick="Previous" Title="上一個" />

            <span class="week-label">
                @DateRangeLabel
            </span>

            <GenericButtonComponent Variant="ButtonVariant.OutlineGray" Size="ButtonSize.Small"
                IconClass="bi bi-chevron-right" OnClick="Next" Title="下一個" />

            <GenericButtonComponent Variant="ButtonVariant.DarkBlue" Size="ButtonSize.Small"
                Text="今天" OnClick="GoToToday" />

            @* 視圖模式切換 *@
            <div class="btn-group btn-group-sm" role="group" aria-label="視圖模式">
                <GenericButtonComponent Text="日"
                    Variant="@(viewMode == ViewMode.Day ? ButtonVariant.DarkBlue : ButtonVariant.OutlineGray)"
                    OnClick="@(() => SetViewMode(ViewMode.Day))" />
                <GenericButtonComponent Text="3天"
                    Variant="@(viewMode == ViewMode.ThreeDay ? ButtonVariant.DarkBlue : ButtonVariant.OutlineGray)"
                    OnClick="@(() => SetViewMode(ViewMode.ThreeDay))" />
                <GenericButtonComponent Text="週"
                    Variant="@(viewMode == ViewMode.Week ? ButtonVariant.DarkBlue : ButtonVariant.OutlineGray)"
                    OnClick="@(() => SetViewMode(ViewMode.Week))" />
            </div>

            <div class="ms-auto d-flex align-items-center gap-2">
                @* 9.5 交期預警 *@
                @if (OverdueCount > 0)
                {
                    <span class="badge bg-danger board-alert-badge"
                          title="有 @OverdueCount 件排程已逾期，請優先處理">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>逾期 @OverdueCount 件
                    </span>
                }
                @if (UrgentCount > 0)
                {
                    <span class="badge bg-warning text-dark board-alert-badge"
                          title="有 @UrgentCount 件排程將在 3 天內到期">
                        <i class="bi bi-clock-fill me-1"></i>緊急 @UrgentCount 件
                    </span>
                }
                @if (IsLoading)
                {
                    <span class="text-secondary" style="font-size:0.8rem;">
                        <span class="spinner-border spinner-border-sm me-1"></span>載入中...
                    </span>
                }
                <DebugComponentLabelComponent ComponentName="ProductionBoardWeekView" />
            </div>
        </div>

        @* Row 2：篩選 + 操作按鈕 *@
        <div class="toolbar-row-2">
            @* 9.3 狀態篩選 *@
            <div class="btn-group" role="group" aria-label="狀態篩選">
                <GenericButtonComponent
                    Text="全部"
                    Variant="@(statusFilter == null ? ButtonVariant.DarkBlue : ButtonVariant.OutlineGray)"
                    OnClick="@(() => statusFilter = null)" />
                <GenericButtonComponent
                    Text="待領料"
                    Variant="@(statusFilter == ProductionItemStatus.WaitingMaterial ? ButtonVariant.Yellow : ButtonVariant.OutlineGray)"
                    OnClick="@(() => statusFilter = ProductionItemStatus.WaitingMaterial)" />
                <GenericButtonComponent
                    Text="生產中"
                    Variant="@(statusFilter == ProductionItemStatus.InProgress ? ButtonVariant.DarkBlue : ButtonVariant.OutlineGray)"
                    OnClick="@(() => statusFilter = ProductionItemStatus.InProgress)" />
                <GenericButtonComponent
                    Text="已完成"
                    Variant="@(statusFilter == ProductionItemStatus.Completed ? ButtonVariant.Green : ButtonVariant.OutlineGray)"
                    OnClick="@(() => statusFilter = ProductionItemStatus.Completed)" />
            </div>

            @* 手機版換行節點：將功能按鈕推到第三行（桌面無作用） *@
            <div class="toolbar-action-break"></div>

            @* 9.2 批次完工 *@
            <GenericButtonComponent Variant="ButtonVariant.Green" Size="ButtonSize.Small"
                IconClass="bi bi-check2-all" Text="批次完工"
                OnClick="@(() => showBatchCompleteModal = true)"
                IsDisabled="@(!boardItems.Any(i => i.ProductionItemStatus == ProductionItemStatus.InProgress))"
                Title="批次確認目前視圖生產中項目完工" />

            @* 列印本週排程 *@
            <GenericButtonComponent Variant="ButtonVariant.OutlineGray" Size="ButtonSize.Small"
                IconClass="bi bi-printer" Text="列印排程"
                OnClick="@HandlePrintScheduleAsync"
                Title="列印本週生產排程表" />

            @* 用料需求報表 *@
            <GenericButtonComponent Variant="ButtonVariant.OutlineGray" Size="ButtonSize.Small"
                IconClass="bi bi-printer" Text="列印用料"
                OnClick="@HandleMaterialRequirementsAsync"
                Title="列印本週用料需求報表" />

            @* 重新整理 *@
            <GenericButtonComponent Variant="ButtonVariant.Green" Size="ButtonSize.Small"
                IconClass="bi bi-arrow-clockwise" Text="重整" OnClick="LoadDataAsync"
                IsDisabled="@IsLoading"
                Title="重新整理看板資料" />
        </div>

    </div>

    @* 9.1 摘要列 *@
    <div class="board-summary-bar">
        <span class="summary-item summary-total">@ViewLabel @TotalBoardItems 件</span>
        @if (WaitingCount > 0)
        {
            <span class="summary-item summary-waiting">等待領料 @WaitingCount</span>
        }
        @if (InProgressCount > 0)
        {
            <span class="summary-item summary-inprogress">生產中 @InProgressCount</span>
        }
        @if (CompletedCount > 0)
        {
            <span class="summary-item summary-completed">已完成 @CompletedCount</span>
        }
    </div>

    @* 主體：sidebar + 週視圖 *@
    <div class="board-body">
        @* 手機版遮罩（點擊關閉 sidebar） *@
        @if (showMobileSidebar)
        {
            <div class="board-sidebar-backdrop" @onclick="() => showMobileSidebar = false"></div>
        }

        @* 手機版左側頁簽把手（sidebar 關閉時顯示） *@
        @if (!showMobileSidebar)
        {
            <button class="sidebar-tab-handle" @onclick="() => showMobileSidebar = true" title="展開待排清單">
                <i class="bi bi-chevron-right"></i>
                <span class="sidebar-tab-label">待排</span>
                @if (pendingItems.Count > 0)
                {
                    <span class="sidebar-tab-count">@pendingItems.Count</span>
                }
            </button>
        }

        @* 左側 Sidebar：未排程項目（支援接收看板卡片拖曳退回） *@
        <ProductionBoardPendingSidebar
            Items="@pendingItems"
            IsLoading="@IsLoading"
            OnDragStart="@HandlePendingDragStart"
            OnDragEnd="@HandleDragEnd"
            IsDropTarget="@(draggingBoardItem != null && draggingBoardItem.CompletedQuantity == 0 && !draggingBoardItem.HasIssuedMaterial)"
            OnBoardItemDropped="@HandleDropOnSidebar"
            IsMobileOpen="@showMobileSidebar" />

        @* 週視圖主體 *@
        <div class="board-week-columns @(viewMode == ViewMode.Day ? "view-day" : viewMode == ViewMode.ThreeDay ? "view-three" : "")">
            @foreach (var day in ViewDays)
            {
                <ProductionBoardDayColumn
                    Date="@day"
                    Items="@GetItemsForDay(day)"
                    IsToday="@(day.Date == DateTime.Today)"
                    DraggingBoardItem="@draggingBoardItem"
                    OnItemDragStart="@HandleBoardItemDragStart"
                    OnItemDragEnd="@HandleDragEnd"
                    OnItemClick="@HandleCardClick"
                    OnDrop="@(date => HandleDropOnDay(date))"
                    OnIntraDayReorder="@(args => HandleIntraDayReorder(args, day))" />
            }
        </div>
    </div>
</div>

@* 卡片快速編輯 Modal *@
<ProductionBoardItemEditModal
    IsVisible="@showEditModal"
    IsVisibleChanged="@((bool v) => showEditModal = v)"
    Item="@editingItem"
    OnSaved="@LoadDataAsync"
    OnDeleted="@LoadDataAsync" />


@* 領料確認 Dialog *@
<GenericConfirmModalComponent
    IsVisible="@showMaterialIssueConfirm"
    IsVisibleChanged="@((bool v) => showMaterialIssueConfirm = v)"
    Title="建立領料單"
    Icon="bi-basket"
    Message="已排入排程。是否現在建立對應的領料單？"
    ConfirmButtonText="建立領料單"
    CancelButtonText="稍後再說"
    ConfirmButtonVariant="ButtonVariant.Blue"
    HeaderColor="BaseModalComponent.HeaderVariant.Info"
    OnConfirm="@HandleMaterialIssueConfirmed" />

@* 領料單編輯 Modal *@
<MaterialIssueEditModalComponent
    IsVisible="@showMaterialIssueModal"
    IsVisibleChanged="@((bool v) => showMaterialIssueModal = v)"
    SourceProductionScheduleId="@pendingMaterialIssueBatchId"
    OnMaterialIssueSaved="@HandleMaterialIssueSaved"
    OnCancel="@(() => showMaterialIssueModal = false)" />

@* 9.2 批次完工 Modal *@
<ProductionBoardBatchCompleteModal
    IsVisible="@showBatchCompleteModal"
    IsVisibleChanged="@((bool v) => showBatchCompleteModal = v)"
    Items="@boardItems.Where(i => i.ProductionItemStatus == ProductionItemStatus.InProgress).ToList()"
    OnCompleted="@LoadDataAsync" />

@* 列印排程 Modal *@
<GenericReportFilterModalComponent
    IsVisible="@showPrintModal"
    IsVisibleChanged="@((bool v) => showPrintModal = v)"
    ReportId="@ReportIds.ProductionSchedule"
    InitialCriteria="@printInitialCriteria" />

@* 用料需求報表 Modal *@
<GenericReportFilterModalComponent
    IsVisible="@showMaterialReqModal"
    IsVisibleChanged="@((bool v) => showMaterialReqModal = v)"
    ReportId="@ReportIds.MaterialRequirements"
    InitialCriteria="@materialReqInitialCriteria" />

@code {
    // ── 視圖模式 ──
    private enum ViewMode { Day, ThreeDay, Week }
    private ViewMode viewMode = ViewMode.Week;

    // ── 視圖導航 ──
    private DateTime ViewStart { get; set; } = GetMonday(DateTime.Today);
    private DateTime ViewEnd   => ViewStart.AddDays(DayCount - 1);
    private IEnumerable<DateTime> ViewDays => Enumerable.Range(0, DayCount).Select(d => ViewStart.AddDays(d));
    private int DayCount => viewMode switch { ViewMode.Day => 1, ViewMode.ThreeDay => 3, _ => 7 };

    private string ViewLabel => viewMode switch
    {
        ViewMode.Day      => "今日",
        ViewMode.ThreeDay => "近 3 日",
        _                 => "本週"
    };

    private string DateRangeLabel => viewMode == ViewMode.Day
        ? $"{ViewStart:yyyy/MM/dd}（{GetDayOfWeekLabel(ViewStart.DayOfWeek)}）"
        : $"{ViewStart:yyyy/MM/dd} – {ViewEnd:MM/dd}";

    // ── 資料 ──
    private List<BoardScheduleItemDto> boardItems = new();
    private List<BoardPendingItemDto>  pendingItems = new();
    private bool IsLoading;

    // ── 當前員工 ID（建立每日批次使用）──
    private int? currentEmployeeId;

    // ── 拖曳狀態 ──
    private BoardScheduleItemDto? draggingBoardItem;
    private BoardPendingItemDto?  draggingPendingItem;

    // ── 卡片編輯 Modal ──
    private bool showEditModal;
    private BoardScheduleItemDto? editingItem;

    // ── 領料單流程 ──
    private bool showMaterialIssueConfirm;
    private bool showMaterialIssueModal;
    private int? pendingMaterialIssueBatchId;

    // ── 9.2 批次完工 ──
    private bool showBatchCompleteModal;

    // ── 列印排程 ──
    private bool showPrintModal;
    private ProductionScheduleCriteria? printInitialCriteria;

    // ── 用料需求報表 ──
    private bool showMaterialReqModal;
    private MaterialRequirementsCriteria? materialReqInitialCriteria;

    // ── 9.3 狀態篩選 ──
    private ProductionItemStatus? statusFilter;

    // ── 手機版 sidebar 切換 ──
    private bool showMobileSidebar;

    // ── 9.1 摘要列 / 9.5 交期預警（直接從 boardItems 計算，無額外 DB 查詢）──
    private int TotalBoardItems  => boardItems.Count;
    private int WaitingCount     => boardItems.Count(i => i.ProductionItemStatus is ProductionItemStatus.WaitingMaterial or ProductionItemStatus.Pending);
    private int InProgressCount  => boardItems.Count(i => i.ProductionItemStatus == ProductionItemStatus.InProgress);
    private int CompletedCount   => boardItems.Count(i => i.ProductionItemStatus == ProductionItemStatus.Completed);
    private int OverdueCount     => boardItems.Count(i =>
        i.ProductionItemStatus != ProductionItemStatus.Completed &&
        i.ExpectedDeliveryDate.HasValue &&
        i.ExpectedDeliveryDate.Value.Date < DateTime.Today);
    private int UrgentCount      => boardItems.Count(i =>
        i.ProductionItemStatus != ProductionItemStatus.Completed &&
        i.ExpectedDeliveryDate.HasValue &&
        (i.ExpectedDeliveryDate.Value.Date - DateTime.Today).TotalDays is >= 0 and <= 3);

    protected override async Task OnInitializedAsync()
    {
        var empId = await NavigationPermissionService.GetCurrentEmployeeIdAsync();
        currentEmployeeId = empId > 0 ? empId : null;
        await LoadDataAsync();
    }

    // ── 資料載入 ──

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        StateHasChanged();
        try
        {
            var boardTask        = ScheduleItemService.GetByDateRangeAsync(ViewStart, ViewEnd);
            var scheduledMapTask = ScheduleItemService.GetScheduledQuantityMapAsync();
            var pendingDetailsTask = SalesOrderDetailService.GetForProductionBoardAsync();
            await Task.WhenAll(boardTask, scheduledMapTask, pendingDetailsTask);

            boardItems   = MapToBoardDtos(boardTask.Result);
            pendingItems = BuildPendingItems(pendingDetailsTask.Result, scheduledMapTask.Result);
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync("載入看板資料失敗");
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadDataAsync), GetType());
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>從預載的訂單明細建立待排清單（已過濾已駁回，已消除 N+1）</summary>
    private List<BoardPendingItemDto> BuildPendingItems(
        List<SalesOrderDetail> details,
        Dictionary<int, decimal> scheduledMap)
    {
        var result = new List<BoardPendingItemDto>();
        foreach (var detail in details)
        {
            var order = detail.SalesOrder;
            if (order == null) continue;

            var scheduled = scheduledMap.TryGetValue(detail.Id, out var sq) ? sq : 0m;
            var pending   = detail.OrderQuantity - scheduled;
            if (pending <= 0) continue;

            result.Add(new BoardPendingItemDto
            {
                SalesOrderDetailId   = detail.Id,
                SalesOrderId         = order.Id,
                SalesOrderCode       = order.Code ?? string.Empty,
                OrderDate            = order.OrderDate,
                ExpectedDeliveryDate = order.ExpectedDeliveryDate,
                CustomerName         = order.Customer?.CompanyName ?? string.Empty,
                ProductId            = detail.ProductId,
                ProductCode          = detail.Product?.Code ?? string.Empty,
                ProductName          = detail.Product?.Name ?? string.Empty,
                OrderQuantity        = detail.OrderQuantity,
                ScheduledQuantity    = scheduled,
                IsApproved           = order.IsApproved
            });
        }
        return result
            .OrderBy(d => d.ExpectedDeliveryDate ?? DateTime.MaxValue)
            .ThenBy(d => d.CustomerName)
            .ToList();
    }

    private static List<BoardScheduleItemDto> MapToBoardDtos(List<ProductionScheduleItem> items)
    {
        return items.Select(i => new BoardScheduleItemDto
        {
            Id                     = i.Id,
            ProductionScheduleId   = i.ProductionScheduleId,
            ProductionScheduleCode = i.ProductionSchedule?.Code ?? string.Empty,
            ProductId              = i.ProductId,
            ProductCode            = i.Product?.Code ?? string.Empty,
            ProductName            = i.Product?.Name ?? string.Empty,
            ScheduledQuantity      = i.ScheduledQuantity,
            CompletedQuantity      = i.CompletedQuantity,
            ProductionItemStatus   = i.ProductionItemStatus,
            Priority               = i.Priority,
            PlannedStartDate       = i.PlannedStartDate,
            PlannedEndDate         = i.PlannedEndDate,
            SalesOrderDetailId     = i.SalesOrderDetailId,
            SalesOrderCode         = i.SalesOrderDetail?.SalesOrder?.Code,
            CustomerName           = i.SalesOrderDetail?.SalesOrder?.Customer?.CompanyName,
            ExpectedDeliveryDate   = i.SalesOrderDetail?.SalesOrder?.ExpectedDeliveryDate,
            IsClosed               = i.IsClosed,
            HasIssuedMaterial      = i.ScheduleDetails?.Any(d => d.IssuedQuantity > 0) ?? false
        }).ToList();
    }

    // ── 導航 ──

    private async Task Previous()
    {
        ViewStart = ViewStart.AddDays(-DayCount);
        await LoadDataAsync();
    }

    private async Task Next()
    {
        ViewStart = ViewStart.AddDays(DayCount);
        await LoadDataAsync();
    }

    private async Task GoToToday()
    {
        ViewStart = viewMode == ViewMode.Week ? GetMonday(DateTime.Today) : DateTime.Today;
        await LoadDataAsync();
    }

    private async Task SetViewMode(ViewMode mode)
    {
        if (viewMode == mode) return;
        ViewStart = mode switch
        {
            ViewMode.Week => GetMonday(ViewStart), // 切到週：保留錨點所在的週一
            _             => DateTime.Today        // 切到日/3天：以今天為起點
        };
        viewMode = mode;
        await LoadDataAsync();
    }

    private static string GetDayOfWeekLabel(DayOfWeek dow) => dow switch
    {
        DayOfWeek.Monday    => "週一",
        DayOfWeek.Tuesday   => "週二",
        DayOfWeek.Wednesday => "週三",
        DayOfWeek.Thursday  => "週四",
        DayOfWeek.Friday    => "週五",
        DayOfWeek.Saturday  => "週六",
        _                   => "週日"
    };

    // ── 卡片點擊 → 快速編輯 ──

    private void HandleCardClick(BoardScheduleItemDto item)
    {
        editingItem = item;
        showEditModal = true;
        StateHasChanged();
    }

    // ── 拖曳處理 ──

    private void HandleBoardItemDragStart(BoardScheduleItemDto item)
    {
        draggingBoardItem   = item;
        draggingPendingItem = null;
    }

    private void HandlePendingDragStart(BoardPendingItemDto item)
    {
        draggingPendingItem = item;
        draggingBoardItem   = null;
    }

    private void HandleDragEnd()
    {
        draggingBoardItem   = null;
        draggingPendingItem = null;
    }

    private async Task HandleDropOnDay(DateTime targetDate)
    {
        int? droppedItemId  = null;
        int? droppedBatchId = null;

        if (draggingBoardItem != null)
        {
            await MoveExistingItemAsync(draggingBoardItem.Id, targetDate);
        }
        else if (draggingPendingItem != null)
        {
            (droppedBatchId, droppedItemId) = await AssignPendingItemAsync(draggingPendingItem, targetDate);
        }

        draggingBoardItem   = null;
        draggingPendingItem = null;
        await LoadDataAsync();

        // 側欄項目首次排入日期後，檢查是否需要建立領料單
        if (droppedItemId.HasValue && droppedBatchId.HasValue)
            await CheckMaterialIssueAfterDropAsync(droppedItemId.Value, droppedBatchId.Value);
    }

    private async Task HandleDropOnSidebar()
    {
        if (draggingBoardItem == null) return;
        var item = draggingBoardItem;
        draggingBoardItem = null;

        if (item.CompletedQuantity > 0)
        {
            await NotificationService.ShowWarningAsync("已有完成數量，無法退回待排清單");
            return;
        }

        if (item.HasIssuedMaterial)
        {
            await NotificationService.ShowWarningAsync("已有領料記錄，無法退回待排清單。請先使用停產功能處理物料");
            return;
        }

        await ReturnBoardItemAsync(item);
        await LoadDataAsync();
    }

    private async Task ReturnBoardItemAsync(BoardScheduleItemDto item)
    {
        try
        {
            var result = await ScheduleItemService.ReturnToSidebarAsync(item.Id);
            if (!result.IsSuccess)
            {
                await NotificationService.ShowErrorAsync($"退回失敗：{result.ErrorMessage}");
                return;
            }

            await NotificationService.ShowSuccessAsync("已退回待排清單");
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"退回失敗：{ex.Message}");
        }
    }

    private async Task MoveExistingItemAsync(int itemId, DateTime targetDate)
    {
        var result = await ScheduleItemService.UpdatePlannedDateAsync(itemId, targetDate.Date);
        if (!result.IsSuccess)
            await NotificationService.ShowErrorAsync($"移動失敗：{result.ErrorMessage}");
    }

    private async Task<(int? BatchId, int? ItemId)> AssignPendingItemAsync(BoardPendingItemDto pending, DateTime targetDate)
    {
        var batchResult = await ScheduleService.GetOrCreateDailyBatchAsync(targetDate.Date, currentEmployeeId);
        if (!batchResult.IsSuccess)
        {
            await NotificationService.ShowErrorAsync($"建立每日批次失敗：{batchResult.ErrorMessage}");
            return (null, null);
        }

        // 建立新排程項目，先以 WaitingMaterial 建立（BOM 展開後再判斷是否升格）
        var item = new ProductionScheduleItem
        {
            ProductionScheduleId  = batchResult.Data!.Id,
            ProductId             = pending.ProductId,
            SalesOrderDetailId    = pending.SalesOrderDetailId > 0 ? pending.SalesOrderDetailId : null,
            ScheduledQuantity     = pending.PendingQuantity,
            CompletedQuantity     = 0,
            ProductionItemStatus  = ProductionItemStatus.WaitingMaterial,
            PlannedStartDate      = targetDate.Date,
            Status                = EntityStatus.Active,
            CreatedAt = DateTime.UtcNow
        };

        var createResult = await ScheduleItemService.CreateAsync(item);
        if (!createResult.IsSuccess)
        {
            await NotificationService.ShowErrorAsync($"建立排程項目失敗：{createResult.ErrorMessage}");
            return (null, null);
        }

        // 回寫 SalesOrderDetail.ScheduledQuantity
        if (pending.SalesOrderDetailId > 0)
        {
            var detail = await SalesOrderDetailService.GetByIdAsync(pending.SalesOrderDetailId);
            if (detail != null)
            {
                detail.ScheduledQuantity += pending.PendingQuantity;
                await SalesOrderDetailService.UpdateAsync(detail);
            }
        }

        // 展開 BOM，建立 ProductionScheduleDetail
        await ExpandBomAsync(item.Id, pending.ProductId, pending.PendingQuantity, pending.SalesOrderDetailId);

        // 檢查每項 BOM 組件的可用庫存，不足時顯示警告（不阻擋）
        var bomDetails = await ScheduleDetailService.GetByScheduleItemIdAsync(item.Id);
        if (bomDetails.Any(d => d.RequiredQuantity > 0))
            await CheckBomStockWarningAsync(bomDetails);

        return (batchResult.Data!.Id, item.Id);
    }

    /// <summary>
    /// 檢查 BOM 組件庫存是否充足，不足時以 Warning 通知（不阻擋排程）
    /// </summary>
    private async Task CheckBomStockWarningAsync(List<ProductionScheduleDetail> bomDetails)
    {
        try
        {
            var shortItems = new List<string>();
            foreach (var d in bomDetails.Where(d => d.RequiredQuantity > 0))
            {
                var stocks = await InventoryStockService.GetByProductIdAsync(d.ComponentProductId);
                var available = stocks.Sum(s => s.TotalAvailableStock);
                if (available < d.RequiredQuantity)
                {
                    var productName = d.ComponentProduct?.Name ?? $"ID:{d.ComponentProductId}";
                    shortItems.Add($"{productName}（需 {NumberFormatHelper.FormatSmart(d.RequiredQuantity)}，現有 {NumberFormatHelper.FormatSmart(available)}）");
                }
            }
            if (shortItems.Any())
            {
                var detail = string.Join("、", shortItems);
                await NotificationService.ShowWarningAsync($"物料庫存不足：{detail}，請安排採購或調撥後再領料");
            }
        }
        catch
        {
            // 庫存查詢失敗不阻擋主流程
        }
    }

    private async Task ExpandBomAsync(int itemId, int productId, decimal qty, int salesOrderDetailId = 0)
    {
        try
        {
            // 優先使用銷貨訂單的自訂 BOM（SalesOrderCompositionDetail）
            if (salesOrderDetailId > 0)
            {
                var customBom = await SalesOrderCompositionDetailService.GetBySalesOrderDetailIdAsync(salesOrderDetailId);
                if (customBom.Any())
                {
                    var customDetails = customBom.Select(d => new ProductionScheduleDetail
                    {
                        ProductionScheduleItemId   = itemId,
                        ComponentProductId         = d.ComponentProductId,
                        RequiredQuantity           = d.Quantity * qty,
                        IssuedQuantity             = 0,
                        Status                     = EntityStatus.Active,
                        CreatedAt = DateTime.UtcNow
                    }).ToList();

                    await ScheduleDetailService.CreateDetailsForItemAsync(itemId, customDetails);
                    return;
                }
            }

            // Fallback：使用品項預設 BOM（ProductComposition）
            var compositions = await ProductCompositionService.GetCompositionsByProductIdAsync(productId);
            var composition  = compositions.FirstOrDefault();
            if (composition == null) return;

            var full = await ProductCompositionService.GetByIdAsync(composition.Id);
            if (full?.CompositionDetails == null || !full.CompositionDetails.Any()) return;

            var details = full.CompositionDetails.Select(d => new ProductionScheduleDetail
            {
                ProductionScheduleItemId   = itemId,
                ComponentProductId         = d.ComponentProductId,
                ProductCompositionDetailId = d.Id,
                RequiredQuantity           = d.Quantity * qty,
                IssuedQuantity             = 0,
                Status                     = EntityStatus.Active,
                CreatedAt = DateTime.UtcNow
            }).ToList();

            await ScheduleDetailService.CreateDetailsForItemAsync(itemId, details);
        }
        catch
        {
            // BOM 展開失敗不中斷主流程
        }
    }

    // ── 領料單流程 ──

    /// <summary>側欄項目拖曳至日期後，檢查該項目是否有未領料的 BOM 明細</summary>
    private async Task CheckMaterialIssueAfterDropAsync(int itemId, int batchId)
    {
        try
        {
            var details = await ScheduleDetailService.GetByScheduleItemIdAsync(itemId);
            if (details.Any(d => d.IssuedQuantity < d.RequiredQuantity))
            {
                pendingMaterialIssueBatchId = batchId;
                showMaterialIssueConfirm = true;
                StateHasChanged();
            }
        }
        catch
        {
            // 不影響主流程
        }
    }

    private void HandleMaterialIssueConfirmed()
    {
        showMaterialIssueConfirm = false;
        showMaterialIssueModal = true;
        StateHasChanged();
    }

    private async Task HandleMaterialIssueSaved(MaterialIssue savedIssue)
    {
        showMaterialIssueModal = false;
        pendingMaterialIssueBatchId = null;
        await LoadDataAsync();
        // 領料完成後，嘗試將已全部領料的 WaitingMaterial 項目升格為 InProgress
        await UpgradeWaitingItemsAsync();
    }

    /// <summary>
    /// 檢查看板上所有「等待領料」項目，若 BOM 明細已全部領完則升格為「生產中」
    /// </summary>
    private async Task UpgradeWaitingItemsAsync()
    {
        var waitingIds = boardItems
            .Where(i => i.ProductionItemStatus == ProductionItemStatus.WaitingMaterial
                     || i.ProductionItemStatus == ProductionItemStatus.Pending)
            .Select(i => i.Id)
            .ToList();

        if (!waitingIds.Any()) return;

        var upgraded = false;
        foreach (var id in waitingIds)
        {
            try
            {
                var bomDetails = await ScheduleDetailService.GetByScheduleItemIdAsync(id);
                if (bomDetails.Any() && bomDetails.All(d => d.IssuedQuantity >= d.RequiredQuantity))
                {
                    var schedItem = await ScheduleItemService.GetByIdAsync(id);
                    if (schedItem != null)
                    {
                        schedItem.ProductionItemStatus = ProductionItemStatus.InProgress;
                        await ScheduleItemService.UpdateAsync(schedItem);
                        upgraded = true;
                    }
                }
            }
            catch { /* 不中斷主流程 */ }
        }

        if (upgraded)
            await LoadDataAsync();
    }

    // ── 日內排序 ──

    private async Task HandleIntraDayReorder((BoardScheduleItemDto Dragged, int TargetSlot) args, DateTime day)
    {
        var dragged = args.Dragged;
        var targetSlot = args.TargetSlot;

        // 取得該天所有卡片（依目前優先序排序，與 DayColumn 內相同邏輯）
        var dayItems = boardItems
            .Where(i => i.PlannedStartDate?.Date == day.Date)
            .OrderBy(i => i.Priority)
            .ThenBy(i => i.ExpectedDeliveryDate)
            .ToList();

        // 從清單移除被拖曳的項目
        dayItems.RemoveAll(i => i.Id == dragged.Id);

        // 插入到目標位置（clamp 防止越界）
        var insertAt = Math.Clamp(targetSlot, 0, dayItems.Count);
        dayItems.Insert(insertAt, dragged);

        // 指派新 Priority（步距 10，方便未來插入）
        var updates = dayItems
            .Select((item, idx) => (item.Id, Priority: (idx + 1) * 10))
            .ToList();

        // 即時更新本地資料（不等 DB，讓 UI 立即反映）
        foreach (var (id, priority) in updates)
        {
            var local = boardItems.FirstOrDefault(i => i.Id == id);
            if (local != null) local.Priority = priority;
        }
        draggingBoardItem = null;
        StateHasChanged();

        // 持久化到 DB
        try
        {
            var result = await ScheduleItemService.UpdatePrioritiesAsync(updates);
            if (!result.IsSuccess)
                await NotificationService.ShowWarningAsync($"排序儲存失敗：{result.ErrorMessage}");
        }
        catch (Exception ex)
        {
            await NotificationService.ShowWarningAsync($"排序儲存失敗：{ex.Message}");
        }
    }

