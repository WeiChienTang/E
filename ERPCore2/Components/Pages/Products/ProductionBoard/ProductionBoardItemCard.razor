@using ERPCore2.Models.Schedule
@using ERPCore2.Models.Enums

<div class="board-item-card @StatusCssClass @(IsOnBoard ? "on-board" : "in-sidebar") @(IsSortDragging ? "sort-dragging" : "")"
     draggable="true"
     @onclick="HandleClick"
     @ondragstart="HandleDragStart"
     @ondragend="HandleDragEnd"
     title="@Item.ProductCode - @Item.ProductName（點擊編輯）">

    @* 狀態色條 *@
    <div class="card-status-bar"></div>

    <div class="card-body-inner">
        @* 商品資訊 + 狀態 *@
        <div class="card-header-row">
            <div class="card-product">
                <span class="product-name">@Item.ProductName</span>
                <span class="product-code">@Item.ProductCode</span>
            </div>
            <span class="card-status-badge @StatusCssClass">@StatusText</span>
        </div>

        <hr class="card-divider" />

        @* 客戶與訂單 *@
        @if (!string.IsNullOrEmpty(Item.CustomerName))
        {
            <div class="card-info-row">
                <span class="info-label">客戶：</span>
                <span class="info-value">@Item.CustomerName</span>
            </div>
        }
        @if (!string.IsNullOrEmpty(Item.SalesOrderCode))
        {
            <div class="card-info-row">
                <span class="info-label">訂單：</span>
                <span class="info-value">@Item.SalesOrderCode</span>
            </div>
        }

        @* 數量與交期 *@
        <div class="card-footer-row">
            <div class="card-qty">
                <span class="qty-label">訂單量：</span>
                @if (Item.CompletedQuantity > 0)
                {
                    <span class="qty-done">@NumberFormatHelper.FormatSmart(Item.CompletedQuantity)</span>
                    <span class="qty-sep">/</span>
                }
                <span class="qty-total">@NumberFormatHelper.FormatSmart(Item.ScheduledQuantity)</span>
            </div>
            @if (Item.ExpectedDeliveryDate.HasValue)
            {
                <span class="card-due @DeliveryUrgencyCss">交期：@DeliveryDateText</span>
            }
        </div>

        @* 進度條（全寬） *@
        @if (Item.CompletedQuantity > 0 && Item.ScheduledQuantity > 0)
        {
            <div class="card-progress">
                <div class="card-progress-bar" style="width: @(ProgressPercent)%"></div>
            </div>
        }

        <DebugComponentLabelComponent ComponentName="ProductionBoardItemCard" />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public BoardScheduleItemDto Item { get; set; } = default!;
    [Parameter] public bool IsOnBoard { get; set; } = true;
    [Parameter] public bool IsSortDragging { get; set; }
    [Parameter] public EventCallback<BoardScheduleItemDto> OnDragStart { get; set; }
    [Parameter] public EventCallback OnDragEnd { get; set; }
    [Parameter] public EventCallback<BoardScheduleItemDto> OnClick { get; set; }

    private string StatusCssClass => Item.ProductionItemStatus switch
    {
        ProductionItemStatus.WaitingMaterial => "status-waitingmaterial",
        ProductionItemStatus.Pending         => "status-waitingmaterial",
        ProductionItemStatus.InProgress      => "status-inprogress",
        ProductionItemStatus.Completed       => "status-completed",
        ProductionItemStatus.Paused          => "status-paused",
        ProductionItemStatus.Aborted         => "status-aborted",
        _                                    => "status-waitingmaterial"
    };

    private string StatusText => Item.ProductionItemStatus switch
    {
        ProductionItemStatus.WaitingMaterial => "等待領料",
        ProductionItemStatus.Pending         => "等待領料",
        ProductionItemStatus.InProgress      => "生產中",
        ProductionItemStatus.Completed       => "已完成",
        ProductionItemStatus.Paused          => "已暫停",
        ProductionItemStatus.Aborted         => "已終止",
        _                                    => "等待領料"
    };

    private string DeliveryUrgencyCss
    {
        get
        {
            if (!Item.ExpectedDeliveryDate.HasValue) return "";
            var daysLeft = (Item.ExpectedDeliveryDate.Value.Date - DateTime.Today).TotalDays;
            return daysLeft <= 0 ? "due-overdue" : daysLeft <= 3 ? "due-urgent" : "";
        }
    }

    private string DeliveryDateText
    {
        get
        {
            if (!Item.ExpectedDeliveryDate.HasValue) return "";
            var days = (int)(Item.ExpectedDeliveryDate.Value.Date - DateTime.Today).TotalDays;
            if (days < 0)  return $"逾期{-days}天";
            if (days == 0) return "今天";
            if (days == 1) return "明天";
            if (days <= 3) return $"+{days}天";
            return Item.ExpectedDeliveryDate.Value.ToString("MM/dd");
        }
    }

    private string ProgressPercent => Item.ScheduledQuantity > 0
        ? Math.Min(100, (double)Item.CompletedQuantity / (double)Item.ScheduledQuantity * 100).ToString("F0")
        : "0";

    private async Task HandleClick()
    {
        await OnClick.InvokeAsync(Item);
    }

    private async Task HandleDragStart(DragEventArgs e)
    {
        await OnDragStart.InvokeAsync(Item);
    }

    private async Task HandleDragEnd(DragEventArgs e)
    {
        await OnDragEnd.InvokeAsync();
    }
}
