@page "/product-compositions"
@inject IProductCompositionService ProductCompositionService
@inject IProductService ProductService
@inject ICompositionCategoryService CompositionCategoryService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@inject IBOMReportService BOMReportService

@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="ProductComposition" 
                        TService="IProductCompositionService"
                        Service="@ProductCompositionService"
                        EntityBasePath="/product-compositions"                          
                        PageTitle="@L["Page.ProductCompositionTitle"]"
                        PageSubtitle="@L["Page.ProductCompositionSubtitle"]"
                        ServerDataLoader="@ServerLoadCompositionsAsync"
                        BreadcrumbItems="@breadcrumbItems"
                        FilterDefinitions="@filterDefinitions"
                        ColumnDefinitions="@columnDefinitions"
                        EntityName="@L["Entity.ProductComposition"]"
                        GetEntityDisplayName="@(comp => comp.Code ?? $"物料清單{comp.Id}")"
                        RequiredPermission="@PermissionRegistry.ProductComposition.Read"
                        RequiredModule="ProductionManagement"
                        OnAddClick="@modalHandler.ShowAddModalAsync"
                        OnRowClick="@modalHandler.ShowEditModalAsync"
                        ShowDraftTab="true"
                        DebugPageName="ProductCompositionIndex"
                        RowPrintService="@BOMReportService"
                        RowPrintReportId="@ReportIds.BOMReport"
                        @ref="indexComponent"/>

@* 商品物料清單編輯 Modal *@
<ProductCompositionEditModalComponent IsVisible="@showEditModal"
                                     IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                     CompositionId="@editingCompositionId"
                                     OnCompositionSaved="@modalHandler.OnEntitySavedAsync"
                                     OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    // 組件參考
    private GenericIndexPageComponent<ProductComposition, IProductCompositionService> indexComponent = default!;
    
    // Modal 相關狀態
    private bool showEditModal = false;
    private int? editingCompositionId = null;
    
    // Modal 處理器
    private ModalHandler<ProductComposition, GenericIndexPageComponent<ProductComposition, IProductCompositionService>> modalHandler = default!;
    
    // 欄位配置
    private ProductCompositionFieldConfiguration fieldConfiguration = default!;
    
    // 配置相關
    private List<BreadcrumbItem> breadcrumbItems = new();
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    
    // 相關資料
    private List<Product> products = new();
    private List<CompositionCategory> compositionCategories = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<ProductComposition, GenericIndexPageComponent<ProductComposition, IProductCompositionService>>(
                id => editingCompositionId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());
            
            await InitializeBreadcrumbsAsync();
            
            // 載入相關資料
            await LoadProductsAsync();
            await LoadCompositionCategoriesAsync();
            
            // 建立欄位配置（傳遞 NotificationService）
            fieldConfiguration = new ProductCompositionFieldConfiguration(products, compositionCategories, NotificationService);
            fieldConfiguration.SetLocalizer(L);

            // 使用欄位配置建立篩選器和表格欄位
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化商品物料清單頁面失敗");
            await NotificationService.ShowErrorAsync("初始化商品物料清單頁面失敗");
        }
    }

    // ===== 原有的初始化方法 =====

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("生產管理", "物料清單", null, NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<ProductComposition> Items, int TotalCount)> ServerLoadCompositionsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return ProductCompositionService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(pc => pc.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadCompositionsAsync), GetType());
                return q;
            },
            page, pageSize);
    }

    // 載入商品資料（用於篩選器）
    private async Task LoadProductsAsync() => products = await DataLoaderHelper.LoadAsync(ProductService.GetAllAsync, "商品", NotificationService, GetType());

    // 載入物料清單類型資料（用於篩選器）
    private async Task LoadCompositionCategoriesAsync() => compositionCategories = await DataLoaderHelper.LoadAsync(CompositionCategoryService.GetAllAsync, "物料清單類型", NotificationService, GetType());

}
