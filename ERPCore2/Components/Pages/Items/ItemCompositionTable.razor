@* 品項合成明細管理組件 - 繼承 BaseDetailTableComponent，統一架構 *@
@inherits BaseDetailTableComponent<ItemComposition, ItemCompositionDetail, ItemCompositionTable.CompositionItem>

@inject INotificationService NotificationService
@inject IUnitService UnitService
@inject IItemCategoryService ItemCategoryService
@inject IStringLocalizer<SharedResource> L
@using ERPCore2.Helpers
@using ERPCore2.Data.Entities

@if (!IsReadOnly)
{
    <div class="mb-2">
        <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                                Size="ButtonSize.Small"
                                Text="批量選擇"
                                OnClick="OpenItemPicker" />
    </div>
}

<ItemPickerModal IsVisible="@_showItemPicker"
                   AvailableItems="@GetAvailableItems()"
                   AvailableCategories="@_availableCategories"
                   AvailableUnits="@AvailableUnits"
                   AlreadyAddedItemIds="@GetAlreadyAddedItemIds()"
                   OnConfirmed="@HandleItemsSelected"
                   OnCancelled="@(() => _showItemPicker = false)" />

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <GenericInteractiveTableComponent @ref="tableComponent"
                                  TItem="CompositionItem"
                                  OnDataChanged="@NotifyDetailsChangedAsync"
                                  Items="@Items"
                                  ColumnDefinitions="@GetColumnDefinitions()"
                                  IsReadOnly="@IsReadOnly"
                                  ShowRowNumbers="true"
                                  EmptyMessage="@EmptyMessage"
                                  ShowBuiltInActions="true"
                                  ShowBuiltInDeleteButton="true"
                                  OnItemDelete="@HandleItemDelete"
                                  EnableAutoEmptyRow="true"
                                  AllowAddNewRow="@(!IsReadOnly)"
                                  DataLoadCompleted="@_dataLoadCompleted"
                                  CreateEmptyItem="@(() => new CompositionItem())" />
    </div>
</div>

@code {
    // ===== 私有欄位 =====
    private readonly HashSet<int> _deletedDetailIds = new HashSet<int>();
    private bool _showItemPicker = false;
    private List<ItemCategory> _availableCategories = new();

    // ===== 額外參數（非 BaseDetailTableComponent 提供）=====
    [Parameter] public List<Item> AvailableItems { get; set; } = new();
    [Parameter] public List<Unit> AvailableUnits { get; set; } = new();
    [Parameter] public int ParentItemId { get; set; }

    // ===== 顯示設定 =====
    [Parameter] public string EmptyMessage { get; set; } = "尚未新增材料";

    // ===== 保留相容性事件 =====
    [Parameter] public EventCallback<ItemCompositionDetail> ItemRemoved { get; set; }

    // ===== 生命週期 =====

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 品項類別只需載入一次，且父組件不提供，在此自行載入
            _availableCategories = await ItemCategoryService.GetAllAsync();
        }
        catch
        {
            _availableCategories = new List<ItemCategory>();
        }

        await base.OnInitializedAsync();
    }

    // ===== BaseDetailTableComponent 抽象方法實作 =====

    /// <summary>
    /// 將 ExistingDetails 對應到 Items (CompositionItem) 列表
    /// </summary>
    protected override Task LoadItemsFromDetailsAsync()
    {
        if (ExistingDetails?.Any() != true) return Task.CompletedTask;

        foreach (var detail in ExistingDetails.Where(d => d.ComponentItem != null))
        {
            Items.Add(new CompositionItem
            {
                SelectedItem = detail.ComponentItem,
                ItemSearchValue = GetItemDisplayText(detail.ComponentItem!),
                Quantity = detail.Quantity,
                UnitId = detail.UnitId,
                Unit = detail.Unit,
                ExistingDetailEntity = detail
            });
        }

        return Task.CompletedTask;
    }

    /// <summary>
    /// BOM 明細沒有「不可刪除」的概念（無進貨記錄鎖定）
    /// </summary>
    protected override bool ComputeHasUndeletableDetails() => false;

    /// <summary>
    /// 將 Items (CompositionItem) 轉換回 ItemCompositionDetail 列表
    /// </summary>
    protected override List<ItemCompositionDetail> ConvertItemsToDetails()
    {
        var details = new List<ItemCompositionDetail>();

        foreach (var item in Items.Where(x => x.SelectedItem != null))
        {
            ItemCompositionDetail detail;

            if (item.ExistingDetailEntity != null)
            {
                detail = item.ExistingDetailEntity;
            }
            else
            {
                detail = new ItemCompositionDetail
                {
                    ItemCompositionId = MainEntity?.Id ?? 0
                };
            }

            detail.ComponentItemId = item.SelectedItem!.Id;
            detail.ComponentItem = item.SelectedItem;
            detail.Quantity = item.Quantity;
            detail.UnitId = item.UnitId;
            detail.Unit = item.Unit;

            details.Add(detail);
        }

        return details;
    }

    // ===== 刪除處理 =====

    private async Task HandleItemDelete(CompositionItem item)
    {
        var index = Items.IndexOf(item);
        await RemoveItemAsync(index);
    }

    public async Task RemoveItemAsync(int index)
    {
        if (IsReadOnly || index < 0 || index >= Items.Count) return;

        var removedItem = Items[index];
        if (removedItem == null) return;

        // 追蹤要刪除的資料庫 ID
        if (removedItem.ExistingDetailEntity?.Id > 0)
            _deletedDetailIds.Add(removedItem.ExistingDetailEntity.Id);

        Items.RemoveAt(index);
        await NotifyDetailsChangedAsync();

        if (removedItem.ExistingDetailEntity != null)
            await ItemRemoved.InvokeAsync(removedItem.ExistingDetailEntity);
    }

    // ===== 欄位定義 =====

    private List<InteractiveColumnDefinition> GetColumnDefinitions()
    {
        return new List<InteractiveColumnDefinition>
        {
            // 材料品項選擇欄位
            new()
            {
                Title = L["Column.MaterialCodeName"],
                Tooltip = "搜尋並選擇材料（輸入編號或名稱）",
                PropertyName = nameof(CompositionItem.ItemSearchValue),
                EmptyCheckPropertyName = nameof(CompositionItem.SelectedItem),
                TriggerEmptyRowOnFilled = true,
                ColumnType = InteractiveColumnType.SearchableSelect,
                Width = "300px",
                Placeholder = "請輸入材料編號或名稱",
                SearchValuePropertyName = nameof(CompositionItem.ItemSearchValue),
                FilteredItemsPropertyName = nameof(CompositionItem.FilteredItems),
                ShowDropdownPropertyName = nameof(CompositionItem.ShowItemDropdown),
                SelectedIndexPropertyName = nameof(CompositionItem.ItemSelectedIndex),
                ItemDisplayFormatter = (item) =>
                {
                    var product = (Item)item;
                    return GetItemDisplayText(product);
                },
                IsDisabledFunc = item => IsReadOnly,
                OnSearchInputChanged = EventCallback.Factory.Create<(object, string?)>(this, (tuple) =>
                {
                    var (item, searchValue) = tuple;
                    OnItemSearchChanged((CompositionItem)item, searchValue);
                }),
                OnItemSelected = EventCallback.Factory.Create<(object, object?)>(this, async (tuple) =>
                {
                    var (item, selectedItem) = tuple;
                    await OnItemSelected((CompositionItem)item, (Item?)selectedItem);
                }),
                OnInputFocus = EventCallback.Factory.Create<object>(this, (item) =>
                {
                    var compositionItem = (CompositionItem)item;
                    compositionItem.FilteredItems = GetAvailableItems().Take(20).ToList();
                    compositionItem.ShowItemDropdown = true;
                    compositionItem.ItemSelectedIndex = -1;
                    StateHasChanged();
                }),
                OnInputBlur = EventCallback.Factory.Create<object>(this, (item) =>
                {
                    Task.Delay(200).ContinueWith(_ =>
                    {
                        var compositionItem = (CompositionItem)item;
                        compositionItem.ShowItemDropdown = false;
                        InvokeAsync(StateHasChanged);
                    });
                }),
                EnableKeyboardNavigation = true,
                GetDropdownItems = (item) => ((CompositionItem)item).FilteredItems,
                GetSelectedIndex = (item) => ((CompositionItem)item).ItemSelectedIndex,
                SetSelectedIndex = (item, index) => ((CompositionItem)item).ItemSelectedIndex = index,
                GetShowDropdown = (item) => ((CompositionItem)item).ShowItemDropdown,
                SetShowDropdown = (item, show) => ((CompositionItem)item).ShowItemDropdown = show,
                MaxDisplayItems = 20
            },

            // 所需數量 + 製程單位（合併顯示）
            new()
            {
                Title = L["Column.RequiredQuantity"],
                Tooltip = "輸入此材料所需的數量（單位由品項設定決定）",
                PropertyName = nameof(CompositionItem.Quantity),
                ColumnType = InteractiveColumnType.Custom,
                Width = "180px",
                ExcludeFromEmptyCheck = true,
                CustomTemplate = context =>
                {
                    var item = (CompositionItem)context;
                    return __builder =>
                    {
                        var unitName = GetProductionUnitName(item);
                        if (!string.IsNullOrEmpty(unitName))
                        {
                            <div class="input-group input-group-sm">
                                <input type="number"
                                       class="form-control text-end"
                                       value="@NumberFormatHelper.FormatForInput(item.Quantity)"
                                       min="0"
                                       step="any"
                                       disabled="@IsReadOnly"
                                       @oninput="@(async e => await OnQuantityChanged(item, e.Value?.ToString()))" />
                                <span class="input-group-text">@unitName</span>
                            </div>
                        }
                        else
                        {
                            <input type="number"
                                   class="form-control form-control-sm text-end"
                                   value="@NumberFormatHelper.FormatForInput(item.Quantity)"
                                   min="0"
                                   step="any"
                                   disabled="@IsReadOnly"
                                   @oninput="@(async e => await OnQuantityChanged(item, e.Value?.ToString()))" />
                        }
                    };
                }
            },
        };
    }

    // ===== 工具方法 =====

    private string GetItemDisplayText(Item product)
    {
        if (!string.IsNullOrWhiteSpace(product.Code))
            return $"{product.Code} - {product.Name}";
        return product.Name ?? string.Empty;
    }

    private string GetProductionUnitName(CompositionItem item)
    {
        if (item.SelectedItem == null) return string.Empty;

        var productionUnitId = item.SelectedItem.ProductionUnitId ?? item.SelectedItem.UnitId;
        if (productionUnitId <= 0) return string.Empty;

        var unit = AvailableUnits.FirstOrDefault(u => u.Id == productionUnitId);
        return unit?.Name ?? string.Empty;
    }

    private List<Item> GetAvailableItems()
        => AvailableItems.Where(p => p.Id != ParentItemId).ToList();

    private HashSet<int> GetAlreadyAddedItemIds()
        => Items.Where(i => i.SelectedItem != null)
                .Select(i => i.SelectedItem!.Id)
                .ToHashSet();

    private void OpenItemPicker() => _showItemPicker = true;

    // ===== 批量選擇器 =====

    private async Task HandleItemsSelected(List<Item> selectedItems)
    {
        _showItemPicker = false;

        var alreadyAdded = GetAlreadyAddedItemIds();
        foreach (var product in selectedItems.Where(p => !alreadyAdded.Contains(p.Id)))
        {
            var effectiveUnitId = product.ProductionUnitId ?? (product.UnitId > 0 ? (int?)product.UnitId : null);
            Items.Add(new CompositionItem
            {
                SelectedItem = product,
                ItemSearchValue = GetItemDisplayText(product),
                UnitId = effectiveUnitId,
                Unit = AvailableUnits.FirstOrDefault(u => u.Id == effectiveUnitId)
            });
        }

        await NotifyDetailsChangedAsync();
    }

    // ===== SearchableSelect 事件處理 =====

    private void OnItemSearchChanged(CompositionItem item, string? searchValue)
    {
        item.ItemSearchValue = searchValue ?? string.Empty;

        var availableItems = GetAvailableItems();

        if (string.IsNullOrWhiteSpace(searchValue))
        {
            item.FilteredItems = availableItems.Take(20).ToList();
        }
        else
        {
            item.FilteredItems = availableItems
                .Where(p => (p.Code?.Contains(searchValue, StringComparison.OrdinalIgnoreCase) ?? false) ||
                            (p.Name?.Contains(searchValue, StringComparison.OrdinalIgnoreCase) ?? false))
                .Take(20)
                .ToList();
        }

        item.ShowItemDropdown = true;
        item.ItemSelectedIndex = -1;
        StateHasChanged();
    }

    private async Task OnItemSelected(CompositionItem item, Item? selectedItem)
    {
        if (selectedItem != null)
        {
            // 防止選到成品本身
            if (ParentItemId > 0 && selectedItem.Id == ParentItemId)
            {
                await NotificationService.ShowErrorAsync("此材料不能是成品本身，請選擇其他材料");
                item.SelectedItem = null;
                item.ItemSearchValue = string.Empty;
                StateHasChanged();
                return;
            }

            // 防止重複選擇
            var existingItemIds = Items
                .Where(i => i != item && i.SelectedItem != null)
                .Select(i => i.SelectedItem!.Id);

            if (existingItemIds.Contains(selectedItem.Id))
            {
                await NotificationService.ShowErrorAsync("此材料已存在，請選擇其他材料");
                item.SelectedItem = null;
                item.ItemSearchValue = string.Empty;
            }
            else
            {
                item.SelectedItem = selectedItem;
                item.ItemSearchValue = GetItemDisplayText(selectedItem);

                // 自動設定製程單位（優先），若無則使用基本單位
                var effectiveUnitId = selectedItem.ProductionUnitId ?? (selectedItem.UnitId > 0 ? (int?)selectedItem.UnitId : null);
                if (effectiveUnitId.HasValue)
                {
                    item.UnitId = effectiveUnitId.Value;
                    item.Unit = await UnitService.GetByIdAsync(effectiveUnitId.Value);
                }
            }
        }
        else
        {
            item.SelectedItem = null;
            item.ItemSearchValue = string.Empty;
        }

        item.ShowItemDropdown = false;
        item.ItemSelectedIndex = -1;

        await NotifyDetailsChangedAsync();
    }

    private async Task OnQuantityChanged(CompositionItem item, string? value)
    {
        item.Quantity = InputEventHelper.HandleQuantityInput(value);
        await NotifyDetailsChangedAsync();
    }

    // ===== 公開方法（供父組件使用）=====

    public async Task<bool> ValidateAsync()
    {
        var errors = new List<string>();
        var nonEmptyItems = Items.Where(item => item.SelectedItem != null).ToList();

        if (!nonEmptyItems.Any())
        {
            errors.Add("至少需要一個材料");
        }
        else
        {
            var productIds = nonEmptyItems.Select(item => item.SelectedItem!.Id).ToList();
            if (productIds.Count != productIds.Distinct().Count())
                errors.Add("存在重複的材料");

            if (nonEmptyItems.Any(item => item.Quantity <= 0))
                errors.Add("所有材料的數量必須大於 0");

            if (ParentItemId > 0 && nonEmptyItems.Any(item => item.SelectedItem!.Id == ParentItemId))
                errors.Add("明細中不能包含成品本身");
        }

        if (errors.Any())
        {
            await NotificationService.ShowErrorAsync(string.Join("\n", errors));
            return false;
        }

        return true;
    }

    public List<ItemCompositionDetail> GetNonEmptyItems() => ConvertItemsToDetails();

    public List<int> GetDeletedDetailIds() => _deletedDetailIds.ToList();

    /// <summary>
    /// 儲存成功後由父組件呼叫，清空已處理的刪除 ID，避免重複刪除
    /// </summary>
    public void ClearDeletedDetailIds() => _deletedDetailIds.Clear();

    // ===== CompositionItem 包裝類別 =====

    public class CompositionItem
    {
        public Item? SelectedItem { get; set; }
        public decimal Quantity { get; set; } = 0;
        public int? UnitId { get; set; }
        public Unit? Unit { get; set; }
        public ItemCompositionDetail? ExistingDetailEntity { get; set; }

        // SearchableSelect 支援屬性
        public string ItemSearchValue { get; set; } = string.Empty;
        public List<Item> FilteredItems { get; set; } = new();
        public bool ShowItemDropdown { get; set; } = false;
        public int ItemSelectedIndex { get; set; } = -1;
    }
}
