@* 品項會計資訊 Tab — 顯示存貨子科目，並可立即建立 *@
@inject ISubAccountService SubAccountService
@inject INotificationService NotificationService
@inject AuthenticationStateProvider AuthStateProvider
@inject IStringLocalizer<SharedResource> L

@if (_productId <= 0)
{
    <div class="text-muted py-3 px-2">
        <i class="bi bi-info-circle me-2"></i>@L["Accounting.SaveFirst"]
    </div>
}
else if (_isLoading)
{
    <div class="text-muted py-3 px-2">
        <i class="bi bi-hourglass-split me-2"></i>@L["Label.Loading"]
    </div>
}
else
{
    <GenericInteractiveTableComponent TItem="AccountItem"
                                     Items="@_tableItems"
                                     ColumnDefinitions="@GetColumnDefinitions()"
                                     ShowHeader="true"
                                     IsStriped="true"
                                     IsHoverable="true"
                                     IsBordered="true"
                                     IsReadOnly="true"
                                     ShowBuiltInActions="false"
                                     EnableAutoEmptyRow="false" />

    @if (_subAccount == null)
    {
        <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                               Text="@L["Accounting.CreateSubAccount"]"
                               OnClick="HandleCreateAsync"
                               IsLoading="@_isCreating"
                               IsDisabled="@_isCreating"
                               Title="@L["Accounting.CreateItemSubAccountTitle"]" />
    }
}

@code {
    /// <summary>品項 ID（由父元件傳入，用於自動載入資料）</summary>
    [Parameter] public int? ItemId { get; set; }

    private int _productId;
    private int _lastLoadedId;
    private bool _isLoading;
    private bool _isCreating;
    private AccountItem? _subAccount;
    private List<AccountItem> _tableItems = new();

    private List<InteractiveColumnDefinition> GetColumnDefinitions()
    {
        return new List<InteractiveColumnDefinition>
        {
            new InteractiveColumnDefinition
            {
                Title = L["Accounting.SubAccountType"],
                PropertyName = "SubAccountType",
                ColumnType = InteractiveColumnType.Display,
                Width = "160px",
                DisplayFormatter = _ => L["Accounting.Inventory"]
            },
            new InteractiveColumnDefinition
            {
                Title = L["Accounting.AccountCode"],
                PropertyName = nameof(AccountItem.Code),
                ColumnType = InteractiveColumnType.Display,
                Width = "140px",
                CellCssClass = "font-monospace small",
                NullDisplayText = "—"
            },
            new InteractiveColumnDefinition
            {
                Title = L["Accounting.AccountName"],
                PropertyName = nameof(AccountItem.Name),
                ColumnType = InteractiveColumnType.Display,
                CellCssClass = "small",
                NullDisplayText = "—"
            },
            new InteractiveColumnDefinition
            {
                Title = L["Column.Status"],
                PropertyName = "Status",
                ColumnType = InteractiveColumnType.Display,
                Width = "90px",
                DisplayFormatter = item =>
                {
                    if (item is AccountItem acct && acct.Id > 0)
                        return L["Accounting.Created"];
                    return L["Accounting.NotCreated"];
                }
            }
        };
    }

    protected override async Task OnParametersSetAsync()
    {
        var newId = ItemId ?? 0;
        if (newId > 0 && newId != _lastLoadedId)
        {
            await LoadAsync(newId);
        }
        else if (newId <= 0 && _lastLoadedId > 0)
        {
            Clear();
        }
    }

    public async Task LoadAsync(int productId)
    {
        _productId = productId;
        _lastLoadedId = productId;
        await RefreshAsync();
        StateHasChanged();
    }

    public void Clear()
    {
        _productId = 0;
        _lastLoadedId = 0;
        _subAccount = null;
        _tableItems = new();
        StateHasChanged();
    }

    private async Task RefreshAsync()
    {
        if (_productId <= 0) return;

        _isLoading = true;
        StateHasChanged();

        _subAccount = await SubAccountService.GetSubAccountForItemAsync(_productId);
        _tableItems = _subAccount != null
            ? new List<AccountItem> { _subAccount }
            : new List<AccountItem> { new AccountItem() };

        _isLoading = false;
    }

    private async Task HandleCreateAsync()
    {
        try
        {
            _isCreating = true;
            StateHasChanged();

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var createdBy = authState.User.Identity?.Name ?? "system";

            await SubAccountService.GetOrCreateItemSubAccountAsync(_productId, createdBy);
            await RefreshAsync();
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync(L["Accounting.CreateError"]);
        }
        finally
        {
            _isCreating = false;
            StateHasChanged();
        }
    }
}
