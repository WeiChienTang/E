@page "/items"
@using ERPCore2.Models
@inject IItemService ItemService
@inject ISizeService SizeService
@rendermode InteractiveServer
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@inject IItemDetailReportService ItemDetailReportService

<GenericIndexPageComponent TEntity="Item" 
                          TService="IItemService"
                          Service="@ItemService"
                          EntityBasePath="/items"
                          PageTitle="@L["Page.ItemTitle"]"
                          PageSubtitle="@L["Page.ItemSubtitle"]"
                          EntityName="@L["Entity.Item"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ShowDraftTab="true"
                          ServerDataLoader="@ServerLoadItemsAsync"
                          GetEntityDisplayName="@(product => product.Name)"
                          RequiredPermission="@PermissionRegistry.Item.Read"
                          RequiredModule="Items"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          DebugPageName="ItemIndex"
                          RowPrintService="@ItemDetailReportService"
                          RowPrintReportId="@ReportIds.ItemDetail"
                          @ref="indexComponent">
</GenericIndexPageComponent>

@* 使用 ItemEditModalComponent 處理新增/編輯 *@
<ItemEditModalComponent IsVisible="@showEditModal"
                          IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                          ItemId="@editingItemId"
                          OnItemSaved="@modalHandler.OnEntitySavedAsync"
                          OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    // 組件參考
    private GenericIndexPageComponent<Item, IItemService> indexComponent = default!;
    
    // Modal 相關狀態
    private bool showEditModal = false;
    private int? editingItemId = null;
    
    // Modal 處理器
    private ModalHandler<Item, GenericIndexPageComponent<Item, IItemService>> modalHandler = default!;
    
    // 選項清單
    private List<ItemCategory> productCategories = new();
    private List<Supplier> suppliers = new();
    private List<Unit> units = new();
    private List<Size> sizes = new();
    
    // 欄位配置
    private ItemFieldConfiguration fieldConfiguration = default!;
    
    // 配置相關
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<Item, GenericIndexPageComponent<Item, IItemService>>(
                id => editingItemId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());
            
            await InitializeBreadcrumbsAsync();
            
            // 載入相關資料（即使某些失敗也要繼續）
            await LoadItemCategoriesAsync();
            await LoadSuppliersAsync();
            await LoadUnitsAsync();
            await LoadSizesAsync();
            await LoadUnitsAsync();
            await LoadSizesAsync();
            
            // 建立欄位配置（確保即使載入失敗也能創建配置）
            try
            {
                fieldConfiguration = new ItemFieldConfiguration(productCategories, suppliers, units, sizes, NotificationService);
                fieldConfiguration.SetLocalizer(L);

                // 使用欄位配置建立篩選器和表格欄位
                filterDefinitions = fieldConfiguration.BuildFilters();
                columnDefinitions = fieldConfiguration.BuildColumns();
            }
            catch (Exception configEx)
            {
                await ErrorHandlingHelper.HandlePageErrorAsync(configEx, $"{nameof(OnInitializedAsync)}_FieldConfiguration", GetType(), additionalData: "欄位配置初始化失敗");
                await NotificationService.ShowErrorAsync("欄位配置初始化失敗，使用預設配置");
                
                // 設定安全的預設配置
                filterDefinitions = new List<SearchFilterDefinition>();
                columnDefinitions = new List<TableColumnDefinition>();
                
                // 創建一個最小的欄位配置以避免 null 引用
                fieldConfiguration = new ItemFieldConfiguration(
                    new List<ItemCategory>(),
                    new List<Supplier>(),
                    new List<Unit>(),
                    new List<Size>(),
                    NotificationService);
                fieldConfiguration.SetLocalizer(L);
            }
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化品項頁面失敗");
            await NotificationService.ShowErrorAsync("初始化品項頁面失敗");
            
            // 確保關鍵變數不會是 null
            filterDefinitions ??= new List<SearchFilterDefinition>();
            columnDefinitions ??= new List<TableColumnDefinition>();
            breadcrumbItems ??= new List<BreadcrumbItem>();
        }
    }    
    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateSimpleAsync("品項管理", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<Item> Items, int TotalCount)> ServerLoadItemsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return ItemService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(p => p.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadItemsAsync), GetType());
                return q;
            },
            page, pageSize);
    }

    // 載入品項分類資料
    private async Task LoadItemCategoriesAsync() => productCategories = await DataLoaderHelper.LoadAsync(() => ItemService.GetItemCategoriesAsync(), "品項分類", NotificationService, GetType());

    // 載入供應商資料
    private async Task LoadSuppliersAsync() => suppliers = await DataLoaderHelper.LoadAsync(() => ItemService.GetSuppliersAsync(), "供應商", NotificationService, GetType());

    // 載入單位資料
    private async Task LoadUnitsAsync() => units = await DataLoaderHelper.LoadAsync(() => ItemService.GetUnitsAsync(), "單位", NotificationService, GetType());

    // 載入尺寸資料
    private async Task LoadSizesAsync() => sizes = await DataLoaderHelper.LoadAsync(() => SizeService.GetActiveSizesAsync(), "尺寸", NotificationService, GetType());
    
}

