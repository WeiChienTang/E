@page "/composition-categories"
@inject ICompositionCategoryService CompositionCategoryService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="CompositionCategory" 
                        TService="ICompositionCategoryService"
                        Service="@CompositionCategoryService"
                        EntityBasePath="/composition-categories"                          
                        PageTitle="@L["Page.CompositionCategoryTitle"]"
                        PageSubtitle="@L["Page.CompositionCategorySubtitle"]"
                        ServerDataLoader="@ServerLoadCompositionCategoriesAsync"
                        BreadcrumbItems="@breadcrumbItems"
                        FilterDefinitions="@filterDefinitions"
                        ColumnDefinitions="@columnDefinitions"
                        EntityName="@L["Entity.CompositionCategory"]"
                        GetEntityDisplayName="@(category => category.Name)"
                        RequiredPermission="@PermissionRegistry.CompositionCategory.Read"
                        RequiredModule="ProductionManagement"
                        OnAddClick="@modalHandler.ShowAddModalAsync"
                        OnRowClick="@modalHandler.ShowEditModalAsync"
                        ShowDraftTab="true"
                        DebugPageName="CompositionCategoryIndex"
                        @ref="indexComponent"/>

@* 物料清單類型編輯 Modal *@
<CompositionCategoryEditModalComponent IsVisible="@showEditModal"
                                      IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                      CompositionCategoryId="@editingCategoryId"
                                      OnCompositionCategorySaved="@modalHandler.OnEntitySavedAsync"
                                      OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    // 組件參考
    private GenericIndexPageComponent<CompositionCategory, ICompositionCategoryService> indexComponent = default!;
    
    // Modal 相關狀態
    private bool showEditModal = false;
    private int? editingCategoryId = null;
    
    // Modal 處理器
    private ModalHandler<CompositionCategory, GenericIndexPageComponent<CompositionCategory, ICompositionCategoryService>> modalHandler = default!;
    
    // 欄位配置
    private CompositionCategoryFieldConfiguration fieldConfiguration = default!;
    
    // 配置相關
    private List<BreadcrumbItem> breadcrumbItems = new();
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<CompositionCategory, GenericIndexPageComponent<CompositionCategory, ICompositionCategoryService>>(
                id => editingCategoryId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());
            
            await InitializeBreadcrumbsAsync();
            
            // 建立欄位配置（傳遞 NotificationService）
            fieldConfiguration = new CompositionCategoryFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            // 使用欄位配置建立篩選器和表格欄位
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化物料清單類型頁面失敗");
            await NotificationService.ShowErrorAsync("初始化物料清單類型頁面失敗");
        }
    }

    // ===== 原有的初始化方法 =====

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("生產管理", "物料清單類型", "#", NotificationService, GetType());

    private Task<(List<CompositionCategory> Items, int TotalCount)> ServerLoadCompositionCategoriesAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return CompositionCategoryService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(x => x.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadCompositionCategoriesAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
