@page "/item-categories"
@inject IItemCategoryService ItemCategoryService
@rendermode InteractiveServer
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<GenericIndexPageComponent TEntity="ItemCategory" 
                        TService="IItemCategoryService"
                        Service="@ItemCategoryService"
                        EntityBasePath="/item-categories"                          
                        PageTitle="@L["Page.ItemCategoryTitle"]"
                        PageSubtitle="@L["Page.ItemCategorySubtitle"]"
                        ShowDraftTab="true"
                        ServerDataLoader="@ServerLoadItemCategoriesAsync"
                        BreadcrumbItems="@breadcrumbItems"
                        FilterDefinitions="@filterDefinitions"
                        ColumnDefinitions="@columnDefinitions"
                        EntityName="@L["Entity.ItemCategory"]"
                        GetEntityDisplayName="@(category => category.Name)"
                        RequiredPermission="@PermissionRegistry.ItemCategory.Read"
                        RequiredModule="Items"
                        OnAddClick="@modalHandler.ShowAddModalAsync"
                        OnRowClick="@modalHandler.ShowEditModalAsync"
                        DebugPageName="ItemCategoryIndex"
                        @ref="indexComponent">
</GenericIndexPageComponent>

<ItemCategoryEditModalComponent IsVisible="@showEditModal"
                                  IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                  ItemCategoryId="@editingItemCategoryId"
                                  OnItemCategorySaved="@modalHandler.OnEntitySavedAsync"
                                  OnCancel="@modalHandler.OnModalCancelAsync" />
@code {
    // 組件參考
    private GenericIndexPageComponent<ItemCategory, IItemCategoryService> indexComponent = default!;
    
    // Modal 相關狀態
    private bool showEditModal = false;
    private int? editingItemCategoryId = null;
    
    // Modal 處理器
    private ModalHandler<ItemCategory, GenericIndexPageComponent<ItemCategory, IItemCategoryService>> modalHandler = default!;
    
    // 欄位配置
    private ItemCategoryFieldConfiguration fieldConfiguration = default!;
    
    // 配置相關
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<ItemCategory, GenericIndexPageComponent<ItemCategory, IItemCategoryService>>(
                id => editingItemCategoryId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());
            
            await InitializeBreadcrumbsAsync();
            
            // 建立欄位配置（傳遞 NotificationService）
            fieldConfiguration = new ItemCategoryFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            // 使用欄位配置建立篩選器和表格欄位
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化品項分類頁面失敗");
            await NotificationService.ShowErrorAsync("初始化品項分類頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("基礎資料", "品項類型管理", "#", NotificationService, GetType());

    private Task<(List<ItemCategory> Items, int TotalCount)> ServerLoadItemCategoriesAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return ItemCategoryService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(x => x.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadItemCategoriesAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
