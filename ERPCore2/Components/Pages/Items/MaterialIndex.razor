@page "/materials"

@inject IMaterialService MaterialService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="Material" 
                          TService="IMaterialService"
                          Service="@MaterialService"
                          EntityBasePath="/materials"
                          PageTitle="@L["Page.MaterialTitle"]"
                          PageSubtitle="@L["Page.MaterialSubtitle"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadMaterialsAsync"
                          EntityName="@L["Entity.Material"]"
                          GetEntityDisplayName="@(material => material.Name)"
                          RequiredPermission="@PermissionRegistry.Material.Read"
                          RequiredModule="ProductionManagement"
                          DebugPageName="MaterialIndex"
                          @ref="indexComponent" />

@code {
    // 組件參考
    private GenericIndexPageComponent<Material, IMaterialService> indexComponent = default!;
    
    // 欄位配置
    private MaterialFieldConfiguration fieldConfiguration = default!;
    
    // 配置相關
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await InitializeBreadcrumbsAsync();
            
            // 建立欄位配置
            fieldConfiguration = new MaterialFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(
                ex,
                nameof(OnInitializedAsync),
                GetType(),
                additionalData: "材質頁面初始化失敗");
            await NotificationService.ShowErrorAsync("初始化材質頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("基礎資料", "材質管理", null, NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<Material> Items, int TotalCount)> ServerLoadMaterialsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return MaterialService.GetPagedWithFiltersAsync(
            q =>
            {
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadMaterialsAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
