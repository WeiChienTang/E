@* 可重用的品項類型編輯組件 - 可在任何頁面中嵌入 *@
@inject IItemCategoryService ItemCategoryService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@using ERPCore2.Models.FeatureGuides.GuideDefinitions

<GenericEditModalComponent TEntity="ItemCategory"
                          TService="IItemCategoryService"
                          @ref="editModalComponent"
                          IsVisible="@IsVisible"
                          IsVisibleChanged="@IsVisibleChanged"
                          @bind-Id="@ItemCategoryId"
                          Service="@ItemCategoryService"
                          EntityName="@L["Entity.ItemCategory"]"
                          EntityNamePlural="@L["Entity.ItemCategory"]"
                          ModalTitle="@(ItemCategoryId.HasValue ? L["Message.EditTitle", L["Entity.ItemCategory"]].ToString() : L["Message.CreateTitle", L["Entity.ItemCategory"]].ToString())"
                          Size="GenericEditModalComponent<ItemCategory, IItemCategoryService>.ModalSize.Desktop"
                          UseGenericForm="true"
                          FormFields="@formFields"
                          FormSections="@formSections"
                          DataLoader="@LoadItemCategoryData"
                          ShowDraftButton="true"
                          DraftSuccessMessage="品項類型草稿已儲存，請記得補齊必填資料"
                          UseGenericSave="true"
                          SaveSuccessMessage="@(ItemCategoryId.HasValue ? L["Message.UpdateSuccess", L["Entity.ItemCategory"]].ToString() : L["Message.CreateSuccess", L["Entity.ItemCategory"]].ToString())"
                          SaveFailureMessage="@L["Message.SaveFailure", L["Entity.ItemCategory"]]"
                          RequiredPermission="@PermissionRegistry.ItemCategory.Read"
                          OnEntitySaved="@OnItemCategorySaved"
                          OnCancel="@OnCancel"
                          ComponentName="ItemCategoryEditModalComponent"
                          FeatureGuide="@ItemCategoryGuide.Create()" />

@code {
    // ===== 必要參數 =====
    [Parameter] public bool IsVisible { get; set; } = false;
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? ItemCategoryId { get; set; }
    [Parameter] public EventCallback<ItemCategory> OnItemCategorySaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public Dictionary<string, object?>? PrefilledValues { get; set; }

    // ===== 內部狀態 =====
    private GenericEditModalComponent<ItemCategory, IItemCategoryService>? editModalComponent;
    private List<FormFieldDefinition> formFields = new();
    private Dictionary<string, string> formSections = new();

    // ===== 必要方法 =====
    private Task<ItemCategory?> LoadItemCategoryData()
        => EditDataLoaderHelper.LoadOrCreateAsync<ItemCategory, IItemCategoryService>(
            ItemCategoryId, ItemCategoryService, NotificationService, "品項類型", "PCAT", PrefilledValues);

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            InitializeFormFields();
        }
    }

    private void InitializeFormFields()
    {
        formFields = new List<FormFieldDefinition>
        {
            new()
            {
                PropertyName = nameof(ItemCategory.Code),
                Label = L["Field.CategoryCode"],
                FieldType = FormFieldType.Text,
                Placeholder = L["Placeholder.PleaseInput", L["Field.CategoryCode"]],
                IsRequired = false,
                MaxLength = 50,
                HelpText = "品項分類的唯一編號，新增時系統會自動產生，也可手動修改"
            },
            new()
            {
                PropertyName = nameof(ItemCategory.Name),
                Label = L["Field.CategoryName"],
                FieldType = FormFieldType.Text,
                Placeholder = L["Placeholder.PleaseInput", L["Field.CategoryName"]],
                IsRequired = true,
                MaxLength = 50,
                HelpText = "品項分類的名稱，用於區分不同的品項類型"
            },
            new FormFieldDefinition()
            {
                PropertyName = nameof(ItemCategory.IsSaleable),
                Label = L["Field.ForSale"],
                FieldType = FormFieldType.Checkbox,
                IsRequired = false,
                HelpText = "指示此品項分類下的品項是否可供銷售"
            },

            FormFieldConfigurationHelper.CreateRemarksField<ItemCategory>()
        };

        formSections = FormSectionHelper<ItemCategory>.Create()
            .AddToSection(FormSectionNames.BasicInfo,
                pc => pc.Code,
                pc => pc.Name,
                pc => pc.IsSaleable)
            .AddToSection(FormSectionNames.AdditionalInfo,
                pc => pc.Remarks)
            .Build();
    }
}