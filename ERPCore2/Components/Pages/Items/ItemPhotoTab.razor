@* 品項照片 Tab - 多張照片，結構與 BusinessCardTab 一致 *@
@inject IItemPhotoService ItemPhotoService
@inject INotificationService NotificationService
@inject IWebHostEnvironment Environment
@inject IStringLocalizer<SharedResource> L

@if (!ItemId.HasValue || ItemId.Value <= 0)
{
    <div class="text-center text-muted py-4">
        <i class="bi bi-image fs-1 d-block mb-2"></i>
        <span>@L["ItemPhoto.SaveFirst"]</span>
    </div>
}
else
{
    <div class="business-card-tab">

        @* Header *@
        <div class="d-flex align-items-center justify-content-between mb-3">
            <span class="fw-semibold">@L["ItemPhoto.PhotoList"]</span>
            <label class="btn btn-sm btn-outline-primary" style="cursor:pointer; margin-bottom:0;">
                <i class="bi bi-upload me-1"></i>@L["ItemPhoto.UploadPhoto"]
                <InputFile OnChange="@HandleFileSelected" accept=".jpg,.jpeg,.png" multiple class="d-none" />
            </label>
        </div>

        @if (!string.IsNullOrEmpty(uploadError))
        {
            <div class="alert alert-danger py-2 mb-2">@uploadError</div>
        }

        @if (isUploading)
        {
            <div class="text-center text-muted py-3">
                <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                @L["Label.PleaseWait"]
            </div>
        }

        @* 照片列表 *@
        @if (!photos.Any())
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-image fs-1 d-block mb-2"></i>
                <span>@L["ItemPhoto.NoPhotos"]</span>
            </div>
        }
        else
        {
            <div class="business-card-grid">
                @foreach (var photo in photos)
                {
                    <div class="business-card-item">
                        <div class="business-card-photo-wrapper">
                            <img src="@photo.PhotoPath" alt="@(photo.Caption ?? L["Entity.Item"])"
                                 class="business-card-photo"
                                 @onclick="@(() => OpenPreview(photo))" />
                        </div>
                        <div class="business-card-info px-2 py-1">
                            <input type="text"
                                   class="form-control form-control-sm border-0 p-0 fw-semibold"
                                   value="@photo.Caption"
                                   placeholder="@L["ItemPhoto.Caption"]"
                                   @onchange="@(e => SaveCaptionAsync(photo, e.Value?.ToString()))" />
                        </div>
                        <div class="business-card-actions px-2 pb-2 d-flex gap-1">
                            <GenericButtonComponent Variant="ButtonVariant.OutlineRed"
                                    CssClass="btn-xs flex-fill"
                                    Title="@L["Button.Delete"]"
                                    IconClass="bi bi-trash"
                                    OnClick="@(() => RequestDelete(photo))" />
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@* 刪除確認 Modal *@
<GenericConfirmModalComponent IsVisible="@showDeleteModal"
                              IsVisibleChanged="@((bool v) => showDeleteModal = v)"
                              Title="@L["ItemPhoto.DeleteTitle"]"
                              Icon="bi-trash"
                              Message="@L["ItemPhoto.DeleteMessage"]"
                              ConfirmButtonText="@L["Button.ConfirmDelete"]"
                              CancelButtonText="@L["Button.Cancel"]"
                              ConfirmButtonVariant="ButtonVariant.Red"
                              OnConfirm="@ConfirmDeleteAsync"
                              OnCancel="@(() => showDeleteModal = false)" />

@* 照片預覽 Modal *@
@if (previewPhoto != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.7); cursor:pointer;" @onclick="ClosePreview">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(previewPhoto.Caption ?? L["Entity.Item"])</h5>
                    <button type="button" class="btn-close" @onclick="ClosePreview"></button>
                </div>
                <div class="modal-body text-center p-2">
                    <img src="@previewPhoto.PhotoPath" class="img-fluid" alt="@previewPhoto.Caption" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? ItemId { get; set; }

    private List<ItemPhoto> photos = new();
    private bool isUploading = false;
    private string? uploadError = null;
    private bool showDeleteModal = false;
    private ItemPhoto? deletingPhoto = null;
    private ItemPhoto? previewPhoto = null;
    private int? _loadedItemId;

    protected override async Task OnParametersSetAsync()
    {
        if (ItemId != _loadedItemId)
        {
            _loadedItemId = ItemId;
            if (ItemId.HasValue && ItemId.Value > 0)
                await LoadAsync(ItemId.Value);
            else
                Clear();
        }
    }

    // ===== 公開方法（供主組件透過 @ref 呼叫） =====

    public async Task LoadAsync(int productId)
    {
        photos = await ItemPhotoService.GetByItemAsync(productId);
        StateHasChanged();
    }

    public void Clear()
    {
        photos = new();
        uploadError = null;
        StateHasChanged();
    }

    // ===== 上傳 =====

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        if (!ItemId.HasValue || ItemId.Value <= 0) return;

        uploadError = null;
        isUploading = true;
        StateHasChanged();

        try
        {
            var nextSortOrder = photos.Count > 0 ? photos.Max(p => p.SortOrder) + 1 : 0;

            foreach (var file in e.GetMultipleFiles(10))
            {
                var (success, message, filePath) = await FileUploadHelper.UploadImageAsync(
                    file, "product-photos", Environment);

                if (!success)
                {
                    uploadError = message;
                    break;
                }

                var photo = new ItemPhoto
                {
                    ItemId = ItemId.Value,
                    OriginalFileName = file.Name,
                    PhotoPath = filePath!,
                    SortOrder = nextSortOrder++
                };

                var result = await ItemPhotoService.CreateAsync(photo);
                if (result.IsSuccess)
                    photos.Add(photo);
                else
                    uploadError = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            uploadError = $"上傳失敗：{ex.Message}";
        }
        finally
        {
            isUploading = false;
            if (ItemId.HasValue && ItemId.Value > 0)
                photos = await ItemPhotoService.GetByItemAsync(ItemId.Value);
            StateHasChanged();
        }
    }

    // ===== 圖說（失去焦點自動儲存）=====

    private async Task SaveCaptionAsync(ItemPhoto photo, string? value)
    {
        photo.Caption = value;
        var result = await ItemPhotoService.UpdateAsync(photo);
        if (!result.IsSuccess)
            await NotificationService.ShowErrorAsync(result.ErrorMessage);
    }

    // ===== 刪除 =====

    private void RequestDelete(ItemPhoto photo)
    {
        deletingPhoto = photo;
        showDeleteModal = true;
        StateHasChanged();
    }

    private async Task ConfirmDeleteAsync()
    {
        if (deletingPhoto == null) return;

        try
        {
            if (!string.IsNullOrEmpty(deletingPhoto.PhotoPath))
                FileUploadHelper.DeleteFile(deletingPhoto.PhotoPath, Environment);

            var result = await ItemPhotoService.DeleteAsync(deletingPhoto.Id);
            if (result.IsSuccess)
            {
                photos.Remove(deletingPhoto);
                await NotificationService.ShowSuccessAsync(L["ItemPhoto.DeleteSuccess"]);
            }
            else
            {
                await NotificationService.ShowErrorAsync(result.ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"刪除失敗：{ex.Message}");
        }
        finally
        {
            deletingPhoto = null;
            showDeleteModal = false;
            StateHasChanged();
        }
    }

    // ===== 預覽 =====

    private void OpenPreview(ItemPhoto photo)
    {
        previewPhoto = photo;
        StateHasChanged();
    }

    private void ClosePreview()
    {
        previewPhoto = null;
        StateHasChanged();
    }
}
