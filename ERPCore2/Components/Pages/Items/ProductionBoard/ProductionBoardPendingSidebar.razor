@using ERPCore2.Models.Schedule

<div class="pending-sidebar @(IsDropTarget ? "drop-target" : "") @(IsDragOver ? "drag-over" : "") @(IsMobileOpen ? "mobile-open" : "")"
     @ondragover:preventDefault="true"
     @ondragover="HandleDragOver"
     @ondragleave="HandleDragLeave"
     @ondrop="HandleDrop">

    @* 標題列 *@
    <div class="sidebar-header">
        <span class="sidebar-title">待排程</span>
        @if (Items.Count > 0)
        {
            <span class="sidebar-count">@Items.Count</span>
        }
        <DebugComponentLabelComponent ComponentName="ProductionBoardPendingSidebar" />
    </div>

    @* 退回提示（拖曳看板卡片時顯示） *@
    @if (IsDropTarget)
    {
        <div class="sidebar-drop-hint">
            <i class="bi bi-arrow-left-circle me-1"></i>拖曳至此退回待排
        </div>
    }

    @* 搜尋列 *@
    <div class="sidebar-search">
        <SearchInputComponent @bind-Value="searchText"
            Placeholder="搜尋品項/客戶/訂單..."
            CssClass="input-group-sm"
            ButtonSize="btn-sm" />
    </div>

    @* 項目列表 *@
    <div class="sidebar-items">
        @if (IsLoading)
        {
            <div class="sidebar-loading">載入中...</div>
        }
        else if (!FilteredItems.Any())
        {
            <div class="sidebar-empty">
                @if (string.IsNullOrEmpty(searchText))
                {
                    <span>所有訂單項目已排程完畢</span>
                }
                else
                {
                    <span>查無符合項目</span>
                }
            </div>
        }
        else
        {
            @foreach (var item in FilteredItems)
            {
                <div class="sidebar-item-wrapper @(IsDraggingItemId == item.SalesOrderDetailId ? "dragging" : "") @(!item.IsApproved ? "not-approved" : "")"
                     draggable="@(item.IsApproved ? "true" : "false")"
                     @ondragstart="() => (item.IsApproved ? HandleDragStart(item) : Task.CompletedTask)"
                     @ondragend="HandleDragEnd"
                     title="@(item.IsApproved ? "拖曳到日期欄以排入生產排程" : "待審核訂單，審核通過後才可排程")">

                    <div class="sidebar-card">
                        @if (!item.IsApproved)
                        {
                            <div class="scard-pending-badge">待審核</div>
                        }
                        <div class="scard-product">
                            <span class="scard-code">@item.ProductCode</span>
                            <span class="scard-name">@item.ProductName</span>
                        </div>
                        @if (!string.IsNullOrEmpty(item.CustomerName))
                        {
                            <div class="scard-customer">@item.CustomerName</div>
                        }
                        <div class="scard-footer">
                            <span class="scard-qty">待排：@NumberFormatHelper.FormatSmart(item.PendingQuantity) / @NumberFormatHelper.FormatSmart(item.OrderQuantity)</span>
                            @if (item.ExpectedDeliveryDate.HasValue)
                            {
                                <span class="scard-due @GetDeliveryUrgencyCss(item.ExpectedDeliveryDate)">
                                    @item.ExpectedDeliveryDate.Value.ToString("MM/dd")
                                </span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(item.SalesOrderCode))
                        {
                            <div class="scard-order">@item.SalesOrderCode</div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public List<BoardPendingItemDto> Items { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<BoardPendingItemDto> OnDragStart { get; set; }
    [Parameter] public EventCallback OnDragEnd { get; set; }
    [Parameter] public bool IsDropTarget { get; set; }
    [Parameter] public EventCallback OnBoardItemDropped { get; set; }
    [Parameter] public bool IsMobileOpen { get; set; }

    private int? IsDraggingItemId;
    private string searchText = string.Empty;
    private bool IsDragOver;

    private IEnumerable<BoardPendingItemDto> FilteredItems
    {
        get
        {
            var items = Items.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchText))
            {
                var term = searchText;
                items = items.Where(i =>
                    i.ProductCode.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    i.ProductName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    i.CustomerName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    i.SalesOrderCode.Contains(term, StringComparison.OrdinalIgnoreCase));
            }
            return items.OrderBy(i => i.ExpectedDeliveryDate).ThenBy(i => i.CustomerName);
        }
    }

    private async Task HandleDragStart(BoardPendingItemDto item)
    {
        IsDraggingItemId = item.SalesOrderDetailId;
        await OnDragStart.InvokeAsync(item);
    }

    private async Task HandleDragEnd()
    {
        IsDraggingItemId = null;
        await OnDragEnd.InvokeAsync();
    }

    private void HandleDragOver(DragEventArgs e)
    {
        if (IsDropTarget)
            IsDragOver = true;
    }

    private void HandleDragLeave(DragEventArgs e)
    {
        IsDragOver = false;
    }

    private async Task HandleDrop(DragEventArgs e)
    {
        IsDragOver = false;
        if (IsDropTarget && OnBoardItemDropped.HasDelegate)
            await OnBoardItemDropped.InvokeAsync();
    }

    private static string GetDeliveryUrgencyCss(DateTime? date)
    {
        if (!date.HasValue) return "";
        var daysLeft = (date.Value.Date - DateTime.Today).TotalDays;
        return daysLeft < 0 ? "due-overdue" : daysLeft <= 3 ? "due-urgent" : "";
    }
}
