@* 可重用的品項合成編輯組件 - 可在任何頁面中嵌入 *@
@using ERPCore2.Services.Reports.Interfaces
@using ERPCore2.Models.Reports
@inject IItemCompositionService ItemCompositionService
@inject IItemCompositionDetailService ItemCompositionDetailService
@inject IItemService ItemService
@inject IItemCategoryService ItemCategoryService
@inject IUnitService UnitService
@inject ICustomerService CustomerService
@inject IEmployeeService EmployeeService
@inject ICompositionCategoryService CompositionCategoryService
@inject INotificationService NotificationService
@inject ActionButtonHelper ActionButtonHelper
@inject IBOMReportService BOMReportService
@inject IStringLocalizer<SharedResource> L

<GenericEditModalComponent TEntity="ItemComposition" 
                          TService="IItemCompositionService"
                          @ref="editModalComponent"
                          IsVisible="@IsVisible"
                          IsVisibleChanged="@IsVisibleChanged"
                          @bind-Id="@CompositionId"
                          Service="@ItemCompositionService"
                          EntityName="@L["Entity.ItemComposition"]"
                          EntityNamePlural="@L["Entity.ItemComposition"]"
                          ModalTitle="@(CompositionId.HasValue ? L["Message.EditTitle", L["Entity.ItemComposition"]].ToString() : L["Message.CreateTitle", L["Entity.ItemComposition"]].ToString())"
                          Size="GenericEditModalComponent<ItemComposition, IItemCompositionService>.ModalSize.Desktop"
                          UseGenericForm="true"
                          FormFields="@formFields"
                          FormSections="@formSections"
                          AutoCompletePrefillers="@autoCompleteConfig?.Prefillers"
                          AutoCompleteCollections="@autoCompleteConfig?.Collections"
                          AutoCompleteDisplayProperties="@autoCompleteConfig?.DisplayProperties"
                          AutoCompleteValueProperties="@autoCompleteConfig?.ValueProperties"
                          ModalManagers="@modalManagers?.AsDictionary()"
                          DataLoader="@LoadCompositionData"
                          SaveHandler="@SaveCompositionWithDetails"
                          ShowDraftButton="true"
                          DraftSuccessMessage="@L["Message.DraftSuccess", L["Entity.ItemComposition"]]"
                          SaveSuccessMessage="@(CompositionId.HasValue ? L["Message.UpdateSuccess", L["Entity.ItemComposition"]].ToString() : L["Message.CreateSuccess", L["Entity.ItemComposition"]].ToString())"
                          SaveFailureMessage="@L["Message.SaveFailure", L["Entity.ItemComposition"]]"
                          RequiredPermission="@PermissionRegistry.ItemComposition.Read"
                          OnEntitySaved="@OnCompositionSaved"
                          OnCancel="@OnCancel"
ShowPrintButton="true"
                          PrintButtonText="@L["Button.Print"]"
                          ReportService="@BOMReportService"
                          ReportId="@ReportIds.BOMReport"
                          ReportPreviewTitle="@L["Label.DocumentPreview", L["Entity.BOM"]]"
                          GetReportDocumentName="@(e => $"物料清單-{e.Code}")"
                          CustomModules="@GetCustomModules()"
                          ComponentName="ItemCompositionEditModalComponent" />

@* 客戶編輯 Modal *@
<CustomerEditModalComponent @ref="customerEditModal"
                           IsVisible="@customerModalManager.IsModalVisible"
                           IsVisibleChanged="@customerModalManager.HandleModalVisibilityChangedAsync"
                           CustomerId="@customerModalManager.SelectedEntityId"
                           OnCustomerSaved="@customerModalManager.OnSavedAsync"
                           OnCancel="@customerModalManager.HandleModalCancelAsync" />

@* 員工編輯 Modal *@
<EmployeeEditModalComponent @ref="employeeEditModal"
                           IsVisible="@employeeModalManager.IsModalVisible"
                           IsVisibleChanged="@employeeModalManager.HandleModalVisibilityChangedAsync"
                           EmployeeId="@employeeModalManager.SelectedEntityId"
                           OnEmployeeSaved="@employeeModalManager.OnSavedAsync"
                           OnCancel="@employeeModalManager.HandleModalCancelAsync" />

@code {
    // ===== 參數 =====
    [Parameter] public bool IsVisible { get; set; } = false;
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? CompositionId { get; set; }
    [Parameter] public EventCallback<ItemComposition> OnCompositionSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public Dictionary<string, object?>? PrefilledValues { get; set; }

    // ===== 內部狀態 =====
    private GenericEditModalComponent<ItemComposition, IItemCompositionService>? editModalComponent;
    private ItemCompositionTable? detailManager;
    private List<FormFieldDefinition> formFields = new();
    private Dictionary<string, string> formSections = new();
    
    // AutoComplete 配置
    private AutoCompleteConfig? autoCompleteConfig;
    
    // 品項列表（分為主檔用和明細用）
    private List<Item> availableParentItems = new();    // 主檔品項選項（只顯示自製品項）
    private List<Item> availableComponentItems = new(); // 明細材料選項（顯示所有品項）
    private List<Unit> availableUnits = new();
    private List<Customer> availableCustomers = new();
    private List<Employee> availableEmployees = new();
    private List<CompositionCategory> availableCompositionCategories = new();
    private List<ItemCompositionDetail> compositionDetails = new();
    private bool isDetailDataReady = false;
    private int _detailsDataVersion = 0;

    // ===== Modal 管理器 =====
    private CustomerEditModalComponent? customerEditModal;
    private RelatedEntityModalManager<Customer> customerModalManager = default!;
    private EmployeeEditModalComponent? employeeEditModal;
    private RelatedEntityModalManager<Employee> employeeModalManager = default!;
    private ModalManagerCollection modalManagers = default!;
    // 資料載入狀態標記
    private bool isDataLoaded = false;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 使用 ModalManagerInitHelper 初始化 Modal 管理器
            modalManagers = ModalManagerInitHelper.CreateBuilder<ItemComposition, IItemCompositionService>(
                    () => editModalComponent,
                    NotificationService,
                    StateHasChanged,
                    LoadAdditionalDataAsync,
                    InitializeFormFieldsAsync)
                .AddManager<Customer>(nameof(ItemComposition.CustomerId), "客戶")
                .AddManager<Employee>(nameof(ItemComposition.CreatedByEmployeeId), "員工")
                .Build();
            customerModalManager = modalManagers.Get<Customer>(nameof(ItemComposition.CustomerId));
            employeeModalManager = modalManagers.Get<Employee>(nameof(ItemComposition.CreatedByEmployeeId));
            
            // 移除自動載入資料，改為在 OnParametersSetAsync 中根據 IsVisible 載入
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync("初始化品項物料清單編輯組件時發生錯誤");
        }
    }
    
    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !isDataLoaded)
        {
            // 每次開啟 Modal 時都重置明細資料
            compositionDetails = new List<ItemCompositionDetail>();
            
            await LoadAdditionalDataAsync();
            await InitializeFormFieldsAsync();
            isDataLoaded = true;
        }
        else if (!IsVisible)
        {
            isDataLoaded = false;
        }
    }
    // ===== 資料載入 =====
    private async Task LoadAdditionalDataAsync()
    {
        try
        {
            isDetailDataReady = false;
            
            // 載入所有品項列表（只查詢一次資料庫）
            var allItems = await ItemService.GetAllAsync();
            
            // 主檔品項選項：顯示所有品項
            availableParentItems = allItems.ToList();

            // 明細材料選項：顯示所有品項（但會在 Table 中排除主檔品項）
            availableComponentItems = allItems.ToList();
            
            // 載入可選擇的單位列表
            availableUnits = await UnitService.GetAllAsync();
            
            // 載入客戶列表
            availableCustomers = await CustomerService.GetAllAsync();
            
            // 載入員工列表（排除超級管理員）
            var allEmployees = await EmployeeService.GetAllAsync();
            availableEmployees = allEmployees.Where(e => !e.IsSuperAdmin).ToList();
            
            // 載入物料清單類型列表
            availableCompositionCategories = await CompositionCategoryService.GetAllAsync();
            
            // 使用 AutoCompleteConfigHelper 建立配置
            autoCompleteConfig = new AutoCompleteConfigBuilder<ItemComposition>()
                .AddField(nameof(ItemComposition.ParentItemId), "Name", availableParentItems)
                .AddField(nameof(ItemComposition.CompositionCategoryId), "Name", availableCompositionCategories)
                .AddField(nameof(ItemComposition.CustomerId), "CompanyName", availableCustomers)
                .AddField(nameof(ItemComposition.CreatedByEmployeeId), "Name", availableEmployees)
                .Build();
            
            // 注意：不在此處清空 compositionDetails！
            // DataLoader (LoadCompositionData) 可能已先執行並載入資料，
            // 若在此清空會造成 race condition（DataLoader 的資料被覆蓋為空）。
            // compositionDetails 的重置由 OnParametersSetAsync 開頭同步執行（在任何 await 前）。
            isDetailDataReady = true;
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入資料時發生錯誤：{ex.Message}");
            availableParentItems = new List<Item>();
            availableComponentItems = new List<Item>();
            availableUnits = new List<Unit>();
            availableCustomers = new List<Customer>();
            availableEmployees = new List<Employee>();
            availableCompositionCategories = new List<CompositionCategory>();
            compositionDetails = new List<ItemCompositionDetail>();
            isDetailDataReady = true;
        }
    }
    
    /// <summary>
    /// 載入品項合成明細資料
    /// </summary>
    private async Task LoadCompositionDetailsAsync()
    {
        try
        {
            if (!CompositionId.HasValue || CompositionId.Value <= 0)
            {
                compositionDetails = new List<ItemCompositionDetail>();
                return;
            }

            // 從資料庫載入明細（只查詢此合成的明細，包含 ComponentItem 導航屬性）
            compositionDetails = await ItemCompositionDetailService.GetDetailsByCompositionIdAsync(CompositionId.Value);
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入品項合成明細時發生錯誤：{ex.Message}");
            compositionDetails = new List<ItemCompositionDetail>();
        }
    }

    private async Task<ItemComposition?> LoadCompositionData()
    {
        try
        {
            if (!CompositionId.HasValue)
            {
                // 新增模式：建立新的品項物料清單實體並生成編號
                var newComposition = new ItemComposition
                {
                    Status = EntityStatus.Active
                };
                
                // 先應用預填值（業務邏輯需要的欄位，如 ParentItemId）
                PrefilledValueHelper.ApplyPrefilledValues(newComposition, PrefilledValues);
                
                // 🔑 關鍵：Code 在應用預填值後才產生，確保每次都是新的
                // 這樣即使 PrefilledValues 中有舊的 Code，也會被覆蓋為新產生的 Code
                newComposition.Code = await EntityCodeGenerationHelper.GenerateForEntity<ItemComposition, IItemCompositionService>(ItemCompositionService, "BOM");
                
                return newComposition;
            }

            var composition = await ItemCompositionService.GetByIdAsync(CompositionId.Value);

            if (composition == null)
            {
                // 如果找不到品項物料清單，建立新的預設實體
                return new ItemComposition
                {
                    Status = EntityStatus.Active
                };
            }

            // 每次導覽（含初次開啟編輯）都重新載入明細，並遞增版本號通知 Table 重載
            await LoadCompositionDetailsAsync();
            _detailsDataVersion++;

            return composition;
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入品項物料清單資料時發生錯誤：{ex.Message}");
            
            // 設定安全的預設值，確保程式不會崩潰
            return new ItemComposition
            {
                Code = "ERROR",
                Status = EntityStatus.Active
            };
        }
    }

    // ===== 表單初始化 =====
    private async Task InitializeFormFieldsAsync()
    {
        try
        {
            // 準備合成類型選項
            var compositionCategoryOptions = availableCompositionCategories.Select(cc => new SelectOption
            {
                Text = cc.Name,
                Value = cc.Id.ToString()
            }).ToList();

            // 準備客戶選項
            var customerOptions = new List<SelectOption>();
            customerOptions.AddRange(availableCustomers.Select(c => new SelectOption
            {
                Text = $"{c.Code} - {c.CompanyName}".Trim(),
                Value = c.Id.ToString()
            }));

            // 準備員工選項
            var employeeOptions = new List<SelectOption>();
            employeeOptions.AddRange(availableEmployees.Select(e => new SelectOption
            {
                Text = !string.IsNullOrEmpty(e.Name) ? $"{e.Code} - {e.Name}".Trim() : e.Code ?? $"員工{e.Id}",
                Value = e.Id.ToString()
            }));

            formFields = new List<FormFieldDefinition>
            {
                // 基本資訊區段
                new()
                {
                    PropertyName = nameof(ItemComposition.Code),
                    Label = L["Field.CompositionCode"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.CompositionCode"]],
                    IsRequired = false,
                    HelpText = "合成的唯一識別編號，新增時系統會自動產生，也可手動修改"
                },
                new()
                {
                    PropertyName = nameof(ItemComposition.Name),
                    Label = L["Field.CompositionName"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.CompositionName"]],
                    IsRequired = false,
                    HelpText = "清單名稱，方便在報價單/訂單中快速辨識此配方"
                },
                new()
                {
                    PropertyName = nameof(ItemComposition.ParentItemId),
                    Label = L["Entity.Item"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = L["Placeholder.PleaseInputOrSelect", L["Entity.Item"]],
                    IsRequired = true,
                    MinSearchLength = 0,
                    HelpText = "此物料清單所屬的品項（建立後無法變更）"
                },
                new()
                {
                    PropertyName = nameof(ItemComposition.CompositionCategoryId),
                    Label = L["Field.CompositionType"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = L["Placeholder.PleaseSelect", L["Field.CompositionType"]],
                    IsRequired = false,
                    MinSearchLength = 0,
                    HelpText = "選擇組合該品項的清單類型"
                },
                new()
                {
                    PropertyName = nameof(ItemComposition.CustomerId),
                    Label = L["Entity.Customer"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = L["Placeholder.PleaseSelect", L["Entity.Customer"]],
                    IsRequired = false,
                    MinSearchLength = 0,
                    HelpText = "選擇此合成的客戶(選填)",
                    ActionButtons = await GetCustomerActionButtonsAsync()
                },
                new()
                {
                    PropertyName = nameof(ItemComposition.CreatedByEmployeeId),
                    Label = L["Field.CompositionCreator"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = L["Placeholder.PleaseSelect", L["Field.CompositionCreator"]],
                    IsRequired = false,
                    MinSearchLength = 0,
                    HelpText = "選擇建立此合成的員工(選填)",
                    ActionButtons = await GetEmployeeActionButtonsAsync()
                },
                new()
                {
                    PropertyName = nameof(ItemComposition.Specification),
                    Label = L["Field.Spec"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.Spec"]],
                    IsRequired = false,
                    HelpText = "品項物料清單的規格說明",
                    ContainerCssClass = "col-6"
                },

                FormFieldConfigurationHelper.CreateRemarksField<ItemComposition>(containerCssClass:"col-6")
            };

            formSections = FormSectionHelper<ItemComposition>.Create()
                .AddToSection(FormSectionNames.BasicInfo,
                    pc => pc.Code,
                    pc => pc.Name,
                    pc => pc.ParentItemId,
                    pc => pc.CompositionCategoryId,
                    pc => pc.CustomerId,
                    pc => pc.CreatedByEmployeeId)
                .AddToSection(FormSectionNames.AdditionalData,
                    pc => pc.Specification,
                    pc => pc.Remarks)
                .Build();
        }
        catch (Exception)
        {
            _ = NotificationService.ShowErrorAsync("初始化表單欄位時發生錯誤");
        }
    }

    // ===== 自訂模組 =====
    private List<GenericEditModalComponent<ItemComposition, IItemCompositionService>.CustomModule> GetCustomModules()
    {
        return new List<GenericEditModalComponent<ItemComposition, IItemCompositionService>.CustomModule>
        {
            new GenericEditModalComponent<ItemComposition, IItemCompositionService>.CustomModule
            {
                Order = 1,
                IsVisible = true,
                Content = CreateDetailManagerContent()
            }
        };
    }

    /// <summary>
    /// 創建明細管理器內容的 RenderFragment
    /// </summary>
    private RenderFragment CreateDetailManagerContent() => __builder =>
    {
        <DetailSectionWrapper IsEntityReady="@(editModalComponent?.Entity != null)"
                              IsDetailDataReady="@isDetailDataReady"
                              IsDataAvailable="@(availableComponentItems != null && availableComponentItems.Any() && availableUnits != null && availableUnits.Any())"
                              DataUnavailableMessage="無可用的品項或單位資料，請聯繫系統管理員"
                              IsPreconditionMet="@(editModalComponent?.Entity?.ParentItemId > 0)"
                              PreconditionMessage="請先選擇品項後再進行材料清單管理">
            <ItemCompositionTable @ref="detailManager"
                                     @key="@(editModalComponent?.Entity?.Id ?? 0)"
                                     ExistingDetails="@compositionDetails"
                                     DataVersion="@_detailsDataVersion"
                                     MainEntity="@editModalComponent?.Entity"
                                     AvailableItems="@availableComponentItems"
                                     AvailableUnits="@availableUnits"
                                     ParentItemId="@(editModalComponent?.Entity?.ParentItemId ?? 0)"
                                     IsReadOnly="false"
                                     OnDetailsChanged="@HandleDetailsChanged"
                                     EmptyMessage="尚未新增材料" />
        </DetailSectionWrapper>
    };
    
    // ===== 明細變更處理 =====
    private void HandleDetailsChanged(List<ItemCompositionDetail> details)
    {
        editModalComponent?.MarkDirty();
        // 僅更新快取，不遞增 DataVersion（避免 Table 重新載入覆蓋使用者的編輯中狀態）
        compositionDetails = details;
        StateHasChanged();
    }
    
    // ===== 自訂儲存邏輯 =====
    
    /// <summary>
    /// 自訂儲存邏輯 - 同時儲存主檔和明細
    /// </summary>
    private async Task<bool> SaveCompositionWithDetails(ItemComposition composition)
    {
        try
        {
            if (composition == null)
            {
                await NotificationService.ShowErrorAsync("沒有要儲存的品項物料清單資料");
                return false;
            }
            
            if (!composition.IsDraft)
            {
                // ========== 第一步：先驗證明細資料（包含 UI 驗證） ==========
                if (detailManager != null)
                {
                    var isValid = await detailManager.ValidateAsync();
                    if (!isValid)
                    {
                        return false;
                    }
                }

                // ========== 第二步：進階驗證 - 檢查循環參考（成品不能包含自己） ==========
                if (detailManager != null)
                {
                    var validDetails = detailManager.GetNonEmptyItems();

                    // 檢查是否有組件與成品相同（循環參考）
                    foreach (var detail in validDetails)
                    {
                        if (detail.ComponentItemId == composition.ParentItemId)
                        {
                            await NotificationService.ShowErrorAsync("明細驗證失敗：組件不能是成品本身（會造成循環參考）");
                            return false;
                        }
                    }
                }
            }
            
            // ========== 第三步：儲存主檔（驗證都通過後才儲存） ==========
            ItemComposition? savedComposition = null;
            bool isNewRecord = !CompositionId.HasValue || CompositionId.Value == 0;
            
            if (CompositionId.HasValue && CompositionId.Value > 0)
            {
                // 更新模式
                var updateResult = await ItemCompositionService.UpdateAsync(composition);
                if (updateResult.IsSuccess)
                {
                    savedComposition = updateResult.Data;
                }
                else
                {
                    await NotificationService.ShowErrorAsync($"更新品項物料清單主檔失敗：{updateResult.ErrorMessage}");
                    return false;
                }
            }
            else
            {
                // 新增模式
                var createResult = await ItemCompositionService.CreateAsync(composition);
                if (createResult.IsSuccess && createResult.Data != null)
                {
                    savedComposition = createResult.Data;
                }
                else
                {
                    await NotificationService.ShowErrorAsync($"新增品項物料清單主檔失敗：{createResult.ErrorMessage}");
                    return false;
                }
            }
            
            if (savedComposition == null)
            {
                await NotificationService.ShowErrorAsync("儲存品項物料清單主檔失敗");
                return false;
            }
            
            // ========== 第四步：儲存明細（循環參考驗證已通過） ==========
            if (detailManager != null)
            {
                var validDetails = detailManager.GetNonEmptyItems();
                
                // 設定主檔 ID 並清除 Navigation Properties
                foreach (var detail in validDetails)
                {
                    detail.ItemCompositionId = savedComposition.Id;
                    
                    // 清除 Navigation Properties（避免 EF Core 追蹤錯誤）
                    detail.ItemComposition = null!;
                    detail.ComponentItem = null!;
                    detail.Unit = null;
                }
                
                // 刪除已標記刪除的明細
                var deletedIds = detailManager.GetDeletedDetailIds();
                foreach (var deletedId in deletedIds)
                {
                    var deleteResult = await ItemCompositionDetailService.DeleteAsync(deletedId);
                    if (!deleteResult.IsSuccess)
                    {
                        await NotificationService.ShowErrorAsync($"刪除明細失敗：{deleteResult.ErrorMessage}");
                        return false;
                    }
                }
                // 清空已處理的刪除 ID，避免重複刪除（例如使用者儲存後繼續編輯再次儲存）
                detailManager.ClearDeletedDetailIds();
                
                // 儲存或更新明細
                foreach (var detail in validDetails)
                {
                    if (detail.Id > 0)
                    {
                        var updateResult = await ItemCompositionDetailService.UpdateAsync(detail);
                        if (!updateResult.IsSuccess)
                        {
                            await NotificationService.ShowErrorAsync($"更新明細失敗：{updateResult.ErrorMessage}");
                            return false;
                        }
                    }
                    else
                    {
                        var createResult = await ItemCompositionDetailService.CreateAsync(detail);
                        if (!createResult.IsSuccess)
                        {
                            await NotificationService.ShowErrorAsync($"新增明細失敗：{createResult.ErrorMessage}");
                            return false;
                        }
                    }
                }
            }
            
            // ========== 第五步：更新組件參數（從新增模式轉為編輯模式） ==========
            if (isNewRecord && savedComposition.Id > 0)
            {
                CompositionId = savedComposition.Id;
            }
            
            return true;
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"儲存品項物料清單時發生錯誤：{ex.Message}");
            return false;
        }
    }

    // ===== 公開方法 (供父組件調用) =====
    public Task ShowAddModal() => editModalComponent!.ShowAddModal();
    public Task ShowEditModal(int id) => editModalComponent!.ShowEditModal(id);
    // ===== Modal 管理器配置方法 =====
    
    // ===== ActionButton 產生方法 =====
    
    /// <summary>
    /// 產生客戶操作按鈕 - 使用統一 Helper
    /// </summary>
    private async Task<List<FieldActionButton>> GetCustomerActionButtonsAsync()
    {
        return await ActionButtonHelper.GenerateFieldActionButtonsAsync(
            editModalComponent, 
            customerModalManager, 
            nameof(ItemComposition.CustomerId)
        );
    }
    
    /// <summary>
    /// 產生製單人員操作按鈕 - 使用統一 Helper
    /// </summary>
    private async Task<List<FieldActionButton>> GetEmployeeActionButtonsAsync()
    {
        return await ActionButtonHelper.GenerateFieldActionButtonsAsync(
            editModalComponent, 
            employeeModalManager, 
            nameof(ItemComposition.CreatedByEmployeeId)
        );
    }
    
    // ===== Modal 事件包裝器方法 =====
    
}
