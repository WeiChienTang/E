@page "/customer-complaints"
@inject ICustomerComplaintService CustomerComplaintService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="CustomerComplaint"
                          TService="ICustomerComplaintService"
                          Service="@CustomerComplaintService"
                          EntityBasePath="/customer-complaints"
                          PageTitle="@L["Page.CustomerComplaintTitle"]"
                          PageSubtitle="@L["Page.CustomerComplaintSubtitle"]"
                          EntityName="@L["Entity.CustomerComplaint"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadComplaintsAsync"
                          GetEntityDisplayName="@(c => $"{c.Customer?.CompanyName} - {c.Title}")"
                          RequiredPermission="@PermissionRegistry.CustomerComplaint.Read"
                          RequiredModule="Customers"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          DebugPageName="CustomerComplaintIndex"
                          @ref="indexComponent" />

<CustomerComplaintEditModalComponent IsVisible="@showEditModal"
                                     IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                     CustomerComplaintId="@editingComplaintId"
                                     OnCustomerComplaintSaved="@modalHandler.OnEntitySavedAsync"
                                     OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    private GenericIndexPageComponent<CustomerComplaint, ICustomerComplaintService> indexComponent = default!;

    private bool showEditModal = false;
    private int? editingComplaintId = null;

    private ModalHandler<CustomerComplaint, GenericIndexPageComponent<CustomerComplaint, ICustomerComplaintService>> modalHandler = default!;

    private CustomerComplaintFieldConfiguration fieldConfiguration = default!;

    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<CustomerComplaint, GenericIndexPageComponent<CustomerComplaint, ICustomerComplaintService>>(
                id => editingComplaintId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new CustomerComplaintFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化客訴頁面失敗");
            await NotificationService.ShowErrorAsync("初始化客訴頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("客戶管理", "客訴管理", "#", NotificationService, GetType());

    private Task<(List<CustomerComplaint> Items, int TotalCount)> ServerLoadComplaintsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return CustomerComplaintService.GetPagedWithFiltersAsync(
            q =>
            {
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadComplaintsAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
