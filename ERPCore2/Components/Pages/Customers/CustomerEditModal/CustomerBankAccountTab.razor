@* 客戶銀行帳號 Tab *@
@using ERPCore2.Models.Enums

<GenericBankAccountTabComponent @ref="_tab"
                                EntityType="BankAccountEntityType.Customer"
                                EntityId="@CustomerId" />

@code {
    [Parameter] public int? CustomerId { get; set; }

    private GenericBankAccountTabComponent? _tab;

    public Task LoadAsync(int id) => _tab?.LoadAsync(id) ?? Task.CompletedTask;
    public void Clear() => _tab?.Clear();
}
