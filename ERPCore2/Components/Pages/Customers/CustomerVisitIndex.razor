@page "/customer-visits"
@inject ICustomerVisitService CustomerVisitService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="CustomerVisit"
                          TService="ICustomerVisitService"
                          Service="@CustomerVisitService"
                          EntityBasePath="/customer-visits"
                          PageTitle="@L["Page.CustomerVisitTitle"]"
                          PageSubtitle="@L["Page.CustomerVisitSubtitle"]"
                          EntityName="@L["Entity.CustomerVisit"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadVisitsAsync"
                          GetEntityDisplayName="@(v => $"{v.Customer?.CompanyName} - {v.VisitDate:yyyy/MM/dd}")"
                          RequiredPermission="@PermissionRegistry.Customer.Read"
                          RequiredModule="Customers"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          DebugPageName="CustomerVisitIndex"
                          @ref="indexComponent" />

<CustomerVisitEditModalComponent IsVisible="@showEditModal"
                                 IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                 CustomerVisitId="@editingVisitId"
                                 OnCustomerVisitSaved="@modalHandler.OnEntitySavedAsync"
                                 OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    private GenericIndexPageComponent<CustomerVisit, ICustomerVisitService> indexComponent = default!;

    private bool showEditModal = false;
    private int? editingVisitId = null;

    private ModalHandler<CustomerVisit, GenericIndexPageComponent<CustomerVisit, ICustomerVisitService>> modalHandler = default!;

    private CustomerVisitFieldConfiguration fieldConfiguration = default!;

    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<CustomerVisit, GenericIndexPageComponent<CustomerVisit, ICustomerVisitService>>(
                id => editingVisitId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new CustomerVisitFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化拜訪紀錄頁面失敗");
            await NotificationService.ShowErrorAsync("初始化拜訪紀錄頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("客戶管理", "拜訪紀錄維護", "#", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<CustomerVisit> Items, int TotalCount)> ServerLoadVisitsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return CustomerVisitService.GetPagedWithFiltersAsync(
            q =>
            {
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadVisitsAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
