@* 檔案存留編輯組件 *@
@inject IDocumentService DocumentService
@inject IDocumentFileService DocumentFileService
@inject IDocumentCategoryService DocumentCategoryService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@inject IWebHostEnvironment Environment
@inject ISystemParameterService SystemParameterService
@using ERPCore2.Models.FeatureGuides.GuideDefinitions

<GenericEditModalComponent TEntity="Document"
                          TService="IDocumentService"
                          @ref="editModalComponent"
                          IsVisible="@IsVisible"
                          IsVisibleChanged="@IsVisibleChanged"
                          @bind-Id="@DocumentId"
                          Service="@DocumentService"
                          EntityName="@L["Entity.Document"]"
                          EntityNamePlural="@L["Entity.Document"]"
                          ModalTitle="@(DocumentId.HasValue ? L["Message.EditTitle", L["Entity.Document"]].ToString() : L["Message.CreateTitle", L["Entity.Document"]].ToString())"
                          Size="GenericEditModalComponent<Document, IDocumentService>.ModalSize.Desktop"
                          UseGenericForm="true"
                          FormFields="@formFields"
                          FormSections="@formSections"
                          TabDefinitions="@tabDefinitions"
                          DataLoader="@LoadData"
                          SaveHandler="@HandleSaveAsync"
                          ShowDraftButton="true"
                          DraftSuccessMessage="@L["Message.DraftSuccess", L["Entity.Document"]]"
                          SaveSuccessMessage="@(DocumentId.HasValue ? L["Message.UpdateSuccess", L["Entity.Document"]].ToString() : L["Message.CreateSuccess", L["Entity.Document"]].ToString())"
                          SaveFailureMessage="@L["Message.SaveFailure", L["Entity.Document"]]"
                          RequiredPermission="@PermissionRegistry.Document.Read"
                          OnEntitySaved="@OnDocumentSaved"
                          OnCancel="@OnCancel"
                          ComponentName="DocumentEditModalComponent"
                          FeatureGuide="@DocumentGuide.Create()">
</GenericEditModalComponent>

@code {
    [Parameter] public bool IsVisible { get; set; } = false;
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? DocumentId { get; set; }
    [Parameter] public EventCallback<Document> OnDocumentSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public Dictionary<string, object?>? PrefilledValues { get; set; }

    private GenericEditModalComponent<Document, IDocumentService>? editModalComponent;
    private List<FormFieldDefinition> formFields = new();
    private Dictionary<string, string> formSections = new();
    private List<FormTabDefinition>? tabDefinitions;

    // 來源實體 Tab
    private string? _relatedEntityType;
    private int? _relatedEntityId;
    private SourceEntityInfoTab? sourceEntityInfoTab;

    // 附件管理狀態
    private List<DocumentFileViewModel> fileViewModels = new();
    private string? fileError = null;

    // 下拉選項
    private List<SelectOption> categoryOptions = new();

    // 檔案大小限制（從系統參數載入）
    private int? _maxDocumentFileSizeMB;

    protected override void OnParametersSet()
    {
        if (IsVisible)
            _ = InitializeAsync();
    }

    private async Task InitializeAsync()
    {
        try
        {
            fileViewModels = new();
            fileError = null;

            var sysParam = await SystemParameterService.GetSystemParameterAsync();
            _maxDocumentFileSizeMB = sysParam?.MaxDocumentFileSizeMB;

            var categories = await DocumentCategoryService.GetAllAsync();
            categoryOptions = categories
                .Where(c => c.Status == EntityStatus.Active)
                .OrderBy(c => c.Name)
                .Select(c => new SelectOption { Value = c.Id.ToString(), Text = c.Name })
                .ToList();

            InitializeFormFields();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(InitializeAsync), GetType(), additionalData: "初始化文件表單失敗");
        }
    }

    private async Task<Document?> LoadData()
    {
        var doc = await EditDataLoaderHelper.LoadOrCreateAsync<Document, IDocumentService>(
            DocumentId, DocumentService, NotificationService, L["Entity.Document"], "DOC", PrefilledValues,
            d => d.Title = string.Empty);

        if (doc != null && doc.Id > 0)
        {
            var existing = await DocumentService.GetWithFilesAsync(doc.Id);
            if (existing?.DocumentFiles != null)
            {
                fileViewModels = existing.DocumentFiles
                    .OrderBy(f => f.SortOrder)
                    .Select(f => new DocumentFileViewModel
                    {
                        Id = f.Id,
                        DisplayName = f.DisplayName,
                        FileName = f.FileName,
                        FilePath = f.FilePath,
                        FileSize = f.FileSize,
                        MimeType = f.MimeType,
                        SortOrder = f.SortOrder
                    })
                    .ToList();
            }
        }
        else
        {
            fileViewModels = new();
        }

        // 記錄來源實體資訊並重建 Tab
        _relatedEntityType = doc?.RelatedEntityType;
        _relatedEntityId = doc?.RelatedEntityId;
        RebuildTabDefinitions();

        await InvokeAsync(StateHasChanged);
        return doc;
    }

    private void HandleFilesSelected(InputFileChangeEventArgs e)
    {
        fileError = null;
        var nextSortOrder = fileViewModels.Count > 0 ? fileViewModels.Max(f => f.SortOrder) + 1 : 0;

        foreach (var file in e.GetMultipleFiles())
        {
            fileViewModels.Add(new DocumentFileViewModel
            {
                DisplayName = Path.GetFileNameWithoutExtension(file.Name),
                FileName = file.Name,
                FileSize = file.Size,
                PendingFile = file,
                SortOrder = nextSortOrder++
            });
        }
        StateHasChanged();
    }

    private void RemoveFile(DocumentFileViewModel vm)
    {
        if (vm.IsPending)
            fileViewModels.Remove(vm);
        else
            vm.IsDeleted = true;
        StateHasChanged();
    }

    private async Task<bool> HandleSaveAsync(Document entity)
    {
        try
        {
            if (!entity.IsDraft)
            {
                bool isDraftEligible = editModalComponent?.ShowDraftButton == true &&
                                       (!DocumentId.HasValue || editModalComponent?.WasOriginallyDraft == true);

                var activeFiles = fileViewModels.Where(f => !f.IsDeleted).ToList();
                if (!activeFiles.Any())
                {
                    if (isDraftEligible)
                        editModalComponent!.PendingSaveError = L["Message.AtLeastOneFile"];
                    else
                        fileError = L["Message.AtLeastOneFile"];
                    return false;
                }
            }

            // 儲存 Document 主體
            ServiceResult result;
            if (entity.Id == 0)
                result = await DocumentService.CreateAsync(entity);
            else
                result = await DocumentService.UpdateAsync(entity);

            if (!result.IsSuccess)
                return false;

            // 更新現有附件的 DisplayName
            foreach (var vm in fileViewModels.Where(f => !f.IsDeleted && !f.IsPending && f.Id.HasValue))
            {
                var existing = await DocumentFileService.GetByIdAsync(vm.Id!.Value);
                if (existing != null && existing.DisplayName != vm.DisplayName)
                {
                    existing.DisplayName = vm.DisplayName;
                    await DocumentFileService.UpdateAsync(existing);
                }
            }

            // 上傳新附件
            int maxSortOrder = fileViewModels.Where(f => !f.IsPending).Any()
                ? fileViewModels.Where(f => !f.IsPending).Max(f => f.SortOrder)
                : -1;

            foreach (var vm in fileViewModels.Where(f => !f.IsDeleted && f.IsPending))
            {
                var (success, message, filePath, mimeType) = await FileUploadHelper.UploadDocumentAsync(
                    vm.PendingFile!, Environment, maxSizeMB: _maxDocumentFileSizeMB);

                if (!success)
                {
                    fileError = message;
                    return false;
                }

                await DocumentFileService.CreateAsync(new DocumentFile
                {
                    DocumentId = entity.Id,
                    DisplayName = vm.DisplayName,
                    FileName = vm.FileName,
                    FilePath = filePath!,
                    FileSize = vm.FileSize,
                    MimeType = mimeType,
                    SortOrder = vm.SortOrder
                });
            }

            // 刪除已標記刪除的現有附件
            foreach (var vm in fileViewModels.Where(f => f.IsDeleted && !f.IsPending && f.Id.HasValue))
            {
                if (!string.IsNullOrEmpty(vm.FilePath))
                    FileUploadHelper.DeleteFile(vm.FilePath, Environment);
                await DocumentFileService.DeleteAsync(vm.Id!.Value);
            }

            return true;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleSaveAsync), GetType(), additionalData: "儲存文件失敗");
            return false;
        }
    }

    private void InitializeFormFields()
    {
        try
        {
            formFields = new List<FormFieldDefinition>
            {
                new()
                {
                    PropertyName = nameof(Document.Code),
                    Label = L["Field.Code"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.Code"]],
                    IsRequired = false,
                    HelpText = "文件的唯一識別編號，新增時系統會自動產生"
                },
                new()
                {
                    PropertyName = nameof(Document.Title),
                    Label = L["Field.DocumentTitle"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.DocumentTitle"]],
                    IsRequired = true,
                    HelpText = "文件的顯示標題"
                },
                new()
                {
                    PropertyName = nameof(Document.DocumentCategoryId),
                    Label = L["Field.DocumentCategory"],
                    FieldType = FormFieldType.Select,
                    IsRequired = false,
                    Options = categoryOptions,
                    HelpText = "選擇文件所屬的分類"
                },
                new()
                {
                    PropertyName = nameof(Document.AccessLevel),
                    Label = L["Field.AccessLevel"],
                    FieldType = FormFieldType.Select,
                    IsRequired = false,
                    Options = new List<SelectOption>
                    {
                        new() { Value = "", Text = L["Document.UseDefaultAccessLevel"] },
                        new() { Value = "1", Text = L["Label.DocumentAccessLevel.Normal"] },
                        new() { Value = "2", Text = L["Label.DocumentAccessLevel.Sensitive"] }
                    },
                    HelpText = "若不設定，則使用所屬分類的預設層級"
                },
                new()
                {
                    PropertyName = nameof(Document.IssuedDate),
                    Label = L["Field.IssuedDate"],
                    FieldType = FormFieldType.Date,
                    IsRequired = false,
                    HelpText = "文件的發文日期"
                },
                new()
                {
                    PropertyName = nameof(Document.ExpiryDate),
                    Label = L["Field.ExpiryDate"],
                    FieldType = FormFieldType.Date,
                    IsRequired = false,
                    HelpText = "文件的有效期限（若有）"
                },
                FormFieldConfigurationHelper.CreateRemarksField<Document>()
            };

            var builder = FormSectionHelper<Document>.Create()
                .AddToSection(FormSectionNames.BasicInfo,
                    d => d.Code,
                    d => d.Title,
                    d => d.DocumentCategoryId,
                    d => d.AccessLevel)
                .AddToSection(L["Section.DocumentInfo"],
                    d => d.IssuedDate,
                    d => d.ExpiryDate)
                .AddToSection(FormSectionNames.AdditionalData,
                    d => d.Remarks)
                .GroupIntoTab(L["Tab.DocumentData"].ToString(), "bi-file-earmark-text",
                    FormSectionNames.BasicInfo, L["Section.DocumentInfo"],
                    FormSectionNames.AdditionalData);

            var layout = builder.BuildAll();
            formSections = layout.FieldSections;
            tabDefinitions = layout.TabDefinitions;

            // 將附件檔案表格嵌入第一個 Tab（文件資料）的 ExtraContent
            if (tabDefinitions != null && tabDefinitions.Count > 0)
            {
                tabDefinitions[0].ExtraContent = CreateDocumentFileTableContent();
            }
        }
        catch (Exception)
        {
            _ = NotificationService.ShowErrorAsync("初始化表單欄位時發生錯誤");
        }
    }

    // ===== Tab 動態重建 =====

    private void RebuildTabDefinitions()
    {
        if (tabDefinitions == null)
            return;

        // 移除先前加入的來源資訊 Tab（避免重複）
        tabDefinitions.RemoveAll(t => t.DebugComponentName == nameof(SourceEntityInfoTab));

        // 有來源實體時，加入來源資訊 Tab
        if (!string.IsNullOrEmpty(_relatedEntityType) && _relatedEntityId.HasValue)
        {
            tabDefinitions.Add(new FormTabDefinition
            {
                Label = L["Document.SourceEntity"].ToString(),
                Icon = "bi-link-45deg",
                SectionNames = new List<string>(),
                CustomContent = CreateSourceEntityInfoTabContent(),
                DebugComponentName = nameof(SourceEntityInfoTab)
            });
        }
    }

    // ===== Tab RenderFragments =====

    private RenderFragment CreateDocumentFileTableContent() => __builder =>
    {
        <div class="col-12 mt-3">
            <DocumentFileTable Items="@fileViewModels"
                               FileError="@fileError"
                               MaxFileSizeMB="@_maxDocumentFileSizeMB"
                               OnFilesSelected="@HandleFilesSelected"
                               OnRemoveFile="@RemoveFile" />
        </div>
    };

    private RenderFragment CreateSourceEntityInfoTabContent() => __builder =>
    {
        <SourceEntityInfoTab @ref="sourceEntityInfoTab"
                             RelatedEntityType="@_relatedEntityType"
                             RelatedEntityId="@_relatedEntityId" />
    };

    public Task ShowAddModal() => editModalComponent!.ShowAddModal();
    public Task ShowEditModal(int id) => editModalComponent!.ShowEditModal(id);
}
