@* 文件 Tab - 顯示與特定實體關聯的文件清單 *@
@inject IDocumentService DocumentService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<div class="d-flex justify-content-between align-items-center mb-2 px-1">
    <div class="d-flex gap-2">
        <GenericButtonComponent IconClass=
                                Variant="ButtonVariant.DarkBlue"
                                Text="@L["Button.AddDocument"]"
                                OnClick="@HandleAdd"
                                IsDisabled="@(!EntityId.HasValue)" />
    </div>
</div>

<GenericInteractiveTableComponent TItem="Document"
                                  Items="@documents"
                                  ColumnDefinitions="@GetColumnDefinitions()"
                                  ShowHeader="true"
                                  ShowRowNumbers="true"
                                  IsStriped="true"
                                  IsHoverable="true"
                                  IsBordered="true"
                                  IsReadOnly="true"
                                  ShowBuiltInActions="true"
                                  ShowBuiltInDeleteButton="false"
                                  EnableAutoEmptyRow="false"
                                  EmptyMessage="@L["Message.NoDocuments"]"
                                  CustomActionsTemplate="@GetActionsTemplate()"
                                  ActionsColumnWidth="80px" />

@* 文件編輯 Modal *@
<DocumentEditModalComponent @ref="editModal"
                            IsVisible="@isModalVisible"
                            IsVisibleChanged="@((bool v) => isModalVisible = v)"
                            DocumentId="@editingId"
                            PrefilledValues="@prefilledValues"
                            OnDocumentSaved="@HandleSaved"
                            OnCancel="@(() => isModalVisible = false)" />

@code {
    [Parameter] public string RelatedEntityType { get; set; } = string.Empty;
    [Parameter] public int? EntityId { get; set; }

    private List<Document> documents = new();
    private DocumentEditModalComponent? editModal;
    private bool isModalVisible = false;
    private int? editingId = null;
    private Dictionary<string, object?>? prefilledValues;
    private int? _lastLoadedEntityId;

    // ===== 生命週期 =====

    protected override async Task OnParametersSetAsync()
    {
        if (EntityId.HasValue && EntityId != _lastLoadedEntityId)
        {
            _lastLoadedEntityId = EntityId;
            await LoadAsync(EntityId.Value);
        }
        else if (!EntityId.HasValue && _lastLoadedEntityId.HasValue)
        {
            _lastLoadedEntityId = null;
            Clear();
        }
    }

    // ===== 欄位定義 =====

    private List<InteractiveColumnDefinition> GetColumnDefinitions()
    {
        return new List<InteractiveColumnDefinition>
        {
            new()
            {
                Title = L["Field.DocumentTitle"],
                PropertyName = nameof(Document.Title),
                ColumnType = InteractiveColumnType.Display
            },
            new()
            {
                Title = L["Field.DocumentCategory"],
                PropertyName = nameof(Document.DocumentCategoryId),
                ColumnType = InteractiveColumnType.Display,
                DisplayFormatter = item =>
                {
                    if (item is Document doc)
                        return doc.DocumentCategory?.Name ?? "-";
                    return "-";
                }
            },
            new()
            {
                Title = L["Field.ExpiryDate"],
                PropertyName = nameof(Document.ExpiryDate),
                ColumnType = InteractiveColumnType.Display,
                Width = "120px",
                DisplayFormatter = item =>
                {
                    if (item is Document doc && doc.ExpiryDate.HasValue)
                    {
                        var date = doc.ExpiryDate.Value;
                        var isExpired = date < DateTime.Today;
                        var isExpiringSoon = !isExpired && date <= DateTime.Today.AddDays(30);
                        var cssClass = isExpired ? "text-danger" : isExpiringSoon ? "text-warning" : "";
                        return $"<span class=\"{cssClass}\">{date:yyyy/MM/dd}</span>";
                    }
                    return "-";
                }
            },
            new()
            {
                Title = L["Field.AttachmentCount"],
                PropertyName = "",
                ColumnType = InteractiveColumnType.Display,
                Width = "100px",
                DisplayFormatter = item =>
                {
                    if (item is Document doc)
                        return doc.DocumentFiles.Count.ToString();
                    return "0";
                }
            }
        };
    }

    private RenderFragment<Document> GetActionsTemplate()
    {
        return doc => __builder =>
        {
            <GenericButtonComponent IconClass="bi bi-pencil"
                                   Variant="ButtonVariant.OutlineDarkBlue"
                                   Title="@L["Button.Edit"]"
                                   OnClick="@(() => HandleEdit(doc.Id))"
                                   CssClass="btn-square" />
        };
    }

    // ===== 資料載入 =====

    public async Task LoadAsync(int entityId)
    {
        documents = await DocumentService.GetByRelatedEntityAsync(RelatedEntityType, entityId);
        StateHasChanged();
    }

    public void Clear()
    {
        documents = new();
        StateHasChanged();
    }

    private void HandleAdd()
    {
        editingId = null;
        prefilledValues = new Dictionary<string, object?>
        {
            { nameof(Document.RelatedEntityType), RelatedEntityType },
            { nameof(Document.RelatedEntityId), EntityId }
        };
        isModalVisible = true;
        StateHasChanged();
    }

    private void HandleEdit(int id)
    {
        editingId = id;
        prefilledValues = null;
        isModalVisible = true;
        StateHasChanged();
    }

    private async Task HandleSaved(Document saved)
    {
        isModalVisible = false;
        if (EntityId.HasValue)
            await LoadAsync(EntityId.Value);
    }

}
