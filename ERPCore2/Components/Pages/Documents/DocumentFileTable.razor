@* 文件附件檔案管理表格 — 用於 DocumentEditModalComponent 的附件區段 *@
@inject IStringLocalizer<SharedResource> L

<div>
    <div class="fw-semibold mb-2">
        @L["Document.AttachmentFiles"]
        <span class="text-danger ms-1">*</span>
    </div>

    <InputFile OnChange="@OnFilesSelected"
               accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png"
               multiple
               class="form-control" />
    <div class="form-text mb-2">@L["Document.SupportedFormats"]</div>

    @if (!string.IsNullOrEmpty(FileError))
    {
        <div class="text-danger small mb-2">@FileError</div>
    }

    <InteractiveTableComponent TItem="DocumentFileViewModel"
                              Items="@Items"
                              ColumnDefinitions="@GetFileColumnDefinitions()"
                              ShowRowNumbers="true"
                              IsReadOnly="false"
                              ShowActions="true"
                              ActionsTemplate="@GetFileActionsTemplate"
                              ActionsColumnWidth="100px"
                              EmptyMessage="@L["Document.NoAttachments"]"
                              IsStriped="false"
                              GetRowCssClass="@((item, idx) => item.IsDeleted ? "table-danger text-muted" : "")"
                              EnableAutoEmptyRow="false" />
</div>

@code {
    [Parameter] public List<DocumentFileViewModel> Items { get; set; } = new();
    [Parameter] public string? FileError { get; set; }
    [Parameter] public EventCallback<InputFileChangeEventArgs> OnFilesSelected { get; set; }
    [Parameter] public EventCallback<DocumentFileViewModel> OnRemoveFile { get; set; }

    private List<InteractiveColumnDefinition> GetFileColumnDefinitions() => new()
    {
        new()
        {
            PropertyName = nameof(DocumentFileViewModel.DisplayName),
            Title = L["Field.FileDisplayName"],
            ColumnType = InteractiveColumnType.Input,
            Placeholder = L["Field.FileDisplayName"],
            Width = "200px",
            IsReadOnly = false
        },
        new()
        {
            PropertyName = nameof(DocumentFileViewModel.FileName),
            Title = L["Field.FileName"],
            ColumnType = InteractiveColumnType.Display,
            Width = "200px"
        },
        new()
        {
            PropertyName = nameof(DocumentFileViewModel.FileSize),
            Title = L["Field.FileSize"],
            ColumnType = InteractiveColumnType.Display,
            DisplayFormatter = obj =>
            {
                var vm = obj as DocumentFileViewModel;
                if (vm == null) return "-";
                var size = FileUploadHelper.GetFileSizeString(vm.FileSize);
                return vm.IsPending ? $"{size} ({L["Label.PendingUpload"]})" : size;
            },
            Width = "100px",
            TextAlign = "right"
        }
    };

    private RenderFragment<DocumentFileViewModel> GetFileActionsTemplate => item => __builder =>
    {
        if (!item.IsDeleted)
        {
            if (!item.IsPending && !string.IsNullOrEmpty(item.FilePath))
            {
                <a href="@item.FilePath" download="@item.FileName"
                   class="btn btn-sm btn-outline-secondary me-1"
                   title="@L["Button.Download"]">
                    <i class="bi bi-download"></i>
                </a>
            }
            <button type="button" class="btn btn-sm btn-outline-danger"
                    title="@L["Button.Delete"]"
                    @onclick="() => OnRemoveFile.InvokeAsync(item)">
                <i class="bi bi-trash"></i>
            </button>
        }
    };
}
