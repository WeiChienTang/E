@page "/vehicle-maintenances"
@inject IVehicleMaintenanceService VehicleMaintenanceService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="VehicleMaintenance" 
                          TService="IVehicleMaintenanceService"
                          Service="@VehicleMaintenanceService"
                          EntityBasePath="/vehicle-maintenances"
                          PageTitle="@L["Page.VehicleMaintenanceTitle"]"
                          PageSubtitle="@L["Page.VehicleMaintenanceSubtitle"]"
                          EntityName="@L["Entity.VehicleMaintenance"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadMaintenancesAsync"
                          GetEntityDisplayName="@(vm => $"{vm.Vehicle?.LicensePlate} - {vm.MaintenanceDate:yyyy/MM/dd}")"
                          RequiredPermission="@PermissionRegistry.VehicleMaintenance.Read"
                          RequiredModule="Vehicles"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          ShowDraftTab="true"
                          DebugPageName="VehicleMaintenanceIndex"
                          @ref="indexComponent" />

<VehicleMaintenanceEditModalComponent IsVisible="@showEditModal"
                                      IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                      VehicleMaintenanceId="@editingMaintenanceId"
                                      OnVehicleMaintenanceSaved="@modalHandler.OnEntitySavedAsync"
                                      OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    private GenericIndexPageComponent<VehicleMaintenance, IVehicleMaintenanceService> indexComponent = default!;

    private bool showEditModal = false;
    private int? editingMaintenanceId = null;

    private ModalHandler<VehicleMaintenance, GenericIndexPageComponent<VehicleMaintenance, IVehicleMaintenanceService>> modalHandler = default!;

    private VehicleMaintenanceFieldConfiguration fieldConfiguration = default!;

    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<VehicleMaintenance, GenericIndexPageComponent<VehicleMaintenance, IVehicleMaintenanceService>>(
                id => editingMaintenanceId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new VehicleMaintenanceFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化保養紀錄頁面失敗");
            await NotificationService.ShowErrorAsync("初始化保養紀錄頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("車輛管理", "保養紀錄維護", "#", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<VehicleMaintenance> Items, int TotalCount)> ServerLoadMaintenancesAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return VehicleMaintenanceService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(vm => vm.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadMaintenancesAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
