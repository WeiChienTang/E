@page "/vehicles"
@inject IVehicleService VehicleService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="Vehicle" 
                          TService="IVehicleService"
                          Service="@VehicleService"
                          EntityBasePath="/vehicles"
                          PageTitle="@L["Page.VehicleTitle"]"
                          PageSubtitle="@L["Page.VehicleSubtitle"]"
                          EntityName="@L["Entity.Vehicle"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadVehiclesAsync"
                          GetEntityDisplayName="@(v => $"{v.LicensePlate} - {v.VehicleName}")"
                          RequiredPermission="@PermissionRegistry.Vehicle.Read"
                          RequiredModule="Vehicles"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          ShowDraftTab="true"
                          DebugPageName="VehicleIndex"
                          @ref="indexComponent" />

<VehicleEditModalComponent IsVisible="@showEditModal"
                           IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                           VehicleId="@editingVehicleId"
                           OnVehicleSaved="@modalHandler.OnEntitySavedAsync"
                           OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    private GenericIndexPageComponent<Vehicle, IVehicleService> indexComponent = default!;

    private bool showEditModal = false;
    private int? editingVehicleId = null;

    private ModalHandler<Vehicle, GenericIndexPageComponent<Vehicle, IVehicleService>> modalHandler = default!;

    private VehicleFieldConfiguration fieldConfiguration = default!;

    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<Vehicle, GenericIndexPageComponent<Vehicle, IVehicleService>>(
                id => editingVehicleId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new VehicleFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化車輛頁面失敗");
            await NotificationService.ShowErrorAsync("初始化車輛頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("車輛管理", "車輛維護", "#", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<Vehicle> Items, int TotalCount)> ServerLoadVehiclesAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return VehicleService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(v => v.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadVehiclesAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
