@page "/vehicle-types"
@inject IVehicleTypeService VehicleTypeService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="VehicleType" 
                          TService="IVehicleTypeService"
                          Service="@VehicleTypeService"
                          EntityBasePath="/vehicle-types"
                          PageTitle="@L["Page.VehicleTypeTitle"]"
                          PageSubtitle="@L["Page.VehicleTypeSubtitle"]"
                          EntityName="@L["Entity.VehicleType"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadVehicleTypesAsync"
                          GetEntityDisplayName="@(vt => vt.Name)"
                          RequiredPermission="@PermissionRegistry.VehicleType.Read"
                          RequiredModule="Vehicles"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          ShowDraftTab="true"
                          DebugPageName="VehicleTypeIndex"
                          @ref="indexComponent" />

<VehicleTypeEditModalComponent IsVisible="@showEditModal"
                               IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                               VehicleTypeId="@editingVehicleTypeId"
                               OnVehicleTypeSaved="@modalHandler.OnEntitySavedAsync"
                               OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    private GenericIndexPageComponent<VehicleType, IVehicleTypeService> indexComponent = default!;

    private bool showEditModal = false;
    private int? editingVehicleTypeId = null;

    private ModalHandler<VehicleType, GenericIndexPageComponent<VehicleType, IVehicleTypeService>> modalHandler = default!;

    private VehicleTypeFieldConfiguration fieldConfiguration = default!;

    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<VehicleType, GenericIndexPageComponent<VehicleType, IVehicleTypeService>>(
                id => editingVehicleTypeId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new VehicleTypeFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化車型頁面失敗");
            await NotificationService.ShowErrorAsync("初始化車型頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("車輛管理", "車型維護", "#", NotificationService, GetType());

    private Task<(List<VehicleType> Items, int TotalCount)> ServerLoadVehicleTypesAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return VehicleTypeService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(x => x.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadVehicleTypesAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
