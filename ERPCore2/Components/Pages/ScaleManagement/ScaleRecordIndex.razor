@page "/scale-records"
@inject IScaleRecordService ScaleRecordService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@inject IScaleRecordReportService ScaleRecordReportService
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="ScaleRecord"
                          TService="IScaleRecordService"
                          Service="@ScaleRecordService"
                          EntityBasePath="/scale-records"
                          PageTitle="@L["Page.WasteRecordTitle"]"
                          PageSubtitle="@L["Page.WasteRecordSubtitle"]"
                          EntityName="@L["Entity.WasteRecord"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadScaleRecordsAsync"
                          GetEntityDisplayName="@(sr => sr.Code ?? $"磅秤紀錄#{sr.Id}")"
                          RequiredPermission="@PermissionRegistry.ScaleRecord.Read"
                          RequiredModule="ScaleManagement"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          ShowDraftTab="true"
                          DebugPageName="ScaleRecordIndex"
                          RowPrintService="@ScaleRecordReportService"
                          RowPrintReportId="@ReportIds.ScaleRecord"
                          @ref="indexComponent" />

<ScaleRecordEditModalComponent IsVisible="@showEditModal"
                               IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                               ScaleRecordId="@editingScaleRecordId"
                               OnScaleRecordSaved="@modalHandler.OnEntitySavedAsync"
                               OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    private GenericIndexPageComponent<ScaleRecord, IScaleRecordService> indexComponent = default!;

    private bool showEditModal = false;
    private int? editingScaleRecordId = null;

    private ModalHandler<ScaleRecord, GenericIndexPageComponent<ScaleRecord, IScaleRecordService>> modalHandler = default!;

    private ScaleRecordFieldConfiguration fieldConfiguration = default!;

    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<ScaleRecord, GenericIndexPageComponent<ScaleRecord, IScaleRecordService>>(
                id => editingScaleRecordId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new ScaleRecordFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化磅秤紀錄頁面失敗");
            await NotificationService.ShowErrorAsync("初始化磅秤紀錄頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() =>
        breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("磅秤管理", "磅秤紀錄", "#", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<ScaleRecord> Items, int TotalCount)> ServerLoadScaleRecordsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return ScaleRecordService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(sr => sr.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadScaleRecordsAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
