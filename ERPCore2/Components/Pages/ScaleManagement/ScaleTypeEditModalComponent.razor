@* 可重用的磅秤類型編輯組件 - 可在任何頁面中嵌入 *@
@inject IScaleTypeService ScaleTypeService
@inject IItemService ItemService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@using ERPCore2.Models.FeatureGuides.GuideDefinitions

<GenericEditModalComponent TEntity="ScaleType"
                          TService="IScaleTypeService"
                          @ref="editModalComponent"
                          IsVisible="@IsVisible"
                          IsVisibleChanged="@IsVisibleChanged"
                          @bind-Id="@ScaleTypeId"
                          Service="@ScaleTypeService"
                          EntityName="@L["Entity.WasteType"]"
                          EntityNamePlural="@L["Entity.WasteType"]"
                          ModalTitle="@(ScaleTypeId.HasValue ? L["Message.EditTitle", L["Entity.WasteType"]].ToString() : L["Message.CreateTitle", L["Entity.WasteType"]].ToString())"
                          Size="GenericEditModalComponent<ScaleType, IScaleTypeService>.ModalSize.Desktop"
                          UseGenericForm="true"
                          FormFields="@formFields"
                          FormSections="@formSections"
                          AutoCompletePrefillers="@autoCompleteConfig?.Prefillers"
                          AutoCompleteCollections="@autoCompleteConfig?.Collections"
                          AutoCompleteDisplayProperties="@autoCompleteConfig?.DisplayProperties"
                          AutoCompleteValueProperties="@autoCompleteConfig?.ValueProperties"
                          DataLoader="@LoadScaleTypeData"
                          UseGenericSave="true"
                          ShowDraftButton="true"
                          DraftSuccessMessage="@L["Message.DraftSuccess", L["Entity.WasteType"]]"
                          SaveSuccessMessage="@(ScaleTypeId.HasValue ? L["Message.UpdateSuccess", L["Entity.WasteType"]].ToString() : L["Message.CreateSuccess", L["Entity.WasteType"]].ToString())"
                          SaveFailureMessage="@L["Message.SaveFailure", L["Entity.WasteType"]]"
                          RequiredPermission="@PermissionRegistry.ScaleRecord.Read"
                          OnEntitySaved="@OnScaleTypeSaved"
                          OnCancel="@OnCancel"
                          ComponentName="ScaleTypeEditModalComponent"
                          FeatureGuide="@ScaleTypeGuide.Create()" />

@code {
    [Parameter] public bool IsVisible { get; set; } = false;
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? ScaleTypeId { get; set; }
    [Parameter] public EventCallback<ScaleType> OnScaleTypeSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public Dictionary<string, object?>? PrefilledValues { get; set; }

    private GenericEditModalComponent<ScaleType, IScaleTypeService>? editModalComponent;
    private List<FormFieldDefinition> formFields = new();
    private Dictionary<string, string> formSections = new();

    private AutoCompleteConfig? autoCompleteConfig;
    private List<Item> availableItems = new();

    private bool isDataLoaded = false;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !isDataLoaded)
        {
            await LoadAdditionalDataAsync();
            InitializeFormFields();
            isDataLoaded = true;
        }
        else if (!IsVisible)
        {
            isDataLoaded = false;
        }
    }

    private async Task LoadAdditionalDataAsync()
    {
        try
        {
            availableItems = await ItemService.GetAllAsync();

            autoCompleteConfig = new AutoCompleteConfigBuilder<ScaleType>()
                .AddField(nameof(ScaleType.ItemId), "Name", availableItems)
                .Build();
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync("載入磅秤類型編輯相關資料時發生錯誤");
            availableItems = new List<Item>();
        }
    }

    private Task<ScaleType?> LoadScaleTypeData()
        => EditDataLoaderHelper.LoadOrCreateAsync<ScaleType, IScaleTypeService>(
            ScaleTypeId, ScaleTypeService, NotificationService, "磅秤類型", "WT", PrefilledValues,
            st => st.Name = string.Empty);

    private void InitializeFormFields()
    {
        formFields = new List<FormFieldDefinition>
        {
            new()
            {
                PropertyName = nameof(ScaleType.Code),
                Label = L["Field.WasteTypeCode"],
                FieldType = FormFieldType.Text,
                Placeholder = L["Placeholder.PleaseInput", L["Field.WasteTypeCode"]],
                IsRequired = true,
                MaxLength = 50,
                HelpText = "唯一識別此磅秤類型的編號，最多50個字元"
            },
            new()
            {
                PropertyName = nameof(ScaleType.Name),
                Label = L["Field.WasteTypeName"],
                FieldType = FormFieldType.Text,
                Placeholder = L["Placeholder.PleaseInput", L["Field.WasteTypeName"]],
                IsRequired = true,
                MaxLength = 100,
                HelpText = "磅秤類型的顯示名稱，最多100個字元"
            },
            new()
            {
                PropertyName = nameof(ScaleType.ItemId),
                Label = L["Field.RelatedItem"],
                FieldType = FormFieldType.AutoComplete,
                Placeholder = L["Placeholder.PleaseInputOrSelect", L["Field.RelatedItem"]],
                IsRequired = false,
                MinSearchLength = 0,
                HelpText = "選填。選擇後，儲存磅秤紀錄時會自動將磅秤數量入庫至此品項"
            },
            new()
            {
                PropertyName = nameof(ScaleType.Description),
                Label = L["Field.Description"],
                FieldType = FormFieldType.TextArea,
                Placeholder = L["Placeholder.PleaseInput", L["Field.Description"]],
                IsRequired = false,
                MaxLength = 200,
                HelpText = "磅秤類型的詳細說明，最多200個字元"
            },

            FormFieldConfigurationHelper.CreateRemarksField<ScaleType>()
        };

        formSections = FormSectionHelper<ScaleType>.Create()
            .AddToSection(FormSectionNames.BasicInfo,
                st => st.Code,
                st => st.Name,
                st => st.Unit,
                st => st.ItemId)
            .AddToSection(FormSectionNames.AdditionalInfo,
                st => st.Description,
                st => st.Remarks)
            .Build();
    }
}
