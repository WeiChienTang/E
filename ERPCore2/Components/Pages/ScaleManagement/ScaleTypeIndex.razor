@page "/scale-types"
@inject IScaleTypeService ScaleTypeService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="ScaleType"
                          TService="IScaleTypeService"
                          Service="@ScaleTypeService"
                          EntityBasePath="/scale-types"
                          PageTitle="@L["Page.WasteTypeTitle"]"
                          PageSubtitle="@L["Page.WasteTypeSubtitle"]"
                          EntityName="@L["Entity.WasteType"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadScaleTypesAsync"
                          GetEntityDisplayName="@(st => st.Name)"
                          RequiredPermission="@PermissionRegistry.ScaleRecord.Read"
                          RequiredModule="ScaleManagement"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          ShowDraftTab="true"
                          DebugPageName="ScaleTypeIndex"
                          @ref="indexComponent" />

<ScaleTypeEditModalComponent IsVisible="@showEditModal"
                             IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                             ScaleTypeId="@editingScaleTypeId"
                             OnScaleTypeSaved="@modalHandler.OnEntitySavedAsync"
                             OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    private GenericIndexPageComponent<ScaleType, IScaleTypeService> indexComponent = default!;

    private bool showEditModal = false;
    private int? editingScaleTypeId = null;

    private ModalHandler<ScaleType, GenericIndexPageComponent<ScaleType, IScaleTypeService>> modalHandler = default!;

    private ScaleTypeFieldConfiguration fieldConfiguration = default!;

    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<ScaleType, GenericIndexPageComponent<ScaleType, IScaleTypeService>>(
                id => editingScaleTypeId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new ScaleTypeFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化磅秤類型頁面失敗");
            await NotificationService.ShowErrorAsync("初始化磅秤類型頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() =>
        breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("磅秤管理", "磅秤類型維護", "#", NotificationService, GetType());

    private Task<(List<ScaleType> Items, int TotalCount)> ServerLoadScaleTypesAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return ScaleTypeService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(x => x.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadScaleTypesAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
