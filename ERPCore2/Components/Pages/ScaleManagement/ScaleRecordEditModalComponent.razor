@* 可重用的磅秤紀錄編輯組件 *@
@using ERPCore2.Models.Reports
@using ERPCore2.Services.Reports
@using ERPCore2.Services.Reports.Interfaces
@inject IScaleRecordService ScaleRecordService
@inject IScaleRecordReportService ScaleRecordReportService
@inject IScaleTypeService ScaleTypeService
@inject IVehicleService VehicleService
@inject ICustomerService CustomerService
@inject IWarehouseService WarehouseService
@inject IWarehouseLocationService WarehouseLocationService
@inject INotificationService NotificationService
@inject ActionButtonHelper ActionButtonHelper
@inject IStringLocalizer<SharedResource> L
@inject ISerialPortService SerialPortService
@implements IDisposable

<GenericEditModalComponent TEntity="ScaleRecord"
                          TService="IScaleRecordService"
                          @ref="editModalComponent"
                          IsVisible="@IsVisible"
                          IsVisibleChanged="@IsVisibleChanged"
                          @bind-Id="@ScaleRecordId"
                          Service="@ScaleRecordService"
                          EntityName="@L["Entity.WasteRecord"]"
                          EntityNamePlural="@L["Entity.WasteRecord"]"
                          ModalTitle="@(ScaleRecordId.HasValue ? L["Message.EditTitle", L["Entity.WasteRecord"]].ToString() : L["Message.CreateTitle", L["Entity.WasteRecord"]].ToString())"
                          Size="GenericEditModalComponent<ScaleRecord, IScaleRecordService>.ModalSize.Desktop"
                          UseGenericForm="true"
                          FormFields="@formFields"
                          FormSections="@formSections"
                          AutoCompletePrefillers="@autoCompleteConfig?.Prefillers"
                          AutoCompleteCollections="@autoCompleteConfig?.Collections"
                          AutoCompleteDisplayProperties="@autoCompleteConfig?.DisplayProperties"
                          AutoCompleteValueProperties="@autoCompleteConfig?.ValueProperties"
                          ModalManagers="@modalManagers?.AsDictionary()"
                          DataLoader="@LoadScaleRecordData"
                          UseGenericSave="true"
                          ShowDraftButton="true"
                          DraftSuccessMessage="@L["Message.DraftSuccess", L["Entity.WasteRecord"]]"
                          SaveSuccessMessage="@(ScaleRecordId.HasValue ? L["Message.UpdateSuccess", L["Entity.WasteRecord"]].ToString() : L["Message.CreateSuccess", L["Entity.WasteRecord"]].ToString())"
                          SaveFailureMessage="@L["Message.SaveFailure", L["Entity.WasteRecord"]]"
                          ShowPrintButton="true"
                          PrintButtonText="@L["Button.Print"]"
                          ReportService="@ScaleRecordReportService"
                          ReportId="@ReportIds.ScaleRecord"
                          ReportPreviewTitle="@L["Label.DocumentPreview", L["Entity.WasteRecord"]]"
                          GetReportDocumentName="@(e => $"磅秤紀錄-{e.Code}")"
                          RequiredPermission="@PermissionRegistry.ScaleRecord.Read"
                          OnEntitySaved="@HandleScaleRecordSavedAsync"
                          OnCancel="@OnCancel"
                          OnEntityLoaded="@HandleEntityLoaded"
                          OnFieldChanged="@HandleFieldChangedAsync"
                          ComponentName="ScaleRecordEditModalComponent">
    <CustomActionButtons>
        <GenericButtonComponent Text="參數設定"
                              Variant="ButtonVariant.Purple"
                              IconClass="bi-gear"
                              OnClick="@(() => _showSerialPortSettings = true)"
                              Title="RS-232C 串列埠參數設定" />
        <GenericButtonComponent Text="@(_isReading ? "停止讀取" : "讀取")"
                              Variant="@(_isReading ? ButtonVariant.Red : ButtonVariant.Green)"
                              IconClass="@(_isReading ? "bi-stop-circle" : "bi-broadcast")"
                              OnClick="HandleToggleReading"
                              IsDisabled="@(!SerialPortService.IsOpen && !_isReading)"
                              Title="@(!SerialPortService.IsOpen ? "請先在參數設定中連線串列埠" : (_isReading ? "停止讀取磅秤數據" : "開始讀取磅秤數據"))" />
        @if (_isReading)
        {
            <span class="badge bg-warning text-dark ms-1 d-flex align-items-center">
                <span class="spinner-grow spinner-grow-sm me-1"></span>
                讀取中... @(_lastStableWeight.HasValue ? $"穩定值: {_lastStableWeight.Value} kg" : "等待穩定...")
            </span>
        }
    </CustomActionButtons>
</GenericEditModalComponent>

@* 磅秤類型編輯 Modal *@
<ScaleTypeEditModalComponent @ref="scaleTypeEditModal"
                             IsVisible="@scaleTypeModalManager.IsModalVisible"
                             IsVisibleChanged="@scaleTypeModalManager.HandleModalVisibilityChangedAsync"
                             ScaleTypeId="@scaleTypeModalManager.SelectedEntityId"
                             OnScaleTypeSaved="@scaleTypeModalManager.OnSavedAsync"
                             OnCancel="@scaleTypeModalManager.HandleModalCancelAsync" />

@* 串列埠參數設定 Modal *@
<ScaleSerialPortSettingsModalComponent IsVisible="@_showSerialPortSettings"
                                       IsVisibleChanged="@(v => _showSerialPortSettings = v)" />

@* 客戶編輯 Modal *@
<CustomerEditModalComponent @ref="customerEditModal"
                           IsVisible="@customerModalManager.IsModalVisible"
                           IsVisibleChanged="@customerModalManager.HandleModalVisibilityChangedAsync"
                           CustomerId="@customerModalManager.SelectedEntityId"
                           OnCustomerSaved="@customerModalManager.OnSavedAsync"
                           OnCancel="@customerModalManager.HandleModalCancelAsync" />

@code {
    // ===== 必要參數 =====
    [Parameter] public bool IsVisible { get; set; } = false;
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? ScaleRecordId { get; set; }
    [Parameter] public EventCallback<ScaleRecord> OnScaleRecordSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public Dictionary<string, object?>? PrefilledValues { get; set; }

    // ===== 內部狀態 =====
    private GenericEditModalComponent<ScaleRecord, IScaleRecordService>? editModalComponent;
    private List<FormFieldDefinition> formFields = new();
    private Dictionary<string, string> formSections = new();

    // AutoComplete 配置
    private AutoCompleteConfig? autoCompleteConfig;

    // 選項資料
    private List<ScaleType> availableScaleTypes = new();
    private List<Vehicle> availableVehicles = new();
    private List<Customer> availableCustomers = new();
    private List<Warehouse> availableWarehouses = new();
    private List<WarehouseLocation> availableWarehouseLocations = new();
    private List<WarehouseLocation> filteredWarehouseLocations = new();

    // Modal Manager 集合
    private ModalManagerCollection? modalManagers;

    // 磅秤類型編輯 Modal
    private ScaleTypeEditModalComponent? scaleTypeEditModal;
    private RelatedEntityModalManager<ScaleType> scaleTypeModalManager = default!;

    // 客戶編輯 Modal
    private CustomerEditModalComponent? customerEditModal;
    private RelatedEntityModalManager<Customer> customerModalManager = default!;

    // 資料載入狀態標記
    private bool isDataLoaded = false;

    // 追蹤是否為新增（儲存後判斷要呼叫 Confirm 還是 UpdateByDifference）
    private bool _isNewRecord = false;

    // ===== 串列埠讀取狀態 =====
    private bool _showSerialPortSettings = false;
    private bool _isReading = false;
    private decimal? _lastStableWeight = null;

    private async Task HandleEntityLoaded(int loadedEntityId)
    {
        try
        {
            // 編輯模式載入後，依載入記錄的 WarehouseId 篩選庫位
            var warehouseId = editModalComponent?.Entity?.WarehouseId ?? 0;
            filteredWarehouseLocations = warehouseId > 0
                ? availableWarehouseLocations.Where(wl => wl.WarehouseId == warehouseId).ToList()
                : new List<WarehouseLocation>();
            RebuildAutoCompleteConfig();
            await InitializeFormFieldsAsync();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入資料時發生錯誤：{ex.Message}");
        }
    }

    private async Task HandleFieldChangedAsync((string PropertyName, object? Value) fieldChange)
    {
        if (editModalComponent?.Entity == null) return;

        if (fieldChange.PropertyName == nameof(ScaleRecord.VehicleId))
            await HandleVehicleChangedAsync();
        else if (fieldChange.PropertyName == nameof(ScaleRecord.CustomerId))
            await HandleCustomerChangedAsync();
        else if (fieldChange.PropertyName == nameof(ScaleRecord.WarehouseId))
            await HandleWarehouseChangedAsync();
    }

    // 選擇車輛 → 自動帶入所屬客戶
    private async Task HandleVehicleChangedAsync()
    {
        var vehicleId = editModalComponent!.Entity.VehicleId;
        if (vehicleId <= 0) return;

        var vehicle = availableVehicles.FirstOrDefault(v => v.Id == vehicleId);
        if (vehicle?.CustomerId == null) return;

        var customer = availableCustomers.FirstOrDefault(c => c.Id == vehicle.CustomerId.Value);
        if (customer == null) return;

        await editModalComponent.SetAutoCompleteFieldValueAsync(
            nameof(ScaleRecord.CustomerId),
            vehicle.CustomerId.Value.ToString(),
            customer.CompanyName ?? "");
    }

    // 選擇客戶 → 若該客戶只有一台車則自動帶入，多台車不帶入（使用者自選）
    private async Task HandleCustomerChangedAsync()
    {
        var customerId = editModalComponent!.Entity.CustomerId;
        if (customerId == null || customerId <= 0) return;

        var customerVehicles = availableVehicles
            .Where(v => v.CustomerId == customerId)
            .ToList();

        if (customerVehicles.Count != 1) return;

        var vehicle = customerVehicles[0];
        await editModalComponent.SetAutoCompleteFieldValueAsync(
            nameof(ScaleRecord.VehicleId),
            vehicle.Id.ToString(),
            vehicle.LicensePlate);
    }

    // 選擇倉庫 → 篩選庫位下拉、清空已選庫位、更新欄位狀態
    private async Task HandleWarehouseChangedAsync()
    {
        var warehouseId = editModalComponent!.Entity.WarehouseId;

        filteredWarehouseLocations = warehouseId > 0
            ? availableWarehouseLocations.Where(wl => wl.WarehouseId == warehouseId).ToList()
            : new List<WarehouseLocation>();

        // 清空已選庫位（傳入空字串讓 ConvertValue 正確轉為 null，避免設成 0 違反 FK 約束）
        await editModalComponent.SetAutoCompleteFieldValueAsync(
            nameof(ScaleRecord.WarehouseLocationId), "", "");

        // 重建 AutoComplete（更新庫位清單）與表單欄位（更新 IsReadOnly 狀態）
        RebuildAutoCompleteConfig();
        await InitializeFormFieldsAsync();
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalManagers = ModalManagerInitHelper.CreateBuilder<ScaleRecord, IScaleRecordService>(
                    () => editModalComponent,
                    NotificationService,
                    StateHasChanged,
                    LoadAdditionalDataAsync,
                    InitializeFormFieldsAsync)
                .AddManager<ScaleType>(nameof(ScaleRecord.ScaleTypeId), "磅秤類型")
                .AddManager<Customer>(nameof(ScaleRecord.CustomerId), "客戶")
                .Build();

            scaleTypeModalManager = modalManagers.Get<ScaleType>(nameof(ScaleRecord.ScaleTypeId));
            customerModalManager = modalManagers.Get<Customer>(nameof(ScaleRecord.CustomerId));
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync("初始化磅秤紀錄編輯組件時發生錯誤");
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !isDataLoaded)
        {
            // 在資料載入前記錄是否為新增
            _isNewRecord = !ScaleRecordId.HasValue;

            await LoadAdditionalDataAsync();
            await InitializeFormFieldsAsync();
            isDataLoaded = true;
        }
        else if (!IsVisible)
        {
            isDataLoaded = false;
        }
    }

    private async Task<ScaleRecord?> LoadScaleRecordData()
    {
        try
        {
            if (!ScaleRecordId.HasValue)
            {
                var newRecord = new ScaleRecord
                {
                    Code = await EntityCodeGenerationHelper.GenerateForEntity<ScaleRecord, IScaleRecordService>(ScaleRecordService, "WR"),
                    RecordDate = DateTime.Today,
                    Status = EntityStatus.Active
                };

                PrefilledValueHelper.ApplyPrefilledValues(newRecord, PrefilledValues);

                return newRecord;
            }

            return await ScaleRecordService.GetByIdAsync(ScaleRecordId.Value);
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入磅秤紀錄資料時發生錯誤：{ex.Message}");
            return null;
        }
    }

    private async Task InitializeFormFieldsAsync()
    {
        try
        {
            var currentWarehouseId = editModalComponent?.Entity?.WarehouseId ?? 0;
            var locationIsReadOnly = currentWarehouseId <= 0;

            formFields = new List<FormFieldDefinition>
            {
                new()
                {
                    PropertyName = nameof(ScaleRecord.Code),
                    Label = L["Field.WasteRecordCode"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.AutoGenerated"],
                    IsRequired = false,
                    MaxLength = 50,
                    HelpText = "磅秤紀錄的唯一識別單號，新增時系統自動產生"
                },
                new()
                {
                    PropertyName = nameof(ScaleRecord.RecordDate),
                    Label = L["Field.RecordDate"],
                    FieldType = FormFieldType.Date,
                    IsRequired = true,
                    HelpText = "磅秤紀錄的日期"
                },
                new()
                {
                    PropertyName = nameof(ScaleRecord.VehicleId),
                    Label = L["Field.LicensePlate"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = L["Placeholder.PleaseInputOrSelect", L["Field.LicensePlate"]],
                    IsRequired = true,
                    MinSearchLength = 0,
                    HelpText = "送來磅秤的車輛，選擇後自動帶入所屬客戶"
                },
                new()
                {
                    PropertyName = nameof(ScaleRecord.ScaleTypeId),
                    Label = L["Entity.WasteType"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = L["Placeholder.PleaseInputOrSelect", L["Entity.WasteType"]],
                    IsRequired = true,
                    MinSearchLength = 0,
                    HelpText = "此次送來的磅秤類型",
                    ActionButtons = await GetScaleTypeActionButtonsAsync()
                },
                new()
                {
                    PropertyName = nameof(ScaleRecord.CustomerId),
                    Label = L["Entity.Customer"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = L["Placeholder.PleaseInputOrSelect", L["Entity.Customer"]],
                    IsRequired = false,
                    MinSearchLength = 0,
                    HelpText = "送料客戶，可由車輛自動帶入或手動選擇",
                    ActionButtons = await GetCustomerActionButtonsAsync()
                },
                new()
                {
                    PropertyName = nameof(ScaleRecord.WarehouseId),
                    Label = L["Field.InboundWarehouse"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = L["Placeholder.PleaseInputOrSelect", L["Entity.Warehouse"]],
                    IsRequired = true,
                    MinSearchLength = 0,
                    HelpText = "磅秤處理後入庫的倉庫，選擇後可進一步指定庫位"
                },
                new()
                {
                    PropertyName = nameof(ScaleRecord.WarehouseLocationId),
                    Label = L["Field.InboundLocation"],
                    FieldType = FormFieldType.AutoComplete,
                    Placeholder = locationIsReadOnly ? L["Placeholder.SelectWarehouseFirst"].ToString() : L["Placeholder.PleaseInputOrSelect", L["Entity.WarehouseLocation"]].ToString(),
                    IsRequired = false,
                    IsReadOnly = locationIsReadOnly,
                    MinSearchLength = 0,
                    HelpText = "倉庫內的具體庫位（選填，需先選擇倉庫）"
                },
                new()
                {
                    PropertyName = nameof(ScaleRecord.TotalWeight),
                    Label = L["Field.TotalWeight"],
                    FieldType = FormFieldType.Number,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.TotalWeight"]],
                    IsRequired = true,
                    HelpText = "磅秤的總重量"
                },
                new()
                {
                    PropertyName = nameof(ScaleRecord.DisposalFee),
                    Label = L["Field.DisposalFee"],
                    FieldType = FormFieldType.Number,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.DisposalFee"]],
                    IsRequired = false,
                    HelpText = "我們向客戶/廠商收取的磅秤處理服務費"
                },
                new()
                {
                    PropertyName = nameof(ScaleRecord.PurchaseFee),
                    Label = L["Field.PurchaseFee"],
                    FieldType = FormFieldType.Number,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.PurchaseFee"]],
                    IsRequired = false,
                    HelpText = "客戶/廠商向我們收取的磅秤採購費用"
                },

                FormFieldConfigurationHelper.CreateRemarksField<ScaleRecord>()
            };

            formSections = FormSectionHelper<ScaleRecord>.Create()
                .AddToSection(FormSectionNames.BasicInfo,
                    sr => sr.Code,
                    sr => sr.RecordDate,
                    sr => sr.VehicleId,
                    sr => sr.CustomerId,
                    sr => sr.ScaleTypeId,
                    sr => sr.Quantity,
                    sr => sr.TotalWeight,
                    sr => sr.WarehouseId,
                    sr => sr.WarehouseLocationId)
                .AddToSection(L["Section.FeeInfo"],
                    sr => sr.DisposalFee,
                    sr => sr.PurchaseFee,
                    sr => sr.NetAmount)
                .AddToSection(FormSectionNames.AdditionalInfo,
                    sr => sr.Remarks)
                .Build();
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync("初始化磅秤紀錄表單欄位時發生錯誤");
        }
    }

    private async Task LoadAdditionalDataAsync()
    {
        try
        {
            availableScaleTypes = await ScaleTypeService.GetAllAsync();
            availableVehicles = await VehicleService.GetAllAsync();
            availableCustomers = await CustomerService.GetAllAsync();
            availableWarehouses = await WarehouseService.GetAllAsync();
            availableWarehouseLocations = await WarehouseLocationService.GetAllAsync();

            // 初始化時依目前選取的倉庫篩選庫位（編輯模式）
            var currentWarehouseId = editModalComponent?.Entity?.WarehouseId ?? 0;
            filteredWarehouseLocations = currentWarehouseId > 0
                ? availableWarehouseLocations.Where(wl => wl.WarehouseId == currentWarehouseId).ToList()
                : new List<WarehouseLocation>();

            RebuildAutoCompleteConfig();
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync("載入磅秤紀錄編輯相關資料時發生錯誤");
            availableScaleTypes = new List<ScaleType>();
            availableVehicles = new List<Vehicle>();
            availableCustomers = new List<Customer>();
            availableWarehouses = new List<Warehouse>();
            availableWarehouseLocations = new List<WarehouseLocation>();
            filteredWarehouseLocations = new List<WarehouseLocation>();
        }
    }

    private void RebuildAutoCompleteConfig()
    {
        autoCompleteConfig = new AutoCompleteConfigBuilder<ScaleRecord>()
            .AddField(nameof(ScaleRecord.VehicleId), "LicensePlate", availableVehicles)
            .AddField(nameof(ScaleRecord.ScaleTypeId), "Name", availableScaleTypes)
            .AddField(nameof(ScaleRecord.CustomerId), "CompanyName", availableCustomers)
            .AddField(nameof(ScaleRecord.WarehouseId), "Name", availableWarehouses)
            .AddField(nameof(ScaleRecord.WarehouseLocationId), "Name", filteredWarehouseLocations)
            .Build();
    }

    // 儲存成功後：呼叫入庫方法，再轉給父組件
    private async Task HandleScaleRecordSavedAsync(ScaleRecord savedRecord)
    {
        try
        {
            ServiceResult inventoryResult;
            if (_isNewRecord)
                inventoryResult = await ScaleRecordService.ConfirmScaleReceiptAsync(savedRecord.Id);
            else
                inventoryResult = await ScaleRecordService.ReverseAndRepostScaleInventoryAsync(savedRecord.Id);

            // 首次儲存後記錄已存在，後續在同一 Modal Session 內再儲存時應執行 ReverseAndRepost
            _isNewRecord = false;

            if (!inventoryResult.IsSuccess)
                await NotificationService.ShowWarningAsync($"記錄已儲存，但庫存更新失敗：{inventoryResult.ErrorMessage}");
        }
        catch (Exception ex)
        {
            await NotificationService.ShowWarningAsync($"記錄已儲存，但庫存更新時發生錯誤：{ex.Message}");
        }

        await OnScaleRecordSaved.InvokeAsync(savedRecord);
    }

    private async Task<List<FieldActionButton>> GetScaleTypeActionButtonsAsync()
    {
        return await ActionButtonHelper.GenerateFieldActionButtonsAsync(
            editModalComponent,
            scaleTypeModalManager,
            nameof(ScaleRecord.ScaleTypeId)
        );
    }

    private async Task<List<FieldActionButton>> GetCustomerActionButtonsAsync()
    {
        return await ActionButtonHelper.GenerateFieldActionButtonsAsync(
            editModalComponent,
            customerModalManager,
            nameof(ScaleRecord.CustomerId)
        );
    }

    // ===== 串列埠讀取磅秤數據 =====

    /// <summary>
    /// 切換讀取狀態：開始/停止監聽串列埠數據
    /// 當收到穩定狀態 (ST) 的重量資料時，自動帶入「總重量」欄位
    /// </summary>
    private async Task HandleToggleReading()
    {
        if (_isReading)
        {
            // 停止讀取
            SerialPortService.DataReceived -= OnScaleDataReceived;
            _isReading = false;
            await NotificationService.ShowInfoAsync("已停止讀取磅秤數據");
        }
        else
        {
            if (!SerialPortService.IsOpen)
            {
                await NotificationService.ShowWarningAsync("請先在『參數設定』中連線串列埠");
                return;
            }

            // 開始讀取
            _lastStableWeight = null;
            SerialPortService.DataReceived += OnScaleDataReceived;
            _isReading = true;
            await NotificationService.ShowInfoAsync("開始讀取磅秤數據，等待穩定重量...");
        }
    }

    /// <summary>
    /// 串列埠數據接收事件處理
    /// 當磅秤回傳穩定狀態 (ST) 時，自動將重量帶入 TotalWeight 欄位
    /// </summary>
    private async void OnScaleDataReceived(object? sender, ScaleDataReceivedEventArgs e)
    {
        if (!e.IsValid) return;

        try
        {
            await InvokeAsync(async () =>
            {
                if (e.IsStable && editModalComponent?.Entity != null)
                {
                    // 穩定狀態：自動帶入重量並停止讀取
                    _lastStableWeight = e.WeightValue;
                    editModalComponent.Entity.TotalWeight = e.WeightValue;

                    // 停止讀取
                    SerialPortService.DataReceived -= OnScaleDataReceived;
                    _isReading = false;

                    await NotificationService.ShowSuccessAsync($"已讀取穩定重量：{e.WeightValue} {e.Unit}");
                    StateHasChanged();
                }
                else if (!e.IsStable)
                {
                    // 不穩定狀態：更新顯示但不帶入
                    _lastStableWeight = null;
                    StateHasChanged();
                }
                else if (e.IsOverload)
                {
                    await NotificationService.ShowWarningAsync("磅秤過載 (OL)，請檢查秤台");
                }
            });
        }
        catch (Exception)
        {
            // 組件可能已被釋放，忽略錯誤
        }
    }

    public void Dispose()
    {
        // 確保組件釋放時取消事件訂閱（不關閉串列埠，因為其他組件可能還在使用）
        SerialPortService.DataReceived -= OnScaleDataReceived;
    }
}
