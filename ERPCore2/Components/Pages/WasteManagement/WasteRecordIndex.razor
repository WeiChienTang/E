@page "/waste-records"
@inject IWasteRecordService WasteRecordService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@inject IWasteRecordReportService WasteRecordReportService
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="WasteRecord"
                          TService="IWasteRecordService"
                          Service="@WasteRecordService"
                          EntityBasePath="/waste-records"
                          PageTitle="@L["Page.WasteRecordTitle"]"
                          PageSubtitle="@L["Page.WasteRecordSubtitle"]"
                          EntityName="@L["Entity.WasteRecord"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadWasteRecordsAsync"
                          GetEntityDisplayName="@(wr => wr.Code ?? $"磅秤紀錄#{wr.Id}")"
                          RequiredPermission="@PermissionRegistry.WasteRecord.Read"
                          RequiredModule="WasteManagement"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          ShowDraftTab="true"
                          DebugPageName="WasteRecordIndex"
                          RowPrintService="@WasteRecordReportService"
                          RowPrintReportId="@ReportIds.WasteRecord"
                          @ref="indexComponent" />

<WasteRecordEditModalComponent IsVisible="@showEditModal"
                               IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                               WasteRecordId="@editingWasteRecordId"
                               OnWasteRecordSaved="@modalHandler.OnEntitySavedAsync"
                               OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    private GenericIndexPageComponent<WasteRecord, IWasteRecordService> indexComponent = default!;

    private bool showEditModal = false;
    private int? editingWasteRecordId = null;

    private ModalHandler<WasteRecord, GenericIndexPageComponent<WasteRecord, IWasteRecordService>> modalHandler = default!;

    private WasteRecordFieldConfiguration fieldConfiguration = default!;

    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<WasteRecord, GenericIndexPageComponent<WasteRecord, IWasteRecordService>>(
                id => editingWasteRecordId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new WasteRecordFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化磅秤紀錄頁面失敗");
            await NotificationService.ShowErrorAsync("初始化磅秤紀錄頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() =>
        breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("磅秤管理", "磅秤紀錄", "#", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<WasteRecord> Items, int TotalCount)> ServerLoadWasteRecordsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return WasteRecordService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(wr => wr.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadWasteRecordsAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
