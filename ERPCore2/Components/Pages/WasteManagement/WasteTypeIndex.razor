@page "/waste-types"
@inject IWasteTypeService WasteTypeService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="WasteType"
                          TService="IWasteTypeService"
                          Service="@WasteTypeService"
                          EntityBasePath="/waste-types"
                          PageTitle="@L["Page.WasteTypeTitle"]"
                          PageSubtitle="@L["Page.WasteTypeSubtitle"]"
                          EntityName="@L["Entity.WasteType"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadWasteTypesAsync"
                          GetEntityDisplayName="@(wt => wt.Name)"
                          RequiredPermission="@PermissionRegistry.WasteType.Read"
                          RequiredModule="WasteManagement"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          ShowDraftTab="true"
                          DebugPageName="WasteTypeIndex"
                          @ref="indexComponent" />

<WasteTypeEditModalComponent IsVisible="@showEditModal"
                             IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                             WasteTypeId="@editingWasteTypeId"
                             OnWasteTypeSaved="@modalHandler.OnEntitySavedAsync"
                             OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    private GenericIndexPageComponent<WasteType, IWasteTypeService> indexComponent = default!;

    private bool showEditModal = false;
    private int? editingWasteTypeId = null;

    private ModalHandler<WasteType, GenericIndexPageComponent<WasteType, IWasteTypeService>> modalHandler = default!;

    private WasteTypeFieldConfiguration fieldConfiguration = default!;

    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<WasteType, GenericIndexPageComponent<WasteType, IWasteTypeService>>(
                id => editingWasteTypeId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new WasteTypeFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化磅秤類型頁面失敗");
            await NotificationService.ShowErrorAsync("初始化磅秤類型頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() =>
        breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("磅秤管理", "磅秤類型維護", "#", NotificationService, GetType());

    private Task<(List<WasteType> Items, int TotalCount)> ServerLoadWasteTypesAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return WasteTypeService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(x => x.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadWasteTypesAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
