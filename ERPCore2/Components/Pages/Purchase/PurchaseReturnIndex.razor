@page "/purchase/returns"
@using ERPCore2.Models
@using ERPCore2.Models.Reports
@inject IPurchaseReturnService PurchaseReturnService
@inject ISupplierService SupplierService
@inject IPurchaseOrderService PurchaseOrderService
@inject IPurchaseReceivingService PurchaseReceivingService
@inject IWarehouseService WarehouseService
@inject IEmployeeService EmployeeService
@inject ISystemParameterService SystemParameterService
@inject INotificationService NotificationService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IPurchaseReturnReportService PurchaseReturnReportService
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="PurchaseReturn" 
                          TService="IPurchaseReturnService"
                          Service="@PurchaseReturnService"
                          EntityBasePath="/purchase/returns"
                          PageTitle="@L["Page.PurchaseReturnTitle"]"
                          PageSubtitle="@L["Page.PurchaseReturnSubtitle"]"
                          EntityName="@L["Entity.PurchaseReturnDoc"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ShowDraftTab="true"
                          ServerDataLoader="@ServerLoadPurchaseReturnsAsync"
                          GetEntityDisplayName="@(returnItem => returnItem.Code)"
                          RequiredPermission="@PermissionRegistry.PurchaseReturn.Read"
                          RequiredModule="Purchase"
                          ShowBatchPrintButton="true"
                          OnBatchPrintClick="@HandleBatchPrintAsync"
                          ShowBatchApprovalButton="@isManualApproval"
                          OnBatchApprovalClick="@HandleBatchApprovalAsync"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          DebugPageName="PurchaseReturnIndex"
                          RowPrintService="@PurchaseReturnReportService"
                          RowPrintReportId="@ReportIds.PurchaseReturn"
                          @ref="indexComponent" />

@* 進貨退出編輯 Modal *@
<PurchaseReturnEditModalComponent IsVisible="@showEditModal"
                                 IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                 PurchaseReturnId="@editingPurchaseReturnId"
                                 OnPurchaseReturnSaved="@modalHandler.OnEntitySavedAsync"
                                 OnCancel="@modalHandler.OnModalCancelAsync" />

@* 批次審核 Modal *@
<BatchApprovalModalComponent TEntity="PurchaseReturn"
                            IsVisible="@showBatchApprovalModal"
                            IsVisibleChanged="@((bool visible) => showBatchApprovalModal = visible)"
                            Title="採購退回單批次審核"
                            EntityName="@L["Entity.PurchaseReturnDoc"]"
                            LoadPendingItems="@LoadPendingPurchaseReturnsAsync"
                            OnApproveItem="@ApproveSinglePurchaseReturnAsync"
                            OnApproveAll="@ApproveAllPurchaseReturnsAsync"
                            OnViewClick="@HandleApprovalViewClick"
                            OnApprovalCompleted="@HandleApprovalCompleted" />

@* 批次列印篩選 Modal - 使用 GenericReportFilterModalComponent 統一架構 *@
<GenericReportFilterModalComponent IsVisible="@showBatchPrintModal"
                                  IsVisibleChanged="@((bool visible) => showBatchPrintModal = visible)"
                                  ReportId="@ReportIds.PurchaseReturn"
                                  OnPrintSuccess="@HandleBatchPrintSuccess" />

@code {
    // 組件參考
    private GenericIndexPageComponent<PurchaseReturn, IPurchaseReturnService> indexComponent = default!;
    
    // Modal 相關狀態
    private bool showEditModal = false;
    private int? editingPurchaseReturnId = null;
    
    // 審核相關狀態
    private bool isManualApproval = false;
    private bool showBatchApprovalModal = false;

    // 批次列印 Modal 相關狀態
    private bool showBatchPrintModal = false;

    // Modal 處理器
    private ModalHandler<PurchaseReturn, GenericIndexPageComponent<PurchaseReturn, IPurchaseReturnService>> modalHandler = default!;
    
    // 欄位配置
    private PurchaseReturnFieldConfiguration fieldConfiguration = default!;
    
    // 配置相關
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    // 相關資料
    private List<Supplier> suppliers = new();
    private List<PurchaseOrder> purchaseOrders = new();
    private List<PurchaseReceiving> purchaseReceivings = new();
    private List<Warehouse> warehouses = new();
    private List<Employee> employees = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<PurchaseReturn, GenericIndexPageComponent<PurchaseReturn, IPurchaseReturnService>>(
                id => editingPurchaseReturnId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());
            
            await InitializeBreadcrumbsAsync();
            
            // 載入相關資料
            await LoadSuppliersAsync();
            await LoadPurchaseOrdersAsync();
            await LoadPurchaseReceivingsAsync();
            await LoadWarehousesAsync();
            await LoadEmployeesAsync();
            
            // 建立欄位配置
            isManualApproval = await SystemParameterService.IsPurchaseReturnManualApprovalAsync();
            fieldConfiguration = new PurchaseReturnFieldConfiguration(
                suppliers,
                purchaseOrders,
                purchaseReceivings,
                warehouses,
                employees,
                isManualApproval,
                NotificationService);
            fieldConfiguration.SetLocalizer(L);
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化進貨退出頁面失敗");
            await NotificationService.ShowErrorAsync("初始化進貨退出頁面失敗");
        }
    }

    /// <summary>
    /// 初始化麵包屑導航
    /// </summary>
    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("採購管理", "進貨退出管理", "#", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<PurchaseReturn> Items, int TotalCount)> ServerLoadPurchaseReturnsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return PurchaseReturnService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(pr => pr.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadPurchaseReturnsAsync), GetType());
                return q;
            },
            page, pageSize);
    }

    /// <summary>
    /// 載入廠商資料
    /// </summary>
    private async Task LoadSuppliersAsync() => suppliers = await DataLoaderHelper.LoadAsync(() => SupplierService.GetAllAsync(), "廠商", NotificationService, GetType());

    /// <summary>
    /// 載入採購訂單資料
    /// </summary>
    private async Task LoadPurchaseOrdersAsync()
    {
        try
        {
            // 載入已核准的採購訂單
            var allOrders = await PurchaseOrderService.GetAllAsync();
            purchaseOrders = allOrders.Where(po => po.IsApproved).ToList();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadPurchaseOrdersAsync), GetType(), additionalData: "載入採購訂單資料失敗");
            await NotificationService.ShowErrorAsync("載入採購訂單資料失敗");
            purchaseOrders = new List<PurchaseOrder>();
        }
    }

    /// <summary>
    /// 載入採購進貨資料
    /// </summary>
    private async Task LoadPurchaseReceivingsAsync() => purchaseReceivings = await DataLoaderHelper.LoadAsync(() => PurchaseReceivingService.GetAllAsync(), "採購進貨", NotificationService, GetType());

    /// <summary>
    /// 載入倉庫資料
    /// </summary>
    private async Task LoadWarehousesAsync() => warehouses = await DataLoaderHelper.LoadAsync(() => WarehouseService.GetAllAsync(), "倉庫", NotificationService, GetType());

    /// <summary>
    /// 載入員工資料
    /// </summary>
    private async Task LoadEmployeesAsync() => employees = await DataLoaderHelper.LoadAsync(() => EmployeeService.GetAllAsync(), "員工", NotificationService, GetType());

    // 多筆列印處理方法
    private async Task HandleBatchPrintAsync()
    {
        try
        {
            // 顯示批次列印篩選 Modal（使用 GenericReportFilterModalComponent）
            showBatchPrintModal = true;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleBatchPrintAsync), GetType(), additionalData: "開啟多筆列印視窗失敗");
            await NotificationService.ShowErrorAsync("開啟多筆列印視窗失敗");
        }
    }

    /// <summary>
    /// 處理批次列印成功事件
    /// </summary>
    private void HandleBatchPrintSuccess()
    {
        showBatchPrintModal = false;
        StateHasChanged();
    }

    // ===== 批次審核相關方法 =====

    private async Task HandleBatchApprovalAsync()
    {
        try
        {
            showBatchApprovalModal = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleBatchApprovalAsync), GetType(), additionalData: "開啟批次審核視窗失敗");
            await NotificationService.ShowErrorAsync("開啟批次審核視窗失敗");
        }
    }

    private async Task<List<PurchaseReturn>> LoadPendingPurchaseReturnsAsync()
    {
        try
        {
            var all = await PurchaseReturnService.GetAllAsync();
            return all.Where(pr => !pr.IsApproved).ToList();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadPendingPurchaseReturnsAsync), GetType(), additionalData: "載入待審核採購退回單失敗");
            await NotificationService.ShowErrorAsync("載入待審核採購退回單失敗");
            return new List<PurchaseReturn>();
        }
    }

    private async Task<bool> ApproveSinglePurchaseReturnAsync(PurchaseReturn entity)
    {
        try
        {
            var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
            if (!userId.HasValue) return false;
            var result = await PurchaseReturnService.ApproveAsync(entity.Id, userId.Value);
            return result.IsSuccess;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(ApproveSinglePurchaseReturnAsync), GetType(), additionalData: new { EntityId = entity.Id });
            return false;
        }
    }

    private async Task<(int successCount, int failCount)> ApproveAllPurchaseReturnsAsync(List<PurchaseReturn> items)
    {
        int successCount = 0, failCount = 0;
        var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
        if (!userId.HasValue) return (0, items.Count);
        foreach (var item in items)
        {
            try
            {
                var result = await PurchaseReturnService.ApproveAsync(item.Id, userId.Value);
                if (result.IsSuccess) successCount++; else failCount++;
            }
            catch (Exception ex)
            {
                failCount++;
                await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(ApproveAllPurchaseReturnsAsync), GetType(), additionalData: new { EntityId = item.Id });
            }
        }
        return (successCount, failCount);
    }

    private async Task HandleApprovalViewClick(PurchaseReturn entity)
    {
        try
        {
            await modalHandler.ShowEditModalAsync(entity);
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleApprovalViewClick), GetType(), additionalData: new { EntityId = entity.Id });
            await NotificationService.ShowErrorAsync("開啟查看視窗失敗");
        }
    }

    private async Task HandleApprovalCompleted()
    {
        try
        {
            if (indexComponent != null)
                await indexComponent.Refresh();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleApprovalCompleted), GetType(), additionalData: "刷新列表失敗");
        }
    }
}
