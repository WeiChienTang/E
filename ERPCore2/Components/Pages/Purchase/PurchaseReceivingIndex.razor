@page "/purchase/receiving"
@using ERPCore2.Models.Reports
@inject IPurchaseReceivingService PurchaseReceivingService
@inject IPurchaseOrderService PurchaseOrderService
@inject IWarehouseService WarehouseService
@inject ISupplierService SupplierService
@inject ISystemParameterService SystemParameterService
@inject INotificationService NotificationService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L
@inject AuthenticationStateProvider AuthenticationStateProvider
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="PurchaseReceiving" 
                          TService="IPurchaseReceivingService"
                          Service="@PurchaseReceivingService"
                          EntityBasePath="/purchase/receiving"
                          PageTitle="@L["Page.PurchaseReceivingTitle"]"
                          PageSubtitle="@L["Page.PurchaseReceivingSubtitle"]"
                          EntityName="@L["Entity.PurchaseReceivingDoc"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ShowDraftTab="true"
                          ServerDataLoader="@ServerLoadPurchaseReceivingsAsync"
                          GetEntityDisplayName="@(receipt => receipt.Code)"
                          RequiredPermission="@PermissionRegistry.PurchaseReceiving.Read"
                          RequiredModule="Purchase"
                          ShowBatchPrintButton="true"
                          OnBatchPrintClick="@HandleBatchPrintAsync"
                          ShowBatchApprovalButton="@isManualApproval"
                          OnBatchApprovalClick="@HandleBatchApprovalAsync"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          DebugPageName="PurchaseReceivingIndex"
                          @ref="indexComponent" />

@* 進貨單編輯 Modal *@
<PurchaseReceivingEditModalComponent IsVisible="@showEditModal"
                                    IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                    PurchaseReceivingId="@editingPurchaseReceivingId"
                                    OnPurchaseReceivingSaved="@modalHandler.OnEntitySavedAsync"
                                    OnCancel="@modalHandler.OnModalCancelAsync" />

@* 批次審核 Modal *@
<BatchApprovalModalComponent TEntity="PurchaseReceiving"
                            IsVisible="@showBatchApprovalModal"
                            IsVisibleChanged="@((bool visible) => showBatchApprovalModal = visible)"
                            Title="進貨單批次審核"
                            EntityName="@L["Entity.PurchaseReceivingDoc"]"
                            LoadPendingItems="@LoadPendingPurchaseReceivingsAsync"
                            OnApproveItem="@ApproveSinglePurchaseReceivingAsync"
                            OnApproveAll="@ApproveAllPurchaseReceivingsAsync"
                            OnViewClick="@HandleApprovalViewClick"
                            OnApprovalCompleted="@HandleApprovalCompleted" />

@* 批次列印篩選 Modal - 使用 GenericReportFilterModalComponent 統一架構 *@
<GenericReportFilterModalComponent IsVisible="@showBatchPrintModal"
                                  IsVisibleChanged="@((bool visible) => showBatchPrintModal = visible)"
                                  ReportId="@ReportIds.PurchaseReceiving"
                                  OnPrintSuccess="@HandleBatchPrintSuccess" />

@code {
    // 組件參考
    private GenericIndexPageComponent<PurchaseReceiving, IPurchaseReceivingService> indexComponent = default!;
    
    // Modal 相關狀態
    private bool showEditModal = false;
    private int? editingPurchaseReceivingId = null;
    
    // 審核相關狀態
    private bool isManualApproval = false;
    private bool showBatchApprovalModal = false;

    // 批次列印 Modal 相關狀態
    private bool showBatchPrintModal = false;
    
    // Modal 處理器
    private ModalHandler<PurchaseReceiving, GenericIndexPageComponent<PurchaseReceiving, IPurchaseReceivingService>> modalHandler = default!;
    
    // 欄位配置
    private PurchaseReceivingFieldConfiguration fieldConfiguration = default!;
    
    // 配置相關
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    // 相關資料
    private List<PurchaseOrder> purchaseOrders = new();
    private List<Warehouse> warehouses = new();
    private List<Supplier> suppliers = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<PurchaseReceiving, GenericIndexPageComponent<PurchaseReceiving, IPurchaseReceivingService>>(
                id => editingPurchaseReceivingId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());
            
            await InitializeBreadcrumbsAsync();
            
            // 載入相關資料
            await LoadPurchaseOrdersAsync();
            await LoadWarehousesAsync();
            await LoadSuppliersAsync();
            
            // 建立欄位配置
            isManualApproval = await SystemParameterService.IsPurchaseReceivingManualApprovalAsync();
            fieldConfiguration = new PurchaseReceivingFieldConfiguration(purchaseOrders, warehouses, isManualApproval, NotificationService);
            fieldConfiguration.SetLocalizer(L);
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化進貨頁面失敗");
            await NotificationService.ShowErrorAsync("初始化進貨頁面失敗");
        }
    }

    /// <summary>
    /// 初始化麵包屑導航
    /// </summary>
    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("採購管理", "進貨管理", "#", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<PurchaseReceiving> Items, int TotalCount)> ServerLoadPurchaseReceivingsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return PurchaseReceivingService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(pr => pr.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadPurchaseReceivingsAsync), GetType());
                return q;
            },
            page, pageSize);
    }

    /// <summary>
    /// 載入採購訂單資料
    /// </summary>
    private async Task LoadPurchaseOrdersAsync()
    {
        try
        {
            // 只載入已核准的採購訂單
            var allOrders = await PurchaseOrderService.GetAllAsync();
            purchaseOrders = allOrders.Where(po => po.IsApproved).ToList();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadPurchaseOrdersAsync), GetType(), additionalData: "載入採購訂單資料失敗");
            await NotificationService.ShowErrorAsync("載入採購訂單資料失敗");
            purchaseOrders = new List<PurchaseOrder>();
        }
    }

    /// <summary>
    /// 載入倉庫資料
    /// </summary>
    private async Task LoadWarehousesAsync() => warehouses = await DataLoaderHelper.LoadAsync(() => WarehouseService.GetAllAsync(), "倉庫", NotificationService, GetType());

    /// <summary>
    /// 載入廠商資料
    /// </summary>
    private async Task LoadSuppliersAsync() => suppliers = await DataLoaderHelper.LoadAsync(() => SupplierService.GetAllAsync(), "廠商", NotificationService, GetType());

    // 多筆列印處理方法
    private async Task HandleBatchPrintAsync()
    {
        try
        {
            // 顯示批次列印篩選 Modal（使用 GenericReportFilterModalComponent）
            showBatchPrintModal = true;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleBatchPrintAsync), GetType(), additionalData: "開啟多筆列印視窗失敗");
            await NotificationService.ShowErrorAsync("開啟多筆列印視窗失敗");
        }
    }

    /// <summary>
    /// 處理批次列印成功事件
    /// </summary>
    private void HandleBatchPrintSuccess()
    {
        showBatchPrintModal = false;
        StateHasChanged();
    }

    // ===== 批次審核相關方法 =====

    private async Task HandleBatchApprovalAsync()
    {
        try
        {
            showBatchApprovalModal = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleBatchApprovalAsync), GetType(), additionalData: "開啟批次審核視窗失敗");
            await NotificationService.ShowErrorAsync("開啟批次審核視窗失敗");
        }
    }

    private async Task<List<PurchaseReceiving>> LoadPendingPurchaseReceivingsAsync()
    {
        try
        {
            var all = await PurchaseReceivingService.GetAllAsync();
            return all.Where(pr => !pr.IsApproved).ToList();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadPendingPurchaseReceivingsAsync), GetType(), additionalData: "載入待審核進貨單失敗");
            await NotificationService.ShowErrorAsync("載入待審核進貨單失敗");
            return new List<PurchaseReceiving>();
        }
    }

    private async Task<bool> ApproveSinglePurchaseReceivingAsync(PurchaseReceiving entity)
    {
        try
        {
            var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
            if (!userId.HasValue) return false;
            var result = await PurchaseReceivingService.ApproveAsync(entity.Id, userId.Value);
            return result.IsSuccess;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(ApproveSinglePurchaseReceivingAsync), GetType(), additionalData: new { EntityId = entity.Id });
            return false;
        }
    }

    private async Task<(int successCount, int failCount)> ApproveAllPurchaseReceivingsAsync(List<PurchaseReceiving> items)
    {
        int successCount = 0, failCount = 0;
        var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
        if (!userId.HasValue) return (0, items.Count);
        foreach (var item in items)
        {
            try
            {
                var result = await PurchaseReceivingService.ApproveAsync(item.Id, userId.Value);
                if (result.IsSuccess) successCount++; else failCount++;
            }
            catch (Exception ex)
            {
                failCount++;
                await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(ApproveAllPurchaseReceivingsAsync), GetType(), additionalData: new { EntityId = item.Id });
            }
        }
        return (successCount, failCount);
    }

    private async Task HandleApprovalViewClick(PurchaseReceiving entity)
    {
        try
        {
            await modalHandler.ShowEditModalAsync(entity);
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleApprovalViewClick), GetType(), additionalData: new { EntityId = entity.Id });
            await NotificationService.ShowErrorAsync("開啟查看視窗失敗");
        }
    }

    private async Task HandleApprovalCompleted()
    {
        try
        {
            if (indexComponent != null)
                await indexComponent.Refresh();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleApprovalCompleted), GetType(), additionalData: "刷新列表失敗");
        }
    }
}
