@page "/purchase/returnReasons"
@inject IPurchaseReturnReasonService PurchaseReturnReasonService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

@using ERPCore2.Helpers.FieldConfiguration

<GenericIndexPageComponent TEntity="PurchaseReturnReason"
                          TService="IPurchaseReturnReasonService"
                          Service="@PurchaseReturnReasonService"
                          EntityBasePath="/purchase/returnReasons"
                          PageTitle="@L["Page.PurchaseReturnReasonTitle"]"
                          PageSubtitle="@L["Page.PurchaseReturnReasonSubtitle"]"
                          EntityName="@L["Entity.PurchaseReturnReason"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ShowDraftTab="true"
                          ServerDataLoader="@ServerLoadPurchaseReturnReasonsAsync"
                          GetEntityDisplayName="@(reason => reason.Name)"
                          RequiredPermission="@PermissionRegistry.PurchaseReturnReason.Read"
                          RequiredModule="Purchase"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          DebugPageName="PurchaseReturnReasonIndex"
                          @ref="indexComponent" />

@* 退出原因編輯 Modal *@
<PurchaseReturnReasonEditModalComponent IsVisible="@showEditModal"
                                       IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                       PurchaseReturnReasonId="@editingPurchaseReturnReasonId"
                                       OnPurchaseReturnReasonSaved="@modalHandler.OnEntitySavedAsync"
                                       OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    // 組件參考
    private GenericIndexPageComponent<PurchaseReturnReason, IPurchaseReturnReasonService> indexComponent = default!;

    // Modal 相關狀態
    private bool showEditModal = false;
    private int? editingPurchaseReturnReasonId = null;

    // Modal 處理器
    private ModalHandler<PurchaseReturnReason, GenericIndexPageComponent<PurchaseReturnReason, IPurchaseReturnReasonService>> modalHandler = default!;

    // 欄位配置
    private PurchaseReturnReasonFieldConfiguration fieldConfiguration = default!;

    // 配置相關
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<PurchaseReturnReason, GenericIndexPageComponent<PurchaseReturnReason, IPurchaseReturnReasonService>>(
                id => editingPurchaseReturnReasonId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            // 建立欄位配置
            fieldConfiguration = new PurchaseReturnReasonFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化進貨退出原因頁面失敗");
            await NotificationService.ShowErrorAsync("初始化進貨退出原因頁面失敗");
        }
    }

    /// <summary>
    /// 初始化麵包屑導航
    /// </summary>
    private async Task InitializeBreadcrumbsAsync() =>
        breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("採購管理", "退出原因管理", "#", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<PurchaseReturnReason> Items, int TotalCount)> ServerLoadPurchaseReturnReasonsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return PurchaseReturnReasonService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(r => r.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadPurchaseReturnReasonsAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
