@page "/custom-tables/{TableId:int}"
@rendermode InteractiveServer
@using ERPCore2.Data.Entities.CustomTables
@using ERPCore2.Services.CustomTables
@using System.Text.Json

@inject ICustomTableDefinitionService TableDefinitionService
@inject ICustomTableRowService RowService
@inject INotificationService NotificationService
@inject INavigationPermissionService PermissionService
@inject NavigationManager NavigationManager

<PageTitle>@(_tableDefinition?.TableName ?? "自訂資料表")</PageTitle>

@if (!_isAuthorized)
{
    <div class="container-fluid p-4">
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-shield-exclamation fs-4 me-3"></i>
            <div>
                <strong>存取被拒</strong><br />
                <span class="text-muted small">您沒有存取此頁面的權限。</span>
            </div>
        </div>
    </div>
}
else if (_isLoading)
{
    <div class="d-flex justify-content-center align-items-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">載入中...</span>
        </div>
    </div>
}
else if (_tableDefinition == null)
{
    <div class="container-fluid p-4">
        <div class="alert alert-warning d-flex align-items-center">
            <i class="bi bi-exclamation-triangle fs-4 me-3"></i>
            <div>
                <strong>找不到資料表</strong><br />
                <span class="text-muted small">此自訂資料表不存在或已被刪除。</span>
            </div>
        </div>
    </div>
}
else
{
    @* ===== 頁面標題列 ===== *@
    <div class="page-header d-flex justify-content-between align-items-center px-4 pt-3 pb-2 border-bottom mb-3">
        <div class="d-flex align-items-center">
            <i class="@(_tableDefinition.IconClass ?? "bi bi-table") fs-4 me-2 text-primary"></i>
            <div>
                <h5 class="mb-0 fw-bold">@_tableDefinition.TableName</h5>
                @if (!string.IsNullOrEmpty(_tableDefinition.Description))
                {
                    <small class="text-muted">@_tableDefinition.Description</small>
                }
            </div>
        </div>
        <div class="d-flex gap-2">
            <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                                   Text="新增資料列"
                                   IconClass="bi bi-plus-lg"
                                   OnClick="StartAddRow"
                                   IsDisabled="@_isFormVisible" />
        </div>
    </div>

    @* ===== 資料列表 ===== *@
    <div class="px-4">
        @if (_isTableLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <span class="ms-2 text-muted">載入中...</span>
            </div>
        }
        else if (!_rows.Any())
        {
            <div class="text-center text-muted py-5 border rounded">
                <i class="@(_tableDefinition.IconClass ?? "bi bi-table") fs-1 d-block mb-3"></i>
                <p class="mb-1">尚無資料</p>
                <p class="small">點擊「新增資料列」開始新增</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 8%">編號</th>
                            @foreach (var field in _listFields)
                            {
                                <th>@field.DisplayName</th>
                            }
                            <th style="width: 6%" class="text-center">狀態</th>
                            <th style="width: 10%">建立時間</th>
                            <th style="width: 8%" class="text-center">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _rows)
                        {
                            <tr>
                                <td class="align-middle">
                                    <small class="text-muted">@row.Code</small>
                                </td>
                                @foreach (var field in _listFields)
                                {
                                    <td class="align-middle">@RenderFieldValue(row, field)</td>
                                }
                                <td class="align-middle text-center">
                                    <GenericStatusBadgeComponent Status="@row.Status" />
                                </td>
                                <td class="align-middle">
                                    <small class="text-muted">@row.CreatedAt.ToString("yyyy/MM/dd")</small>
                                </td>
                                <td class="align-middle text-center">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary btn-sm"
                                                @onclick="() => StartEditRow(row)"
                                                title="編輯">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm"
                                                @onclick="() => HandleDeleteRow(row)"
                                                title="刪除">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* ===== 分頁 ===== *@
            @if (_totalCount > _pageSize)
            {
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <small class="text-muted">共 @_totalCount 筆，第 @_currentPage / @TotalPages 頁</small>
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-secondary" disabled="@(_currentPage <= 1)"
                                @onclick="() => GoToPage(_currentPage - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <button class="btn btn-outline-secondary" disabled="@(_currentPage >= TotalPages)"
                                @onclick="() => GoToPage(_currentPage + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
            }
        }
    </div>
}

@* ===== 新增/編輯 Modal ===== *@
<BaseModalComponent IsVisible="@_isFormVisible"
                    IsVisibleChanged="@((v) => _isFormVisible = v)"
                    Title="@(_editingRow == null ? $"新增 - {_tableDefinition?.TableName}" : $"編輯 - {_tableDefinition?.TableName}")"
                    Icon="@(_tableDefinition?.IconClass ?? "bi bi-table")"
                    Size="BaseModalComponent.ModalSize.Large"
                    CloseOnEscape="true"
                    CloseOnBackdropClick="false"
                    IsLoading="@_isSaving"
                    OnClose="@CloseForm"
                    DebugComponentName="CustomTableDataPage">
    <HeaderButtons>
        <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                               Text="儲存"
                               IconClass="bi bi-check-lg"
                               OnClick="HandleSaveRow"
                               IsDisabled="@_isSaving"
                               IsLoading="@_isSaving" />
        <GenericButtonComponent Variant="ButtonVariant.Red"
                               Text="取消"
                               OnClick="CloseForm" />
    </HeaderButtons>
    <BodyContent>
        @if (_tableDefinition != null)
        {
            <div class="row g-3">
                @foreach (var field in _tableDefinition.FieldDefinitions.Where(f => f.ShowInForm).OrderBy(f => f.SortOrder))
                {
                    <div class="@(field.FieldType == CustomFieldType.TextArea ? "col-12" : "col-md-6")">
                        <label class="form-label fw-semibold">
                            @field.DisplayName
                            @if (field.IsRequired)
                            {
                                <span class="text-danger ms-1">*</span>
                            }
                        </label>
                        @switch (field.FieldType)
                        {
                            case CustomFieldType.Text:
                                <input type="text" class="form-control"
                                       placeholder="@field.Placeholder"
                                       value="@GetFormValue(field.Id)"
                                       @oninput="e => SetFormValue(field.Id, e.Value?.ToString() ?? string.Empty)" />
                                break;
                            case CustomFieldType.TextArea:
                                <textarea class="form-control" rows="3"
                                          placeholder="@field.Placeholder"
                                          value="@GetFormValue(field.Id)"
                                          @oninput="e => SetFormValue(field.Id, e.Value?.ToString() ?? string.Empty)"></textarea>
                                break;
                            case CustomFieldType.Number:
                                <input type="number" class="form-control"
                                       placeholder="@field.Placeholder"
                                       value="@GetFormValue(field.Id)"
                                       @oninput="e => SetFormValue(field.Id, e.Value?.ToString() ?? string.Empty)" />
                                break;
                            case CustomFieldType.Date:
                                <input type="date" class="form-control"
                                       value="@GetFormValue(field.Id)"
                                       @oninput="e => SetFormValue(field.Id, e.Value?.ToString() ?? string.Empty)" />
                                break;
                            case CustomFieldType.DateTime:
                                <input type="datetime-local" class="form-control"
                                       value="@GetFormValue(field.Id)"
                                       @oninput="e => SetFormValue(field.Id, e.Value?.ToString() ?? string.Empty)" />
                                break;
                            case CustomFieldType.Boolean:
                                <div class="form-check mt-2">
                                    <input type="checkbox" class="form-check-input"
                                           id="field_@field.Id"
                                           checked="@(GetFormValue(field.Id) == "true")"
                                           @onchange="e => SetFormValue(field.Id, ((bool)(e.Value ?? false)).ToString().ToLower())" />
                                    <label class="form-check-label" for="field_@field.Id">@field.DisplayName</label>
                                </div>
                                break;
                            case CustomFieldType.Select:
                                <select class="form-select"
                                        value="@GetFormValue(field.Id)"
                                        @onchange="e => SetFormValue(field.Id, e.Value?.ToString() ?? string.Empty)">
                                    <option value="">（請選擇）</option>
                                    @foreach (var opt in GetSelectOptions(field))
                                    {
                                        <option value="@opt">@opt</option>
                                    }
                                </select>
                                break;
                        }
                    </div>
                }
            </div>
        }
    </BodyContent>
</BaseModalComponent>

@* ===== 刪除確認 ===== *@
<GenericConfirmModalComponent IsVisible="@_isDeleteConfirmVisible"
                              IsVisibleChanged="@((v) => _isDeleteConfirmVisible = v)"
                              Title="確認刪除"
                              Icon="bi-trash"
                              Message="@($"確定要刪除這筆資料列嗎？此操作無法復原。")"
                              ConfirmButtonText="確認刪除"
                              ConfirmButtonVariant="ButtonVariant.Red"
                              OnConfirm="ConfirmDeleteRow" />

@code {
    [Parameter] public int TableId { get; set; }

    // ===== 狀態 =====
    private bool _isAuthorized;
    private bool _isLoading = true;
    private bool _isTableLoading;
    private bool _isSaving;

    // ===== 資料 =====
    private CustomTableDefinition? _tableDefinition;
    private List<CustomFieldDefinition> _listFields = new();
    private List<CustomTableRow> _rows = new();
    private int _totalCount;
    private int _currentPage = 1;
    private const int _pageSize = 20;
    private int TotalPages => (int)Math.Ceiling((double)_totalCount / _pageSize);

    // ===== 表單 =====
    private bool _isFormVisible;
    private CustomTableRow? _editingRow;
    private Dictionary<int, string> _formValues = new();

    // ===== 刪除確認 =====
    private bool _isDeleteConfirmVisible;
    private CustomTableRow? _rowToDelete;

    protected override async Task OnInitializedAsync()
    {
        // 權限檢查
        bool isAdmin = await PermissionService.CanAccessAsync("System.Admin");
        _isAuthorized = isAdmin || await PermissionService.CanAccessAsync(PermissionRegistry.System.CustomTable);

        if (!_isAuthorized)
        {
            _isLoading = false;
            return;
        }

        await LoadDefinitionAsync();
        _isLoading = false;

        if (_tableDefinition != null)
        {
            await LoadRowsAsync();
        }
    }

    private async Task LoadDefinitionAsync()
    {
        _tableDefinition = await TableDefinitionService.GetByIdWithFieldsAsync(TableId);
        if (_tableDefinition != null)
        {
            _listFields = _tableDefinition.FieldDefinitions
                .Where(f => f.ShowInList)
                .OrderBy(f => f.SortOrder)
                .ToList();
        }
    }

    private async Task LoadRowsAsync()
    {
        _isTableLoading = true;
        StateHasChanged();
        try
        {
            var (items, total) = await RowService.GetPagedByTableIdAsync(TableId, _currentPage, _pageSize);
            _rows = items;
            _totalCount = total;
        }
        finally
        {
            _isTableLoading = false;
            StateHasChanged();
        }
    }

    private async Task GoToPage(int page)
    {
        _currentPage = page;
        await LoadRowsAsync();
    }

    // ===== 新增/編輯 =====

    private void StartAddRow()
    {
        _editingRow = null;
        _formValues = new Dictionary<int, string>();
        if (_tableDefinition != null)
        {
            foreach (var field in _tableDefinition.FieldDefinitions)
            {
                _formValues[field.Id] = field.DefaultValue ?? (field.FieldType == CustomFieldType.Boolean ? "false" : "");
            }
        }
        _isFormVisible = true;
    }

    private void StartEditRow(CustomTableRow row)
    {
        _editingRow = row;
        _formValues = new Dictionary<int, string>();
        if (_tableDefinition != null)
        {
            foreach (var field in _tableDefinition.FieldDefinitions)
            {
                var existingValue = row.FieldValues.FirstOrDefault(v => v.CustomFieldDefinitionId == field.Id);
                _formValues[field.Id] = existingValue?.Value ?? field.DefaultValue ?? (field.FieldType == CustomFieldType.Boolean ? "false" : "");
            }
        }
        _isFormVisible = true;
    }

    private void CloseForm()
    {
        _isFormVisible = false;
        _editingRow = null;
        _formValues = new();
    }

    private async Task HandleSaveRow()
    {
        if (_tableDefinition == null) return;

        // 必填驗證
        foreach (var field in _tableDefinition.FieldDefinitions.Where(f => f.IsRequired))
        {
            var value = GetFormValue(field.Id);
            if (string.IsNullOrWhiteSpace(value) || (field.FieldType == CustomFieldType.Select && string.IsNullOrEmpty(value)))
            {
                await NotificationService.ShowErrorAsync($"「{field.DisplayName}」為必填欄位");
                return;
            }
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            var fieldValues = _formValues
                .Select(kvp => new CustomFieldValue
                {
                    CustomFieldDefinitionId = kvp.Key,
                    Value = kvp.Value
                })
                .ToList();

            if (_editingRow == null)
            {
                // 新增
                var newRow = new CustomTableRow
                {
                    CustomTableDefinitionId = TableId
                };
                var result = await RowService.CreateRowWithValuesAsync(newRow, fieldValues);
                if (result.IsSuccess)
                {
                    await NotificationService.ShowSuccessAsync("新增成功");
                    CloseForm();
                    await LoadRowsAsync();
                }
                else
                {
                    await NotificationService.ShowErrorAsync(result.ErrorMessage ?? "新增失敗");
                }
            }
            else
            {
                // 更新
                foreach (var fv in fieldValues)
                    fv.CustomTableRowId = _editingRow.Id;

                var result = await RowService.UpdateRowWithValuesAsync(_editingRow, fieldValues);
                if (result.IsSuccess)
                {
                    await NotificationService.ShowSuccessAsync("更新成功");
                    CloseForm();
                    await LoadRowsAsync();
                }
                else
                {
                    await NotificationService.ShowErrorAsync(result.ErrorMessage ?? "更新失敗");
                }
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"儲存失敗：{ex.Message}");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    // ===== 刪除 =====

    private void HandleDeleteRow(CustomTableRow row)
    {
        _rowToDelete = row;
        _isDeleteConfirmVisible = true;
    }

    private async Task ConfirmDeleteRow()
    {
        if (_rowToDelete == null) return;

        var result = await RowService.DeleteAsync(_rowToDelete.Id);
        if (result.IsSuccess)
        {
            await NotificationService.ShowSuccessAsync("已刪除");
            if (_rows.Count == 1 && _currentPage > 1)
                _currentPage--;
            await LoadRowsAsync();
        }
        else
        {
            await NotificationService.ShowErrorAsync(result.ErrorMessage ?? "刪除失敗");
        }
        _rowToDelete = null;
    }

    // ===== 輔助方法 =====

    private string GetFormValue(int fieldId) =>
        _formValues.TryGetValue(fieldId, out var v) ? v : "";

    private void SetFormValue(int fieldId, string value) =>
        _formValues[fieldId] = value;

    private string RenderFieldValue(CustomTableRow row, CustomFieldDefinition field)
    {
        var fv = row.FieldValues.FirstOrDefault(v => v.CustomFieldDefinitionId == field.Id);
        if (fv?.Value == null) return "—";

        return field.FieldType switch
        {
            CustomFieldType.Boolean => fv.Value == "true" ? "是" : "否",
            CustomFieldType.Date => DateTime.TryParse(fv.Value, out var d) ? d.ToString("yyyy/MM/dd") : fv.Value,
            CustomFieldType.DateTime => DateTime.TryParse(fv.Value, out var dt) ? dt.ToString("yyyy/MM/dd HH:mm") : fv.Value,
            _ => fv.Value
        };
    }

    private IEnumerable<string> GetSelectOptions(CustomFieldDefinition field)
    {
        if (string.IsNullOrEmpty(field.Options)) return Enumerable.Empty<string>();
        try
        {
            return JsonSerializer.Deserialize<List<string>>(field.Options) ?? new List<string>();
        }
        catch
        {
            return Enumerable.Empty<string>();
        }
    }
}
