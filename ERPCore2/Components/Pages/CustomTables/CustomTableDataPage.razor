@page "/custom-tables/{TableId:int}"
@rendermode InteractiveServer
@using ERPCore2.Data.Entities.CustomTables
@using ERPCore2.Services.CustomTables
@using System.Text.Json
@using ERPCore2.Models.Navigation

@inject ICustomTableDefinitionService TableDefinitionService
@inject ICustomTableRowService RowService
@inject INotificationService NotificationService
@inject INavigationPermissionService PermissionService
@inject IStringLocalizer<SharedResource> L
@inject NavigationManager NavigationManager

<PageTitle>@(_tableDefinition?.TableName ?? "自訂資料表")</PageTitle>

@if (!_isAuthorized)
{
    <div class="container-fluid p-4">
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-shield-exclamation fs-4 me-3"></i>
            <div>
                <strong>存取被拒</strong><br />
                <span class="text-muted small">您沒有存取此頁面的權限。</span>
            </div>
        </div>
    </div>
}
else if (_isLoading)
{
    <div class="d-flex justify-content-center align-items-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">載入中...</span>
        </div>
    </div>
}
else if (_tableDefinition == null)
{
    <div class="container-fluid p-4">
        <div class="alert alert-warning d-flex align-items-center">
            <i class="bi bi-exclamation-triangle fs-4 me-3"></i>
            <div>
                <strong>找不到資料表</strong><br />
                <span class="text-muted small">此自訂資料表不存在或已被刪除。</span>
            </div>
        </div>
    </div>
}
else
{
    @* ===== 頁面標題 ===== *@
    <GenericHeaderComponent Title="@_tableDefinition.TableName"
                            Subtitle="@_tableDefinition.Description"
                            BreadcrumbItems="@_breadcrumbItems"
                            ShowDivider="true">
        <ActionButtons>
            @* 草稿/正式 Tab *@
            <div class="index-draft-tab-btn-group">
                <button type="button"
                        class="index-draft-tab-btn @(!_showingDrafts ? "active" : "")"
                        @onclick="@(() => SwitchDraftTab(false))">
                    <i class="bi bi-check-circle me-1"></i>
                    @L["Label.Official"]
                </button>
                <button type="button"
                        class="index-draft-tab-btn @(_showingDrafts ? "active" : "")"
                        @onclick="@(() => SwitchDraftTab(true))">
                    <i class="bi bi-pencil-square me-1"></i>
                    @L["Label.Draft"]
                    @if (_draftCount > 0)
                    {
                        <span class="badge bg-danger ms-1">@_draftCount</span>
                    }
                </button>
            </div>

            <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                                   Text="@L["Button.Add"]"
                                   IconClass="bi bi-plus-lg"
                                   OnClick="HandleAdd" />
        </ActionButtons>
    </GenericHeaderComponent>

    @* ===== 搜尋列 ===== *@
    <div class="px-3 mb-2">
        <GenericSearchFilterComponent TModel="SearchFilterModel"
                                     FilterModel="@_searchModel"
                                     OnSearch="@HandleSearch"
                                     AutoSearch="true"
                                     SearchDelayMs="300" />
    </div>

    @* ===== 資料表格 ===== *@
    <div class="px-3">
        @if (_isTableLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <span class="ms-2 text-muted">載入中...</span>
            </div>
        }
        else
        {
            <GenericTableComponent TItem="CustomTableRow"
                                  Items="@_rows"
                                  ColumnDefinitions="@_columnDefinitions"
                                  EnableRowClick="true"
                                  OnRowClick="@HandleRowClick"
                                  IsStriped="true"
                                  IsHoverable="true"
                                  IsBordered="true"
                                  EmptyMessage="@(_showingDrafts ? "尚無草稿資料" : "尚無資料，點擊「新增」開始建立")" />

            <GenericPaginationComponent CurrentPage="@_currentPage"
                                       PageSize="@_pageSize"
                                       TotalItems="@_totalCount"
                                       OnPageChanged="@HandlePageChanged"
                                       OnPageSizeChanged="@HandlePageSizeChanged"
                                       ShowPageSizeSelector="true" />
        }
    </div>
}

@* ===== 編輯 Modal ===== *@
@if (_tableDefinition != null)
{
    <CustomTableEditModalComponent IsVisible="@_showEditModal"
                                   IsVisibleChanged="@((v) => _showEditModal = v)"
                                   RowId="@_editingRowId"
                                   RowIdChanged="@HandleRowIdChanged"
                                   TableDefinitionId="@TableId"
                                   TableDefinition="@_tableDefinition"
                                   OnRowSaved="@HandleRowSaved"
                                   OnCancel="@HandleModalCancel" />
}

@code {
    [Parameter] public int TableId { get; set; }

    // ===== 狀態 =====
    private bool _isAuthorized;
    private bool _isLoading = true;
    private bool _isTableLoading;
    private bool _showingDrafts;
    private int _draftCount;

    // ===== 資料 =====
    private List<BreadcrumbItem> _breadcrumbItems = new();
    private CustomTableDefinition? _tableDefinition;
    private List<CustomTableRow> _rows = new();
    private List<TableColumnDefinition> _columnDefinitions = new();
    private int _totalCount;
    private int _currentPage = 1;
    private int _pageSize = 20;

    // ===== 搜尋 =====
    private SearchFilterModel _searchModel = new();

    // ===== Modal =====
    private bool _showEditModal;
    private int? _editingRowId;

    protected override async Task OnInitializedAsync()
    {
        // 權限檢查
        bool isAdmin = await PermissionService.CanAccessAsync("System.Admin");
        _isAuthorized = isAdmin || await PermissionService.CanAccessAsync(PermissionRegistry.System.CustomTable);

        if (!_isAuthorized)
        {
            _isLoading = false;
            return;
        }

        await LoadDefinitionAsync();
        _isLoading = false;

        if (_tableDefinition != null)
        {
            BuildColumnDefinitions();
            await LoadRowsAsync();
            await LoadDraftCountAsync();
        }
    }

    private async Task LoadDefinitionAsync()
    {
        _tableDefinition = await TableDefinitionService.GetByIdWithFieldsAsync(TableId);
        if (_tableDefinition != null)
        {
            _breadcrumbItems = new List<BreadcrumbItem>
            {
                new("首頁", "/"),
                new(_tableDefinition.TableName)
            };
        }
    }

    // ===== 欄位定義 → 表格欄位 =====

    private void BuildColumnDefinitions()
    {
        if (_tableDefinition == null) return;

        var columns = new List<TableColumnDefinition>();

        // 編號欄
        var codeCol = TableColumnDefinition.Text("編號", nameof(CustomTableRow.Code));
        codeCol.Width = "8%";
        codeCol.CellCssClass = "text-muted";
        columns.Add(codeCol);

        // 動態欄位（ShowInList）
        var listFields = _tableDefinition.FieldDefinitions
            .Where(f => f.ShowInList)
            .OrderBy(f => f.SortOrder)
            .ToList();

        foreach (var field in listFields)
        {
            var capturedField = field;
            columns.Add(TableColumnDefinition.Template(
                field.DisplayName,
                (object item) =>
                {
                    var row = (CustomTableRow)item;
                    return RenderFieldValueFragment(row, capturedField);
                }
            ));
        }

        // 狀態欄
        var statusCol = TableColumnDefinition.Status("狀態", nameof(CustomTableRow.Status),
            new Dictionary<object, string>
            {
                { EntityStatus.Active, "bg-success:啟用" },
                { EntityStatus.Inactive, "bg-secondary:停用" }
            });
        statusCol.Width = "6%";
        statusCol.CellCssClass = "text-center";
        statusCol.HeaderCssClass = "text-center";
        columns.Add(statusCol);

        // 建立時間
        var dateCol = TableColumnDefinition.Date("建立時間", nameof(CustomTableRow.CreatedAt));
        dateCol.Width = "10%";
        columns.Add(dateCol);

        _columnDefinitions = columns;
    }

    private RenderFragment RenderFieldValueFragment(CustomTableRow row, CustomFieldDefinition field)
    {
        return builder =>
        {
            var fv = row.FieldValues.FirstOrDefault(v => v.CustomFieldDefinitionId == field.Id);
            var displayText = FormatFieldValue(fv?.Value, field.FieldType);
            builder.AddContent(0, displayText);
        };
    }

    private static string FormatFieldValue(string? value, CustomFieldType fieldType)
    {
        if (value == null) return "—";
        return fieldType switch
        {
            CustomFieldType.Boolean => value == "true" ? "是" : "否",
            CustomFieldType.Date => DateTime.TryParse(value, out var d) ? d.ToString("yyyy/MM/dd") : value,
            CustomFieldType.DateTime => DateTime.TryParse(value, out var dt) ? dt.ToString("yyyy/MM/dd HH:mm") : value,
            _ => value
        };
    }

    // ===== 資料載入 =====

    private async Task LoadRowsAsync()
    {
        _isTableLoading = true;
        StateHasChanged();
        try
        {
            var searchTerm = _searchModel.TextFilters.TryGetValue("Search", out var s) ? s : null;
            bool? isDraftParam = _showingDrafts ? true : null; // null=正式, true=草稿
            var (items, total) = await RowService.GetPagedByTableIdAsync(
                TableId, _currentPage, _pageSize, searchTerm, isDraftParam);
            _rows = items;
            _totalCount = total;
        }
        finally
        {
            _isTableLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadDraftCountAsync()
    {
        var (_, draftTotal) = await RowService.GetPagedByTableIdAsync(TableId, 1, 1, isDraft: true);
        _draftCount = draftTotal;
    }

    // ===== Tab 切換 =====

    private async Task SwitchDraftTab(bool showDrafts)
    {
        if (_showingDrafts == showDrafts) return;
        _showingDrafts = showDrafts;
        _currentPage = 1;
        await LoadRowsAsync();
    }

    // ===== 搜尋 =====

    private async Task HandleSearch(SearchFilterModel model)
    {
        _searchModel = model;
        _currentPage = 1;
        await LoadRowsAsync();
    }

    // ===== 分頁 =====

    private async Task HandlePageChanged(int page)
    {
        _currentPage = page;
        await LoadRowsAsync();
    }

    private async Task HandlePageSizeChanged(int pageSize)
    {
        _pageSize = pageSize;
        _currentPage = 1;
        await LoadRowsAsync();
    }

    // ===== Modal 操作 =====

    private void HandleAdd()
    {
        _editingRowId = null;
        _showEditModal = true;
    }

    private void HandleRowClick(CustomTableRow row)
    {
        _editingRowId = row.Id;
        _showEditModal = true;
    }

    private async Task HandleRowIdChanged(int? newRowId)
    {
        _editingRowId = newRowId;
    }

    private async Task HandleRowSaved()
    {
        await LoadRowsAsync();
        await LoadDraftCountAsync();
    }

    private void HandleModalCancel()
    {
        _showEditModal = false;
        _editingRowId = null;
    }
}
