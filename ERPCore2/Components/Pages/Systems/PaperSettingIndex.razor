@page "/paper-settings"
@inject IPaperSettingService PaperSettingService
@rendermode InteractiveServer
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<GenericIndexPageComponent TEntity="PaperSetting" 
                      TService="IPaperSettingService"
                      Service="@PaperSettingService"
                      EntityBasePath="/paper-settings"
                      PageTitle="@L["Page.PaperSettingTitle"]"
                      PageSubtitle="@L["Page.PaperSettingSubtitle"]"
                      EntityName="@L["Entity.PaperSetting"]"
                      BreadcrumbItems="@breadcrumbItems"
                      FilterDefinitions="@filterDefinitions"
                      ColumnDefinitions="@columnDefinitions"
                      ServerDataLoader="@ServerLoadPaperSettingsAsync"
                      GetEntityDisplayName="@(paper => paper.Name)"
                      RequiredPermission="@PermissionRegistry.PaperSetting.Read"
                      RequiredModule="Systems"
                      OnAddClick="@modalHandler.ShowAddModalAsync"
                      OnRowClick="@modalHandler.ShowEditModalAsync"
                      DebugPageName="PaperSettingIndex"
                      @ref="indexComponent" />

<PaperSettingEditModalComponent IsVisible="@showEditModal"
                          IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                          PaperSettingId="@editingPaperSettingId"
                          OnPaperSettingSaved="@modalHandler.OnEntitySavedAsync"
                          OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    // 組件參考
    private GenericIndexPageComponent<PaperSetting, IPaperSettingService> indexComponent = default!;
    
    // Modal 相關狀態
    private bool showEditModal = false;
    private int? editingPaperSettingId = null;
    
    // Modal 處理器
    private ModalHandler<PaperSetting, GenericIndexPageComponent<PaperSetting, IPaperSettingService>> modalHandler = default!;
    
    // 欄位配置
    private PaperSettingFieldConfiguration fieldConfiguration = default!;
    
    // 配置相關
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<PaperSetting, GenericIndexPageComponent<PaperSetting, IPaperSettingService>>(
                id => editingPaperSettingId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());
            
            await InitializeBreadcrumbsAsync();
            
            // 建立欄位配置（傳遞 NotificationService）
            fieldConfiguration = new PaperSettingFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            // 使用欄位配置建立篩選器和表格欄位
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化紙張設定頁面失敗");
            await NotificationService.ShowErrorAsync("初始化紙張設定頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("系統管理", "紙張設定", "/systems", NotificationService, GetType());

    private Task<(List<PaperSetting> Items, int TotalCount)> ServerLoadPaperSettingsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return PaperSettingService.GetPagedWithFiltersAsync(
            q =>
            {
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadPaperSettingsAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
