@* 子科目設定 Tab *@

@inject ISubAccountService SubAccountService
@inject INotificationService NotificationService
@inject AuthenticationStateProvider AuthStateProvider
@inject IStringLocalizer<SharedResource> L

<GenericFormComponent TModel="SystemParameter"
                      Model="@Model"
                      FieldDefinitions="@allFields"
                      FieldSections="@fieldSections" />

@* 批次補建子科目（需 SubAccount.BatchCreate 權限） *@
@if (CanBatchCreate)
{
<div class="mt-4 pt-3 border-top">
    <h6 class="mb-3"><i class="bi bi-diagram-3 me-2"></i>@L["SubAccount.BatchCreateTitle"]</h6>
    <p class="text-muted mb-3">@L["SubAccount.BatchCreateDesc"]</p>
    <div class="d-flex flex-wrap gap-2 mb-3">
        <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                               Text="@L["SubAccount.CreateCustomer"]"
                               OnClick="HandleBatchCreateCustomerAsync"
                               IsDisabled="@(isBatchCreating || IsDisabled)"
                               IsLoading="@IsBatchCreatingCustomer"
                               Title="@L["SubAccount.CreateCustomerTitle"]" />
        <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                               Text="@L["SubAccount.CreateSupplier"]"
                               OnClick="HandleBatchCreateSupplierAsync"
                               IsDisabled="@(isBatchCreating || IsDisabled)"
                               IsLoading="@IsBatchCreatingSupplier"
                               Title="@L["SubAccount.CreateSupplierTitle"]" />
        <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                               Text="@L["SubAccount.CreateItem"]"
                               OnClick="HandleBatchCreateItemAsync"
                               IsDisabled="@(isBatchCreating || IsDisabled)"
                               IsLoading="@IsBatchCreatingItem"
                               Title="@L["SubAccount.CreateItemTitle"]" />
    </div>
    @if (!string.IsNullOrEmpty(batchResultMessage))
    {
        <div class="alert @batchResultCssClass py-2 mb-0 small">
            <i class="bi @batchResultIcon me-1"></i>@batchResultMessage
        </div>
    }
</div>
}

@* 確認開啟自動產生子科目 Modal *@
<GenericConfirmModalComponent IsVisible="@showEnableAutoCreateModal"
                              IsVisibleChanged="@(v => showEnableAutoCreateModal = v)"
                              Title="@L["SubAccount.ConfirmEnableAutoCreateTitle"]"
                              Icon="bi-toggle-on"
                              Message="@confirmMessage"
                              ConfirmButtonText="@L["SubAccount.ConfirmEnableYes"]"
                              CancelButtonText="@L["SubAccount.ConfirmEnableNo"]"
                              ConfirmButtonVariant="ButtonVariant.Blue"
                              OnConfirm="HandleEnableAutoCreateConfirmed"
                              OnCancel="HandleEnableAutoCreateDeclined" />

@code {
    [Parameter]
    public SystemParameter Model { get; set; } = new();

    [Parameter]
    public bool IsDisabled { get; set; }

    /// <summary>
    /// 是否有批次補建子科目權限（SubAccount.BatchCreate），由父元件傳入
    /// </summary>
    [Parameter]
    public bool CanBatchCreate { get; set; }

    // 批次補建子科目
    private bool isBatchCreating = false;
    private string batchTarget = string.Empty;
    private string batchResultMessage = string.Empty;
    private string batchResultCssClass = "alert-info";
    private string batchResultIcon = "bi-info-circle";
    private bool IsBatchCreatingCustomer => isBatchCreating && batchTarget == "customer";
    private bool IsBatchCreatingSupplier => isBatchCreating && batchTarget == "supplier";
    private bool IsBatchCreatingItem  => isBatchCreating && batchTarget == "product";

    // 確認開啟自動產生 Modal 狀態
    private bool showEnableAutoCreateModal = false;
    private string confirmMessage = string.Empty;
    private Action<bool>? pendingSetFlag = null;
    private string pendingBatchTarget = string.Empty;
    private Func<string, Task<(int Created, int Skipped, List<string> Errors)>>? pendingBatchFunc = null;
    private string pendingEntityLabel = string.Empty;

    private List<FormFieldDefinition> allFields = new();
    private Dictionary<string, string> fieldSections = new();

    protected override void OnInitialized()
    {
        var customerSection = L["Section.CustomerSubAccount"].ToString();
        var supplierSection = L["Section.SupplierSubAccount"].ToString();
        var itemSection     = L["Section.ItemSubAccount"].ToString();
        var generalSection  = L["Section.GeneralSetting"].ToString();

        allFields = new List<FormFieldDefinition>
        {
            // ===== 客戶子科目設定 =====
            new FormFieldDefinition { PropertyName = "AutoCreateCustomerSubAccount",        Label = L["Field.CustomerSubAccount"],       FieldType = FormFieldType.Checkbox },
            new FormFieldDefinition { PropertyName = "CustomerSubAccountParentCode",        Label = L["Field.CustomerReceivableAccount"], FieldType = FormFieldType.Text, Placeholder = "預設：1191", MaxLength = 20 },
            new FormFieldDefinition { PropertyName = "CustomerNoteSubAccountParentCode",    Label = L["Field.CustomerNoteAccount"],       FieldType = FormFieldType.Text, Placeholder = "預設：1181", MaxLength = 20 },
            new FormFieldDefinition { PropertyName = "CustomerReturnSubAccountParentCode",  Label = L["Field.CustomerReturnAccount"],     FieldType = FormFieldType.Text, Placeholder = "預設：4113", MaxLength = 20 },
            new FormFieldDefinition { PropertyName = "CustomerAdvanceSubAccountParentCode", Label = L["Field.CustomerAdvanceAccount"],    FieldType = FormFieldType.Text, Placeholder = "預設：2221", MaxLength = 20 },
            // ===== 廠商子科目設定 =====
            new FormFieldDefinition { PropertyName = "AutoCreateSupplierSubAccount",        Label = L["Field.SupplierSubAccount"],       FieldType = FormFieldType.Checkbox },
            new FormFieldDefinition { PropertyName = "SupplierSubAccountParentCode",        Label = L["Field.SupplierPayableAccount"],   FieldType = FormFieldType.Text, Placeholder = "預設：2171", MaxLength = 20 },
            new FormFieldDefinition { PropertyName = "SupplierNoteSubAccountParentCode",    Label = L["Field.SupplierNoteAccount"],      FieldType = FormFieldType.Text, Placeholder = "預設：2161", MaxLength = 20 },
            new FormFieldDefinition { PropertyName = "SupplierReturnSubAccountParentCode",  Label = L["Field.SupplierReturnAccount"],    FieldType = FormFieldType.Text, Placeholder = "預設：5123", MaxLength = 20 },
            new FormFieldDefinition { PropertyName = "SupplierAdvanceSubAccountParentCode", Label = L["Field.SupplierAdvanceAccount"],   FieldType = FormFieldType.Text, Placeholder = "預設：1266", MaxLength = 20 },
            // ===== 品項子科目設定 =====
            new FormFieldDefinition { PropertyName = "AutoCreateItemSubAccount",            Label = L["Field.ItemSubAccount"],           FieldType = FormFieldType.Checkbox },
            new FormFieldDefinition { PropertyName = "ItemSubAccountParentCode",            Label = L["Field.ItemInventoryAccount"],     FieldType = FormFieldType.Text, Placeholder = "預設：1231", MaxLength = 20 },
            // ===== 通用設定 =====
            new FormFieldDefinition
            {
                PropertyName = "SubAccountCodeFormat",
                Label = L["Field.SubAccountCodeFormat"],
                FieldType = FormFieldType.Select,
                Options = new List<SelectOption>
                {
                    new() { Value = "0", Text = L["Option.Sequential"] },
                    new() { Value = "1", Text = L["Option.EntityCode"] }
                },
                LabelHelpItems = new List<LabelHelpItem>
                {
                    new() { Title = "流水號", Description = "依序產生三位流水號，例：1191.001、1191.002。簡潔整齊，適合大量客戶/廠商。" },
                    new() { Title = "實體編碼", Description = "使用客戶/廠商/品項的代碼作為後綴，例：1191.C0001。一眼可辨認對應實體，適合代碼有意義的場景。" }
                }
            },
        };

        fieldSections = new Dictionary<string, string>
        {
            // 客戶
            { "AutoCreateCustomerSubAccount",        customerSection },
            { "CustomerSubAccountParentCode",        customerSection },
            { "CustomerNoteSubAccountParentCode",    customerSection },
            { "CustomerReturnSubAccountParentCode",  customerSection },
            { "CustomerAdvanceSubAccountParentCode", customerSection },
            // 廠商
            { "AutoCreateSupplierSubAccount",        supplierSection },
            { "SupplierSubAccountParentCode",        supplierSection },
            { "SupplierNoteSubAccountParentCode",    supplierSection },
            { "SupplierReturnSubAccountParentCode",  supplierSection },
            { "SupplierAdvanceSubAccountParentCode", supplierSection },
            // 品項
            { "AutoCreateItemSubAccount",            itemSection },
            { "ItemSubAccountParentCode",            itemSection },
            // 通用
            { "SubAccountCodeFormat",                generalSection },
        };
    }

    // ===== 批次補建子科目 =====

    private async Task<string> GetCurrentUserAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            return authState.User.Identity?.Name ?? "system";
        }
        catch
        {
            return "system";
        }
    }

    private async Task HandleBatchCreateCustomerAsync()
    {
        if (!Model.AutoCreateCustomerSubAccount)
        {
            StorePendingBatchCreate(
                "customer",
                v => Model.AutoCreateCustomerSubAccount = v,
                async (createdBy) => await SubAccountService.BatchCreateForAllCustomersAsync(createdBy),
                L["Entity.Customer"].ToString());
            return;
        }

        await ExecuteBatchCreateAsync("customer", async (createdBy) =>
            await SubAccountService.BatchCreateForAllCustomersAsync(createdBy), L["Entity.Customer"].ToString());
    }

    private async Task HandleBatchCreateSupplierAsync()
    {
        if (!Model.AutoCreateSupplierSubAccount)
        {
            StorePendingBatchCreate(
                "supplier",
                v => Model.AutoCreateSupplierSubAccount = v,
                async (createdBy) => await SubAccountService.BatchCreateForAllSuppliersAsync(createdBy),
                L["Entity.Supplier"].ToString());
            return;
        }

        await ExecuteBatchCreateAsync("supplier", async (createdBy) =>
            await SubAccountService.BatchCreateForAllSuppliersAsync(createdBy), L["Entity.Supplier"].ToString());
    }

    private async Task HandleBatchCreateItemAsync()
    {
        if (!Model.AutoCreateItemSubAccount)
        {
            StorePendingBatchCreate(
                "product",
                v => Model.AutoCreateItemSubAccount = v,
                async (createdBy) => await SubAccountService.BatchCreateForAllItemsAsync(createdBy),
                L["Entity.Item"].ToString());
            return;
        }

        await ExecuteBatchCreateAsync("product", async (createdBy) =>
            await SubAccountService.BatchCreateForAllItemsAsync(createdBy), L["Entity.Item"].ToString());
    }

    /// <summary>
    /// 暫存待執行的批次補建資訊，並顯示確認 Modal
    /// </summary>
    private void StorePendingBatchCreate(
        string target,
        Action<bool> setFlag,
        Func<string, Task<(int Created, int Skipped, List<string> Errors)>> batchFunc,
        string entityLabel)
    {
        pendingBatchTarget = target;
        pendingSetFlag = setFlag;
        pendingBatchFunc = batchFunc;
        pendingEntityLabel = entityLabel;
        confirmMessage = string.Format(L["SubAccount.ConfirmEnableAutoCreate"], entityLabel);
        showEnableAutoCreateModal = true;
    }

    /// <summary>
    /// 使用者確認開啟自動產生 → 設定開關 + 執行批次補建
    /// </summary>
    private async Task HandleEnableAutoCreateConfirmed()
    {
        pendingSetFlag?.Invoke(true);
        showEnableAutoCreateModal = false;
        StateHasChanged();

        if (pendingBatchFunc != null)
        {
            await ExecuteBatchCreateAsync(pendingBatchTarget, pendingBatchFunc, pendingEntityLabel);
        }
        ClearPendingState();
    }

    /// <summary>
    /// 使用者選擇不開啟自動產生 → 仍執行批次補建（僅補建，不啟用自動產生）
    /// </summary>
    private async Task HandleEnableAutoCreateDeclined()
    {
        showEnableAutoCreateModal = false;
        StateHasChanged();

        if (pendingBatchFunc != null)
        {
            await ExecuteBatchCreateAsync(pendingBatchTarget, pendingBatchFunc, pendingEntityLabel);
        }
        ClearPendingState();
    }

    /// <summary>清除暫存的待執行狀態</summary>
    private void ClearPendingState()
    {
        pendingSetFlag = null;
        pendingBatchFunc = null;
        pendingBatchTarget = string.Empty;
        pendingEntityLabel = string.Empty;
        confirmMessage = string.Empty;
    }

    private async Task ExecuteBatchCreateAsync(
        string target,
        Func<string, Task<(int Created, int Skipped, List<string> Errors)>> batchFunc,
        string entityLabel)
    {
        try
        {
            isBatchCreating = true;
            batchTarget = target;
            batchResultMessage = string.Empty;
            StateHasChanged();

            var createdBy = await GetCurrentUserAsync();
            var (created, skipped, errors) = await batchFunc(createdBy);

            if (errors.Count == 0)
            {
                batchResultMessage = string.Format(L["SubAccount.CreateResult"], entityLabel, created, skipped);
                batchResultCssClass = "alert-success";
                batchResultIcon = "bi-check-circle";
            }
            else
            {
                batchResultMessage = string.Format(L["SubAccount.CreateResultWithErrors"], entityLabel, created, skipped, errors.Count, string.Join("；", errors.Take(3)), errors.Count > 3 ? L["SubAccount.Ellipsis"].ToString() : "");
                batchResultCssClass = "alert-warning";
                batchResultIcon = "bi-exclamation-triangle";
            }
        }
        catch (Exception ex)
        {
            batchResultMessage = string.Format(L["SubAccount.CreateError"], entityLabel, ex.Message);
            batchResultCssClass = "alert-danger";
            batchResultIcon = "bi-x-circle";
            await NotificationService.ShowErrorAsync(string.Format(L["SubAccount.CreateErrorNotify"], entityLabel));
        }
        finally
        {
            isBatchCreating = false;
            batchTarget = string.Empty;
            StateHasChanged();
        }
    }

    /// <summary>
    /// 清除批次結果訊息（主檔關閉時呼叫）
    /// </summary>
    public void ClearBatchResult()
    {
        batchResultMessage = string.Empty;
        batchResultCssClass = "alert-info";
        batchResultIcon = "bi-info-circle";
    }
}
