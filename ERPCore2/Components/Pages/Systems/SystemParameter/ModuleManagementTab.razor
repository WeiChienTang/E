@* 模組管理 Tab（SuperAdmin 限定） *@

@inject ICompanyModuleService CompanyModuleService
@inject INotificationService NotificationService
@inject AuthenticationStateProvider AuthStateProvider
@inject IStringLocalizer<SharedResource> L

<div class="mt-2">
    <p class="text-muted mb-3">@L["System.ModuleControlDesc"]</p>
    <div class="d-flex gap-2 mb-3">
        <GenericButtonComponent Text="@L["Button.EnableAll"]"
                                Variant="ButtonVariant.Green"
                                IsDisabled="@(isModuleSaving || IsDisabled)"
                                OnClick="@EnableAll" />
        <GenericButtonComponent Text="@L["Button.DisableAll"]"
                                Variant="ButtonVariant.Gray"
                                IsDisabled="@(isModuleSaving || IsDisabled)"
                                OnClick="@DisableAll" />
    </div>
    <div class="row row-cols-2 row-cols-md-3 row-cols-xl-4 g-2 mb-3">
        @foreach (var module in companyModules)
        {
            var m = module;
            <div class="col">
                <div class="card h-100 @(m.IsEnabled ? "border-success" : "border-secondary")"
                     style="cursor: @(isModuleSaving || IsDisabled ? "not-allowed" : "pointer")"
                     @onclick="@(() => { if (!isModuleSaving && !IsDisabled) m.IsEnabled = !m.IsEnabled; })">
                    <div class="card-body p-2 d-flex flex-column gap-1">
                        <div class="d-flex justify-content-between align-items-start">
                            <strong class="small">@m.DisplayName</strong>
                            <span class="badge @(m.IsEnabled ? "bg-success" : "bg-secondary") ms-1 flex-shrink-0">
                                @(m.IsEnabled ? L["System.Enabled"].ToString() : L["System.Disabled"].ToString())
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public bool IsDisabled { get; set; }

    private List<CompanyModule> companyModules = new();
    private bool isModuleSaving = false;

    private void EnableAll()
    {
        foreach (var module in companyModules)
            module.IsEnabled = true;
    }

    private void DisableAll()
    {
        foreach (var module in companyModules)
            module.IsEnabled = false;
    }

    protected override async Task OnInitializedAsync()
    {
        companyModules = await CompanyModuleService.GetAllAsync();
    }

    private async Task<string> GetCurrentUserAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            return authState.User.Identity?.Name ?? "system";
        }
        catch
        {
            return "system";
        }
    }

    public async Task SaveAsync()
    {
        try
        {
            isModuleSaving = true;
            StateHasChanged();

            var createdBy = await GetCurrentUserAsync();
            var result = await CompanyModuleService.UpdateModulesAsync(companyModules, createdBy);

            if (!result.IsSuccess)
            {
                await NotificationService.ShowErrorAsync($"{L["Message.SaveFailed"]}：{result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"{L["Message.SaveFailed"]}：{ex.Message}");
        }
        finally
        {
            isModuleSaving = false;
            StateHasChanged();
        }
    }
}
