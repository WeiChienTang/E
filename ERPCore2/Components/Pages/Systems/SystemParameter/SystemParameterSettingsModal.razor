@* 系統參數設定 Modal - 主檔（Tab 切換與共用 CRUD 操作） *@
@using ERPCore2.Data.Entities
@using ERPCore2.Data.Navigation
@using ERPCore2.Helpers.EditModal
@using System.ComponentModel.DataAnnotations

@inject ISystemParameterService SystemParameterService
@inject IEmployeeService EmployeeService
@inject IPermissionService PermissionService
@inject INotificationService NotificationService
@inject AuthenticationStateProvider AuthStateProvider
@inject IStringLocalizer<SharedResource> L

<BaseModalComponent IsVisible="@IsVisible"
                    IsVisibleChanged="@IsVisibleChanged"
                    Title="@L["SystemParam.Title"]"
                    Icon="bi-gear-fill"
                    Size="BaseModalComponent.ModalSize.Desktop"
                    CloseOnEscape="true"
                    CloseOnBackdropClick="false"
                    IsLoading="@isLoading"
                    ErrorMessage="@errorMessage"
                    ShowFooter="@(systemParameter.Id > 0)"
                    AuditInfo="@GetAuditInfo()"
                    OnClose="@HandleClose"
                    DebugComponentName="@DebugName">
    <HeaderButtons>
        <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                               Text="@L["Button.Confirm"]"
                               OnClick="HandleSaveAsync"
                               IsDisabled="@(isSaving || isLoading)"
                               IsLoading="@isSaving"
                               Title="@L["SystemParam.SaveTitle"]" />
        <GenericButtonComponent Variant="ButtonVariant.Green"
                               Text="@L["Button.Refresh"]"
                               OnClick="ReloadData"
                               IsDisabled="@(isSaving || isLoading)"
                               Title="@L["SystemParam.RefreshTitle"]" />
        <GenericButtonComponent Variant="ButtonVariant.Yellow"
                               Text="@L["Button.ResetToDefault"]"
                               OnClick="HandleResetToDefault"
                               IsDisabled="@(isSaving || isLoading)"
                               Title="@L["SystemParam.ResetTitle"]" />
        <GenericButtonComponent Variant="ButtonVariant.Red"
                               Text="@L["Button.Cancel"]"
                               OnClick="HandleClose"
                               Title="@L["SystemParam.CloseTitle"]" />
    </HeaderButtons>
    <BodyContent>
        <GenericFormComponent TModel="SystemParameter"
                              Model="@systemParameter"
                              FieldDefinitions="@allFields"
                              FieldSections="@fieldSections"
                              TabDefinitions="@tabDefinitions"
                              OnTabChanged="@HandleTabChanged" />

    </BodyContent>
</BaseModalComponent>

@* 恢復預設確認對話框 *@
<GenericConfirmModalComponent IsVisible="@isResetConfirmVisible"
                              IsVisibleChanged="@((value) => isResetConfirmVisible = value)"
                              Title="@L["SystemParam.ResetConfirmTitle"]"
                              Icon="bi-arrow-counterclockwise"
                              Message="@L["SystemParam.ResetConfirmMessage"]"
                              ConfirmButtonText="@L["SystemParam.ResetConfirmButton"]"
                              ConfirmButtonVariant="ButtonVariant.Yellow"
                              OnConfirm="ConfirmResetToDefault" />

@code {
    // ===== 參數 =====

    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    // ===== 狀態變數 =====

    private bool isLoading = false;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private SystemParameter systemParameter = new();
    private bool isResetConfirmVisible = false;

    // Tab 子元件參考
    private SubAccountSettingsTab? subAccountTab;
    private ModuleManagementTab? moduleManagementTab;
    private ApprovalSettingsTab? approvalSettingsTab;

    // Tab 與權限
    private bool isSuperAdmin = false;
    private bool hasSubAccountRead = false;
    private bool hasSubAccountBatchCreate = false;
    private bool hasPayrollRateTable = false;

    // ===== 表單欄位與 Tab 定義（所有 Tab 使用 CustomContent，欄位定義為空） =====

    private readonly List<FormFieldDefinition> allFields = new();
    private readonly Dictionary<string, string> fieldSections = new();
    private List<FormTabDefinition> tabDefinitions = new();

    // Debug Tab 追蹤（僅 SuperAdmin 可見的 Debug Bar 使用）
    private int _activeTabIndex = 0;

    private string DebugName
    {
        get
        {
            if (_activeTabIndex < 0 || _activeTabIndex >= tabDefinitions.Count)
                return "SystemParameterSettingsModal";
            var tabDebugName = tabDefinitions[_activeTabIndex].DebugComponentName;
            return string.IsNullOrEmpty(tabDebugName)
                ? "SystemParameterSettingsModal"
                : $"SystemParameterSettingsModal > {tabDebugName}";
        }
    }

    private void HandleTabChanged(int index)
    {
        _activeTabIndex = index;
        StateHasChanged();
    }

    // ===== Tab 內容 RenderFragment =====

    private RenderFragment CreateTaxTabContent() => __builder =>
    {
        <TaxSettingsTab Model="@systemParameter" />
    };

    private RenderFragment CreateSubAccountTabContent() => __builder =>
    {
        <SubAccountSettingsTab @ref="subAccountTab"
                               Model="@systemParameter"
                               IsDisabled="@(isSaving || isLoading)"
                               CanBatchCreate="@hasSubAccountBatchCreate" />
    };

    private RenderFragment CreatePayrollSettingsTabContent() => __builder =>
    {
        <PayrollSettingsTab Model="@systemParameter" />
    };

    private RenderFragment CreateCertificateTabContent() => __builder =>
    {
        <CertificateTab />
    };

    private RenderFragment CreateModuleManagementTabContent() => __builder =>
    {
        <ModuleManagementTab @ref="moduleManagementTab"
                             IsDisabled="@(isSaving || isLoading)" />
    };

    private RenderFragment CreateApprovalSettingsTabContent() => __builder =>
    {
        <ApprovalSettingsTab @ref="approvalSettingsTab"
                             Model="@systemParameter" />
    };

    // ===== 生命週期方法 =====

    protected override void OnInitialized()
    {
        _activeTabIndex = 0;
        tabDefinitions = new List<FormTabDefinition>
        {
            new() { Label = L["Section.TaxSettings"],    Icon = "bi bi-cash-stack", SectionNames = new(), CustomContent = CreateTaxTabContent(),         DebugComponentName = nameof(TaxSettingsTab) },
            // 子科目 Tab 由 OnInitializedAsync 權限檢查後動態加入
            // 安全憑證 Tab 暫時停用（HTTPS 自簽憑證方案未完成，詳見 README_HTTPS憑證設計(失敗).md）
            // new() { Label = "安全憑證", Icon = "bi bi-shield-lock", SectionNames = new(), CustomContent = CreateCertificateTabContent(), DebugComponentName = "CertificateTab" },
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        // 檢查當前使用者是否為超級管理員（根據 Employee.IsSuperAdmin 欄位）
        try
        {
            isSuperAdmin = await EmployeeService.IsSuperAdminAsync();
        }
        catch { }

        // 檢查子科目相關權限
        await CheckSubAccountPermissionsAsync();

        // 有 SubAccount.Read 權限（或 SuperAdmin）才加入子科目設定 Tab
        if (hasSubAccountRead || isSuperAdmin)
        {
            // 插入在稅務設定之後（index 1）
            tabDefinitions.Insert(1, new FormTabDefinition
            {
                Label = L["Tab.SubAccountSettings"],
                Icon = "bi bi-diagram-3",
                SectionNames = new(),
                CustomContent = CreateSubAccountTabContent(),
                DebugComponentName = nameof(SubAccountSettingsTab)
            });
        }

        // 有 Payroll.RateTable 權限（或 SuperAdmin）才加入薪資管理 Tab
        await CheckPayrollPermissionsAsync();
        if (hasPayrollRateTable || isSuperAdmin)
        {
            tabDefinitions.Add(new FormTabDefinition
            {
                Label = L["Tab.PayrollSettings"],
                Icon = "bi bi-cash-coin",
                SectionNames = new(),
                CustomContent = CreatePayrollSettingsTabContent(),
                DebugComponentName = nameof(PayrollSettingsTab)
            });
        }

        // SuperAdmin 才加入審核設定與模組管理 Tab
        if (isSuperAdmin)
        {
            tabDefinitions.Add(new FormTabDefinition
            {
                Label = L["Tab.ApprovalSettings"],
                Icon = "bi bi-check2-square",
                SectionNames = new(),
                CustomContent = CreateApprovalSettingsTabContent(),
                DebugComponentName = nameof(ApprovalSettingsTab)
            });

            tabDefinitions.Add(new FormTabDefinition
            {
                Label = L["Tab.ModuleManagement"],
                Icon = "bi bi-toggles",
                SectionNames = new(),
                CustomContent = CreateModuleManagementTabContent(),
                DebugComponentName = nameof(ModuleManagementTab)
            });
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && systemParameter.Id == 0 && !isLoading)
        {
            await LoadSystemParameterAsync();
        }
    }

    // ===== 權限檢查 =====

    /// <summary>
    /// 檢查當前使用者的子科目相關權限（SubAccount.Read / SubAccount.BatchCreate）
    /// </summary>
    private async Task CheckSubAccountPermissionsAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState?.User;
            if (user?.Identity?.IsAuthenticated != true) return;

            var employeeIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!int.TryParse(employeeIdClaim, out int employeeId)) return;

            // 檢查 AccountItem.SubAccountRead
            var readResult = await PermissionService.HasPermissionAsync(employeeId, PermissionRegistry.AccountItem.SubAccountRead);
            hasSubAccountRead = readResult.IsSuccess && readResult.Data;

            // 檢查 AccountItem.SubAccountBatchCreate
            var batchResult = await PermissionService.HasPermissionAsync(employeeId, PermissionRegistry.AccountItem.SubAccountBatchCreate);
            hasSubAccountBatchCreate = batchResult.IsSuccess && batchResult.Data;
        }
        catch
        {
            hasSubAccountRead = false;
            hasSubAccountBatchCreate = false;
        }
    }

    private async Task CheckPayrollPermissionsAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState?.User;
            if (user?.Identity?.IsAuthenticated != true) return;

            var employeeIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!int.TryParse(employeeIdClaim, out int employeeId)) return;

            var result = await PermissionService.HasPermissionAsync(employeeId, PermissionRegistry.Payroll.RateTable);
            hasPayrollRateTable = result.IsSuccess && result.Data;
        }
        catch
        {
            hasPayrollRateTable = false;
        }
    }

    // ===== 資料載入 =====

    private async Task LoadSystemParameterAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            StateHasChanged();

            var existingParameter = await SystemParameterService.GetSystemParameterAsync();

            if (existingParameter != null)
            {
                systemParameter = existingParameter;
            }
            else
            {
                systemParameter = new SystemParameter();
                SystemParameterDefaults.ApplyDefaults(systemParameter);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"載入系統參數時發生錯誤：{ex.Message}";
            await NotificationService.ShowErrorAsync("載入系統參數失敗");

            systemParameter = new SystemParameter();
            SystemParameterDefaults.ApplyDefaults(systemParameter);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // ===== 儲存 =====

    private async Task HandleSaveAsync()
    {
        if (isSaving) return;

        try
        {
            isSaving = true;
            StateHasChanged();

            // 程式化驗證
            var validationContext = new ValidationContext(systemParameter);
            var validationResults = new List<ValidationResult>();
            if (!Validator.TryValidateObject(systemParameter, validationContext, validationResults, true))
            {
                var errors = string.Join("、", validationResults.Select(r => r.ErrorMessage));
                await NotificationService.ShowErrorAsync($"驗證失敗：{errors}");
                return;
            }

            ServiceResult<SystemParameter> result;

            if (systemParameter.Id > 0)
            {
                result = await SystemParameterService.UpdateAsync(systemParameter);
            }
            else
            {
                result = await SystemParameterService.CreateAsync(systemParameter);
            }

            if (result.IsSuccess)
            {
                if (result.Data != null)
                {
                    systemParameter = result.Data;
                }

                if (isSuperAdmin && moduleManagementTab != null)
                {
                    await moduleManagementTab.SaveAsync();
                }

                await NotificationService.ShowSuccessAsync(L["SystemParam.SaveSuccess"]);
            }
            else
            {
                var errorMsg = !string.IsNullOrEmpty(result.ErrorMessage)
                    ? result.ErrorMessage
                    : L["SystemParam.SaveFailed"].ToString();
                await NotificationService.ShowErrorAsync(string.Format(L["SystemParam.SaveFailed"], errorMsg));
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"儲存系統參數時發生錯誤：{ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    // ===== 重整 =====

    private async Task ReloadData()
    {
        await LoadSystemParameterAsync();
        await NotificationService.ShowSuccessAsync(L["SystemParam.DataReloaded"]);
    }

    // ===== 關閉 =====

    private async Task HandleClose()
    {
        subAccountTab?.ClearBatchResult();

        if (IsVisibleChanged.HasDelegate)
        {
            await IsVisibleChanged.InvokeAsync(false);
        }
    }

    // ===== 審計資訊 =====

    private BaseModalComponent.ModalAuditInfo? GetAuditInfo()
    {
        if (systemParameter.Id == 0) return null;
        return new BaseModalComponent.ModalAuditInfo
        {
            CreatedAt = systemParameter.CreatedAt,
            CreatedBy = systemParameter.CreatedBy ?? L["SystemParam.System"].ToString(),
            UpdatedAt = systemParameter.UpdatedAt,
            UpdatedBy = !string.IsNullOrEmpty(systemParameter.UpdatedBy) ? systemParameter.UpdatedBy : (systemParameter.UpdatedAt.HasValue ? L["SystemParam.System"].ToString() : null)
        };
    }

    // ===== 恢復預設 =====

    private void HandleResetToDefault()
    {
        isResetConfirmVisible = true;
    }

    private async Task ConfirmResetToDefault()
    {
        try
        {
            isSaving = true;
            StateHasChanged();

            var result = await SystemParameterService.ResetToDefaultAsync();

            if (result.IsSuccess)
            {
                await NotificationService.ShowSuccessAsync(L["SystemParam.ResetSuccess"]);
                await LoadSystemParameterAsync();
            }
            else
            {
                var errorMsg = !string.IsNullOrEmpty(result.ErrorMessage)
                    ? result.ErrorMessage
                    : L["SystemParam.ResetFailed"].ToString();
                await NotificationService.ShowErrorAsync(string.Format(L["SystemParam.ResetFailed"], errorMsg));
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"恢復預設時發生錯誤：{ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }
}
