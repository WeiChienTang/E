@* 公司 Logo Tab - 結構與 BusinessCardTab 一致 *@
@inject ICompanyService CompanyService
@inject INotificationService NotificationService
@inject IWebHostEnvironment Environment
@inject IStringLocalizer<SharedResource> L

@if (!CompanyId.HasValue || CompanyId.Value <= 0)
{
    <div class="text-center text-muted py-4">
        <i class="bi bi-image fs-1 d-block mb-2"></i>
        <span>@L["CompanyLogo.SaveFirst"]</span>
    </div>
}
else
{
    <div class="business-card-tab">

        @* Header - 與 BusinessCardTab 相同佈局 *@
        <div class="d-flex align-items-center justify-content-between mb-3">
            <span class="fw-semibold">@L["Tab.CompanyLogo"]</span>
            <label class="btn btn-sm btn-outline-primary" style="cursor:pointer; margin-bottom:0;">
                <i class="bi bi-upload me-1"></i>
                @(string.IsNullOrEmpty(currentLogoPath) ? L["CompanyLogo.Upload"] : L["CompanyLogo.Change"])
                <InputFile OnChange="@HandleFileSelected" accept=".jpg,.jpeg,.png,.gif,.svg" class="d-none" />
            </label>
        </div>

        @if (!string.IsNullOrEmpty(uploadError))
        {
            <div class="alert alert-danger py-2 mb-2">@uploadError</div>
        }

        @if (isUploading)
        {
            <div class="text-center text-muted py-3">
                <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                @L["Label.PleaseWait"]
            </div>
        }

        @* 空狀態 *@
        @if (string.IsNullOrEmpty(currentLogoPath))
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-image fs-1 d-block mb-2"></i>
                <span>@L["CompanyLogo.NoLogo"]</span>
            </div>
        }
        else
        {
            @* 單張 Logo 卡片 - 與 BusinessCardTab 相同卡片結構 *@
            <div class="business-card-grid">
                <div class="business-card-item">
                    <div class="business-card-photo-wrapper">
                        <img src="@currentLogoPath" alt="Company Logo"
                             class="business-card-photo"
                             @onclick="OpenPreview" />
                    </div>
                    <div class="business-card-info px-2 py-1">
                        <span class="fw-semibold small">@L["Entity.Company"]</span>
                        <span class="text-muted small d-block">@L["CompanyLogo.Hint"]</span>
                    </div>
                    <div class="business-card-actions px-2 pb-2 d-flex gap-1">
                        <button class="btn btn-xs btn-outline-secondary flex-fill"
                                title="@L["Button.Preview"]"
                                type="button"
                                @onclick="OpenPreview">
                            <i class="bi bi-eye"></i>
                        </button>
                        <button class="btn btn-xs btn-outline-danger flex-fill"
                                title="@L["Button.Delete"]"
                                type="button"
                                @onclick="RequestDelete">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* 刪除確認 Modal *@
<GenericConfirmModalComponent IsVisible="@showDeleteModal"
                              IsVisibleChanged="@((bool v) => showDeleteModal = v)"
                              Title="@L["CompanyLogo.Delete"]"
                              Icon="bi-trash"
                              Message="@L["CompanyLogo.DeleteMessage"]"
                              ConfirmButtonText="@L["Button.ConfirmDelete"]"
                              CancelButtonText="@L["Button.Cancel"]"
                              ConfirmButtonVariant="ButtonVariant.Red"
                              OnConfirm="@ConfirmDeleteAsync"
                              OnCancel="@(() => showDeleteModal = false)" />

@* 預覽 Modal *@
@if (showPreview)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.7); cursor:pointer;" @onclick="ClosePreview">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@L["Tab.CompanyLogo"]</h5>
                    <button type="button" class="btn-close" @onclick="ClosePreview"></button>
                </div>
                <div class="modal-body text-center p-2">
                    <img src="@currentLogoPath" class="img-fluid" alt="Company Logo" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? CompanyId { get; set; }
    [Parameter] public string? InitialLogoPath { get; set; }

    private string? currentLogoPath;
    private bool isUploading = false;
    private string? uploadError = null;
    private bool showDeleteModal = false;
    private bool showPreview = false;
    private int? _loadedCompanyId;

    protected override void OnParametersSet()
    {
        if (CompanyId != _loadedCompanyId)
        {
            _loadedCompanyId = CompanyId;
            currentLogoPath = InitialLogoPath;
            uploadError = null;
        }
    }

    // ===== 公開方法（供主組件透過 @ref 呼叫） =====

    public void LoadAsync(int companyId, string? logoPath)
    {
        currentLogoPath = logoPath;
        uploadError = null;
        StateHasChanged();
    }

    public void Clear()
    {
        currentLogoPath = null;
        uploadError = null;
        StateHasChanged();
    }

    // ===== 上傳 =====

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        if (!CompanyId.HasValue || CompanyId.Value <= 0) return;

        uploadError = null;
        isUploading = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            var (success, message, filePath) = await FileUploadHelper.UploadCompanyLogoAsync(
                file, CompanyId.Value, Environment, currentLogoPath);

            if (!success)
            {
                uploadError = message;
                return;
            }

            var result = await CompanyService.UpdateLogoPathAsync(CompanyId.Value, filePath!);
            if (result.IsSuccess)
            {
                currentLogoPath = filePath;
                await NotificationService.ShowSuccessAsync(L["CompanyLogo.UploadSuccess"]);
            }
            else
            {
                uploadError = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            uploadError = $"上傳失敗：{ex.Message}";
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    // ===== 刪除 =====

    private void RequestDelete()
    {
        showDeleteModal = true;
        StateHasChanged();
    }

    private async Task ConfirmDeleteAsync()
    {
        if (string.IsNullOrEmpty(currentLogoPath)) return;

        try
        {
            FileUploadHelper.DeleteFile(currentLogoPath, Environment);
            var result = await CompanyService.ClearLogoAsync(CompanyId!.Value);
            if (result.IsSuccess)
            {
                currentLogoPath = null;
                await NotificationService.ShowSuccessAsync(L["CompanyLogo.DeleteSuccess"]);
            }
            else
            {
                await NotificationService.ShowErrorAsync(result.ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"刪除失敗：{ex.Message}");
        }
        finally
        {
            showDeleteModal = false;
            StateHasChanged();
        }
    }

    // ===== 預覽 =====

    private void OpenPreview()
    {
        showPreview = true;
        StateHasChanged();
    }

    private void ClosePreview()
    {
        showPreview = false;
        StateHasChanged();
    }
}
