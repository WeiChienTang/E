    /// <summary>
    /// 全部沖款 - 將所有未結清項目的本次沖款填滿至未沖款餘額
    /// </summary>
    private async Task FillAllSetoffAmounts()
    {
        if (IsReadOnly) return;

        try
        {
            int filledCount = 0;
            
            foreach (var item in SetoffItems)
            {
                if (item.UnsettledDetail != null)
                {
                    var baseRemainingAmount = item.UnsettledDetail.RemainingAmount;
                    
                    // 使用 AdjustedBalanceHelper 計算可填入的最大金額
                    var originalTotalUsed = 0m;
                    
                    if (IsEditMode() && item.ExistingDetail != null)
                    {
                        // 原有的總使用金額（沖款 + 折讓）
                        originalTotalUsed = item.ExistingDetail.CurrentSetoffAmount + 
                                          item.ExistingDetail.CurrentAllowanceAmount;
                    }
                    
                    var maxFillableAmount = AdjustedBalanceHelper.GetMaxFillableAmount(
                        baseRemainingAmount,
                        originalTotalUsed,
                        0, // 不考慮其他欄位，直接填滿
                        IsEditMode());
                    
                    // 只有當可填入金額大於0時才填入
                    if (maxFillableAmount > 0)
                    {
                        item.CurrentSetoffAmount = maxFillableAmount;
                        item.CurrentAllowanceAmount = 0; // 清空折讓
                        filledCount++;
                    }
                }
            }

            await NotifyDetailsChanged();
            
            if (filledCount > 0)
            {
                await NotificationService.ShowSuccessAsync($"已自動填入 {filledCount} 項沖款金額", "全部沖款完成");
            }
            else
            {
                await NotificationService.ShowInfoAsync("沒有可填入的沖款項目", "提示");
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"全部沖款失敗：{ex.Message}", "錯誤");
        }
    }

    /// <summary>
    /// 沖款清空 - 清空所有本次沖款和本次折讓金額
    /// </summary>
    private async Task ClearAllSetoffAmounts()
    {
        if (IsReadOnly) return;

        try
        {
            int clearedCount = 0;
            
            foreach (var item in SetoffItems)
            {
                if (item.CurrentSetoffAmount > 0 || item.CurrentAllowanceAmount > 0)
                {
                    item.CurrentSetoffAmount = 0;
                    item.CurrentAllowanceAmount = 0;
                    clearedCount++;
                }
            }

            await NotifyDetailsChanged();
            
            if (clearedCount > 0)
            {
                await NotificationService.ShowSuccessAsync($"已清空 {clearedCount} 項沖款金額", "沖款清空完成");
            }
            else
            {
                await NotificationService.ShowInfoAsync("沒有需要清空的沖款項目", "提示");
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"沖款清空失敗：{ex.Message}", "錯誤");
        }
    }

    private async Task NotifyDetailsChanged()
    {
        var details = SetoffItems
            .Where(item => 
                item.CurrentSetoffAmount > 0 || 
                item.CurrentAllowanceAmount > 0 || 
                !string.IsNullOrWhiteSpace(item.Remarks) || // 包含有備註的項目
                item.ExistingDetail != null) // 編輯模式下包含所有已存在的明細
            .Select(item => new SetoffItemDetail
            {
                Id = item.ExistingDetail?.Id ?? 0,
                SetoffDocumentId = SetoffDocumentId ?? 0,
                ItemId = item.ItemId,
                SourceDetailType = item.SourceDetailType,
                SourceDetailId = item.SourceDetailId,
                CurrentSetoffAmount = item.CurrentSetoffAmount,
                CurrentAllowanceAmount = item.CurrentAllowanceAmount,
                TotalSetoffAmount = item.ExistingDetail?.TotalSetoffAmount ?? 0,
                TotalAllowanceAmount = item.ExistingDetail?.TotalAllowanceAmount ?? 0,
                Remarks = item.Remarks
            }).ToList();

        await DetailSyncHelper.SyncToParentAsync(details, OnDetailsChanged);
    }
    
    /// <summary>
    /// 取得本期沖銷總額（只計算本次沖款，不包含折讓，考慮退貨為負數）
    /// </summary>
    public decimal GetCurrentSetoffTotal()
    {
        return SetoffItems
            .Where(item => item.CurrentSetoffAmount > 0 || item.CurrentAllowanceAmount > 0)
            .Sum(item =>
            {
                var total = item.CurrentSetoffAmount; // 只計算本次沖款
                // 如果是退貨單據，金額取負值
                var isReturn = item.SourceDetailType == SetoffDetailType.SalesReturnDetail || 
                              item.SourceDetailType == SetoffDetailType.PurchaseReturnDetail;
                return isReturn ? -total : total;
            });
    }
    
    /// <summary>
    /// 取得本期折讓總額（考慮退貨為負數）
    /// </summary>
    public decimal GetCurrentAllowanceTotal()
    {
        return SetoffItems
            .Where(item => item.CurrentSetoffAmount > 0 || item.CurrentAllowanceAmount > 0)
            .Sum(item =>
            {
                var total = item.CurrentAllowanceAmount;
                // 如果是退貨單據，金額取負值
                var isReturn = item.SourceDetailType == SetoffDetailType.SalesReturnDetail || 
                              item.SourceDetailType == SetoffDetailType.PurchaseReturnDetail;
                return isReturn ? -total : total;
            });
    }
    
    /// <summary>
    /// 處理移除明細項目
    /// </summary>
    private async Task HandleRemoveItem(SetoffItemDetailItem item)
    {
        // 如果是編輯模式中的已存在明細，將金額清零而不移除項目（保留在列表中以便恢復）
        if (item.ExistingDetail != null)
        {
            item.CurrentSetoffAmount = 0;
            item.CurrentAllowanceAmount = 0;
            await NotificationService.ShowInfoAsync("已清除此項目的沖款金額");
        }
        else
        {
            // 新增模式下的項目可以直接移除（實際上是將金額清零）
            item.CurrentSetoffAmount = 0;
            item.CurrentAllowanceAmount = 0;
            await NotificationService.ShowInfoAsync("已清除此項目的沖款金額");
        }
        
        await NotifyDetailsChanged();
        StateHasChanged();
    }
    
    /// <summary>
    /// 取得當前選中明細的來源總金額（用於計算本期應收）
    /// 退貨單據會以負數計算
    /// </summary>
    public decimal GetSourceTotalAmount()
    {
        return SetoffItems
            .Where(item => item.CurrentSetoffAmount > 0 || item.CurrentAllowanceAmount > 0)
            .Sum(item => 
            {
                var amount = item.SourceTotalAmount;
                // 如果是退貨單據，金額取負值
                return item.UnsettledDetail?.IsReturn == true ? -amount : amount;
            });
    }
    
    /// <summary>
    /// 公開的刷新方法，用於外部觸發明細刷新（例如：上下筆切換時）
    /// </summary>
    public async Task RefreshDetailsAsync()
    {
        await LoadUnsettledDetailsAsync();
        LoadExistingDetails();
        StateHasChanged();
    }
    
    /// <summary>
    /// 從進貨單載入未結清明細（用於「進貨轉沖款」轉單功能）
    /// </summary>
    /// <param name="purchaseReceivingId">進貨單ID</param>
    /// <remarks>
    /// 此方法會載入指定進貨單的所有未結清品項明細，並預設填入本次沖款金額。
    /// 主要用於從 PurchaseReceivingEditModalComponent 呼叫。
    /// </remarks>
    public async Task LoadDetailsFromPurchaseReceiving(int purchaseReceivingId)
    {
        try
        {
            // 檢查關聯方是否已設定
            if (!RelatedPartyId.HasValue || RelatedPartyId.Value <= 0)
            {
                await NotificationService.ShowWarningAsync("請先選擇廠商");
                return;
            }
            
            // 取得進貨單的編號（用於篩選）
            var purchaseReceiving = await PurchaseReceivingService.GetByIdAsync(purchaseReceivingId);
            if (purchaseReceiving == null)
            {
                await NotificationService.ShowWarningAsync("找不到指定的進貨單");
                return;
            }
            var purchaseReceivingCode = purchaseReceiving.Code;
            
            // 確保已載入品項資料
            if (!Items.Any())
            {
                await LoadItemsAsync();
            }
            
            // 載入該廠商的所有未結清明細
            await LoadUnsettledDetailsAsync();
            
            // 篩選出指定進貨單的明細（透過單號比對）
            var matchingDetails = UnsettledDetails
                .Where(d => d.SourceDetailType == SetoffDetailType.PurchaseReceivingDetail)
                .Where(d => !string.IsNullOrEmpty(d.SourceDocumentNumber) && 
                           d.SourceDocumentNumber == purchaseReceivingCode)
                .ToList();
            
            // 轉換為 SetoffItems，預設本次沖款為未沖款餘額（全額沖款）
            SetoffItems = matchingDetails
                .Select(detail => new SetoffItemDetailItem
                {
                    SourceDetailType = detail.SourceDetailType,
                    SourceDetailId = detail.SourceDetailId,
                    ItemId = detail.ItemId,
                    Item = Items.FirstOrDefault(p => p.Id == detail.ItemId),
                    CurrentSetoffAmount = detail.RemainingAmount, // 預設全額沖款
                    CurrentAllowanceAmount = 0,
                    Remarks = null,
                    ExistingDetail = null,
                    UnsettledDetail = detail,
                    NeedsSourceDetailLoad = false
                }).ToList();
            
            // 標記已載入
            _dataLoaded = true;
            
            // 顯示載入結果
            var loadedCount = SetoffItems.Count;
            if (loadedCount > 0)
            {
                await NotificationService.ShowSuccessAsync($"已載入 {loadedCount} 筆進貨明細", "載入完成");
            }
            else
            {
                await NotificationService.ShowInfoAsync("該進貨單沒有未結清的應付明細", "提示");
            }
            
            // 通知父組件資料已變更
            await NotifyDetailsChanged();
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入進貨明細時發生錯誤：{ex.Message}");
        }
    }
    
