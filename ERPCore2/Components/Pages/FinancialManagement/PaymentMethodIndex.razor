@page "/paymentMethods"
@inject IPaymentMethodService PaymentMethodService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="PaymentMethod" 
                        TService="IPaymentMethodService"
                        Service="@PaymentMethodService"
                        EntityBasePath="/paymentMethods"                          
                        PageTitle="@L["Page.PaymentMethodTitle"]"
                        PageSubtitle="@L["Page.PaymentMethodSubtitle"]"
                        ServerDataLoader="@ServerLoadPaymentMethodsAsync"
                        BreadcrumbItems="@breadcrumbItems"
                        FilterDefinitions="@filterDefinitions"
                        ColumnDefinitions="@columnDefinitions"
                        ShowDraftTab="true"
                        EntityName="@L["Entity.PaymentMethod"]"
                        GetEntityDisplayName="@(pm => pm.Name)"
                        RequiredPermission="@PermissionRegistry.PaymentMethod.Read"
                        RequiredModule="FinancialManagement"
                        OnAddClick="@modalHandler.ShowAddModalAsync"
                        OnRowClick="@modalHandler.ShowEditModalAsync"
                        DebugPageName="PaymentMethodIndex"
                        @ref="indexComponent"/>

@* 付款方式編輯 Modal *@
<PaymentMethodEditModalComponent IsVisible="@showEditModal"
                                IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                PaymentMethodId="@editingPaymentMethodId"
                                OnPaymentMethodSaved="@modalHandler.OnEntitySavedAsync"
                                OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    // 組件參考
    private GenericIndexPageComponent<PaymentMethod, IPaymentMethodService> indexComponent = default!;
    
    // Modal 相關狀態
    private bool showEditModal = false;
    private int? editingPaymentMethodId = null;
    
    // Modal 處理器
    private ModalHandler<PaymentMethod, GenericIndexPageComponent<PaymentMethod, IPaymentMethodService>> modalHandler = default!;
    
    // 欄位配置
    private PaymentMethodFieldConfiguration fieldConfiguration = default!;
    
    // 配置相關
    private List<BreadcrumbItem> breadcrumbItems = new();
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<PaymentMethod, GenericIndexPageComponent<PaymentMethod, IPaymentMethodService>>(
                id => editingPaymentMethodId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());
            
            await InitializeBreadcrumbsAsync();
            
            // 建立欄位配置（傳遞 NotificationService）
            fieldConfiguration = new PaymentMethodFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            // 使用欄位配置建立篩選器和表格欄位
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化付款方式頁面失敗");
            await NotificationService.ShowErrorAsync("初始化付款方式頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("財務管理", "付款方式管理", null, NotificationService, GetType());

    private Task<(List<PaymentMethod> Items, int TotalCount)> ServerLoadPaymentMethodsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return PaymentMethodService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(x => x.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadPaymentMethodsAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
