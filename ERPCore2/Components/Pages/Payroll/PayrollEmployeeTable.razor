@* 薪資員工表格 - 含欄位定義、操作按鈕與合計欄 *@
@inject IStringLocalizer<SharedResource> L

@if (IsLoading)
{
    <div class="text-center py-4">
        <span class="spinner-border spinner-border-sm me-2"></span>@L["Label.Loading"]
    </div>
}
else
{
    <div class="px-3 pt-2 pb-3">
        <div class="card">
            <GenericInteractiveTableComponent TItem="RowViewModel"
                                             Items="@RowViewModels"
                                             ColumnDefinitions="@GetColumnDefinitions()"
                                             ShowRowNumbers="true"
                                             ShowBuiltInActions="false"
                                             ShowActions="true"
                                             IsReadOnly="true"
                                             ActionsColumnWidth="@(CanCalculate || CanConfirm ? "130px" : CanViewPayslip ? "60px" : "0px")"
                                             EmptyMessage="@L["Message.NoData"]">
                <ActionsTemplate>
                    <div class="d-flex gap-1 justify-content-center">
                        @if (CanCalculate && SelectedPeriod?.PeriodStatus != PayrollPeriodStatus.Closed)
                        {
                            <GenericButtonComponent IconClass="bi bi-arrow-repeat"
                                                   Variant="ButtonVariant.OutlineDarkBlue"
                                                   Size="ButtonSize.Large"
                                                   Title="@L["Payroll.CalculateEmployee"]"
                                                   IsDisabled="@(context.Record?.RecordStatus == PayrollRecordStatus.Confirmed)"
                                                   IsLoading="@(CalculatingEmployeeId == context.Employee.Id)"
                                                   OnClick="@(() => OnCalculateOne.InvokeAsync(context.Employee.Id))"
                                                   CssClass="btn-square" />
                        }
                        @if (CanConfirm && context.Record != null && SelectedPeriod?.PeriodStatus != PayrollPeriodStatus.Closed)
                        {
                            @if (context.Record.RecordStatus == PayrollRecordStatus.Draft)
                            {
                                <GenericButtonComponent IconClass="bi bi-check-circle"
                                                       Variant="ButtonVariant.OutlineGreen"
                                                       Size="ButtonSize.Large"
                                                       Title="@L["Payroll.ConfirmRecord"]"
                                                       OnClick="@(() => OnConfirmRecord.InvokeAsync(context.Record.Id))"
                                                       CssClass="btn-square" />
                            }
                            else
                            {
                                <GenericButtonComponent IconClass="bi bi-x-circle"
                                                       Variant="ButtonVariant.OutlineGray"
                                                       Size="ButtonSize.Large"
                                                       Title="@L["Payroll.UnconfirmRecord"]"
                                                       OnClick="@(() => OnUnconfirmRecord.InvokeAsync(context.Record.Id))"
                                                       CssClass="btn-square" />
                            }
                        }
                        @if (context.Record != null && CanViewPayslip)
                        {
                            <GenericButtonComponent IconClass="bi bi-file-earmark-person"
                                                   Variant="ButtonVariant.OutlineBlue"
                                                   Size="ButtonSize.Large"
                                                   Title="@L["Payroll.ViewPayslip"]"
                                                   OnClick="@(() => OnShowPayslip.InvokeAsync(context.Record.Id))"
                                                   CssClass="btn-square" />
                        }
                    </div>
                </ActionsTemplate>
            </GenericInteractiveTableComponent>

            @* ===== 合計欄 ===== *@
            <div class="d-flex flex-wrap gap-4 px-3 py-2 border-top align-items-center small"
                 style="background: var(--bg-secondary); color: var(--text-secondary);">
                <span>
                    <span class="text-muted">@L["Payroll.StatTotal"]：</span>
                    <strong>@RowViewModels.Count</strong>
                </span>
                @if (CanReadAmount)
                {
                    <span>
                        <span class="text-muted">@L["Payroll.StatGross"]：</span>
                        <strong>@RowViewModels.Where(r => r.Record != null).Sum(r => r.Record!.GrossIncome).ToString("N0")</strong>
                    </span>
                    <span>
                        <span class="text-muted">@L["Payroll.StatNet"]：</span>
                        <strong class="text-success">@RowViewModels.Where(r => r.Record != null).Sum(r => r.Record!.NetPay).ToString("N0")</strong>
                    </span>
                }
                <span>
                    <span class="text-muted">@L["Payroll.StatConfirmed"]：</span>
                    <strong class="text-primary">@RowViewModels.Count(r => r.Record?.RecordStatus == PayrollRecordStatus.Confirmed)</strong>
                </span>
            </div>
        </div>
    </div>
}

@code {
    // ── 參數 ──────────────────────────────────────────────────────
    [Parameter] public List<RowViewModel> RowViewModels { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool CanCalculate { get; set; }
    [Parameter] public bool CanConfirm { get; set; }
    [Parameter] public bool CanReadAmount { get; set; }
    [Parameter] public bool CanViewPayslip { get; set; }
    [Parameter] public PayrollPeriod? SelectedPeriod { get; set; }
    [Parameter] public int? CalculatingEmployeeId { get; set; }
    [Parameter] public EventCallback<int> OnCalculateOne { get; set; }
    [Parameter] public EventCallback<int> OnConfirmRecord { get; set; }
    [Parameter] public EventCallback<int> OnUnconfirmRecord { get; set; }
    [Parameter] public EventCallback<int> OnShowPayslip { get; set; }

    // ── 欄位定義 ─────────────────────────────────────────────────

    private List<InteractiveColumnDefinition> GetColumnDefinitions()
    {
        var cols = new List<InteractiveColumnDefinition>
        {
            new InteractiveColumnDefinition
            {
                Title = L["Field.Employee"].ToString(),
                ColumnType = InteractiveColumnType.Display,
                PropertyName = "Employee",
                DisplayFormatter = obj =>
                {
                    if (obj is not RowViewModel r) return "";
                    var name = System.Web.HttpUtility.HtmlEncode(r.Employee?.Name ?? "");
                    var code = System.Web.HttpUtility.HtmlEncode(r.Employee?.Code ?? "");
                    return string.IsNullOrEmpty(code) ? name : $"{code} · {name}";
                },
                Width = "200px"
            },
            new InteractiveColumnDefinition
            {
                Title = L["Payroll.AttendanceDays"].ToString(),
                ColumnType = InteractiveColumnType.Display,
                PropertyName = "Record",
                DisplayFormatter = obj =>
                {
                    if (obj is not RowViewModel r) return "—";
                    return r.Record != null ? $"{r.Record.ActualWorkDays}/{r.Record.ScheduledWorkDays}" : "—";
                },
                Width = "80px",
                HeaderCssClass = "text-center",
                CellCssClass = "text-center",
                HideOnMobile = true
            }
        };

        if (CanReadAmount)
        {
            cols.Add(new InteractiveColumnDefinition
            {
                Title = L["Payroll.GrossIncome"].ToString(),
                ColumnType = InteractiveColumnType.Display,
                PropertyName = "Record",
                DisplayFormatter = obj => (obj as RowViewModel)?.Record?.GrossIncome.ToString("N0") ?? "—",
                Width = "110px",
                HeaderCssClass = "text-end",
                CellCssClass = "text-end",
                HideOnMobile = true
            });
            cols.Add(new InteractiveColumnDefinition
            {
                Title = L["Payroll.TotalDeduction"].ToString(),
                ColumnType = InteractiveColumnType.Display,
                PropertyName = "Record",
                DisplayFormatter = obj => (obj as RowViewModel)?.Record?.TotalDeduction.ToString("N0") ?? "—",
                Width = "110px",
                HeaderCssClass = "text-end",
                CellCssClass = "text-end",
                HideOnMobile = true
            });
            cols.Add(new InteractiveColumnDefinition
            {
                Title = L["Payroll.NetPay"].ToString(),
                ColumnType = InteractiveColumnType.Display,
                PropertyName = "Record",
                DisplayFormatter = obj => (obj as RowViewModel)?.Record?.NetPay.ToString("N0") ?? "—",
                Width = "110px",
                HeaderCssClass = "text-end",
                CellCssClass = "text-end"
            });
        }

        cols.Add(new InteractiveColumnDefinition
        {
            Title = L["Field.PeriodStatus"].ToString(),
            ColumnType = InteractiveColumnType.Custom,
            PropertyName = "Record",
            CustomTemplate = obj => builder =>
            {
                var r = (RowViewModel)obj;
                string cssClass, text;
                if (r.Record == null)
                {
                    cssClass = "badge bg-secondary";
                    text = L["Payroll.NotCalculated"].ToString();
                }
                else if (r.Record.RecordStatus == PayrollRecordStatus.Draft)
                {
                    cssClass = "badge bg-warning text-dark";
                    text = L["Payroll.RecordDraft"].ToString();
                }
                else
                {
                    cssClass = "badge bg-success";
                    text = L["Payroll.RecordConfirmed"].ToString();
                }
                builder.OpenElement(0, "span");
                builder.AddAttribute(1, "class", cssClass);
                builder.AddContent(2, text);
                builder.CloseElement();
            },
            Width = "100px",
            HeaderCssClass = "text-center",
            CellCssClass = "text-center"
        });

        return cols;
    }

    // ── ViewModel ─────────────────────────────────────────────────

    public class RowViewModel
    {
        public Employee Employee { get; set; } = null!;
        public PayrollRecord? Record { get; set; }
    }
}
