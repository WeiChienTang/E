@inject IMinimumWageService WageService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNew ? L["Payroll.AddMinimumWage"] : L["Payroll.EditMinimumWage"])
                    </h5>
                    <button class="btn-close" @onclick="Cancel"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">@L["Field.EffectiveDate"] <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" @bind="model.EffectiveDate" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["Field.MonthlyMinWage"] <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" @bind="model.MonthlyAmount" min="0" step="1" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["Field.HourlyMinWage"] <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" @bind="model.HourlyAmount" min="0" step="0.01" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["Label.Remarks"]</label>
                        <input type="text" class="form-control" @bind="model.Remarks" maxlength="200" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="Cancel">@L["Button.Cancel"]</button>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @L["Button.Save"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public MinimumWage? EditingItem { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private MinimumWage model = new();
    private bool isNew = true;
    private bool isSaving = false;

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            isNew = EditingItem == null;
            model = isNew ? new MinimumWage { EffectiveDate = DateOnly.FromDateTime(DateTime.Today) }
                          : new MinimumWage
                          {
                              Id = EditingItem!.Id,
                              EffectiveDate = EditingItem.EffectiveDate,
                              MonthlyAmount = EditingItem.MonthlyAmount,
                              HourlyAmount = EditingItem.HourlyAmount,
                              Remarks = EditingItem.Remarks
                          };
        }
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        ServiceResult<MinimumWage> result = isNew
            ? await WageService.CreateAsync(model)
            : await WageService.UpdateAsync(model);

        if (result.IsSuccess)
        {
            await NotificationService.ShowSuccessAsync(L["Message.SaveSuccess"].ToString());
            await IsVisibleChanged.InvokeAsync(false);
            await OnSaved.InvokeAsync();
        }
        else
        {
            await NotificationService.ShowErrorAsync(result.ErrorMessage ?? L["Message.SaveFailed"].ToString());
        }
        isSaving = false;
    }

    private async Task Cancel() => await IsVisibleChanged.InvokeAsync(false);
}
