@inject IInsuranceRateService RateService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNew ? L["Payroll.AddInsuranceRate"] : L["Payroll.EditInsuranceRate"])
                    </h5>
                    <button class="btn-close" @onclick="Cancel"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">@L["Field.EffectiveDate"] <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" @bind="model.EffectiveDate" />
                    </div>
                    <h6 class="text-muted mt-3 mb-2">@L["Payroll.LaborInsuranceRates"]</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@L["Field.LaborInsEERate"] <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="laborInsEEPct" min="0" max="100" step="0.01" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@L["Field.LaborInsERRate"] <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="laborInsERPct" min="0" max="100" step="0.01" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                    </div>
                    <h6 class="text-muted mt-3 mb-2">@L["Payroll.HealthInsuranceRates"]</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@L["Field.HealthInsEERate"] <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="healthInsEEPct" min="0" max="100" step="0.001" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@L["Field.HealthInsERRate"] <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="healthInsERPct" min="0" max="100" step="0.001" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                    </div>
                    <h6 class="text-muted mt-3 mb-2">@L["Payroll.RetirementAndTaxFree"]</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">@L["Field.RetirementERRate"] <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" class="form-control" @bind="retirementERPct" min="0" max="100" step="0.01" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@L["Field.MealTaxFreeLimit"] <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="model.MealTaxFreeLimit" min="0" step="1" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@L["Field.TransportTaxFreeLimit"] <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="model.TransportTaxFreeLimit" min="0" step="1" />
                        </div>
                    </div>
                    <h6 class="text-muted mt-3 mb-1">@L["Payroll.OvertimeRates"]</h6>
                    <div class="alert alert-warning py-2 px-3 mb-2 small">
                        <i class="bi bi-exclamation-triangle me-1"></i>@L["Payroll.OvertimeRatesWarning"]
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label small">@L["Field.OvertimeRate1"]</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">×</span>
                                <input type="number" class="form-control" @bind="model.OvertimeRate1"
                                       min="1" max="5" step="0.0001" />
                                <span class="input-group-text text-muted">@L["Payroll.TimesHourlyRate"]</span>
                            </div>
                            <div class="form-text">@L["Payroll.LegalDefault"]：4/3 ≈ 1.3333</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">@L["Field.OvertimeRate2"]</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">×</span>
                                <input type="number" class="form-control" @bind="model.OvertimeRate2"
                                       min="1" max="5" step="0.0001" />
                                <span class="input-group-text text-muted">@L["Payroll.TimesHourlyRate"]</span>
                            </div>
                            <div class="form-text">@L["Payroll.LegalDefault"]：5/3 ≈ 1.6667</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">@L["Field.RestDayRate1"]</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">×</span>
                                <input type="number" class="form-control" @bind="model.RestDayRate1"
                                       min="1" max="5" step="0.0001" />
                                <span class="input-group-text text-muted">@L["Payroll.TimesHourlyRate"]</span>
                            </div>
                            <div class="form-text">@L["Payroll.LegalDefault"]：4/3 ≈ 1.3333</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">@L["Field.RestDayRate2"]</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">×</span>
                                <input type="number" class="form-control" @bind="model.RestDayRate2"
                                       min="1" max="5" step="0.0001" />
                                <span class="input-group-text text-muted">@L["Payroll.TimesHourlyRate"]</span>
                            </div>
                            <div class="form-text">@L["Payroll.LegalDefault"]：5/3 ≈ 1.6667</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">@L["Field.NationalHolidayRate"]</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">×</span>
                                <input type="number" class="form-control" @bind="model.NationalHolidayRate"
                                       min="0" max="5" step="0.0001" />
                                <span class="input-group-text text-muted">@L["Payroll.TimesHourlyRate"]</span>
                            </div>
                            <div class="form-text">@L["Payroll.LegalDefault"]：1.0000（@L["Payroll.NationalHolidayRateNote"]）</div>
                        </div>
                    </div>

                    <div class="mb-3 mt-3">
                        <label class="form-label">@L["Label.Remarks"]</label>
                        <input type="text" class="form-control" @bind="model.Remarks" maxlength="200" />
                    </div>
                </div>
                <div class="modal-footer">
                    <GenericButtonComponent Variant="ButtonVariant.Gray" Text="@L["Button.Cancel"]" OnClick="Cancel" />
                    <GenericButtonComponent Variant="ButtonVariant.DarkBlue" Text="@L["Button.Save"]" OnClick="SaveAsync"
                                            IsLoading="@isSaving" IsDisabled="@isSaving" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public InsuranceRate? EditingItem { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private InsuranceRate model = new();
    private bool isNew = true;
    private bool isSaving = false;

    // 百分比輸入用（將 0.02 轉為 2.00 顯示）
    private decimal laborInsEEPct { get => model.LaborInsuranceEmployeeRate * 100; set => model.LaborInsuranceEmployeeRate = value / 100; }
    private decimal laborInsERPct { get => model.LaborInsuranceEmployerRate * 100; set => model.LaborInsuranceEmployerRate = value / 100; }
    private decimal healthInsEEPct { get => model.HealthInsuranceEmployeeRate * 100; set => model.HealthInsuranceEmployeeRate = value / 100; }
    private decimal healthInsERPct { get => model.HealthInsuranceEmployerRate * 100; set => model.HealthInsuranceEmployerRate = value / 100; }
    private decimal retirementERPct { get => model.RetirementEmployerRate * 100; set => model.RetirementEmployerRate = value / 100; }

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            isNew = EditingItem == null;
            if (isNew)
            {
                model = new InsuranceRate
                {
                    EffectiveDate = DateOnly.FromDateTime(DateTime.Today),
                    LaborInsuranceEmployeeRate  = 0.02m,
                    LaborInsuranceEmployerRate  = 0.10m,
                    HealthInsuranceEmployeeRate = 0.0235m,
                    HealthInsuranceEmployerRate = 0.0611m,
                    RetirementEmployerRate      = 0.06m,
                    MealTaxFreeLimit            = 3000m,
                    TransportTaxFreeLimit       = 3000m,
                    OvertimeRate1               = 1.3333m,
                    OvertimeRate2               = 1.6667m,
                    RestDayRate1                = 1.3333m,
                    RestDayRate2                = 1.6667m,
                    NationalHolidayRate         = 1.0000m
                };
            }
            else
            {
                model = new InsuranceRate
                {
                    Id                          = EditingItem!.Id,
                    EffectiveDate               = EditingItem.EffectiveDate,
                    LaborInsuranceEmployeeRate  = EditingItem.LaborInsuranceEmployeeRate,
                    LaborInsuranceEmployerRate  = EditingItem.LaborInsuranceEmployerRate,
                    HealthInsuranceEmployeeRate = EditingItem.HealthInsuranceEmployeeRate,
                    HealthInsuranceEmployerRate = EditingItem.HealthInsuranceEmployerRate,
                    RetirementEmployerRate      = EditingItem.RetirementEmployerRate,
                    MealTaxFreeLimit            = EditingItem.MealTaxFreeLimit,
                    TransportTaxFreeLimit       = EditingItem.TransportTaxFreeLimit,
                    OvertimeRate1               = EditingItem.OvertimeRate1,
                    OvertimeRate2               = EditingItem.OvertimeRate2,
                    RestDayRate1                = EditingItem.RestDayRate1,
                    RestDayRate2                = EditingItem.RestDayRate2,
                    NationalHolidayRate         = EditingItem.NationalHolidayRate,
                    Remarks                     = EditingItem.Remarks
                };
            }
        }
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        ServiceResult<InsuranceRate> result = isNew
            ? await RateService.CreateAsync(model)
            : await RateService.UpdateAsync(model);

        if (result.IsSuccess)
        {
            await NotificationService.ShowSuccessAsync(L["Message.SaveSuccess"].ToString());
            await IsVisibleChanged.InvokeAsync(false);
            await OnSaved.InvokeAsync();
        }
        else
        {
            await NotificationService.ShowErrorAsync(result.ErrorMessage ?? L["Message.SaveFailed"].ToString());
        }
        isSaving = false;
    }

    private async Task Cancel() => await IsVisibleChanged.InvokeAsync(false);
}
