@* 薪資項目編輯組件 *@
@inject IPayrollItemService PayrollItemService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@using ERPCore2.Models.FeatureGuides.GuideDefinitions

<GenericEditModalComponent TEntity="PayrollItem"
                          TService="IPayrollItemService"
                          @ref="editModalComponent"
                          IsVisible="@IsVisible"
                          IsVisibleChanged="@IsVisibleChanged"
                          @bind-Id="@PayrollItemId"
                          Service="@PayrollItemService"
                          EntityName="@L["Entity.PayrollItem"]"
                          EntityNamePlural="@L["Entity.PayrollItem"]"
                          ModalTitle="@(PayrollItemId.HasValue ? L["Message.EditTitle", L["Entity.PayrollItem"]].ToString() : L["Message.CreateTitle", L["Entity.PayrollItem"]].ToString())"
                          Size="GenericEditModalComponent<PayrollItem, IPayrollItemService>.ModalSize.Desktop"
                          UseGenericForm="true"
                          FormFields="@formFields"
                          FormSections="@formSections"
                          DataLoader="@LoadPayrollItemData"
                          UseGenericSave="true"
                          SaveSuccessMessage="@(PayrollItemId.HasValue ? L["Message.UpdateSuccess", L["Entity.PayrollItem"]].ToString() : L["Message.CreateSuccess", L["Entity.PayrollItem"]].ToString())"
                          SaveFailureMessage="@L["Message.SaveFailure", L["Entity.PayrollItem"]]"
                          RequiredPermission="@PermissionRegistry.Payroll.RateTable"
                          OnEntitySaved="@OnPayrollItemSaved"
                          OnCancel="@OnCancel"
                          ComponentName="PayrollItemEditModalComponent"
                          FeatureGuide="@PayrollItemGuide.Create()" />

@code {
    [Parameter] public bool IsVisible { get; set; } = false;
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? PayrollItemId { get; set; }
    [Parameter] public EventCallback<PayrollItem> OnPayrollItemSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public Dictionary<string, object?>? PrefilledValues { get; set; }

    private GenericEditModalComponent<PayrollItem, IPayrollItemService>? editModalComponent;
    private List<FormFieldDefinition> formFields = new();
    private Dictionary<string, string> formSections = new();

    private Task<PayrollItem?> LoadPayrollItemData() =>
        EditDataLoaderHelper.LoadOrCreateAsync<PayrollItem, IPayrollItemService>(
            PayrollItemId, PayrollItemService, NotificationService, "薪資項目", "ITEM", PrefilledValues,
            item => item.Name = string.Empty);

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            InitializeFormFields();
        }
    }

    private void InitializeFormFields()
    {
        try
        {
            formFields = new List<FormFieldDefinition>
            {
                new()
                {
                    PropertyName = nameof(PayrollItem.Code),
                    Label = L["Field.PayrollItemCode"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.PayrollItemCode"]],
                    IsRequired = true,
                    HelpText = "薪資項目的唯一識別代碼，例如 BASE、OT1"
                },
                new()
                {
                    PropertyName = nameof(PayrollItem.Name),
                    Label = L["Field.PayrollItemName"],
                    FieldType = FormFieldType.Text,
                    Placeholder = L["Placeholder.PleaseInput", L["Field.PayrollItemName"]],
                    IsRequired = true
                },
                new()
                {
                    PropertyName = nameof(PayrollItem.ItemType),
                    Label = L["Field.PayrollItemType"],
                    FieldType = FormFieldType.Select,
                    IsRequired = true,
                    Options = new List<SelectOption>
                    {
                        new() { Value = ((int)PayrollItemType.Income).ToString(),    Text = L["Payroll.Income"]    ?? "收入" },
                        new() { Value = ((int)PayrollItemType.Deduction).ToString(), Text = L["Payroll.Deduction"] ?? "扣除" }
                    }
                },
                new()
                {
                    PropertyName = nameof(PayrollItem.Category),
                    Label = L["Field.PayrollItemCategory"],
                    FieldType = FormFieldType.Select,
                    IsRequired = true,
                    Options = new List<SelectOption>
                    {
                        new() { Value = ((int)PayrollItemCategory.Salary).ToString(),    Text = L["Payroll.Salary"]    ?? "薪資" },
                        new() { Value = ((int)PayrollItemCategory.Allowance).ToString(), Text = L["Payroll.Allowance"] ?? "津貼補助" },
                        new() { Value = ((int)PayrollItemCategory.Overtime).ToString(),  Text = L["Payroll.Overtime"]  ?? "加班費" },
                        new() { Value = ((int)PayrollItemCategory.Bonus).ToString(),     Text = L["Payroll.Bonus"]     ?? "獎金" },
                        new() { Value = ((int)PayrollItemCategory.Legal).ToString(),     Text = L["Payroll.Legal"]     ?? "法定扣繳" },
                        new() { Value = ((int)PayrollItemCategory.Other).ToString(),     Text = L["Payroll.Other"]     ?? "其他" }
                    }
                },
                new()
                {
                    PropertyName = nameof(PayrollItem.IsTaxable),
                    Label = L["Field.PayrollItemIsTaxable"],
                    FieldType = FormFieldType.Checkbox
                },
                new()
                {
                    PropertyName = nameof(PayrollItem.IsInsuranceBasis),
                    Label = L["Field.PayrollItemIsInsuranceBasis"],
                    FieldType = FormFieldType.Checkbox
                },
                new()
                {
                    PropertyName = nameof(PayrollItem.IsRetirementBasis),
                    Label = L["Field.PayrollItemIsRetirementBasis"],
                    FieldType = FormFieldType.Checkbox
                },
                new()
                {
                    PropertyName = nameof(PayrollItem.IsProrated),
                    Label = L["Field.PayrollItemIsProrated"],
                    FieldType = FormFieldType.Checkbox,
                    HelpText = L["Payroll.IsProratedHelpText"]
                },
                new()
                {
                    PropertyName = nameof(PayrollItem.SortOrder),
                    Label = L["Field.SortOrder"],
                    FieldType = FormFieldType.Number
                },
                new()
                {
                    PropertyName = nameof(PayrollItem.Status),
                    Label = L["Field.Status"],
                    FieldType = FormFieldType.Select,
                    Options = new List<SelectOption>
                    {
                        new() { Value = ((int)EntityStatus.Active).ToString(),   Text = L["Toggle.Enabled"]  ?? "啟用" },
                        new() { Value = ((int)EntityStatus.Inactive).ToString(), Text = L["Toggle.Disabled"] ?? "停用" }
                    }
                },

                FormFieldConfigurationHelper.CreateRemarksField<PayrollItem>()
            };

            formSections = FormSectionHelper<PayrollItem>.Create()
                .AddToSection(FormSectionNames.BasicInfo,
                    i => i.Code,
                    i => i.Name,
                    i => i.ItemType,
                    i => i.Category)
                .AddToSection(FormSectionNames.OtherInfo,
                    i => i.IsTaxable,
                    i => i.IsInsuranceBasis,
                    i => i.IsRetirementBasis,
                    i => i.IsProrated,
                    i => i.SortOrder,
                    i => i.Status)
                .AddToSection(FormSectionNames.AdditionalData,
                    i => i.Remarks)
                .Build();
        }
        catch (Exception)
        {
            _ = NotificationService.ShowErrorAsync("初始化薪資項目表單欄位時發生錯誤");
        }
    }

    public Task ShowAddModal() => editModalComponent!.ShowAddModal();
    public Task ShowEditModal(int id) => editModalComponent!.ShowEditModal(id);
}
