@inject IHealthInsuranceGradeService GradeService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(isNew ? L["Payroll.AddGrade"] : L["Payroll.EditGrade"])
                    </h5>
                    <button class="btn-close" @onclick="Cancel"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">@L["Field.EffectiveDate"] <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" @bind="model.EffectiveDate" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["Field.InsuranceGrade"] <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" @bind="model.Grade" min="1" max="99" />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@L["Field.SalaryFrom"] <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="model.SalaryFrom" min="0" step="1" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@L["Field.SalaryTo"]</label>
                            <input type="number" class="form-control" @bind="model.SalaryTo" min="0" step="1" placeholder="@L["Label.NoUpperLimit"]" />
                        </div>
                    </div>
                    <div class="mb-3 mt-3">
                        <label class="form-label">@L["Field.InsuredAmount"] <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" @bind="model.InsuredAmount" min="0" step="1" />
                    </div>
                </div>
                <div class="modal-footer">
                    <GenericButtonComponent Variant="ButtonVariant.Gray" Text="@L["Button.Cancel"]" OnClick="Cancel" />
                    <GenericButtonComponent Variant="ButtonVariant.DarkBlue" Text="@L["Button.Save"]" OnClick="SaveAsync"
                                            IsLoading="@isSaving" IsDisabled="@isSaving" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public HealthInsuranceGrade? EditingItem { get; set; }
    [Parameter] public DateOnly DefaultEffectiveDate { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private HealthInsuranceGrade model = new();
    private bool isNew = true;
    private bool isSaving = false;

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            isNew = EditingItem == null;
            model = isNew ? new HealthInsuranceGrade { EffectiveDate = DefaultEffectiveDate != default ? DefaultEffectiveDate : DateOnly.FromDateTime(DateTime.Today) }
                          : new HealthInsuranceGrade
                          {
                              Id = EditingItem!.Id,
                              EffectiveDate = EditingItem.EffectiveDate,
                              Grade = EditingItem.Grade,
                              SalaryFrom = EditingItem.SalaryFrom,
                              SalaryTo = EditingItem.SalaryTo,
                              InsuredAmount = EditingItem.InsuredAmount
                          };
        }
    }

    private async Task SaveAsync()
    {
        isSaving = true;
        ServiceResult<HealthInsuranceGrade> result = isNew
            ? await GradeService.CreateAsync(model)
            : await GradeService.UpdateAsync(model);

        if (result.IsSuccess)
        {
            await NotificationService.ShowSuccessAsync(L["Message.SaveSuccess"].ToString());
            await IsVisibleChanged.InvokeAsync(false);
            await OnSaved.InvokeAsync();
        }
        else
        {
            await NotificationService.ShowErrorAsync(result.ErrorMessage ?? L["Message.SaveFailed"].ToString());
        }
        isSaving = false;
    }

    private async Task Cancel() => await IsVisibleChanged.InvokeAsync(false);
}
