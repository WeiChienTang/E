@* 薪資計算 Modal *@
@inject IPayrollPeriodService PeriodService
@inject IPayrollCalculationService CalculationService
@inject IEmployeeService EmployeeService
@inject INavigationPermissionService NavigationPermissionService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<BaseModalComponent IsVisible="@IsVisible"
                    IsVisibleChanged="@IsVisibleChanged"
                    Title="@L["Page.PayrollTitle"]"
                    Icon="bi bi-calculator-fill"
                    Size="BaseModalComponent.ModalSize.Desktop"
                    AllowFullscreen="true"
                    ScrollableBody="true"
                    ShowCloseButton="@ShowCloseButton"
                    CloseOnBackdropClick="@CloseOnBackdropClick"
                    CloseOnEscape="@CloseOnEscape"
                    BodyCssClass="p-0"
                    DebugComponentName="@DebugName">

    <BodyContent>
        <div class="form-tab-container">

            @* ===== Tab 按鈕（由 tabDefinitions 動態產生）===== *@
            <div class="form-tab-btn-group">
                @for (var i = 0; i < tabDefinitions.Count; i++)
                {
                    var index = i;
                    var tab = tabDefinitions[i];
                    <button type="button"
                            class="form-tab-btn @(activeTabIndex == index ? "active" : "")"
                            @onclick="() => SetTab(index)">
                        @if (!string.IsNullOrEmpty(tab.Icon))
                        {
                            <i class="@tab.Icon"></i>
                        }
                        @tab.Label
                    </button>
                }
            </div>

            @* ===== Tab 內容（只渲染目前 active 的 tab）===== *@
            <div class="form-tab-content">
                @if (tabDefinitions.Count > activeTabIndex)
                {
                    @tabDefinitions[activeTabIndex].CustomContent
                }
            </div>

        </div>
    </BodyContent>

</BaseModalComponent>

@if (showPayslip && payslipRecordId.HasValue)
{
    <PayslipModalComponent RecordId="@payslipRecordId.Value"
                           IsVisible="@showPayslip"
                           IsVisibleChanged="@((v) => showPayslip = v)" />
}

@code {
    // ── 參數 ──────────────────────────────────────────────────────
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public bool ShowCloseButton { get; set; } = true;
    [Parameter] public bool CloseOnBackdropClick { get; set; } = true;
    [Parameter] public bool CloseOnEscape { get; set; } = true;

    // ── 資料 ──────────────────────────────────────────────────────
    private List<PayrollPeriod> periods = new();
    private PayrollPeriod? selectedPeriod;
    private int? selectedPeriodId;
    private List<PayrollEmployeeTable.RowViewModel> rowViewModels = new();

    // ── 狀態 ──────────────────────────────────────────────────────
    private bool _lastVisible = false;
    private bool _isInitialLoading = false;
    private bool isLoading = false;
    private bool isCalculating = false;
    private int? calculatingEmployeeId;
    private int activeTabIndex = 0;
    private List<FormTabDefinition> tabDefinitions = new();

    // ── 權限 ──────────────────────────────────────────────────────
    private bool canCalculate = false;
    private bool canConfirm = false;
    private bool canReadAmount = false;
    private bool canViewPayslip = false;
    private bool canRateTable = false;
    private bool canClose = false;
    private bool canAttendance = false;

    // ── 薪資單 Modal ──────────────────────────────────────────────
    private bool showPayslip = false;
    private int? payslipRecordId;

    // ── 生命週期 ──────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            canCalculate   = await NavigationPermissionService.CanAccessAsync(PermissionRegistry.Payroll.Calculate);
            canConfirm     = await NavigationPermissionService.CanAccessAsync(PermissionRegistry.Payroll.Confirm);
            canReadAmount  = await NavigationPermissionService.CanAccessAsync(PermissionRegistry.Payroll.ReadAmount);
            canViewPayslip = await NavigationPermissionService.CanAccessAsync(PermissionRegistry.Payroll.Payslip);
            canRateTable   = await NavigationPermissionService.CanAccessAsync(PermissionRegistry.Payroll.RateTable);
            canClose       = await NavigationPermissionService.CanAccessAsync(PermissionRegistry.Payroll.Close);
            canAttendance  = await NavigationPermissionService.CanAccessAsync(PermissionRegistry.Payroll.Attendance);
            BuildTabDefinitions();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType());
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !_lastVisible)
        {
            _lastVisible = true;
            await LoadInitialDataAsync();
        }
        else if (!IsVisible && _lastVisible)
        {
            _lastVisible = false;
            activeTabIndex = 0;
        }
    }

    // ── 資料載入 ─────────────────────────────────────────────────

    private async Task LoadInitialDataAsync()
    {
        try
        {
            _isInitialLoading = true;

            periods = await PeriodService.GetAllAsync();
            if (!periods.Any())
            {
                var today = DateTime.Today;
                await PeriodService.EnsurePeriodExistsAsync(today.Year - 1911, today.Month);
                periods = await PeriodService.GetAllAsync();
            }

            selectedPeriod = periods.FirstOrDefault(p => p.PeriodStatus != PayrollPeriodStatus.Closed)
                          ?? periods.FirstOrDefault();
            selectedPeriodId = selectedPeriod?.Id;
            _isInitialLoading = false;

            if (selectedPeriod != null)
                await LoadPeriodDataAsync();
        }
        catch (Exception ex)
        {
            _isInitialLoading = false;
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadInitialDataAsync), GetType());
            await NotificationService.ShowErrorAsync(L["Message.InitPageFailed"].ToString());
        }
    }

    private async Task LoadPeriodDataAsync()
    {
        if (selectedPeriod == null) return;
        try
        {
            isLoading = true;
            StateHasChanged();

            var empResult = await EmployeeService.GetActiveEmployeesAsync();
            var employees = (empResult.IsSuccess ? (empResult.Data ?? new()) : new())
                .Where(e => !e.IsSuperAdmin)
                .ToList();
            var records = await CalculationService.GetByPeriodAsync(selectedPeriod.Id);

            rowViewModels = employees.Select(emp => new PayrollEmployeeTable.RowViewModel
            {
                Employee = emp,
                Record = records.FirstOrDefault(r => r.EmployeeId == emp.Id)
            }).ToList();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadPeriodDataAsync), GetType());
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // ── Tab 定義（依權限動態建立，與 CustomerEditModalComponent 相同作法）──

    private string DebugName
    {
        get
        {
            const string baseName = "PayrollModalComponent";
            if (tabDefinitions.Count == 0 || activeTabIndex >= tabDefinitions.Count) return baseName;
            var tabDebugName = tabDefinitions[activeTabIndex].DebugComponentName;
            return string.IsNullOrEmpty(tabDebugName) ? baseName : $"{baseName} > {tabDebugName}";
        }
    }

    private void BuildTabDefinitions()
    {
        tabDefinitions = new List<FormTabDefinition>
        {
            new() { Label = L["Payroll.TabCalculation"],       Icon = "bi bi-calculator",     CustomContent = CreateCalculationTabContent() }
        };

        if (canRateTable)
        {
            tabDefinitions.Add(new() { Label = L["Payroll.Tab.InsuranceRate"],        Icon = "bi bi-shield-check",    CustomContent = CreateInsuranceRateTabContent(),        DebugComponentName = nameof(InsuranceRateTab) });
            tabDefinitions.Add(new() { Label = L["Payroll.Tab.LaborInsuranceGrade"], Icon = "bi bi-people",           CustomContent = CreateLaborInsuranceGradeTabContent(), DebugComponentName = nameof(LaborInsuranceGradeTab) });
            tabDefinitions.Add(new() { Label = L["Payroll.Tab.HealthInsuranceGrade"],Icon = "bi bi-heart-pulse",      CustomContent = CreateHealthInsuranceGradeTabContent(), DebugComponentName = nameof(HealthInsuranceGradeTab) });
            tabDefinitions.Add(new() { Label = L["Payroll.Tab.WithholdingTaxTable"], Icon = "bi bi-receipt-cutoff",   CustomContent = CreateWithholdingTaxTableTabContent(), DebugComponentName = nameof(WithholdingTaxTableTab) });
        }

        if (canClose)
            tabDefinitions.Add(new() { Label = L["Payroll.Tab.PayrollPeriods"], Icon = "bi bi-calendar3",  CustomContent = CreatePayrollPeriodTabContent(), DebugComponentName = nameof(PayrollPeriodTab) });

        if (canAttendance)
            tabDefinitions.Add(new() { Label = L["Payroll.Tab.Attendance"],     Icon = "bi bi-clock",      CustomContent = CreateAttendanceTabContent(), DebugComponentName = nameof(AttendanceTab) });
    }

    private RenderFragment CreateCalculationTabContent() => __builder =>
    {
        <div class="px-3 pt-3 pb-2 border-bottom">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="fw-semibold text-nowrap">@L["Payroll.SelectPeriod"]：</span>
                @if (_isInitialLoading)
                {
                    <span class="text-muted">
                        <span class="spinner-border spinner-border-sm me-1"></span>@L["Label.Loading"]
                    </span>
                }
                else if (periods.Any())
                {
                    <select class="form-select form-select-sm w-auto" @onchange="OnPeriodChanged">
                        @foreach (var p in periods)
                        {
                            <option value="@p.Id" selected="@(p.Id == selectedPeriodId)">
                                @p.Year 年 @p.Month 月 — @GetPeriodStatusLabel(p.PeriodStatus)
                            </option>
                        }
                    </select>
                    @if (selectedPeriod != null)
                    {
                        <span class="badge @GetPeriodStatusBadgeCss(selectedPeriod.PeriodStatus)">
                            @GetPeriodStatusLabel(selectedPeriod.PeriodStatus)
                        </span>
                    }
                }
            </div>
        </div>
        @if (selectedPeriod != null)
        {
            <PayrollEmployeeTable RowViewModels="@rowViewModels"
                                  IsLoading="@isLoading"
                                  CanCalculate="@canCalculate"
                                  CanConfirm="@canConfirm"
                                  CanReadAmount="@canReadAmount"
                                  CanViewPayslip="@canViewPayslip"
                                  SelectedPeriod="@selectedPeriod"
                                  CalculatingEmployeeId="@calculatingEmployeeId"
                                  OnCalculateOne="@CalculateOneAsync"
                                  OnConfirmRecord="@ConfirmRecordAsync"
                                  OnUnconfirmRecord="@UnconfirmRecordAsync"
                                  OnShowPayslip="@ShowPayslip" />
        }
    };

    private RenderFragment CreateInsuranceRateTabContent() => __builder =>
    {
        <div class="p-3"><InsuranceRateTab /></div>
    };

    private RenderFragment CreateLaborInsuranceGradeTabContent() => __builder =>
    {
        <div class="p-3"><LaborInsuranceGradeTab /></div>
    };

    private RenderFragment CreateHealthInsuranceGradeTabContent() => __builder =>
    {
        <div class="p-3"><HealthInsuranceGradeTab /></div>
    };

    private RenderFragment CreateWithholdingTaxTableTabContent() => __builder =>
    {
        <div class="p-3"><WithholdingTaxTableTab /></div>
    };

    private RenderFragment CreatePayrollPeriodTabContent() => __builder =>
    {
        <div class="p-3"><PayrollPeriodTab /></div>
    };

    private RenderFragment CreateAttendanceTabContent() => __builder =>
    {
        <div class="p-3">
            <AttendanceTab Year="@(selectedPeriod?.Year ?? 0)" Month="@(selectedPeriod?.Month ?? 0)" />
        </div>
    };

    // ── Tab 切換 ─────────────────────────────────────────────────

    private void SetTab(int index) => activeTabIndex = index;

    // ── 事件處理 ─────────────────────────────────────────────────

    private async Task OnPeriodChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            selectedPeriodId = id;
            selectedPeriod = periods.FirstOrDefault(p => p.Id == id);
            await LoadPeriodDataAsync();
        }
    }

    private async Task CalculateAllAsync()
    {
        if (selectedPeriod == null || isCalculating) return;
        try
        {
            isCalculating = true;
            var result = await CalculationService.CalculateAllAsync(selectedPeriod.Id);
            if (result.IsSuccess)
            {
                await NotificationService.ShowSuccessAsync(L["Payroll.CalculateAllSuccess"].ToString());
                await LoadPeriodDataAsync();
            }
            else
                await NotificationService.ShowErrorAsync(result.ErrorMessage ?? L["Payroll.CalculateFailed"].ToString());
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(CalculateAllAsync), GetType());
        }
        finally
        {
            isCalculating = false;
        }
    }

    private async Task CalculateOneAsync(int employeeId)
    {
        if (selectedPeriod == null) return;
        try
        {
            calculatingEmployeeId = employeeId;
            StateHasChanged();

            var result = await CalculationService.CalculateEmployeeAsync(employeeId, selectedPeriod.Id);
            if (result.IsSuccess)
            {
                var idx = rowViewModels.FindIndex(r => r.Employee.Id == employeeId);
                if (idx >= 0)
                    rowViewModels[idx] = new PayrollEmployeeTable.RowViewModel { Employee = rowViewModels[idx].Employee, Record = result.Data };
            }
            else
                await NotificationService.ShowErrorAsync(result.ErrorMessage ?? L["Payroll.CalculateFailed"].ToString());
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(CalculateOneAsync), GetType());
        }
        finally
        {
            calculatingEmployeeId = null;
        }
    }

    private async Task ConfirmRecordAsync(int recordId)
    {
        try
        {
            var result = await CalculationService.ConfirmRecordAsync(recordId);
            if (result.IsSuccess)
            {
                var vm = rowViewModels.FirstOrDefault(r => r.Record?.Id == recordId);
                if (vm?.Record != null) vm.Record.RecordStatus = PayrollRecordStatus.Confirmed;
                StateHasChanged();
            }
            else
                await NotificationService.ShowErrorAsync(result.ErrorMessage ?? L["Payroll.ConfirmFailed"].ToString());
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(ConfirmRecordAsync), GetType());
        }
    }

    private async Task UnconfirmRecordAsync(int recordId)
    {
        try
        {
            var result = await CalculationService.UnconfirmRecordAsync(recordId);
            if (result.IsSuccess)
            {
                var vm = rowViewModels.FirstOrDefault(r => r.Record?.Id == recordId);
                if (vm?.Record != null) vm.Record.RecordStatus = PayrollRecordStatus.Draft;
                StateHasChanged();
            }
            else
                await NotificationService.ShowErrorAsync(result.ErrorMessage ?? L["Payroll.UnconfirmFailed"].ToString());
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(UnconfirmRecordAsync), GetType());
        }
    }

    private void ShowPayslip(int recordId)
    {
        payslipRecordId = recordId;
        showPayslip = true;
    }

    // ── 輔助方法 ─────────────────────────────────────────────────

    private string GetPeriodStatusLabel(PayrollPeriodStatus status) => status switch
    {
        PayrollPeriodStatus.Draft      => L["Payroll.PeriodDraft"],
        PayrollPeriodStatus.Processing => L["Payroll.PeriodProcessing"],
        PayrollPeriodStatus.Closed     => L["Payroll.PeriodClosed"],
        _ => status.ToString()
    };

    private string GetPeriodStatusBadgeCss(PayrollPeriodStatus status) => status switch
    {
        PayrollPeriodStatus.Draft      => "bg-secondary",
        PayrollPeriodStatus.Processing => "bg-warning text-dark",
        PayrollPeriodStatus.Closed     => "bg-success",
        _ => "bg-secondary"
    };
}
