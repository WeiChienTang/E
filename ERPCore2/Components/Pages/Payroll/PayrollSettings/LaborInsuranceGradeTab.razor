@* 勞保投保分級表 Tab *@
@inject ILaborInsuranceGradeService GradeService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<div class="d-flex align-items-center justify-content-between mb-2">
    <div class="d-flex align-items-center gap-2">
        <label class="form-label mb-0 fw-semibold">@L["Field.EffectiveDate"]：</label>
        <select class="form-select form-select-sm w-auto" @onchange="OnYearChanged">
            @foreach (var date in availableYears)
            {
                <option value="@date.ToString("yyyy-MM-dd")" selected="@(date == selectedYear)">
                    @date.ToString("yyyy-MM-dd")
                </option>
            }
        </select>
        <span class="text-muted small">@L["Payroll.TotalGrades"]：@grades.Count</span>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" @onclick="ShowCopyYear">
            <i class="bi bi-copy me-1"></i>@L["Payroll.CopyYear"]
        </button>
        <button class="btn btn-primary" @onclick="ShowAdd">
            <i class="bi bi-plus-lg me-1"></i>@L["Button.Add"]
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-4"><span class="spinner-border spinner-border-sm me-2"></span>@L["Label.Loading"]</div>
}
else
{
    <GenericInteractiveTableComponent TItem="LaborInsuranceGrade"
                                     Items="@grades"
                                     ColumnDefinitions="@GetColumnDefinitions()"
                                     ShowRowNumbers="false"
                                     ShowBuiltInActions="false"
                                     ShowActions="true"
                                     IsReadOnly="true"
                                     ActionsColumnWidth="100px"
                                     EmptyMessage="@L["Message.NoData"]">
        <ActionsTemplate Context="g">
            <div class="d-flex gap-1 justify-content-center">
                <GenericButtonComponent IconClass="bi bi-pencil"
                                       Variant="ButtonVariant.OutlineDarkBlue"
                                       Size="ButtonSize.Large"
                                       Title="@L["Button.Edit"]"
                                       OnClick="@(() => ShowEdit(g))"
                                       CssClass="btn-square" />
                <GenericButtonComponent IconClass="bi bi-trash"
                                       Variant="ButtonVariant.OutlineRed"
                                       Size="ButtonSize.Large"
                                       Title="@L["Button.Delete"]"
                                       OnClick="@(() => ConfirmDeleteAsync(g))"
                                       CssClass="btn-square" />
            </div>
        </ActionsTemplate>
    </GenericInteractiveTableComponent>
}

<LaborInsuranceGradeEditModalComponent IsVisible="@showModal"
                                       IsVisibleChanged="@((bool v) => showModal = v)"
                                       EditingItem="@editingItem"
                                       DefaultEffectiveDate="@selectedYear"
                                       OnSaved="@ReloadGradesAsync" />

@if (showCopyDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@L["Payroll.CopyYear"]</h5>
                    <button class="btn-close" @onclick="() => showCopyDialog = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">@L["Payroll.CopySource"]</label>
                        <select class="form-select" @bind="copySourceDate">
                            @foreach (var date in availableYears)
                            {
                                <option value="@date.ToString("yyyy-MM-dd")">@date.ToString("yyyy-MM-dd")</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@L["Payroll.CopyTarget"] <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" @bind="copyTargetDate" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showCopyDialog = false">@L["Button.Cancel"]</button>
                    <button class="btn btn-primary" @onclick="DoCopyYearAsync" disabled="@isCopying">
                        @if (isCopying) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @L["Button.Confirm"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<LaborInsuranceGrade> grades = new();
    private List<DateOnly> availableYears = new();
    private DateOnly selectedYear;
    private bool isLoading = true;
    private bool showModal = false;
    private LaborInsuranceGrade? editingItem;
    private bool showCopyDialog = false;
    private string copySourceDate = "";
    private DateOnly copyTargetDate = DateOnly.FromDateTime(DateTime.Today);
    private bool isCopying = false;
    private bool _loaded = false;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    public async Task LoadAsync()
    {
        if (_loaded) return;
        _loaded = true;
        availableYears = await GradeService.GetAvailableYearsAsync();
        selectedYear = availableYears.FirstOrDefault();
        await ReloadGradesAsync();
    }

    private async Task ReloadGradesAsync()
    {
        isLoading = true;
        StateHasChanged();
        availableYears = await GradeService.GetAvailableYearsAsync();
        if (selectedYear == default && availableYears.Any())
            selectedYear = availableYears.First();
        grades = selectedYear != default
            ? await GradeService.GetByEffectiveDateAsync(selectedYear)
            : new List<LaborInsuranceGrade>();
        isLoading = false;
    }

    private async Task OnYearChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
        { selectedYear = date; await ReloadGradesAsync(); }
    }

    private void ShowAdd() { editingItem = null; showModal = true; }
    private void ShowEdit(LaborInsuranceGrade item) { editingItem = item; showModal = true; }
    private void ShowCopyYear() { copySourceDate = availableYears.FirstOrDefault().ToString("yyyy-MM-dd"); showCopyDialog = true; }

    private async Task ConfirmDeleteAsync(LaborInsuranceGrade item)
    {
        var result = await GradeService.DeleteAsync(item.Id);
        if (result.IsSuccess) { await NotificationService.ShowSuccessAsync(L["Message.DeleteSuccess"].ToString()); await ReloadGradesAsync(); }
        else await NotificationService.ShowErrorAsync(result.ErrorMessage ?? L["Message.DeleteFailed"].ToString());
    }

    private async Task DoCopyYearAsync()
    {
        if (!DateOnly.TryParse(copySourceDate, out var src)) return;
        isCopying = true;
        var result = await GradeService.CopyYearAsync(src, copyTargetDate);
        isCopying = false; showCopyDialog = false;
        if (result.IsSuccess) { await NotificationService.ShowSuccessAsync(L["Message.SaveSuccess"].ToString()); selectedYear = copyTargetDate; await ReloadGradesAsync(); }
        else await NotificationService.ShowErrorAsync(result.ErrorMessage ?? L["Message.SaveFailed"].ToString());
    }

    private List<InteractiveColumnDefinition> GetColumnDefinitions() => new()
    {
        new() { Title = L["Field.InsuranceGrade"].ToString(), ColumnType = InteractiveColumnType.Display, PropertyName = "Grade",
                DisplayFormatter = obj => (obj as LaborInsuranceGrade)?.Grade.ToString() ?? "",
                HeaderCssClass = "text-center", CellCssClass = "text-center", Width = "80px" },
        new() { Title = L["Field.SalaryFrom"].ToString(), ColumnType = InteractiveColumnType.Display, PropertyName = "SalaryFrom",
                DisplayFormatter = obj => (obj as LaborInsuranceGrade)?.SalaryFrom.ToString("N0") ?? "",
                HeaderCssClass = "text-end", CellCssClass = "text-end", Width = "110px" },
        new() { Title = L["Field.SalaryTo"].ToString(), ColumnType = InteractiveColumnType.Display, PropertyName = "SalaryTo",
                DisplayFormatter = obj => { var g = obj as LaborInsuranceGrade; return g == null ? "" : g.SalaryTo.HasValue ? g.SalaryTo.Value.ToString("N0") : "—"; },
                HeaderCssClass = "text-end", CellCssClass = "text-end", Width = "110px" },
        new() { Title = L["Field.InsuredSalary"].ToString(), ColumnType = InteractiveColumnType.Display, PropertyName = "InsuredSalary",
                DisplayFormatter = obj => (obj as LaborInsuranceGrade)?.InsuredSalary.ToString("N0") ?? "",
                HeaderCssClass = "text-end", CellCssClass = "text-end", Width = "110px" },
    };
}
