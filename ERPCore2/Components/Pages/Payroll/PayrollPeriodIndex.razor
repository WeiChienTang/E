@page "/payroll/periods"
@inject IPayrollPeriodService PeriodService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="PayrollPeriod"
                        TService="IPayrollPeriodService"
                        Service="@PeriodService"
                        EntityBasePath="/payroll/periods"
                        PageTitle="@L["Page.PayrollPeriodTitle"]"
                        PageSubtitle="@L["Page.PayrollPeriodSubtitle"]"
                        ServerDataLoader="@ServerLoadPeriodsAsync"
                        BreadcrumbItems="@breadcrumbItems"
                        FilterDefinitions="@filterDefinitions"
                        ColumnDefinitions="@columnDefinitions"
                        EntityName="@L["Entity.PayrollPeriod"]"
                        GetEntityDisplayName="@(p => $"{p.Year}年{p.Month}月")"
                        RequiredPermission="@PermissionRegistry.Payroll.Close"
                        RequiredModule="Payroll"
                        ShowAddButton="false"
                        OnRowClick="@modalHandler.ShowEditModalAsync"
                        DebugPageName="PayrollPeriodIndex"
                        @ref="indexComponent"/>

<PayrollPeriodEditModalComponent IsVisible="@showEditModal"
                                  IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                  PayrollPeriodId="@editingId"
                                  OnPayrollPeriodSaved="@modalHandler.OnEntitySavedAsync"
                                  OnCancel="@modalHandler.OnModalCancelAsync"
                                  OnClosePeriod="@HandleClosePeriodAsync" />

@code {
    private GenericIndexPageComponent<PayrollPeriod, IPayrollPeriodService> indexComponent = default!;

    private bool showEditModal = false;
    private int? editingId = null;

    private ModalHandler<PayrollPeriod, GenericIndexPageComponent<PayrollPeriod, IPayrollPeriodService>> modalHandler = default!;

    private PayrollPeriodFieldConfiguration fieldConfiguration = default!;

    private List<BreadcrumbItem> breadcrumbItems = new();
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<PayrollPeriod, GenericIndexPageComponent<PayrollPeriod, IPayrollPeriodService>>(
                id => editingId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new PayrollPeriodFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化薪資週期頁面失敗");
            await NotificationService.ShowErrorAsync("初始化薪資週期頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() =>
        breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("薪資管理", "薪資週期管理", "#", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<PayrollPeriod> Items, int TotalCount)> ServerLoadPeriodsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return PeriodService.GetPagedWithFiltersAsync(
            q =>
            {
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadPeriodsAsync), GetType());
                return q;
            },
            page, pageSize);
    }

    // ===== 關帳（由 EditModal 觸發） =====
    private async Task HandleClosePeriodAsync(int periodId)
    {
        try
        {
            var result = await PeriodService.ClosePeriodAsync(periodId);
            if (result.IsSuccess)
            {
                showEditModal = false;
                await NotificationService.ShowSuccessAsync("關帳成功");
                await indexComponent.Refresh();
            }
            else
            {
                await NotificationService.ShowErrorAsync(result.ErrorMessage ?? "關帳失敗");
            }
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleClosePeriodAsync), GetType());
            await NotificationService.ShowErrorAsync("關帳時發生錯誤");
        }
    }
}
