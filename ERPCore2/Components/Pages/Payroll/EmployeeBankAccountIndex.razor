@page "/payroll/bank-accounts"
@inject IEmployeeBankAccountService BankAccountService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="EmployeeBankAccount"
                        TService="IEmployeeBankAccountService"
                        Service="@BankAccountService"
                        EntityBasePath="/payroll/bank-accounts"
                        PageTitle="@L["Page.EmployeeBankAccountTitle"]"
                        PageSubtitle="@L["Page.EmployeeBankAccountSubtitle"]"
                        ServerDataLoader="@ServerLoadBankAccountsAsync"
                        BreadcrumbItems="@breadcrumbItems"
                        FilterDefinitions="@filterDefinitions"
                        ColumnDefinitions="@columnDefinitions"
                        EntityName="@L["Entity.EmployeeBankAccount"]"
                        GetEntityDisplayName="@(b => $"{b.Employee?.Name} - {b.BankCode}")"
                        RequiredPermission="@PermissionRegistry.Payroll.SalaryConfig"
                        RequiredModule="Payroll"
                        OnAddClick="@modalHandler.ShowAddModalAsync"
                        OnRowClick="@modalHandler.ShowEditModalAsync"
                        DebugPageName="EmployeeBankAccountIndex"
                        @ref="indexComponent"/>

<EmployeeBankAccountEditModalComponent IsVisible="@showEditModal"
                                        IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                        BankAccountId="@editingId"
                                        OnBankAccountSaved="@modalHandler.OnEntitySavedAsync"
                                        OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    private GenericIndexPageComponent<EmployeeBankAccount, IEmployeeBankAccountService> indexComponent = default!;

    private bool showEditModal = false;
    private int? editingId = null;

    private ModalHandler<EmployeeBankAccount, GenericIndexPageComponent<EmployeeBankAccount, IEmployeeBankAccountService>> modalHandler = default!;

    private EmployeeBankAccountFieldConfiguration fieldConfiguration = default!;

    private List<BreadcrumbItem> breadcrumbItems = new();
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<EmployeeBankAccount, GenericIndexPageComponent<EmployeeBankAccount, IEmployeeBankAccountService>>(
                id => editingId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new EmployeeBankAccountFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化銀行帳戶頁面失敗");
            await NotificationService.ShowErrorAsync("初始化銀行帳戶頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() =>
        breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("薪資管理", "員工銀行帳戶", "#", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<EmployeeBankAccount> Items, int TotalCount)> ServerLoadBankAccountsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return BankAccountService.GetPagedWithFiltersAsync(
            q =>
            {
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadBankAccountsAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
