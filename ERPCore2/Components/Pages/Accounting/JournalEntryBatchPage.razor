@*
    舊路由相容性重導向頁面
    批次轉傳票功能已整合至傳票管理頁面 (/journal-entries) 的 Modal 中。
    此頁面保留 /journal-entry-batch 路由，自動重導向至傳票管理頁面。
*@
@page "/journal-entry-batch"
@attribute [Authorize]
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

@code {
    protected override void OnInitialized()
    {
        NavigationManager.NavigateTo("/journal-entries", replace: true);
    }
}
