@page "/journal-entries"
@inject IJournalEntryService JournalEntryService
@rendermode InteractiveServer
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<GenericIndexPageComponent TEntity="JournalEntry"
                          TService="IJournalEntryService"
                          Service="@JournalEntryService"
                          EntityBasePath="/journal-entries"
                          PageTitle="@L["Page.JournalEntryTitle"]"
                          PageSubtitle="@L["Page.JournalEntrySubtitle"]"
                          EntityName="@L["Entity.JournalEntry"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadDataAsync"
                          GetEntityDisplayName="@(je => $"{je.Code} {je.Description}")"
                          RequiredPermission="@PermissionRegistry.JournalEntry.Read"
                          RequiredModule="Accounting"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          DebugPageName="JournalEntryIndex"
                          @ref="indexComponent">
    <CustomIndexButtons>
        <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                                Text="@L["Journal.BatchTransfer"]"
                                IconClass="bi bi-journal-arrow-up"
                                OnClick="@(() => showBatchModal = true)"
                                Title="@L["Journal.BatchTransfer"]" />
    </CustomIndexButtons>
</GenericIndexPageComponent>

<JournalEntryEditModalComponent IsVisible="@showEditModal"
                                IsVisibleChanged="@((bool v) => showEditModal = v)"
                                JournalEntryId="@editingId"
                                OnJournalEntrySaved="@modalHandler.OnEntitySavedAsync"
                                OnCancel="@modalHandler.OnModalCancelAsync" />

<JournalEntryBatchModalComponent IsVisible="@showBatchModal"
                                 IsVisibleChanged="@((bool v) => showBatchModal = v)"
                                 OnClose="@HandleBatchModalCloseAsync" />

@code {
    // 組件參考
    private GenericIndexPageComponent<JournalEntry, IJournalEntryService> indexComponent = default!;

    // Modal 狀態
    private bool showEditModal = false;
    private bool showBatchModal = false;
    private int? editingId = null;

    // Modal 處理器
    private ModalHandler<JournalEntry, GenericIndexPageComponent<JournalEntry, IJournalEntryService>> modalHandler = default!;

    // 欄位配置
    private JournalEntryFieldConfiguration fieldConfiguration = default!;
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<JournalEntry,
                GenericIndexPageComponent<JournalEntry, IJournalEntryService>>(
                id => editingId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            // 2. 初始化麵包屑
            await InitializeBreadcrumbsAsync();

            // 3. 建立欄位配置
            fieldConfiguration = new JournalEntryFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            // 4. 建立篩選器和表格欄位
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(
                ex, nameof(OnInitializedAsync), GetType(),
                additionalData: "初始化傳票管理頁面失敗");
            await NotificationService.ShowErrorAsync("初始化頁面失敗");
        }
    }

    // 麵包屑
    private async Task InitializeBreadcrumbsAsync() =>
        breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync(
            "財務管理", "傳票管理", null, NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<JournalEntry> Items, int TotalCount)> ServerLoadDataAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return JournalEntryService.GetPagedWithFiltersAsync(
            q =>
            {
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadDataAsync), GetType());
                return q;
            },
            page, pageSize);
    }

    // 批次轉傳票 Modal 關閉時重新整理列表
    private async Task HandleBatchModalCloseAsync()
    {
        showBatchModal = false;
        if (indexComponent != null)
        {
            await indexComponent.SmoothRefresh();
        }
        StateHasChanged();
    }
}
