@page "/account-items"
@inject IAccountItemService AccountItemService
@inject IAccountItemListReportService AccountItemListReportService
@rendermode InteractiveServer
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<GenericIndexPageComponent TEntity="AccountItem"
                          TService="IAccountItemService"
                          Service="@AccountItemService"
                          EntityBasePath="/account-items"
                          PageTitle="@L["Page.AccountItemTitle"]"
                          PageSubtitle="@L["Page.AccountItemSubtitle"]"
                          EntityName="@L["Entity.AccountItem"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadDataAsync"
                          GetEntityDisplayName="@(a => $"{a.Code} {a.Name}")"
                          RequiredPermission="@PermissionRegistry.AccountItem.Read"
                          RequiredModule="Accounting"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          RowPrintService="@AccountItemListReportService"
                          RowPrintReportId="@ReportIds.AccountItemList"
                          ShowBatchDeleteButton="true"
                          BatchDeleteTitle="批次刪除會計科目"
                          BatchDeleteColumnDefinitions="@batchDeleteColumns"
                          OnBatchDelete="@ExecuteBatchDeleteAsync"
                          DebugPageName="AccountItemIndex"
                          @ref="indexComponent" />

<AccountItemEditModalComponent IsVisible="@showEditModal"
                              IsVisibleChanged="@((bool v) => showEditModal = v)"
                              AccountItemId="@editingId"
                              OnAccountItemSaved="@modalHandler.OnEntitySavedAsync"
                              OnCancel="@modalHandler.OnModalCancelAsync" />


@code {
    // 組件參考
    private GenericIndexPageComponent<AccountItem, IAccountItemService> indexComponent = default!;

    // Modal 狀態
    private bool showEditModal = false;
    private int? editingId = null;

    // 批次刪除欄位定義
    private List<InteractiveColumnDefinition> batchDeleteColumns = new();

    // Modal 處理器
    private ModalHandler<AccountItem, GenericIndexPageComponent<AccountItem, IAccountItemService>> modalHandler = default!;

    // 欄位配置
    private AccountItemFieldConfiguration fieldConfiguration = default!;
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<AccountItem,
                GenericIndexPageComponent<AccountItem, IAccountItemService>>(
                id => editingId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            // 2. 初始化麵包屑
            await InitializeBreadcrumbsAsync();

            // 3. 建立欄位配置
            fieldConfiguration = new AccountItemFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);

            // 4. 建立篩選器和表格欄位
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();

            // 5. 批次刪除欄位定義
            batchDeleteColumns = new List<InteractiveColumnDefinition>
            {
                new() { Title = "科目編號", PropertyName = nameof(AccountItem.Code), Width = "120px" },
                new() { Title = "科目名稱", PropertyName = nameof(AccountItem.Name) },
                new() { Title = "層級", PropertyName = nameof(AccountItem.AccountLevel), Width = "70px", TextAlign = "center" },
                new() { Title = "科目類型", PropertyName = nameof(AccountItem.AccountType), Width = "110px" }
            };
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(
                ex, nameof(OnInitializedAsync), GetType(),
                additionalData: "初始化會計科目頁面失敗");
            await NotificationService.ShowErrorAsync("初始化頁面失敗");
        }
    }

    // 麵包屑
    private async Task InitializeBreadcrumbsAsync() =>
        breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync(
            "財務管理", "會計科目管理", null, NotificationService, GetType());

    // 伺服器端分頁載入（DB 層篩選，無 Include）
    private Task<(List<AccountItem> Items, int TotalCount)> ServerLoadDataAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return AccountItemService.GetPagedWithFiltersAsync(
            q =>
            {
                // 統一 IsDraft 處理：無 ShowDraftTab 時 ShowDrafts 為 null，?? false 永遠只看正式資料
                q = q.Where(a => a.IsDraft == (filter.ShowDrafts ?? false));

                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadDataAsync), GetType());

                var remarks = filter.GetFilterValue("Remarks")?.ToString();
                if (!string.IsNullOrWhiteSpace(remarks))
                    q = q.Where(a => a.Remarks != null && a.Remarks.Contains(remarks));

                return q;
            },
            page,
            pageSize);
    }

    // 批次刪除方法
    private async Task ExecuteBatchDeleteAsync(List<AccountItem> selectedItems)
    {
        var ids = selectedItems.Select(i => i.Id).ToList();
        var result = await AccountItemService.DeleteBatchAsync(ids);
        if (result.IsSuccess)
            await NotificationService.ShowSuccessAsync($"成功刪除 {selectedItems.Count} 筆會計科目");
        else
            await NotificationService.ShowErrorAsync($"批次刪除失敗：{result.ErrorMessage}");
    }
}
