@* 領貨明細管理組件 - 使用條碼掃描和 InteractiveTableComponent *@

@inject IItemService ItemService
@inject IInventoryStockService InventoryStockService
@inject IMaterialIssueService MaterialIssueService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@using ERPCore2.Data.Entities
@using ERPCore2.Helpers

<div class="material-issue-detail-manager">
    <!-- 條碼掃描區 -->
    <div class="card mb-3 border-0 shadow-sm">
        <div class="card-body">
            <div class="row g-3">
                <!-- 條碼輸入欄位 -->
                <div class="col-md-12">
                    <label class="form-label">
                        <i class="bi bi-upc-scan me-2"></i>條碼掃描
                    </label>
                    <input type="text" 
                           class="form-control form-control" 
                           placeholder="請掃描或輸入品項條碼，按 Enter 新增..."
                           @bind="barcodeInput"
                           @bind:event="oninput"
                           @onkeydown="HandleBarcodeKeyDown"
                           @ref="barcodeInputElement"
                           disabled="@IsReadOnly" />
                    <small class="text-muted">掃描條碼後按 Enter 自動新增品項，或直接在下方表格手動輸入</small>
                </div>
            </div>
        </div>
    </div>

    <!-- 明細表格 -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <GenericInteractiveTableComponent @ref="tableComponent"
                                     TItem="DetailItem"
                                     OnDataChanged="@SyncToDetails"
                                     Items="@DetailItems"
                                     ColumnDefinitions="@GetColumnDefinitions()"
                                     IsReadOnly="@IsReadOnly"
                                     ShowRowNumbers="true"
                                     EmptyMessage="尚未新增品項"
                                     ShowBuiltInActions="true"
                                     ShowBuiltInDeleteButton="false"
                                     ActionsColumnWidth="80px"
                                     CustomActionsTemplate="@GetCustomActionsTemplate"
                                     EnableAutoEmptyRow="true"
                                     AllowAddNewRow="@(!IsReadOnly)"
                                     DataLoadCompleted="@_dataLoadCompleted"
                                     CreateEmptyItem="@CreateEmptyItem" />
        </div>
    </div>
</div>

@code {
    // ===== GenericInteractiveTableComponent 參考 =====
    private GenericInteractiveTableComponent<DetailItem>? tableComponent;
    
    // ===== 資料載入完成標記 =====
    private bool _dataLoadCompleted = false; // 初始為 false，LoadExistingDetailsAsync 完成後才設為 true，確保空白行在資料載入後才加入
    private bool _isInitialLoad = true;      // 初次載入標記，避免觸發 MarkDirty
    
    // ===== 參數 =====
    [Parameter] public List<MaterialIssueDetail> Details { get; set; } = new();
    [Parameter] public EventCallback<List<MaterialIssueDetail>> DetailsChanged { get; set; }
    [Parameter] public bool IsReadOnly { get; set; } = false;

    // ===== 私有欄位 =====
    private ElementReference barcodeInputElement;
    private string barcodeInput = string.Empty;
    
    private List<Item> allItems = new();
    
    private List<DetailItem> DetailItems = new();

    // ===== 內部 Item 類別 =====
    private class DetailItem
    {
        public int? ItemId { get; set; }
        public Item? SelectedItem { get; set; }
        public int? WarehouseId { get; set; }
        public int? WarehouseLocationId { get; set; }
        public int? InventoryStockDetailId { get; set; } // 新增：庫存明細ID
        public decimal IssueQuantity { get; set; }
        public decimal UnitCost { get; set; }
        public decimal? AvailableStock { get; set; }
        public int? ProductionScheduleDetailId { get; set; } // 保留關聯排程明細 ID
        
        // SearchableSelect 支援屬性
        public string ItemSearchValue { get; set; } = string.Empty;
        public List<Item> FilteredItems { get; set; } = new();
        public bool ShowItemDropdown { get; set; }
        public int ItemSelectedIndex { get; set; } = -1;
        
        // 倉庫庫位組合選項
        public List<InventoryStockDetail> AvailableWarehouseLocations { get; set; } = new();
    }

    // ===== 生命週期方法 =====
    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadRelatedDataAsync();
            await LoadExistingDetailsAsync();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), 
                additionalData: "初始化領貨明細管理器失敗");
            await NotificationService.ShowErrorAsync("初始化明細管理器失敗");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await barcodeInputElement.FocusAsync();
            }
            catch
            {
                // 忽略 Focus 失敗
            }
        }
    }

    // ===== 資料載入方法 =====

    private async Task LoadRelatedDataAsync()
    {
        try
        {
            allItems = await ItemService.GetAllAsync();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadRelatedDataAsync), GetType(), 
                additionalData: "載入相關資料失敗");
            await NotificationService.ShowErrorAsync("載入相關資料失敗");
            
            allItems = new List<Item>();
        }
    }

    /// <summary>
    /// 公開的刷新方法，用於外部觸發明細刷新（例如：上下筆切換時）
    /// </summary>
    public async Task RefreshDetailsAsync()
    {
        await LoadExistingDetailsAsync();
        tableComponent?.RefreshEmptyRow();
        StateHasChanged();
    }
    
    private async Task LoadExistingDetailsAsync()
    {
        try
        {
            // 🔑 開始載入資料
            _dataLoadCompleted = false;
            
            DetailItems.Clear();
            
            foreach (var detail in Details)
            {
                var product = allItems.FirstOrDefault(p => p.Id == detail.ItemId);
                
                var item = new DetailItem
                {
                    ItemId = detail.ItemId,
                    SelectedItem = product,
                    WarehouseId = detail.WarehouseId > 0 ? (int?)detail.WarehouseId : null,
                    WarehouseLocationId = detail.WarehouseLocationId,
                    IssueQuantity = detail.IssueQuantity,
                    UnitCost = detail.UnitCost ?? 0m,
                    ItemSearchValue = product != null ? $"[{product.Code}] {product.Name}" : "",
                    ProductionScheduleDetailId = detail.ProductionScheduleDetailId
                };

                // 載入該品項的可用倉庫位置清單
                if (item.ItemId.HasValue)
                {
                    item.AvailableWarehouseLocations = await InventoryStockService.GetAvailableWarehouseLocationsByItemAsync(item.ItemId.Value);

                    if (item.WarehouseId.HasValue)
                    {
                        // 已有倉庫（從現有領料單載入）：找到對應的庫存明細ID
                        var stockDetail = item.AvailableWarehouseLocations.FirstOrDefault(d =>
                            d.WarehouseId == item.WarehouseId.Value &&
                            d.WarehouseLocationId == item.WarehouseLocationId);

                        if (stockDetail != null)
                        {
                            item.InventoryStockDetailId = stockDetail.Id;
                            item.AvailableStock = stockDetail.AvailableStock;
                        }
                    }
                    else
                    {
                        // 無倉庫（從排程載入的新項目）：嘗試自動選取
                        await AutoSelectWarehouseAsync(item);
                    }
                }

                DetailItems.Add(item);
            }

            // 將自動選取的倉庫同步回父層
            await SyncToDetails();

            // 🔑 資料載入完成
            _dataLoadCompleted = true;
            _isInitialLoad = false;
            StateHasChanged();
            tableComponent?.RefreshEmptyRow(); // 確保資料載入後空白行正確顯示
        }
        catch (Exception ex)
        {
            _dataLoadCompleted = true;  // 這裡也要設為 true
            _isInitialLoad = false;
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadExistingDetailsAsync), GetType(), 
                additionalData: "載入現有明細失敗");
            DetailItems = new List<DetailItem>();
        }
    }

    // ===== InteractiveTableComponent 欄位定義 =====

    private List<InteractiveColumnDefinition> GetColumnDefinitions()
    {
        var columns = new List<InteractiveColumnDefinition>();

        // 品項欄位 - 使用 SearchableSelect
        columns.Add(new()
        {
            Title = L["Entity.Item"],
            PropertyName = "ItemId",
            EmptyCheckPropertyName = "SelectedItem",
            TriggerEmptyRowOnFilled = true,
            ColumnType = InteractiveColumnType.SearchableSelect,
            Width = "250px",
            Tooltip = "搜尋並選擇品項",
            Placeholder = "請輸入品項編號或名稱",
            SearchValuePropertyName = nameof(DetailItem.ItemSearchValue),
            FilteredItemsPropertyName = nameof(DetailItem.FilteredItems),
            ShowDropdownPropertyName = nameof(DetailItem.ShowItemDropdown),
            SelectedIndexPropertyName = nameof(DetailItem.ItemSelectedIndex),
            ItemDisplayFormatter = (item) =>
            {
                var product = (Item)item;
                return $"[{product.Code}] {product.Name}";
            },
            OnSearchInputChanged = EventCallback.Factory.Create<(object, string?)>(this, (tuple) =>
            {
                var (item, searchValue) = tuple;
                OnItemSearchChanged((DetailItem)item, searchValue);
            }),
            OnItemSelected = EventCallback.Factory.Create<(object, object?)>(this, async (tuple) =>
            {
                var (item, selectedItem) = tuple;
                await OnItemSelected((DetailItem)item, (Item?)selectedItem);
            }),
            OnInputFocus = EventCallback.Factory.Create<object>(this, (item) =>
            {
                var detailItem = (DetailItem)item;
                detailItem.FilteredItems = allItems.Take(20).ToList();
                detailItem.ShowItemDropdown = true;
                detailItem.ItemSelectedIndex = -1;
                StateHasChanged();
            }),
            OnInputBlur = EventCallback.Factory.Create<object>(this, (item) =>
            {
                Task.Delay(200).ContinueWith(_ =>
                {
                    var detailItem = (DetailItem)item;
                    detailItem.ShowItemDropdown = false;
                    InvokeAsync(StateHasChanged);
                });
            }),
            EnableKeyboardNavigation = true,
            GetDropdownItems = (item) => ((DetailItem)item).FilteredItems,
            GetShowDropdown = (item) => ((DetailItem)item).ShowItemDropdown,
            GetSelectedIndex = (item) => ((DetailItem)item).ItemSelectedIndex,
            SetSelectedIndex = (item, index) => ((DetailItem)item).ItemSelectedIndex = index,
            SetShowDropdown = (item, show) => ((DetailItem)item).ShowItemDropdown = show
        });

        // 倉庫 - 庫位欄位（合併顯示）
        columns.Add(new()
        {
            Title = L["Column.MaterialIssueWL"],
            PropertyName = "InventoryStockDetailId",
            ColumnType = InteractiveColumnType.Custom,
            Width = "200px",
            Tooltip = "選擇倉庫和庫位（僅顯示有庫存的位置）",
            CustomTemplate = item =>
            {
                var detailItem = (DetailItem)item;
                var selectedValue = detailItem.InventoryStockDetailId?.ToString() ?? "";
                var isDisabled = IsReadOnly || !detailItem.ItemId.HasValue || !detailItem.AvailableWarehouseLocations.Any();

                return @<select class="form-select form-select-sm"
                                value="@selectedValue"
                                disabled="@isDisabled"
                                @onchange="@(async (e) => await OnWarehouseLocationChanged(detailItem, e.Value))">
                    <option value="">請選擇</option>
                    @foreach (var stockDetail in detailItem.AvailableWarehouseLocations)
                    {
                        var warehouseName = stockDetail.Warehouse?.Name ?? "未知倉庫";
                        var locationName = stockDetail.WarehouseLocation?.Name ?? "預設位置";
                        var displayText = $"{warehouseName} - {locationName}";
                        <option value="@stockDetail.Id">@displayText</option>
                    }
                </select>;
            }
        });

        // 可用庫存欄位
        columns.Add(new()
        {
            Title = L["Column.AvailableInventory"],
            PropertyName = "AvailableStock",
            ColumnType = InteractiveColumnType.Display,
            Width = "100px",
            Tooltip = "當前可用庫存數量",
            DisplayFormatter = (item) =>
            {
                var issueItem = item as DetailItem;
                if (issueItem?.AvailableStock == null) return "-";
                return NumberFormatHelper.FormatSmart(issueItem.AvailableStock.Value);
            }
        });

        // 領貨數量欄位
        columns.Add(new()
        {
            Title = L["Column.IssuedQuantity"],
            PropertyName = "IssueQuantity",
            ColumnType = InteractiveColumnType.Number,
            Width = "120px",
            Tooltip = "輸入領貨數量",
            MinValue = 1,
            OnInputChanged = EventCallback.Factory.Create<(object, string?)>(this, async args =>
            {
                var (item, valueString) = args;
                await OnIssueQuantityChanged((DetailItem)item, valueString);
            })
        });

        return columns;
    }

    // ===== 事件處理方法 =====

    private async Task HandleBarcodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await HandleBarcodeScanned();
        }
    }

    private async Task HandleBarcodeScanned()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(barcodeInput))
            {
                await NotificationService.ShowWarningAsync("請輸入條碼");
                return;
            }

            var product = await ItemService.GetByBarcodeAsync(barcodeInput.Trim());
            
            if (product == null)
            {
                await NotificationService.ShowWarningAsync($"找不到條碼 {barcodeInput} 的品項");
                barcodeInput = string.Empty;
                return;
            }

            // 檢查是否已存在
            if (DetailItems.Any(item => item.ItemId == product.Id))
            {
                await NotificationService.ShowWarningAsync($"品項 {product.Name} 已存在明細中");
                barcodeInput = string.Empty;
                return;
            }

            // 載入可用倉庫位置
            var availableLocations = await InventoryStockService.GetAvailableWarehouseLocationsByItemAsync(product.Id);

            // 建立新明細項目
            var newItem = new DetailItem
            {
                ItemId = product.Id,
                SelectedItem = product,
                ItemSearchValue = $"[{product.Code}] {product.Name}",
                IssueQuantity = 0, // 預設為0（空白）
                UnitCost = 0m, // Item 實體中沒有 Cost 屬性,預設為 0
                AvailableWarehouseLocations = availableLocations
            };
            await AutoSelectWarehouseAsync(newItem);

            // 將新項目加到列表
            DetailItems.Add(newItem);
            
            await SyncToDetails();
            await NotificationService.ShowSuccessAsync($"已新增品項: {product.Name}");
            
            barcodeInput = string.Empty;
            await barcodeInputElement.FocusAsync();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleBarcodeScanned), GetType(), 
                additionalData: $"處理條碼掃描失敗 - 條碼: {barcodeInput}");
            await NotificationService.ShowErrorAsync("處理條碼掃描失敗");
            barcodeInput = string.Empty;
        }
    }

    private void OnItemSearchChanged(DetailItem item, string? searchValue)
    {
        item.ItemSearchValue = searchValue ?? "";
        
        if (string.IsNullOrWhiteSpace(searchValue))
        {
            item.FilteredItems = allItems.Take(20).ToList();
        }
        else
        {
            var search = searchValue.ToLower();
            item.FilteredItems = allItems
                .Where(p => (p.Code?.ToLower().Contains(search) ?? false) || 
                           (p.Name?.ToLower().Contains(search) ?? false) ||
                           (p.Barcode?.ToLower().Contains(search) ?? false))
                .Take(20)
                .ToList();
        }
        
        item.ShowItemDropdown = true;
        item.ItemSelectedIndex = -1;
        
        StateHasChanged();
    }

    private async Task OnItemSelected(DetailItem item, Item? product)
    {
        if (product == null) return;

        item.ItemId = product.Id;
        item.SelectedItem = product;
        item.ItemSearchValue = $"[{product.Code}] {product.Name}";
        item.ShowItemDropdown = false;
        item.UnitCost = 0m; // Item 實體中沒有 Cost 屬性,預設為 0
        
        // 載入該品項的可用倉庫位置清單
        item.AvailableWarehouseLocations = await InventoryStockService.GetAvailableWarehouseLocationsByItemAsync(product.Id);

        // 重置選擇後嘗試自動選取
        item.InventoryStockDetailId = null;
        item.WarehouseId = null;
        item.WarehouseLocationId = null;
        item.AvailableStock = null;
        await AutoSelectWarehouseAsync(item);

        await SyncToDetails();
        StateHasChanged();
    }

    private async Task OnWarehouseLocationChanged(DetailItem item, object? value)
    {
        if (value == null || !int.TryParse(value.ToString(), out int detailId))
        {
            item.InventoryStockDetailId = null;
            item.WarehouseId = null;
            item.WarehouseLocationId = null;
            item.AvailableStock = null;
        }
        else
        {
            item.InventoryStockDetailId = detailId;
            
            // 從可用位置清單中找到對應的明細
            var selectedDetail = item.AvailableWarehouseLocations.FirstOrDefault(d => d.Id == detailId);
            if (selectedDetail != null)
            {
                item.WarehouseId = selectedDetail.WarehouseId;
                item.WarehouseLocationId = selectedDetail.WarehouseLocationId;
                item.AvailableStock = selectedDetail.AvailableStock;
            }
        }
        
        await SyncToDetails();
        StateHasChanged();
    }

    private async Task OnIssueQuantityChanged(DetailItem item, object? value)
    {
        item.IssueQuantity = InputEventHelper.HandleQuantityInput(value?.ToString());

        await SyncToDetails();
        StateHasChanged();
    }

    private async Task HandleItemDelete(DetailItem item)
    {
        try
        {
            if (IsReadOnly) return;
            
            DetailItems.Remove(item);
            
            await SyncToDetails();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleItemDelete), GetType(), 
                additionalData: "刪除明細失敗");
            await NotificationService.ShowErrorAsync("刪除明細失敗");
        }
    }

    // ===== 建立空項目方法 =====
    
    private DetailItem CreateEmptyItem()
    {
        return new DetailItem
        {
            FilteredItems = new List<Item>()
        };
    }

    private RenderFragment<DetailItem> GetCustomActionsTemplate => item => __builder =>
    {
        var isLastEmptyRow = tableComponent?.IsLastEmptyRow(item) ?? false;
        
        // 如果是空行，不顯示刪除按鈕（但最後一個空行需要保護）
        if (item.SelectedItem != null)
        {
            <GenericButtonComponent
                IconClass="bi bi-trash text-white"
                Title="刪除"
                Variant="ButtonVariant.Red"
                OnClick="async () => await HandleItemDelete(item)"
                IsDisabled="@IsReadOnly" />
        }
        else if (isLastEmptyRow)
        {
            // 最後一個空行：顯示禁用的刪除按鈕
            <GenericButtonComponent
                IconClass="bi bi-trash text-white"
                Title="至少需要保留一個空行"
                Variant="ButtonVariant.Red"
                IsDisabled="true" />
        }
    };

    // ===== 輔助方法 =====

    /// <summary>
    /// 根據以下優先順序自動選取倉庫庫位：
    /// 1. 若只有一個可用庫位 → 直接選取
    /// 2. 若有歷史領料記錄且仍在可用清單中 → 選取歷史庫位
    /// 3. 否則保持未選取，由使用者手動選擇
    /// </summary>
    private async Task AutoSelectWarehouseAsync(DetailItem item)
    {
        if (!item.AvailableWarehouseLocations.Any()) return;

        InventoryStockDetail? target = null;

        if (item.AvailableWarehouseLocations.Count == 1)
        {
            // 只有一個可用庫位，直接選取
            target = item.AvailableWarehouseLocations[0];
        }
        else if (item.ItemId.HasValue)
        {
            // 查詢歷史最後一次領料的庫位
            var lastLocation = await MaterialIssueService.GetLastIssuedLocationForItemAsync(item.ItemId.Value);
            if (lastLocation.HasValue)
            {
                target = item.AvailableWarehouseLocations.FirstOrDefault(d =>
                    d.WarehouseId == lastLocation.Value.WarehouseId &&
                    d.WarehouseLocationId == lastLocation.Value.WarehouseLocationId);
            }
        }

        if (target != null)
        {
            item.InventoryStockDetailId = target.Id;
            item.WarehouseId = target.WarehouseId;
            item.WarehouseLocationId = target.WarehouseLocationId;
            item.AvailableStock = target.AvailableStock;
        }
    }

    private async Task SyncToDetails()
    {
        Details.Clear();
        
        foreach (var item in DetailItems)
        {
            // 只有在有品項ID、有效倉庫ID（>0）、且領貨數量大於0時才加入
            if (item.ItemId.HasValue && item.WarehouseId.HasValue && item.WarehouseId.Value > 0 && item.IssueQuantity > 0)
            {
                Details.Add(new MaterialIssueDetail
                {
                    ItemId = item.ItemId.Value,
                    WarehouseId = item.WarehouseId.Value,
                    WarehouseLocationId = item.WarehouseLocationId,
                    IssueQuantity = item.IssueQuantity,
                    UnitCost = item.UnitCost,
                    ProductionScheduleDetailId = item.ProductionScheduleDetailId
                });
            }
        }
        
        // 初次載入時不觸發 DetailsChanged 回呼，避免 MarkDirty 被錯誤呼叫
        if (!_isInitialLoad)
            await DetailSyncHelper.SyncToParentAsync(Details, DetailsChanged);
    }
}
