    /// <summary>
    /// 群組鍵：倉庫名稱/庫位名稱。空白表示未指定倉庫（新增空行），將顯示在群組外。
    /// </summary>
    private string GetGroupKey(StockDetailItem item)
    {
        if (!item.SelectedWarehouseId.HasValue || item.SelectedWarehouseId.Value <= 0)
            return ""; // 未指定倉庫 → 不歸群組

        var warehouseName = Warehouses.FirstOrDefault(w => w.Id == item.SelectedWarehouseId.Value)?.Name
                            ?? $"#{item.SelectedWarehouseId}";
        var locationName = item.SelectedWarehouseLocationId.HasValue
            ? WarehouseLocations.FirstOrDefault(l => l.Id == item.SelectedWarehouseLocationId.Value)?.Name
              ?? $"#{item.SelectedWarehouseLocationId}"
            : "（無指定庫位）";
        return $"{warehouseName} / {locationName}";
    }

