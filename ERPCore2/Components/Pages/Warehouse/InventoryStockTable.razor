    private async Task SaveNewWarehouseAsync()
    {
        if (string.IsNullOrWhiteSpace(_newWarehouseName) || string.IsNullOrWhiteSpace(_newWarehouseCode)) return;

        _isSavingWarehouse = true;
        StateHasChanged();
        try
        {
            var warehouse = new Warehouse
            {
                Name = _newWarehouseName.Trim(),
                Code = _newWarehouseCode.Trim(),
                Status = EntityStatus.Active
            };

            var result = await WarehouseService.CreateAsync(warehouse);
            if (result.IsSuccess && result.Data != null)
            {
                Warehouses.Add(result.Data);
                _columnDefinitions = BuildColumnDefinitions(); // 重建以更新倉庫選項
                CancelAddWarehouse();
                await NotificationService.ShowSuccessAsync($"倉庫「{result.Data.Name}」已建立");
            }
            else
            {
                await NotificationService.ShowErrorAsync(!string.IsNullOrEmpty(result.ErrorMessage) ? result.ErrorMessage : "建立倉庫失敗");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"建立倉庫時發生錯誤：{ex.Message}");
        }
        finally
        {
            _isSavingWarehouse = false;
            StateHasChanged();
        }
    }

    private async Task SaveNewLocationAsync()
    {
        if (!_newLocationWarehouseId.HasValue || string.IsNullOrWhiteSpace(_newLocationName) || string.IsNullOrWhiteSpace(_newLocationCode)) return;

        _isSavingLocation = true;
        StateHasChanged();
        try
        {
            var location = new WarehouseLocation
            {
                Name = _newLocationName.Trim(),
                Code = _newLocationCode.Trim(),
                WarehouseId = _newLocationWarehouseId.Value,
                Status = EntityStatus.Active
            };

            var result = await WarehouseLocationService.CreateAsync(location);
            if (result.IsSuccess && result.Data != null)
            {
                WarehouseLocations.Add(result.Data);
                CancelAddLocation();
                await NotificationService.ShowSuccessAsync($"庫位「{result.Data.Name}」已建立");
            }
            else
            {
                await NotificationService.ShowErrorAsync(!string.IsNullOrEmpty(result.ErrorMessage) ? result.ErrorMessage : "建立庫位失敗");
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"建立庫位時發生錯誤：{ex.Message}");
        }
        finally
        {
            _isSavingLocation = false;
            StateHasChanged();
        }
    }

