@* 庫存明細管理組件 - 使用 InteractiveTableComponent 統一UI *@
@using ERPCore2.Data.Entities
@using ERPCore2.Services
@using ERPCore2.Helpers
@inject IWarehouseService WarehouseService
@inject IWarehouseLocationService WarehouseLocationService
@inject IInventoryStockDetailService InventoryStockDetailService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@typeparam TMainEntity where TMainEntity : BaseEntity
@typeparam TDetailEntity where TDetailEntity : BaseEntity, new()

<div class="card border-0 shadow-sm">
    @* 標題列：庫存明細 + 快速新增按鈕 *@
    @if (!IsReadOnly)
    {
        <div class="card-header d-flex align-items-center justify-content-between py-2 px-3 bg-transparent">
            <div class="d-flex gap-2">
                <GenericButtonComponent Text="新增倉庫"
                                        Variant="ButtonVariant.OutlineGray"
                                        IconClass="bi bi-building"
                                        OnClick="ToggleAddWarehouseForm" />
                <GenericButtonComponent Text="新增庫位"
                                        Variant="ButtonVariant.OutlineGray"
                                        IconClass="bi bi-pin-map"
                                        OnClick="ToggleAddLocationForm" />
            </div>
        </div>
    }

    @* 快速新增倉庫 inline 表單 *@
    @if (_showAddWarehouseForm)
    {
        <div class="px-3 py-2 border-bottom small" style="background-color: var(--bg-secondary);">
            <div class="d-flex gap-2 align-items-end flex-wrap">
                <div>
                    <label class="form-label form-label-sm mb-1">倉庫編號 <span class="text-danger">*</span></label>
                    <input class="form-control form-control-sm" style="min-width:100px"
                           placeholder="系統自動產生"
                           @bind="_newWarehouseCode" @bind:event="oninput" />
                </div>
                <div>
                    <label class="form-label form-label-sm mb-1">倉庫名稱 <span class="text-danger">*</span></label>
                    <input class="form-control form-control-sm" style="min-width:130px"
                           placeholder="倉庫名稱"
                           @bind="_newWarehouseName" @bind:event="oninput" />
                </div>
                <GenericButtonComponent Text="儲存"
                                        Variant="ButtonVariant.DarkBlue"
                                        IconClass="bi bi-check2"
                                        IsLoading="_isSavingWarehouse"
                                        IsDisabled="@(_isSavingWarehouse || string.IsNullOrWhiteSpace(_newWarehouseName) || string.IsNullOrWhiteSpace(_newWarehouseCode))"
                                        OnClick="SaveNewWarehouseAsync" />
                <GenericButtonComponent Variant="ButtonVariant.OutlineGray"
                                        IconClass="bi bi-x"
                                        OnClick="CancelAddWarehouse" />
            </div>
        </div>
    }

    @* 快速新增庫位 inline 表單 *@
    @if (_showAddLocationForm)
    {
        <div class="px-3 py-2 border-bottom small" style="background-color: var(--bg-secondary);">
            <div class="d-flex gap-2 align-items-end flex-wrap">
                <div>
                    <label class="form-label form-label-sm mb-1">庫位編號 <span class="text-danger">*</span></label>
                    <input class="form-control form-control-sm" style="min-width:100px"
                           placeholder="系統自動產生"
                           @bind="_newLocationCode" @bind:event="oninput" />
                </div>
                <div>
                    <label class="form-label form-label-sm mb-1">庫位名稱 <span class="text-danger">*</span></label>
                    <input class="form-control form-control-sm" style="min-width:130px"
                           placeholder="庫位名稱"
                           @bind="_newLocationName" @bind:event="oninput" />
                </div>
                <div>
                    <label class="form-label form-label-sm mb-1">所屬倉庫 <span class="text-danger">*</span></label>
                    <select class="form-select form-select-sm" style="min-width:130px" @bind="_newLocationWarehouseId">
                        <option value="">請選擇</option>
                        @foreach (var wh in Warehouses)
                        {
                            <option value="@wh.Id">@wh.Name</option>
                        }
                    </select>
                </div>
                <GenericButtonComponent Text="儲存"
                                        Variant="ButtonVariant.DarkBlue"
                                        IconClass="bi bi-check2"
                                        IsLoading="_isSavingLocation"
                                        IsDisabled="@(_isSavingLocation || !_newLocationWarehouseId.HasValue || string.IsNullOrWhiteSpace(_newLocationName) || string.IsNullOrWhiteSpace(_newLocationCode))"
                                        OnClick="SaveNewLocationAsync" />
                <GenericButtonComponent Variant="ButtonVariant.OutlineGray"
                                        IconClass="bi bi-x"
                                        OnClick="CancelAddLocation" />
            </div>
        </div>
    }

    <div class="card-body p-0">
        <GenericInteractiveTableComponent @ref="tableComponent"
                                  TItem="StockDetailItem"
                                  OnDataChanged="@NotifyDetailsChanged"
                                  Items="@StockDetailItems"
                                  ColumnDefinitions="@_columnDefinitions"
                                  ShowHeader="true"
                                  ShowActions="false"
                                  ShowBuiltInActions="true"
                                  ShowBuiltInDeleteButton="false"
                                  CustomActionsTemplate="@GetCustomActionsTemplate"
                                  IsReadOnly="@IsReadOnly"
                                  OnItemDelete="@HandleItemDelete"
                                  CssClass="mb-0"
                                  EnableAutoEmptyRow="true"
                                  AllowAddNewRow="@(!IsReadOnly)"
                                  DataLoadCompleted="@_dataLoadCompleted"
                                  CreateEmptyItem="@CreateEmptyItem"
                                  EnableGrouping="true"
                                  GroupKeyFunc="@GetGroupKey"
                                  DefaultGroupsExpanded="true" />
    </div>
</div>

@* 彙總列（含品項單位換算資訊）*@
@if (GetValidItemCount() > 0 || !string.IsNullOrEmpty(PurchaseUnitName))
{
    <div class="d-flex flex-wrap gap-3 px-3 py-2 border-top small"
         style="background-color: var(--bg-secondary); color: var(--text-secondary);">
        @* 品項單位換算資訊 *@
        @if (!string.IsNullOrEmpty(PurchaseUnitName))
        {
            <span>
                <i class="bi bi-rulers me-1"></i>
                <strong>基本單位：</strong>@PurchaseUnitName
            </span>
            @if (!string.IsNullOrEmpty(ProductionUnitName) && ProductionUnitConversionRate.HasValue)
            {
                <span class="text-muted">|</span>
                <span>
                    <strong>製程換算：</strong>
                    @($"1{PurchaseUnitName} = {NumberFormatHelper.FormatSmart(ProductionUnitConversionRate.Value, useThousandsSeparator: false)}{ProductionUnitName}")
                </span>
            }
        }

        @* 庫存彙總 *@
        @if (GetValidItemCount() > 0)
        {
            @if (!string.IsNullOrEmpty(PurchaseUnitName)) { <span class="text-muted">｜</span> }
            <span>
                <i class="bi bi-boxes me-1"></i>
                <strong>@L["Label.TotalCurrentStock"]：</strong>
                @NumberFormatHelper.FormatSmart(GetTotalCurrentStock(), useThousandsSeparator: true)
                @if (!string.IsNullOrEmpty(PurchaseUnitName)) { <span> @PurchaseUnitName</span> }
            </span>
            @if (GetTotalReservedStock() > 0)
            {
                <span>
                    <i class="bi bi-lock me-1"></i>
                    <strong>@L["Label.TotalReservedStock"]：</strong>
                    @NumberFormatHelper.FormatSmart(GetTotalReservedStock(), useThousandsSeparator: true)
                </span>
            }
            @if (GetTotalInTransitStock() > 0)
            {
                <span>
                    <i class="bi bi-truck me-1"></i>
                    <strong>@L["Label.TotalInTransitStock"]：</strong>
                    @NumberFormatHelper.FormatSmart(GetTotalInTransitStock(), useThousandsSeparator: true)
                </span>
            }
        }
    </div>
}


@code {
    // ===== InteractiveTableComponent 參考 =====
    private GenericInteractiveTableComponent<StockDetailItem>? tableComponent;

    // ===== 私有欄位 =====
    private bool _dataLoadCompleted = true;  // 資料載入完成標記
    private List<InteractiveColumnDefinition> _columnDefinitions = new();

    // 用於偵測顯示參數是否變更（快取欄位用）
    private bool _prevShowBatchTracking;
    private bool _prevShowAverageCost;
    private bool _prevIsReadOnly;
    private string _prevPurchaseUnitName = "";
    private string _prevProductionUnitName = "";
    private decimal? _prevConversionRate;

    // 快速新增倉庫/庫位表單狀態
    private bool _showAddWarehouseForm = false;
    private bool _showAddLocationForm = false;
    private string _newWarehouseName = "";
    private string _newWarehouseCode = "";
    private string _newLocationName = "";
    private string _newLocationCode = "";
    private int? _newLocationWarehouseId = null;
    private bool _isSavingWarehouse = false;
    private bool _isSavingLocation = false;

    // ===== 基本參數 =====
    [Parameter] public List<Warehouse> Warehouses { get; set; } = new List<Warehouse>();
    [Parameter] public List<WarehouseLocation> WarehouseLocations { get; set; } = new List<WarehouseLocation>();
    [Parameter] public EventCallback<List<StockDetailItem>> OnStockDetailItemsChanged { get; set; }

    // ===== 庫存主檔ID參數 =====
    [Parameter] public int? SelectedInventoryStockId { get; set; }

    // ===== 泛型參數 =====
    [Parameter] public TMainEntity? MainEntity { get; set; }
    [Parameter] public List<TDetailEntity> ExistingDetails { get; set; } = new List<TDetailEntity>();
    [Parameter] public EventCallback<List<TDetailEntity>> OnDetailsChanged { get; set; }

    // ===== 欄位映射參數 =====
    [Parameter] public string MainEntityIdPropertyName { get; set; } = "InventoryStockId";
    [Parameter] public string CurrentStockPropertyName { get; set; } = "CurrentStock";
    [Parameter] public string ReservedStockPropertyName { get; set; } = "ReservedStock";
    [Parameter] public string InTransitStockPropertyName { get; set; } = "InTransitStock";
    [Parameter] public string AverageCostPropertyName { get; set; } = "AverageCost";
    [Parameter] public string MinStockLevelPropertyName { get; set; } = "MinStockLevel";
    [Parameter] public string MaxStockLevelPropertyName { get; set; } = "MaxStockLevel";
    [Parameter] public string BatchNumberPropertyName { get; set; } = "BatchNumber";
    [Parameter] public string BatchDatePropertyName { get; set; } = "BatchDate";
    [Parameter] public string ExpiryDatePropertyName { get; set; } = "ExpiryDate";
    [Parameter] public string WarehouseIdPropertyName { get; set; } = "WarehouseId";
    [Parameter] public string WarehouseLocationIdPropertyName { get; set; } = "WarehouseLocationId";
    [Parameter] public string RemarksPropertyName { get; set; } = "Remarks";

    // ===== 顯示設定 =====
    [Parameter] public string Title { get; set; } = "庫存明細";
    [Parameter] public string Subtitle { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "boxes";
    [Parameter] public string ItemDisplayName { get; set; } = "明細";
    [Parameter] public string EmptyIcon { get; set; } = "box-open";
    [Parameter] public string EmptyMessage { get; set; } = "尚未新增庫存明細";

    // ===== 顯示控制參數 =====
    [Parameter] public bool ShowBatchTracking { get; set; } = true;
    [Parameter] public bool ShowAverageCost { get; set; } = true;
    [Parameter] public string PurchaseUnitName { get; set; } = "";
    [Parameter] public string ProductionUnitName { get; set; } = "";
    [Parameter] public decimal? ProductionUnitConversionRate { get; set; }

    // ===== 唯讀模式參數 =====
    [Parameter] public bool IsReadOnly { get; set; } = false;

    private List<StockDetailItem> StockDetailItems { get; set; } = new List<StockDetailItem>();
    private int? _previousSelectedInventoryStockId = null;
    private bool _isInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        _previousSelectedInventoryStockId = SelectedInventoryStockId;
        CacheDisplayParams();
        _columnDefinitions = BuildColumnDefinitions();
        await LoadExistingDetailsAsync();
        _isInitialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        base.OnParametersSet();

        if (!_isInitialized)
        {
            return;
        }

        // 顯示參數變更時重建欄位定義（避免每次渲染都重建 EventCallback）
        if (DisplayParamsChanged())
        {
            CacheDisplayParams();
            _columnDefinitions = BuildColumnDefinitions();
        }

        // 🔑 簡化邏輯：檢查庫存主檔是否變更
        if (_previousSelectedInventoryStockId != SelectedInventoryStockId)
        {
            _previousSelectedInventoryStockId = SelectedInventoryStockId;
            StockDetailItems.Clear();
            await LoadExistingDetailsAsync();
            return;
        }
    }

    private bool DisplayParamsChanged() =>
        ShowBatchTracking          != _prevShowBatchTracking  ||
        ShowAverageCost            != _prevShowAverageCost    ||
        IsReadOnly                 != _prevIsReadOnly         ||
        PurchaseUnitName           != _prevPurchaseUnitName   ||
        ProductionUnitName         != _prevProductionUnitName ||
        ProductionUnitConversionRate != _prevConversionRate;

    private void CacheDisplayParams()
    {
        _prevShowBatchTracking     = ShowBatchTracking;
        _prevShowAverageCost       = ShowAverageCost;
        _prevIsReadOnly            = IsReadOnly;
        _prevPurchaseUnitName      = PurchaseUnitName;
        _prevProductionUnitName    = ProductionUnitName;
        _prevConversionRate        = ProductionUnitConversionRate;
    }

    // ===== 建立空項目方法 =====
    private StockDetailItem CreateEmptyItem() => new StockDetailItem();

    // ===== 欄位定義建立（僅在顯示參數變更時重建）=====
    private List<InteractiveColumnDefinition> BuildColumnDefinitions()
    {
        var columns = new List<InteractiveColumnDefinition>();

        // 倉庫選擇欄位
        columns.Add(new()
        {
            Title = L["Entity.Warehouse"],
            PropertyName = "SelectedWarehouseId",
            ColumnType = InteractiveColumnType.Select,
            TriggerEmptyRowOnFilled = true,
            Width = "150px",
            Placeholder = L["Placeholder.PleaseSelect", ""],
            Options = GetWarehouseOptions(),
            OnSelectionChanged = EventCallback.Factory.Create<(object, object?)>(this, async args =>
            {
                var (item, value) = args;
                await OnWarehouseChanged((StockDetailItem)item, value);
            })
        });

        // 庫位選擇欄位
        columns.Add(new()
        {
            Title = L["Column.Location"],
            PropertyName = "SelectedWarehouseLocationId",
            ColumnType = InteractiveColumnType.Custom,
            Width = "150px",
            CustomTemplate = item =>
            {
                var stockItem = (StockDetailItem)item;
                var selectedValue = stockItem.SelectedWarehouseLocationId?.ToString() ?? "";
                var isDisabled = IsReadOnly || !stockItem.SelectedWarehouseId.HasValue;

                return @<select class="form-select form-select-sm"
                                value="@selectedValue"
                                @onchange="@(async e => await OnWarehouseLocationChanged(stockItem, e.Value))"
                                disabled="@isDisabled">
                    <option value="">@L["Placeholder.PleaseSelect", ""]</option>
                    @foreach (var location in GetAvailableLocations(stockItem.SelectedWarehouseId))
                    {
                        <option value="@location.Id">@location.Name</option>
                    }
                </select>;
            }
        });

        // 現有庫存欄位（已存在的明細行顯示唯讀，新增行顯示可編輯輸入框）
        columns.Add(new()
        {
            Title = L["Column.CurrentStock"],
            PropertyName = "CurrentStock",
            ColumnType = InteractiveColumnType.Custom,
            Width = "130px",
            CellCssClass = "text-end",
            CustomTemplate = item =>
            {
                var stockItem = (StockDetailItem)item;
                if (stockItem.ExistingDetailEntity != null || IsReadOnly)
                {
                    var valueStr = NumberFormatHelper.FormatSmart(stockItem.CurrentStock, useThousandsSeparator: true);
                    var display = string.IsNullOrEmpty(PurchaseUnitName) ? valueStr : $"{valueStr} {PurchaseUnitName}";
                    return @<span class="d-block text-end" title="@L["Inventory.CurrentStockReadonlyHint"]">@display</span>;
                }
                else
                {
                    return @<input type="number" class="form-control form-control-sm text-end"
                                   min="0"
                                   value="@(stockItem.CurrentStock == 0 ? "" : stockItem.CurrentStock.ToString())"
                                   placeholder="0"
                                   @onchange="@(async e => await OnCurrentStockInput(stockItem, e.Value?.ToString()))" />;
                }
            }
        });

        // 預留庫存欄位（唯讀顯示，系統自動管理）
        columns.Add(new()
        {
            Title = L["Column.ReservedStock"],
            PropertyName = "ReservedStock",
            ColumnType = InteractiveColumnType.Display,
            Width = "100px",
            CellCssClass = "text-end text-muted",
            DisplayFormatter = item =>
            {
                var stockItem = (StockDetailItem)item!;
                return stockItem.ReservedStock > 0
                    ? NumberFormatHelper.FormatSmart(stockItem.ReservedStock, useThousandsSeparator: true)
                    : "—";
            }
        });

        // 在途庫存欄位（唯讀顯示，系統自動管理）
        columns.Add(new()
        {
            Title = L["Column.InTransitStock"],
            PropertyName = "InTransitStock",
            ColumnType = InteractiveColumnType.Display,
            Width = "100px",
            CellCssClass = "text-end text-muted",
            DisplayFormatter = item =>
            {
                var stockItem = (StockDetailItem)item!;
                return stockItem.InTransitStock > 0
                    ? NumberFormatHelper.FormatSmart(stockItem.InTransitStock, useThousandsSeparator: true)
                    : "—";
            }
        });

        // 製程庫存欄位（有設製程單位且不同於基本單位時顯示）
        if (!string.IsNullOrEmpty(ProductionUnitName) && ProductionUnitConversionRate.HasValue && ProductionUnitConversionRate.Value > 0)
        {
            var rate = ProductionUnitConversionRate.Value;
            var productionUnit = ProductionUnitName;
            columns.Add(new()
            {
                Title = L["Field.ProductionUnitStock"],
                PropertyName = "CurrentStock",
                ColumnType = InteractiveColumnType.Display,
                Width = "130px",
                CellCssClass = "text-end text-muted",
                DisplayFormatter = item =>
                {
                    var stockItem = (StockDetailItem)item!;
                    var converted = stockItem.CurrentStock * rate;
                    var valueStr = NumberFormatHelper.FormatSmart(converted, useThousandsSeparator: true);
                    return string.IsNullOrEmpty(productionUnit) ? valueStr : $"{valueStr} {productionUnit}";
                }
            });
        }

        // 平均成本欄位（條件顯示）
        if (ShowAverageCost)
        {
            columns.Add(new()
            {
                Title = L["Column.AverageCost"],
                PropertyName = "AverageCost",
                ColumnType = InteractiveColumnType.Number,
                Width = "120px",
                CellCssClass = "text-end",
                MinValue = 0,
                OnInputChanged = EventCallback.Factory.Create<(object, string?)>(this, async args =>
                {
                    var (item, valueString) = args;
                    await OnAverageCostInput((StockDetailItem)item, valueString);
                })
            });
        }

        // 最低庫存警戒線欄位
        columns.Add(new()
        {
            Title = L["Column.MinAlertLevel"],
            PropertyName = "MinStockLevel",
            ColumnType = InteractiveColumnType.Number,
            Width = "120px",
            CellCssClass = "text-end",
            MinValue = 0,
            OnInputChanged = EventCallback.Factory.Create<(object, string?)>(this, async args =>
            {
                var (item, valueString) = args;
                await OnMinStockLevelInput((StockDetailItem)item, valueString);
            })
        });

        // 最高庫存警戒線欄位
        columns.Add(new()
        {
            Title = L["Column.MaxAlertLevel"],
            PropertyName = "MaxStockLevel",
            ColumnType = InteractiveColumnType.Number,
            Width = "120px",
            CellCssClass = "text-end",
            MinValue = 0,
            OnInputChanged = EventCallback.Factory.Create<(object, string?)>(this, async args =>
            {
                var (item, valueString) = args;
                await OnMaxStockLevelInput((StockDetailItem)item, valueString);
            })
        });

        // 批次追蹤欄位（條件顯示）
        if (ShowBatchTracking)
        {
            columns.Add(new()
            {
                Title = L["Column.BatchNumber"],
                PropertyName = "BatchNumber",
                ColumnType = InteractiveColumnType.Input,
                Width = "130px",
                Placeholder = "",
                OnInputChanged = EventCallback.Factory.Create<(object, string?)>(this, async args =>
                {
                    var (item, valueString) = args;
                    await OnBatchNumberInput((StockDetailItem)item, valueString);
                })
            });

            columns.Add(new()
            {
                Title = L["Column.BatchDate"],
                PropertyName = "BatchDate",
                ColumnType = InteractiveColumnType.Custom,
                Width = "140px",
                CustomTemplate = item =>
                {
                    var stockItem = (StockDetailItem)item;
                    var val = stockItem.BatchDate?.ToString("yyyy-MM-dd") ?? "";
                    return @<input type="date" class="form-control form-control-sm"
                                   value="@val"
                                   disabled="@IsReadOnly"
                                   @onchange="@(async e => await OnBatchDateChanged(stockItem, e.Value?.ToString()))" />;
                }
            });

            columns.Add(new()
            {
                Title = L["Column.ExpiryDate"],
                PropertyName = "ExpiryDate",
                ColumnType = InteractiveColumnType.Custom,
                Width = "140px",
                CustomTemplate = item =>
                {
                    var stockItem = (StockDetailItem)item;
                    var val = stockItem.ExpiryDate?.ToString("yyyy-MM-dd") ?? "";
                    var isExpired = stockItem.ExpiryDate.HasValue && stockItem.ExpiryDate.Value.Date < DateTime.Today;
                    var cssClass = isExpired
                        ? "form-control form-control-sm border-danger text-danger"
                        : "form-control form-control-sm";
                    return @<input type="date" class="@cssClass"
                                   value="@val"
                                   disabled="@IsReadOnly"
                                   @onchange="@(async e => await OnExpiryDateChanged(stockItem, e.Value?.ToString()))" />;
                }
            });
        }

        // 備註欄位
        columns.Add(new()
        {
            Title = L["Label.Remarks"],
            PropertyName = "Remarks",
            ColumnType = InteractiveColumnType.Input,
            Width = "200px",
            Placeholder = "",
            OnInputChanged = EventCallback.Factory.Create<(object, string?)>(this, async args =>
            {
                var (item, valueString) = args;
                await OnRemarksInput((StockDetailItem)item, valueString);
            })
        });

        return columns;
    }

    private RenderFragment<StockDetailItem> GetCustomActionsTemplate => item => __builder =>
    {
        var isLastEmptyRow = tableComponent?.IsLastEmptyRow(item) ?? false;
        var isDisabled = IsReadOnly || !CanDeleteItem(item, out _) || isLastEmptyRow;
        var title = isLastEmptyRow ? L["Label.KeepOneEmptyRow"].ToString() : L["Button.Delete"].ToString();

        <GenericButtonComponent Variant="ButtonVariant.Red"
                               IconClass="bi bi-trash text-white"
                               Size="ButtonSize.Large"
                               OnClick="@(() => HandleItemDelete(item))"
                               Title="@title"
                               IsDisabled="@isDisabled"
                               StopPropagation="true"
                               CssClass="btn-square" />
    };

    private async Task HandleItemDelete(StockDetailItem item)
    {
        // 若為既有 DB 記錄，先顯示確認對話框
        if (item.ExistingDetailEntity != null && item.ExistingDetailEntity.Id > 0)
        {
            var confirmed = await NotificationService.ShowConfirmAsync(
                L["Message.ConfirmDeleteExistingDetail"],
                L["Button.Delete"]
            );
            if (!confirmed) return;
        }

        var index = StockDetailItems.IndexOf(item);
        await RemoveItemAsync(index);
    }

    // ===== 內部方法 =====

    private async Task LoadExistingDetailsAsync()
    {
        if (ExistingDetails?.Any() != true)
        {
            return;
        }

        // 🔑 開始載入資料 - 設定為未完成
        _dataLoadCompleted = false;

        StockDetailItems.Clear();

        foreach (var detail in ExistingDetails)
        {
            var warehouseId = GetPropertyValue<int>(detail, WarehouseIdPropertyName);
            var warehouseLocationId = GetPropertyValue<int?>(detail, WarehouseLocationIdPropertyName);

            var item = new StockDetailItem
            {
                SelectedWarehouseId = warehouseId,
                SelectedWarehouseLocationId = warehouseLocationId,
                CurrentStock = GetPropertyValue<int>(detail, CurrentStockPropertyName),
                ReservedStock = GetPropertyValue<int>(detail, ReservedStockPropertyName),
                InTransitStock = GetPropertyValue<int>(detail, InTransitStockPropertyName),
                AverageCost = GetPropertyValue<decimal?>(detail, AverageCostPropertyName),
                MinStockLevel = GetPropertyValue<int?>(detail, MinStockLevelPropertyName),
                MaxStockLevel = GetPropertyValue<int?>(detail, MaxStockLevelPropertyName),
                BatchNumber = GetPropertyValue<string>(detail, BatchNumberPropertyName),
                BatchDate = GetPropertyValue<DateTime?>(detail, BatchDatePropertyName),
                ExpiryDate = GetPropertyValue<DateTime?>(detail, ExpiryDatePropertyName),
                Remarks = GetPropertyValue<string>(detail, RemarksPropertyName),
                ExistingDetailEntity = detail
            };

            StockDetailItems.Add(item);
        }

        // 🔑 資料載入完成 - 觸發空行檢查
        _dataLoadCompleted = true;

        await Task.CompletedTask;
    }

    private List<TDetailEntity> ConvertToDetailEntities()
    {
        var details = new List<TDetailEntity>();

        foreach (var item in StockDetailItems.Where(x => x.SelectedWarehouseId.HasValue && x.SelectedWarehouseId.Value > 0))
        {
            TDetailEntity detail;

            if (item.ExistingDetailEntity != null)
            {
                detail = item.ExistingDetailEntity;
            }
            else
            {
                detail = new TDetailEntity();

                if (MainEntity != null)
                {
                    var mainEntityIdProperty = typeof(TDetailEntity).GetProperty(MainEntityIdPropertyName);
                    if (mainEntityIdProperty != null && mainEntityIdProperty.CanWrite)
                    {
                        mainEntityIdProperty.SetValue(detail, SelectedInventoryStockId);
                    }
                }
            }

            SetPropertyValue(detail, WarehouseIdPropertyName, item.SelectedWarehouseId);
            SetPropertyValue(detail, WarehouseLocationIdPropertyName, item.SelectedWarehouseLocationId);
            SetPropertyValue(detail, CurrentStockPropertyName, item.CurrentStock);
            SetPropertyValue(detail, ReservedStockPropertyName, item.ReservedStock);
            SetPropertyValue(detail, InTransitStockPropertyName, item.InTransitStock);
            SetPropertyValue(detail, AverageCostPropertyName, item.AverageCost);
            SetPropertyValue(detail, MinStockLevelPropertyName, item.MinStockLevel);
            SetPropertyValue(detail, MaxStockLevelPropertyName, item.MaxStockLevel);
            SetPropertyValue(detail, BatchNumberPropertyName, item.BatchNumber);
            SetPropertyValue(detail, BatchDatePropertyName, item.BatchDate);
            SetPropertyValue(detail, ExpiryDatePropertyName, item.ExpiryDate);
            SetPropertyValue(detail, RemarksPropertyName, item.Remarks);

            details.Add(detail);
        }

        return details;
    }

    private async Task NotifyDetailsChanged()
    {
        var details = ConvertToDetailEntities();
        await DetailSyncHelper.SyncToParentAsync(details, OnDetailsChanged);
    }

    private T? GetPropertyValue<T>(object obj, string propertyName)
    {
        var property = obj.GetType().GetProperty(propertyName);
        if (property == null) return default(T);

        var value = property.GetValue(obj);
        if (value == null) return default(T);

        if (typeof(T) == typeof(object)) return (T)value;

        var targetType = Nullable.GetUnderlyingType(typeof(T)) ?? typeof(T);

        if (targetType.IsAssignableFrom(value.GetType()))
        {
            return (T)value;
        }

        try
        {
            return (T)Convert.ChangeType(value, targetType);
        }
        catch
        {
            return default(T);
        }
    }

    private void SetPropertyValue(object obj, string propertyName, object? value)
    {
        var property = obj.GetType().GetProperty(propertyName);
        if (property != null && property.CanWrite)
        {
            if (value != null && property.PropertyType != value.GetType())
            {
                var targetType = Nullable.GetUnderlyingType(property.PropertyType) ?? property.PropertyType;
                try
                {
                    value = Convert.ChangeType(value, targetType);
                }
                catch
                {
                    value = null;
                }
            }
            property.SetValue(obj, value);
        }
    }

