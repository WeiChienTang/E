@* 領料單編輯組件 *@
@using ERPCore2.Components.Shared.UI.Form
@using ERPCore2.Helpers
@using ERPCore2.Models
@inject IMaterialIssueService MaterialIssueService
@inject IEmployeeService EmployeeService
@inject IDepartmentService DepartmentService
@inject IProductionScheduleItemService ProductionScheduleItemService
@inject IProductionScheduleDetailService ProductionScheduleDetailService
@inject INotificationService NotificationService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IStringLocalizer<SharedResource> L
@using ERPCore2.Models.FeatureGuides.GuideDefinitions

<GenericEditModalComponent TEntity="MaterialIssue"
                          TService="IMaterialIssueService"
                          @ref="editModalComponent"
                          IsVisible="@IsVisible"
                          IsVisibleChanged="@IsVisibleChanged"
                          @bind-Id="@MaterialIssueId"
                          Service="@MaterialIssueService"
                          EntityName="@L["Entity.MaterialIssue"]"
                          EntityNamePlural="@L["Entity.MaterialIssue"]"
                          ModalTitle="@(MaterialIssueId.HasValue ? L["Message.EditTitle", L["Entity.MaterialIssue"]].ToString() : L["Message.CreateTitle", L["Entity.MaterialIssue"]].ToString())"
                          Size="GenericEditModalComponent<MaterialIssue, IMaterialIssueService>.ModalSize.Desktop"
                          UseGenericForm="true"
                          FormFields="@formFields"
                          FormSections="@formSections"
                          TabDefinitions="@tabDefinitions"
                          AutoCompleteCollections="@(autoCompleteConfig?.Collections)"
                          AutoCompleteDisplayProperties="@(autoCompleteConfig?.DisplayProperties)"
                          AutoCompleteValueProperties="@(autoCompleteConfig?.ValueProperties)"
                          DataLoader="@LoadMaterialIssueData"
                          SaveHandler="@SaveMaterialIssueWrapper"
                          ShowDraftButton="true"
                          DraftSuccessMessage="@L["Message.DraftSuccess", L["Entity.MaterialIssue"]]"
                          SaveSuccessMessage="@(MaterialIssueId.HasValue ? L["Message.UpdateSuccess", L["Entity.MaterialIssue"]].ToString() : L["Message.CreateSuccess", L["Entity.MaterialIssue"]].ToString())"
                          SaveFailureMessage="@L["Message.SaveFailure", L["Entity.MaterialIssue"]]"
                          RequiredPermission="@PermissionRegistry.MaterialIssue.Read"
                          OnEntitySaved="@OnMaterialIssueSaved"
                          OnCancel="@OnCancel"
                          OnFieldChanged="@OnFieldValueChanged"
                          CustomValidator="@ValidateMaterialIssueDetailsAsync"
                          OnEntityLoaded="@HandleEntityLoaded"
                          ComponentName="MaterialIssueEditModalComponent"
                          FeatureGuide="@MaterialIssueGuide.Create()">
</GenericEditModalComponent>

@code {
    // ===== 必要參數 =====
    [Parameter] public bool IsVisible { get; set; } = false;
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? MaterialIssueId { get; set; }
    [Parameter] public EventCallback<MaterialIssue> OnMaterialIssueSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    /// <summary>
    /// 從生產排程建立時傳入的排程 ID，會自動載入排程物料需求
    /// </summary>
    [Parameter] public int? SourceProductionScheduleId { get; set; }

    /// <summary>
    /// 從排程看板卡片開啟時傳入的排程項目 ID，只載入該項目的 BOM 物料需求
    /// </summary>
    [Parameter] public int? SourceProductionScheduleItemId { get; set; }

    // ===== 內部狀態 =====
    private GenericEditModalComponent<MaterialIssue, IMaterialIssueService>? editModalComponent;
    private List<FormFieldDefinition> formFields = new();
    private Dictionary<string, string> formSections = new();
    private List<FormTabDefinition>? tabDefinitions;

    // 原始資料集合（用於 AutoComplete）
    private List<Employee> availableEmployees = new();
    private List<Department> availableDepartments = new();

    // 領料明細
    private List<MaterialIssueDetail> materialIssueDetails = new();
    private MaterialIssueTable? detailManagerComponent;

    // 下拉選單選項
    private List<Employee> employees = new();
    private List<Department> departments = new();
    private List<SelectOption> employeeOptions = new();
    private List<SelectOption> departmentOptions = new();

    // AutoComplete 配置
    private AutoCompleteConfig? autoCompleteConfig;

    // 訂單來源 Tab
    private MaterialIssueOrderSourceTab? orderSourceTab;
    private List<ProductionScheduleItem> _sourceScheduleItems = new();

    // 資料載入狀態標記
    private bool isDataLoaded = false;

    // ===== 必要方法 =====
    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !isDataLoaded)
        {
            // 每次開啟 Modal 時都重置明細資料
            materialIssueDetails = new List<MaterialIssueDetail>();
            _sourceScheduleItems = new List<ProductionScheduleItem>();

            await LoadAdditionalDataAsync();
            await InitializeFormFieldsAsync();
            isDataLoaded = true;
        }
        else if (!IsVisible)
        {
            isDataLoaded = false;
        }
    }

    /// <summary>
    /// 處理實體載入完成事件（由 GenericEditModalComponent 的導航觸發）
    /// 當上下筆切換時，重新載入對應的明細資料
    /// </summary>
    private async Task HandleEntityLoaded(int loadedEntityId)
    {
        try
        {
            // 1. 使用 GetWithDetailsAsync 重新載入明細資料
            var materialIssue = await MaterialIssueService.GetWithDetailsAsync(loadedEntityId);
            
            if (materialIssue?.MaterialIssueDetails != null)
            {
                materialIssueDetails = materialIssue.MaterialIssueDetails.ToList();
            }
            else
            {
                materialIssueDetails = new List<MaterialIssueDetail>();
            }
            
            // 🔑 關鍵修正：立即觸發 UI 更新，確保 Table 元件收到新的 Details 參數
            // 這樣 RefreshDetailsAsync() 才能讀取到正確的明細資料
            StateHasChanged();

            // 2. 觸發 Table 元件刷新（此時 Details 已經是新的資料）
            if (detailManagerComponent != null)
            {
                await detailManagerComponent.RefreshDetailsAsync();
            }

            // 3. 重置排程項目（訂單來源 Tab 會透過參數變更自動重新計算）
            _sourceScheduleItems = new List<ProductionScheduleItem>();

            // 4. 最後再次更新 UI（確保所有變更都反映在畫面上）
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleEntityLoaded), GetType(), 
                additionalData: $"處理實體載入事件失敗 - EntityId: {loadedEntityId}");
            await NotificationService.ShowErrorAsync("載入明細資料時發生錯誤");
        }
    }
    // ===== 資料載入方法 =====

    private async Task<MaterialIssue?> LoadMaterialIssueData()
    {
        try
        {
            // 先清空明細資料，避免顯示上一次的資料
            materialIssueDetails = new List<MaterialIssueDetail>();
            
            if (!MaterialIssueId.HasValue)
            {
                // 新增模式：建立新的領料單實體並生成單號
                var newMaterialIssue = new MaterialIssue
                {
                    Code = await EntityCodeGenerationHelper.GenerateForEntity<MaterialIssue, IMaterialIssueService>(MaterialIssueService, "MI"),
                    IssueDate = DateTime.Today,
                    Status = EntityStatus.Active,
                    ProductionScheduleId = SourceProductionScheduleId,
                    MaterialIssueDetails = new List<MaterialIssueDetail>()
                };

                // 從排程項目（看板卡片）載入單一項目的物料需求（優先）
                if (SourceProductionScheduleItemId.HasValue)
                {
                    await LoadMaterialsFromScheduleItemAsync(SourceProductionScheduleItemId.Value);
                }
                // 否則若有來源排程批次，載入整批待領物料明細
                else if (SourceProductionScheduleId.HasValue)
                {
                    await LoadMaterialsFromScheduleAsync(SourceProductionScheduleId.Value);
                }

                return newMaterialIssue;
            }

            var materialIssue = await MaterialIssueService.GetWithDetailsAsync(MaterialIssueId.Value);

            if (materialIssue != null)
            {
                // 載入明細（訂單來源 Tab 會透過參數變更自動重新計算）
                materialIssueDetails = materialIssue.MaterialIssueDetails?.ToList() ?? new List<MaterialIssueDetail>();
            }

            return materialIssue;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadMaterialIssueData), GetType(), 
                additionalData: $"載入領料單資料失敗 - ID: {MaterialIssueId}");
            await NotificationService.ShowErrorAsync("載入領料單資料失敗");
            return null;
        }
    }

    /// <summary>
    /// 從生產排程自動載入待領物料到 materialIssueDetails
    /// 只載入 PendingIssueQuantity > 0 的項目
    /// </summary>
    private async Task LoadMaterialsFromScheduleAsync(int scheduleId)
    {
        try
        {
            // 取得此排程的所有項目（包含 SalesOrderDetail.SalesOrder）
            var targetItems = await ProductionScheduleItemService.GetByScheduleIdAsync(scheduleId);
            targetItems = targetItems.Where(i => !i.IsClosed).ToList();

            if (!targetItems.Any()) return;

            var details = new List<MaterialIssueDetail>();
            foreach (var item in targetItems)
            {
                var scheduleDetails = await ProductionScheduleDetailService.GetByScheduleItemIdAsync(item.Id);
                foreach (var sd in scheduleDetails.Where(d => d.PendingIssueQuantity > 0))
                {
                    details.Add(new MaterialIssueDetail
                    {
                        ItemId = sd.ComponentItemId,
                        IssueQuantity = sd.PendingIssueQuantity,
                        ProductionScheduleDetailId = sd.Id,
                        Status = EntityStatus.Active
                    });
                }
            }

            if (details.Any())
            {
                materialIssueDetails = details;
                await NotificationService.ShowInfoAsync($"已從生產排程載入 {details.Count} 筆物料需求");
            }

            // 儲存排程項目供訂單來源 Tab 使用
            _sourceScheduleItems = targetItems;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadMaterialsFromScheduleAsync), GetType(),
                additionalData: $"從排程載入物料失敗 - ScheduleId: {scheduleId}");
        }
    }

    /// <summary>
    /// 從單一排程項目（看板卡片）載入待領物料到 materialIssueDetails
    /// </summary>
    private async Task LoadMaterialsFromScheduleItemAsync(int scheduleItemId)
    {
        try
        {
            var scheduleDetails = await ProductionScheduleDetailService.GetByScheduleItemIdAsync(scheduleItemId);
            var pending = scheduleDetails.Where(d => d.PendingIssueQuantity > 0).ToList();

            if (!pending.Any()) return;

            materialIssueDetails = pending.Select(sd => new MaterialIssueDetail
            {
                ItemId = sd.ComponentItemId,
                IssueQuantity = sd.PendingIssueQuantity,
                ProductionScheduleDetailId = sd.Id,
                Status = EntityStatus.Active
            }).ToList();

            await NotificationService.ShowInfoAsync($"已從排程項目載入 {materialIssueDetails.Count} 筆物料需求");

            // 載入排程項目（含 SalesOrderDetail.SalesOrder）供訂單來源 Tab 使用
            var item = await ProductionScheduleItemService.GetByIdAsync(scheduleItemId);
            if (item != null)
                _sourceScheduleItems = new List<ProductionScheduleItem> { item };
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadMaterialsFromScheduleItemAsync), GetType(),
                additionalData: $"從排程項目載入物料失敗 - ScheduleItemId: {scheduleItemId}");
        }
    }

    private async Task LoadAdditionalDataAsync()
    {
        try
        {
            // 並行載入相關資料
            var employeesTask = EmployeeService.GetAllAsync();
            var departmentsTask = DepartmentService.GetAllAsync();

            await Task.WhenAll(employeesTask, departmentsTask);

            // 過濾掉超級管理員
            var allEmployees = await employeesTask;
            employees = allEmployees.Where(e => !e.IsSuperAdmin).ToList();
            departments = await departmentsTask;
            
            availableEmployees = employees;
            availableDepartments = departments;

            // 建立下拉選單選項
            employeeOptions = employees.Select(e => new SelectOption
            {
                Text = e.Name ?? "",
                Value = e.Id.ToString()
            }).ToList();

            departmentOptions = departments.Select(d => new SelectOption
            {
                Text = d.Name ?? "",
                Value = d.Id.ToString()
            }).ToList();
            
            // 配置 AutoComplete
            autoCompleteConfig = new AutoCompleteConfigBuilder<MaterialIssue>()
                .AddField(nameof(MaterialIssue.EmployeeId), "Name", availableEmployees)
                .AddField(nameof(MaterialIssue.DepartmentId), "Name", availableDepartments)
                .Build();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadAdditionalDataAsync), GetType(), 
                additionalData: "載入領料單相關資料失敗");
            await NotificationService.ShowErrorAsync("載入相關資料失敗");
            
            // 設定安全的預設值
            employees = new List<Employee>();
            departments = new List<Department>();
            employeeOptions = new List<SelectOption>();
            departmentOptions = new List<SelectOption>();
        }
    }

    // ===== Tab 內容 RenderFragment =====

    private RenderFragment CreateDetailExtraContent() => __builder =>
    {
        if (editModalComponent?.Entity != null)
        {
            <MaterialIssueTable @ref="detailManagerComponent"
                                Details="@materialIssueDetails"
                                DetailsChanged="@HandleDetailsChanged"
                                IsReadOnly="false" />
        }
    };

    private RenderFragment CreateOrderSourceTabContent() => __builder =>
    {
        <MaterialIssueOrderSourceTab @ref="orderSourceTab"
                                     IssueDetails="@materialIssueDetails"
                                     SourceScheduleItems="@_sourceScheduleItems" />
    };

    private async Task InitializeFormFieldsAsync()
    {
        try
        {
            formFields = new List<FormFieldDefinition>
            {
                new FormFieldDefinition()
                {
                    PropertyName = nameof(MaterialIssue.Code),
                    Label = L["Field.MaterialIssueCode"],
                    FieldType = FormFieldType.Text,
                    IsReadOnly = true,
                    Placeholder = L["Placeholder.AutoGenerated"],
                    HelpText = "系統自動產生的唯一領料單號"
                },
                new FormFieldDefinition()
                {
                    PropertyName = nameof(MaterialIssue.IssueDate),
                    Label = L["Field.MaterialIssueDate"],
                    FieldType = FormFieldType.Date,
                    IsRequired = true,
                    DefaultValue = DateTime.Today,
                    HelpText = "請選擇領料的日期"
                },
                new FormFieldDefinition()
                {
                    PropertyName = nameof(MaterialIssue.EmployeeId),
                    Label = L["Field.MaterialIssueStaff"],
                    FieldType = FormFieldType.Select,
                    IsRequired = false,
                    Options = employeeOptions,
                    Placeholder = L["Placeholder.PleaseSelect", L["Field.MaterialIssueStaff"]],
                    HelpText = "選擇負責領料的員工"
                },
                new FormFieldDefinition()
                {
                    PropertyName = nameof(MaterialIssue.DepartmentId),
                    Label = L["Field.MaterialIssueDept"],
                    FieldType = FormFieldType.Select,
                    IsRequired = false,
                    Options = departmentOptions,
                    Placeholder = L["Placeholder.PleaseSelect", L["Field.MaterialIssueDept"]],
                    HelpText = "選擇負責領料的部門"
                },

                FormFieldConfigurationHelper.CreateRemarksField<MaterialIssue>()
            };

            var layout = FormSectionHelper<MaterialIssue>.Create()
                .AddToSection(FormSectionNames.BasicInfo,
                    mi => mi.Code,
                    mi => mi.IssueDate,
                    mi => mi.EmployeeId,
                    mi => mi.DepartmentId)
                .AddToSection(FormSectionNames.AdditionalData,
                    mi => mi.Remarks)
                .GroupIntoTab(L["Tab.BasicData"].ToString(), "bi-info-circle",
                    FormSectionNames.BasicInfo, FormSectionNames.AdditionalData)
                .GroupIntoCustomTab(L["Tab.OrderSource"].ToString(), "bi-receipt", CreateOrderSourceTabContent(), nameof(MaterialIssueOrderSourceTab))
                .BuildAll();

            formSections = layout.FieldSections;
            tabDefinitions = layout.TabDefinitions;

            // 將領料明細表格附加在「基本資料」Tab 的表單欄位下方
            var basicTab = tabDefinitions?.FirstOrDefault(t => t.Label == "基本資料");
            if (basicTab != null)
                basicTab.ExtraContent = CreateDetailExtraContent();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(InitializeFormFieldsAsync), GetType(), 
                additionalData: "初始化表單欄位失敗");
            formFields = new List<FormFieldDefinition>();
            formSections = new Dictionary<string, string>();
        }
    }

    private void HandleDetailsChanged(List<MaterialIssueDetail> details)
    {
        editModalComponent?.MarkDirty();
        materialIssueDetails = details;
        StateHasChanged();
    }

    // ===== 儲存處理 =====

    private async Task<bool> SaveMaterialIssueWrapper(MaterialIssue materialIssue)
    {
        try
        {
            if (materialIssue == null)
            {
                await NotificationService.ShowErrorAsync("沒有要儲存的領料單資料");
                return false;
            }

            if (!materialIssue.IsDraft)
            {
                // 草稿模式跳過明細驗證；非草稿才執行，錯誤依情境路由
                bool isDraftEligible = editModalComponent?.ShowDraftButton == true &&
                                       (!MaterialIssueId.HasValue || editModalComponent?.WasOriginallyDraft == true);

                var validationErrors = new List<string>();

                if (!materialIssueDetails.Any())
                    validationErrors.Add("請至少新增一筆領料明細");
                else
                {
                    var invalidDetails = materialIssueDetails.Where(d =>
                        d.ItemId <= 0 || d.WarehouseId <= 0 || d.IssueQuantity <= 0).ToList();
                    if (invalidDetails.Any())
                        validationErrors.Add("存在無效的明細資料，請檢查品項、倉庫和數量是否都已填寫");
                }

                if (validationErrors.Any())
                {
                    // 明細驗證錯誤一律以 Toast 顯示，不觸發「儲存草稿」提示
                    // 草稿提示僅適用於必填表單欄位（如領料日期），不適用於明細資料問題
                    await NotificationService.ShowErrorAsync(string.Join("；", validationErrors));
                    return false;
                }
            }

            // 設定明細
            materialIssue.MaterialIssueDetails = materialIssueDetails;

            // 儲存領料單
            ServiceResult<MaterialIssue> result;
            var isNewRecord = materialIssue.Id == 0;
            List<MaterialIssueDetail> oldDetails = new();

            if (materialIssue.Id > 0)
            {
                // 編輯模式：先載入舊明細（用於計算 IssuedQuantity 差異）
                var oldMaterialIssue = await MaterialIssueService.GetWithDetailsAsync(materialIssue.Id);
                oldDetails = oldMaterialIssue?.MaterialIssueDetails?.ToList() ?? new();

                // 步驟 1: 更新主檔和明細（不處理庫存）
                result = await MaterialIssueService.UpdateAsync(materialIssue);

                if (!result.IsSuccess || result.Data == null)
                {
                    await NotificationService.ShowErrorAsync(result.ErrorMessage ?? "更新領料單失敗");
                    return false;
                }

                // 步驟 2: 單獨處理庫存差異
                var inventoryResult = await MaterialIssueService.UpdateInventoryByDifferenceAsync(result.Data.Id, 0);

                if (!inventoryResult.IsSuccess)
                {
                    await NotificationService.ShowErrorAsync(inventoryResult.ErrorMessage ?? "更新庫存失敗");
                    return false;
                }
            }
            else
            {
                // 新增模式：CreateAsync 已包含庫存處理
                result = await MaterialIssueService.CreateAsync(materialIssue);

                if (!result.IsSuccess || result.Data == null)
                {
                    await NotificationService.ShowErrorAsync(result.ErrorMessage ?? "儲存領料單失敗");
                    return false;
                }
            }

            // 回寫 ProductionScheduleDetail.IssuedQuantity
            // 新增時由 CreateAsync 在服務層負責（含交易保護），不可重複累加
            // 編輯時由此計算差異並更新
            if (!isNewRecord)
            {
                await UpdateScheduleDetailIssuedQuantityAsync(materialIssueDetails, oldDetails, isNewRecord);
            }

            return true;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(SaveMaterialIssueWrapper), GetType(),
                additionalData: $"儲存領料單失敗 - ID: {materialIssue?.Id}");
            await NotificationService.ShowErrorAsync($"儲存時發生錯誤：{ex.Message}");
            return false;
        }
    }

    // ===== 驗證方法 =====

    private async Task<bool> ValidateMaterialIssueDetailsAsync(MaterialIssue materialIssue)
    {
        try
        {
            // 驗證至少有一筆明細
            if (!materialIssueDetails.Any())
            {
                await NotificationService.ShowErrorAsync("請至少新增一筆領料明細");
                return false;
            }

            // 驗證明細資料完整性
            var invalidDetails = materialIssueDetails.Where(d => 
                d.ItemId <= 0 || 
                d.WarehouseId <= 0 || 
                d.IssueQuantity <= 0
            ).ToList();

            if (invalidDetails.Any())
            {
                await NotificationService.ShowErrorAsync("存在無效的明細資料，請檢查品項、倉庫和數量是否都已填寫");
                return false;
            }

            return true;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(ValidateMaterialIssueDetailsAsync), GetType(), 
                additionalData: "驗證領料明細失敗");
            await NotificationService.ShowErrorAsync("驗證明細資料時發生錯誤");
            return false;
        }
    }

    // ===== 欄位變更處理 =====

    private async Task OnFieldValueChanged((string PropertyName, object? Value) fieldChange)
    {
        try
        {
            // 可在此處理欄位變更邏輯
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnFieldValueChanged), GetType(), 
                additionalData: $"處理欄位變更失敗 - Property: {fieldChange.PropertyName}");
        }
    }

    // ===== 輔助方法 =====

    /// <summary>
    /// 儲存領料單後，回寫對應的 ProductionScheduleDetail.IssuedQuantity
    /// 新增時直接累加；編輯時計算差異（避免重複累加）
    /// </summary>
    private async Task UpdateScheduleDetailIssuedQuantityAsync(
        List<MaterialIssueDetail> newDetails,
        List<MaterialIssueDetail> oldDetails,
        bool isNewRecord)
    {
        try
        {
            // 收集所有受影響的 ProductionScheduleDetail ID（新舊合集）
            var allAffectedIds = newDetails
                .Where(d => d.ProductionScheduleDetailId.HasValue)
                .Select(d => d.ProductionScheduleDetailId!.Value)
                .Union(oldDetails
                    .Where(d => d.ProductionScheduleDetailId.HasValue)
                    .Select(d => d.ProductionScheduleDetailId!.Value))
                .Distinct()
                .ToList();

            foreach (var scheduleDetailId in allAffectedIds)
            {
                var sd = await ProductionScheduleDetailService.GetByIdAsync(scheduleDetailId);
                if (sd == null) continue;

                var newQty = newDetails
                    .Where(d => d.ProductionScheduleDetailId == scheduleDetailId)
                    .Sum(d => d.IssueQuantity);

                if (isNewRecord)
                {
                    // 新增：直接累加
                    sd.IssuedQuantity += newQty;
                }
                else
                {
                    // 編輯：只加差異，避免重複累加
                    var oldQty = oldDetails
                        .Where(d => d.ProductionScheduleDetailId == scheduleDetailId)
                        .Sum(d => d.IssueQuantity);
                    sd.IssuedQuantity = Math.Max(0, sd.IssuedQuantity + (newQty - oldQty));
                }

                await ProductionScheduleDetailService.UpdateAsync(sd);
            }
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(UpdateScheduleDetailIssuedQuantityAsync), GetType(),
                additionalData: "回寫排程已領數量失敗");
            // 不拋出例外，不中斷主流程
        }
    }
}
