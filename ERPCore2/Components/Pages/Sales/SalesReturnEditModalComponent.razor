    /// <summary>
    /// 使用差異比較更新庫存（統一處理新增和編輯）
    /// </summary>
    private async Task UpdateInventoryByDifferenceAsync(int salesReturnId)
    {
        var inventoryUpdateResult = await SalesReturnService.UpdateInventoryByDifferenceAsync(salesReturnId);
        
        if (!inventoryUpdateResult.IsSuccess)
        {
            await NotificationService.ShowErrorAsync($"庫存更新失敗：{inventoryUpdateResult.ErrorMessage}");
            throw new Exception($"庫存更新失敗：{inventoryUpdateResult.ErrorMessage}");
        }
    }

    // ===== 審核功能 =====

    private bool ShouldShowApprovalSection()
        => isManualApproval && SalesReturnId.HasValue && SalesReturnId.Value > 0;

    private Func<bool>? GetCanPrintCheck()
        => isManualApproval
            ? () => ApprovalConfigHelper.CanPerformActionRequiringApproval(
                  isManualApproval, editModalComponent?.Entity?.IsApproved ?? false)
            : null;

    private async Task<bool> HandleSalesReturnApprove()
    {
        try
        {
            var entity = editModalComponent?.Entity;
            if (entity == null || !SalesReturnId.HasValue)
            {
                await NotificationService.ShowErrorAsync("找不到銷貨退回單資料");
                return false;
            }

            var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
            if (!userId.HasValue)
            {
                await NotificationService.ShowErrorAsync("無法取得目前使用者資訊");
                return false;
            }

            if (!await ValidateSalesReturnDetailsAsync(entity))
                return false;

            var saveResult = await SalesReturnService.SaveWithDetailsAsync(entity, salesReturnDetails);
            if (saveResult == null || !saveResult.IsSuccess)
            {
                await NotificationService.ShowErrorAsync(saveResult?.ErrorMessage ?? "儲存銷貨退回單失敗");
                return false;
            }

            // 先核准
            var approveResult = await SalesReturnService.ApproveAsync(entity.Id, userId.Value);
            if (!approveResult.IsSuccess)
            {
                await NotificationService.ShowErrorAsync(approveResult.ErrorMessage ?? "核准失敗");
                return false;
            }

            // 核准成功後觸發庫存更新（人工審核模式下，庫存在此才執行）
            if (saveResult.Data != null)
            {
                try
                {
                    await UpdateInventoryByDifferenceAsync(saveResult.Data.Id);
                }
                catch (Exception inventoryEx)
                {
                    await NotificationService.ShowWarningAsync($"核准成功，但庫存更新發生錯誤：{inventoryEx.Message}");
                }
            }

            return true;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleSalesReturnApprove), GetType());
            return false;
        }
    }

    private async Task<bool> HandleSalesReturnRejectWithReason(string rejectReason)
    {
        try
        {
            if (!SalesReturnId.HasValue)
            {
                await NotificationService.ShowErrorAsync("找不到銷貨退回單資料");
                return false;
            }

            var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
            if (!userId.HasValue)
            {
                await NotificationService.ShowErrorAsync("無法取得目前使用者資訊");
                return false;
            }

            var rejectResult = await SalesReturnService.RejectAsync(SalesReturnId.Value, userId.Value, rejectReason);
            if (!rejectResult.IsSuccess)
            {
                await NotificationService.ShowErrorAsync(rejectResult.ErrorMessage ?? "駁回失敗");
                return false;
            }

            return true;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleSalesReturnRejectWithReason), GetType());
            return false;
        }
    }

