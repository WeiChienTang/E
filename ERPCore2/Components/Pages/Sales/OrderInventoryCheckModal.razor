@* 訂單庫存檢視 Modal *@
@using ERPCore2.Data.Entities
@using ERPCore2.Models
@using ERPCore2.Helpers
@inject ISalesOrderService SalesOrderService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<BaseModalComponent IsVisible="@IsVisible"
                   IsVisibleChanged="@IsVisibleChanged"
                   Title="@GetModalTitle()"
                   Icon="bi bi-box-seam"
                   ShowFooter="false"
                   CloseOnBackdropClick="true"
                   CloseOnEscape="true"
                   IsLoading="@isLoading"
                   LoadingMessage="@L["Inventory.LoadingMessage"]"
                   DebugComponentName="OrderInventoryCheckModal">
    <BodyContent>
        @if (checkResult == null)
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                @L["Inventory.CannotLoad"]
            </div>
        }
        else
        {
            @* 統計摘要 *@
            <div class="inventory-summary @GetSummaryClass() mb-3 p-3 rounded-3">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <span class="fw-bold">
                            <i class="bi bi-clipboard-check me-1"></i>
                            @L["Inventory.SummaryTitle"]
                        </span>
                        <span class="badge bg-secondary">
                            @L["Inventory.TotalItems", checkResult.Items.Count]
                        </span>
                        @if (checkResult.InsufficientItemCount > 0)
                        {
                            <span class="badge bg-danger">
                                <i class="bi bi-x-circle me-1"></i>
                                @L["Inventory.Insufficient"] @checkResult.InsufficientItemCount
                            </span>
                        }
                        @if (checkResult.WarningItemCount > 0)
                        {
                            <span class="badge bg-warning text-dark">
                                <i class="bi bi-exclamation-triangle me-1"></i>
                                @L["Inventory.Warning"] @checkResult.WarningItemCount
                            </span>
                        }
                        @if (checkResult.IsFullySatisfied)
                        {
                            <span class="badge bg-success">
                                <i class="bi bi-check-circle me-1"></i>
                                @L["Inventory.AllSufficient"]
                            </span>
                        }
                    </div>
                    <div class="text-end">
                        <div class="small text-muted mb-1">@L["Inventory.SatisfactionRate"]</div>
                        <div class="d-flex align-items-center gap-2">
                            <div class="progress" style="width: 100px; height: 8px;">
                                <div class="progress-bar @GetProgressBarClass()"
                                     style="width: @(checkResult.OverallSatisfactionRate)%"></div>
                            </div>
                            <span class="fw-bold @GetSatisfactionTextClass()">
                                @checkResult.OverallSatisfactionRate.ToString("F0")%
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            @* 項目列表 *@
            <div class="inventory-item-list">
                @foreach (var item in checkResult.Items)
                {
                    <div class="inventory-item @GetItemBorderClass(item.Status) mb-2 rounded-3">
                        @* 主項目列 *@
                        <div class="d-flex align-items-center p-2 gap-2 cursor-pointer @(item.IsComposition && item.Children.Any() ? "item-header" : "")"
                             @onclick="@(() => ToggleItem(item))">

                            @* 展開/收合按鈕 *@
                            <div class="expand-btn">
                                @if (item.IsComposition && item.Children.Any())
                                {
                                    <i class="bi @(IsItemExpanded(item) ? "bi-chevron-down" : "bi-chevron-right") text-muted"></i>
                                }
                                else
                                {
                                    <i class="bi bi-dash text-muted opacity-0"></i>
                                }
                            </div>

                            @* 狀態圖示 *@
                            <div class="status-icon">
                                <i class="bi @GetStatusIcon(item.Status) @GetStatusIconClass(item.Status) fs-5"></i>
                            </div>

                            @* 品項資訊 *@
                            <div class="flex-grow-1 min-width-0">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <span class="fw-bold text-primary">@item.ItemCode</span>
                                    <span class="text-truncate">@item.ItemName</span>
                                    @if (!string.IsNullOrEmpty(item.ItemSpecification))
                                    {
                                        <span class="badge bg-light text-secondary border">@item.ItemSpecification</span>
                                    }
                                    @if (item.IsComposition)
                                    {
                                        <span class="badge bg-info text-white">
                                            <i class="bi bi-diagram-3 me-1"></i>BOM
                                        </span>
                                    }
                                </div>
                                @* 進度條 *@
                                @{
                                    var pct = item.RequiredQuantity > 0
                                        ? Math.Min(100m, item.AvailableStock / item.RequiredQuantity * 100)
                                        : 100m;
                                }
                                <div class="progress mt-1" style="height: 4px;">
                                    <div class="progress-bar @GetProgressBarClass(item.Status)"
                                         style="width: @pct.ToString("F0")%"></div>
                                </div>
                            </div>

                            @* 數量資訊 *@
                            <div class="qty-info text-end text-nowrap">
                                <div>
                                    <span class="text-muted">@L["Inventory.Required"]</span>
                                    <span class="fw-bold ms-1">@NumberFormatHelper.FormatSmart(item.RequiredQuantity)</span>
                                    <span class="text-muted ms-1">@item.UnitName</span>
                                </div>
                                <div>
                                    <span class="text-muted">@L["Inventory.Stock"]</span>
                                    <span class="fw-bold ms-1 @GetStatusIconClass(item.Status)">
                                        @NumberFormatHelper.FormatSmart(item.AvailableStock)
                                    </span>
                                    <span class="text-muted ms-1">@item.UnitName</span>
                                </div>
                                @if (item.ShortageQuantity > 0)
                                {
                                    <div>
                                        <span class="text-muted">@L["Inventory.Shortage"]</span>
                                        <span class="fw-bold ms-1 text-danger">
                                            @NumberFormatHelper.FormatSmart(item.ShortageQuantity)
                                        </span>
                                        <span class="text-muted ms-1">@item.UnitName</span>
                                    </div>
                                }
                            </div>
                        </div>

                        @* BOM 子項目（展開後顯示） *@
                        @if (item.IsComposition && item.Children.Any() && IsItemExpanded(item))
                        {
                            <div class="bom-children border-top mx-2 mb-2 pt-2">
                                @foreach (var child in item.Children)
                                {
                                    <div class="bom-child-row d-flex align-items-center gap-2 py-1 px-2 rounded @GetChildRowClass(child.Status)">
                                        <i class="bi bi-arrow-return-right text-muted"></i>
                                        <i class="bi @GetStatusIcon(child.Status) @GetStatusIconClass(child.Status)"></i>
                                        <span class="fw-bold text-primary">@child.ItemCode</span>
                                        <span class="text-truncate flex-grow-1">@child.ItemName</span>
                                        @if (child.CompositionMultiplier.HasValue)
                                        {
                                            <span class="badge bg-light text-secondary border">
                                                @L["Inventory.CompositionRatio"] ×@child.CompositionMultiplier.Value.ToString("G")
                                            </span>
                                        }
                                        <div class="text-end text-nowrap">
                                            <span class="text-muted">@L["Inventory.Required"]</span>
                                            <span class="fw-bold ms-1">@NumberFormatHelper.FormatSmart(child.RequiredQuantity)</span>
                                            <span class="text-muted ms-1">@child.UnitName</span>
                                            <span class="text-muted mx-1">|</span>
                                            <span class="text-muted">@L["Inventory.Stock"]</span>
                                            <span class="fw-bold ms-1 @GetStatusIconClass(child.Status)">
                                                @NumberFormatHelper.FormatSmart(child.AvailableStock)
                                            </span>
                                            <span class="text-muted ms-1">@child.UnitName</span>
                                            @if (child.ShortageQuantity > 0)
                                            {
                                                <span class="text-muted mx-1">|</span>
                                                <span class="text-muted">@L["Inventory.Shortage"]</span>
                                                <span class="fw-bold ms-1 text-danger">
                                                    @NumberFormatHelper.FormatSmart(child.ShortageQuantity)
                                                </span>
                                                <span class="text-muted ms-1">@child.UnitName</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="text-muted small text-end mt-2">
                @L["Inventory.SummaryNote"] @checkResult.CheckedAt.ToString("HH:mm:ss")
            </div>
        }
    </BodyContent>
</BaseModalComponent>

@code {
    // ===== 參數定義 =====
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? SalesOrderId { get; set; }
    [Parameter] public string OrderNumber { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClose { get; set; }

    // ===== 私有欄位 =====
    private bool isLoading = false;
    private OrderInventoryCheckResult? checkResult;
    private HashSet<int> expandedItemIds = new();

    // ===== 生命週期 =====
    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && SalesOrderId.HasValue)
        {
            await LoadInventoryCheckAsync();
        }
    }

    private async Task LoadInventoryCheckAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            checkResult = await SalesOrderService.GetOrderInventoryCheckAsync(SalesOrderId!.Value);
            expandedItemIds.Clear();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"{ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetModalTitle()
    {
        if (!string.IsNullOrEmpty(OrderNumber))
            return string.Format(L["Inventory.CheckTitleWithOrder"].ToString(), OrderNumber);
        return L["Inventory.CheckTitle"].ToString();
    }

    // ===== 展開/收合 =====
    private void ToggleItem(OrderInventoryCheckItem item)
    {
        if (!item.IsComposition || !item.Children.Any() || !item.DetailId.HasValue) return;
        if (!expandedItemIds.Remove(item.DetailId.Value))
            expandedItemIds.Add(item.DetailId.Value);
    }

    private bool IsItemExpanded(OrderInventoryCheckItem item)
        => item.DetailId.HasValue && expandedItemIds.Contains(item.DetailId.Value);

    // ===== 樣式輔助 =====
    private string GetSummaryClass() => checkResult switch
    {
        { InsufficientItemCount: > 0 } => "bg-danger bg-opacity-10 border border-danger border-opacity-25",
        { WarningItemCount: > 0 }      => "bg-warning bg-opacity-10 border border-warning border-opacity-25",
        _                              => "bg-success bg-opacity-10 border border-success border-opacity-25"
    };

    private string GetProgressBarClass() => checkResult switch
    {
        { InsufficientItemCount: > 0 } => "bg-danger",
        { WarningItemCount: > 0 }      => "bg-warning",
        _                              => "bg-success"
    };

    private string GetSatisfactionTextClass() => checkResult switch
    {
        { InsufficientItemCount: > 0 } => "text-danger",
        { WarningItemCount: > 0 }      => "text-warning",
        _                              => "text-success"
    };

    private string GetProgressBarClass(InventoryStatus status) => status switch
    {
        InventoryStatus.Sufficient   => "bg-success",
        InventoryStatus.Warning      => "bg-warning",
        InventoryStatus.Insufficient => "bg-danger",
        _                            => "bg-secondary"
    };

    private string GetStatusIcon(InventoryStatus status) => status switch
    {
        InventoryStatus.Sufficient   => "bi-check-circle-fill",
        InventoryStatus.Warning      => "bi-exclamation-triangle-fill",
        InventoryStatus.Insufficient => "bi-x-circle-fill",
        _                            => "bi-question-circle"
    };

    private string GetStatusIconClass(InventoryStatus status) => status switch
    {
        InventoryStatus.Sufficient   => "text-success",
        InventoryStatus.Warning      => "text-warning",
        InventoryStatus.Insufficient => "text-danger",
        _                            => "text-secondary"
    };

    private string GetItemBorderClass(InventoryStatus status) => status switch
    {
        InventoryStatus.Sufficient   => "item-sufficient",
        InventoryStatus.Warning      => "item-warning",
        InventoryStatus.Insufficient => "item-insufficient",
        _                            => "item-default"
    };

    private string GetChildRowClass(InventoryStatus status) => status switch
    {
        InventoryStatus.Insufficient => "bg-danger bg-opacity-10",
        InventoryStatus.Warning      => "bg-warning bg-opacity-10",
        _                            => ""
    };
}
