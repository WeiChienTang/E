@page "/salesOrders"
@using ERPCore2.Models.Reports
@inject ISalesOrderService SalesOrderService
@inject ICustomerService CustomerService
@inject IEmployeeService EmployeeService
@inject ISystemParameterService SystemParameterService
@inject INotificationService NotificationService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISalesOrderReportService SalesOrderReportService
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="SalesOrder" 
                      TService="ISalesOrderService"
                      Service="@SalesOrderService"
                      EntityBasePath="/sales-orders"
                      PageTitle="@L["Page.SalesOrderTitle"]"
                      PageSubtitle="@L["Page.SalesOrderSubtitle"]"
                      EntityName="@L["Entity.SalesOrder"]"
                      BreadcrumbItems="@breadcrumbItems"
                      FilterDefinitions="@filterDefinitions"
                      ColumnDefinitions="@columnDefinitions"
                      ShowDraftTab="true"
                      ServerDataLoader="@ServerLoadSalesOrdersAsync"
                      GetEntityDisplayName="@(salesOrder => salesOrder.Code)"
                      RequiredPermission="@PermissionRegistry.SalesOrder.Read"
                      RequiredModule="Sales"
                      ShowBatchPrintButton="true"
                      OnBatchPrintClick="@HandleBatchPrintAsync"
                      ShowBatchApprovalButton="@isManualApproval"
                      OnBatchApprovalClick="@HandleBatchApprovalAsync"
                      OnAddClick="@modalHandler.ShowAddModalAsync"
                      OnRowClick="@modalHandler.ShowEditModalAsync"
                      DebugPageName="SalesOrderIndex"
                      RowPrintService="@SalesOrderReportService"
                      RowPrintReportId="@ReportIds.SalesOrder"
                      @ref="indexComponent" />

@* 訂單編輯 Modal *@
<SalesOrderEditModalComponent IsVisible="@showEditModal"
                           IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                           SalesOrderId="@editingSalesOrderId"
                           OnSalesOrderSaved="@modalHandler.OnEntitySavedAsync"
                           OnCancel="@modalHandler.OnModalCancelAsync" />

@* 批次審核 Modal *@
<BatchApprovalModalComponent TEntity="SalesOrder"
                            IsVisible="@showBatchApprovalModal"
                            IsVisibleChanged="@((bool visible) => showBatchApprovalModal = visible)"
                            Title="銷貨訂單批次審核"
                            EntityName="@L["Entity.SalesOrder"]"
                            LoadPendingItems="@LoadPendingSalesOrdersAsync"
                            OnApproveItem="@ApproveSingleSalesOrderAsync"
                            OnApproveAll="@ApproveAllSalesOrdersAsync"
                            OnViewClick="@HandleApprovalViewClick"
                            OnApprovalCompleted="@HandleApprovalCompleted" />

@* 批次列印篩選 Modal - 使用 GenericReportFilterModalComponent 統一架構 *@
<GenericReportFilterModalComponent IsVisible="@showBatchPrintModal"
                                  IsVisibleChanged="@((bool visible) => showBatchPrintModal = visible)"
                                  ReportId="@ReportIds.SalesOrder"
                                  OnPrintSuccess="@HandleBatchPrintSuccess" />

@code {
    // 組件參考
    private GenericIndexPageComponent<SalesOrder, ISalesOrderService> indexComponent = default!;
    
    // Modal 相關狀態
    private bool showEditModal = false;
    private int? editingSalesOrderId = null;
    
    // 審核相關狀態
    private bool isManualApproval = false;
    private bool showBatchApprovalModal = false;

    // 批次列印 Modal 相關狀態
    private bool showBatchPrintModal = false;

    // 從 URL 直接開啟指定單據的 Edit Modal（由 CustomerTransactionTable 導航時使用）
    [Parameter, SupplyParameterFromQuery(Name = "editId")]
    public int? EditId { get; set; }

    // Modal 處理器
    private ModalHandler<SalesOrder, GenericIndexPageComponent<SalesOrder, ISalesOrderService>> modalHandler = default!;
    
    // 選項清單
    private List<Customer> customers = new();
    private List<Employee> employees = new();
    
    // 欄位配置
    private SalesOrderFieldConfiguration fieldConfiguration = default!;
    
    // 配置相關
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && EditId.HasValue)
        {
            editingSalesOrderId = EditId.Value;
            showEditModal = true;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<SalesOrder, GenericIndexPageComponent<SalesOrder, ISalesOrderService>>(
                id => editingSalesOrderId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());
            
            await InitializeBreadcrumbsAsync();
            
            // 載入相關資料
            await LoadCustomersAsync();
            await LoadEmployeesAsync();
            
            // 建立欄位配置（在載入相關資料後，並傳遞 NotificationService）
            isManualApproval = await SystemParameterService.IsSalesOrderManualApprovalAsync();
            fieldConfiguration = new SalesOrderFieldConfiguration(customers, employees, isManualApproval, NotificationService);
            fieldConfiguration.SetLocalizer(L);

            // 使用欄位配置建立篩選器和表格欄位
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化訂單頁面失敗");
            await NotificationService.ShowErrorAsync("初始化訂單頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() => breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("銷售管理", "銷貨管理", "#", NotificationService, GetType());

    // 載入客戶資料
    private async Task LoadCustomersAsync() => customers = await DataLoaderHelper.LoadAsync(() => CustomerService.GetAllAsync(), "客戶", NotificationService, GetType());

    // 載入員工資料
    private async Task LoadEmployeesAsync() => employees = await DataLoaderHelper.LoadAsync(() => EmployeeService.GetAllAsync(), "員工", NotificationService, GetType());

    // 伺服器端分頁載入
    private Task<(List<SalesOrder> Items, int TotalCount)> ServerLoadSalesOrdersAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return SalesOrderService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(so => so.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadSalesOrdersAsync), GetType());
                return q;
            },
            page, pageSize);
    }

    // 多筆列印處理方法
    private async Task HandleBatchPrintAsync()
    {
        try
        {
            // 顯示批次列印篩選 Modal
            showBatchPrintModal = true;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleBatchPrintAsync), GetType(), additionalData: "開啟多筆列印視窗失敗");
            await NotificationService.ShowErrorAsync("開啟多筆列印視窗失敗");
        }
    }

    // 處理批次列印成功
    private void HandleBatchPrintSuccess()
    {
        showBatchPrintModal = false;
        StateHasChanged();
    }

    // ===== 批次審核相關方法 =====

    private async Task HandleBatchApprovalAsync()
    {
        try
        {
            showBatchApprovalModal = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleBatchApprovalAsync), GetType(), additionalData: "開啟批次審核視窗失敗");
            await NotificationService.ShowErrorAsync("開啟批次審核視窗失敗");
        }
    }

    private async Task<List<SalesOrder>> LoadPendingSalesOrdersAsync()
    {
        try
        {
            var all = await SalesOrderService.GetAllAsync();
            return all.Where(so => !so.IsApproved).ToList();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadPendingSalesOrdersAsync), GetType(), additionalData: "載入待審核銷貨訂單失敗");
            await NotificationService.ShowErrorAsync("載入待審核銷貨訂單失敗");
            return new List<SalesOrder>();
        }
    }

    private async Task<bool> ApproveSingleSalesOrderAsync(SalesOrder entity)
    {
        try
        {
            var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
            if (!userId.HasValue) return false;
            var result = await SalesOrderService.ApproveAsync(entity.Id, userId.Value);
            return result.IsSuccess;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(ApproveSingleSalesOrderAsync), GetType(), additionalData: new { EntityId = entity.Id });
            return false;
        }
    }

    private async Task<(int successCount, int failCount)> ApproveAllSalesOrdersAsync(List<SalesOrder> items)
    {
        int successCount = 0, failCount = 0;
        var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
        if (!userId.HasValue) return (0, items.Count);
        foreach (var item in items)
        {
            try
            {
                var result = await SalesOrderService.ApproveAsync(item.Id, userId.Value);
                if (result.IsSuccess) successCount++; else failCount++;
            }
            catch (Exception ex)
            {
                failCount++;
                await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(ApproveAllSalesOrdersAsync), GetType(), additionalData: new { EntityId = item.Id });
            }
        }
        return (successCount, failCount);
    }

    private async Task HandleApprovalViewClick(SalesOrder entity)
    {
        try
        {
            await modalHandler.ShowEditModalAsync(entity);
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleApprovalViewClick), GetType(), additionalData: new { EntityId = entity.Id });
            await NotificationService.ShowErrorAsync("開啟查看視窗失敗");
        }
    }

    private async Task HandleApprovalCompleted()
    {
        try
        {
            if (indexComponent != null)
                await indexComponent.Refresh();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleApprovalCompleted), GetType(), additionalData: "刷新列表失敗");
        }
    }
}
