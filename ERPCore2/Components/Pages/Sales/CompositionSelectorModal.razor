@*
    品項配方選擇對話框
    用於選擇要使用的 BOM 配方或自定義模式
    統一由報價單、銷貨訂單等模組共用
*@
@using ERPCore2.Components.Shared.UI.Button
@using ERPCore2.Components.Shared.UI.Input
@using ERPCore2.Data.Entities
@implements IDisposable
@inject IStringLocalizer<SharedResource> L

<BaseModalComponent IsVisible="@IsVisible"
                   IsVisibleChanged="@IsVisibleChanged"
                   Title="@GetModalTitle()"
                   Icon="bi bi-diagram-3"
                   IsLoading="@IsLoading"
                   LoadingMessage="@L["Composition.Loading"]"
                   CloseOnBackdropClick="true"
                   CloseOnEscape="true"
                   Size="BaseModalComponent.ModalSize.Large"
                   OnClose="@CloseModal"
                   DebugComponentName="@DebugComponentName">
    <HeaderButtons>
        <GenericButtonComponent Text="@L["Composition.CustomModeTitle"].ToString()"
                              Icon="bi bi-stars"
                              Variant="ButtonVariant.Yellow"
                              OnClick="SelectCustomMode"
                              Title="@L["Composition.CustomModeDesc"]" />
        <GenericButtonComponent Text="@L["Button.Cancel"].ToString()"
                              Variant="ButtonVariant.Gray"
                              OnClick="CloseModal" />
    </HeaderButtons>
    <BodyContent>
        <div class="container-fluid">
            @if (Compositions.Any())
            {
                <!-- 搜尋框 -->
                <div class="mb-3">
                    <SearchInputComponent @bind-Value="searchTerm"
                                         Placeholder="@L["Composition.SearchPlaceholder"]" />
                </div>

                @if (!FilteredCompositions.Any())
                {
                    <div class="alert alert-warning text-center">
                        <i class="bi bi-search me-2"></i>
                        @L["Composition.NoMatch"]
                    </div>
                }
                else
                {
                    <!-- 配方清單 -->
                    <div class="composition-selector-list list-group mb-3">
                        @foreach (var composition in FilteredCompositions)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action @(composition.CustomerId == CurrentCustomerId ? "list-group-item-info" : "")"
                                    @onclick="() => SelectComposition(composition.Id)">
                                <div class="d-flex w-100 justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1">
                                            <i class="bi bi-diagram-3 me-2 text-primary"></i>
                                            [@composition.Code]
                                            @if (composition.CustomerId == CurrentCustomerId)
                                            {
                                                <span class="badge bg-info ms-2">@L["Composition.CurrentCustomer"]</span>
                                            }
                                        </h6>
                                        <p class="mb-1 text-muted small">
                                            @GetCompositionDisplayInfo(composition)
                                        </p>
                                        <small class="text-muted">
                                            @string.Format(L["Composition.ComponentCount"].ToString(), composition.CompositionDetails?.Count ?? 0)
                                            <span class="ms-2">@string.Format(L["Composition.CreatedDate"].ToString(), composition.CreatedAt.ToString("yyyy/MM/dd"))</span>
                                        </small>
                                    </div>
                                    <div class="ms-3">
                                        <i class="bi bi-chevron-right text-muted"></i>
                                    </div>
                                </div>
                            </button>
                        }
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    @L["Composition.NoBOMInfo"]
                </div>
            }
        </div>
    </BodyContent>
</BaseModalComponent>

<style>
    .composition-selector-list {
        max-height: 400px;
        overflow-y: auto;
    }
</style>

@code {
    // ===== 參數定義 =====
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public string ItemName { get; set; } = string.Empty;
    [Parameter] public List<ItemComposition> Compositions { get; set; } = new();
    [Parameter] public int? CurrentCustomerId { get; set; }
    [Parameter] public EventCallback<(int? compositionId, bool isCustomMode)> OnSelected { get; set; }

    /// <summary>載入中狀態（由父元件控制）</summary>
    [Parameter] public bool IsLoading { get; set; }

    /// <summary>Debug 用元件名稱，預設 CompositionSelectorModal</summary>
    [Parameter] public string DebugComponentName { get; set; } = "CompositionSelectorModal";

    // ===== 私有欄位 =====
    private string searchTerm = string.Empty;

    // ===== 計算屬性 =====
    private List<ItemComposition> FilteredCompositions
    {
        get
        {
            var filtered = Compositions.AsEnumerable();

            // 搜尋過濾
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                filtered = filtered.Where(c =>
                    (c.Code?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.Specification?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.Customer?.CompanyName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (c.CompositionCategory?.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                );
            }

            // 排序：當前客戶 > 通用配方 > 其他 > 最新日期
            return filtered
                .OrderByDescending(c => c.CustomerId == CurrentCustomerId)
                .ThenByDescending(c => c.CustomerId == null)
                .ThenByDescending(c => c.CreatedAt)
                .ToList();
        }
    }

    // ===== 方法 =====
    private string GetModalTitle()
    {
        return string.IsNullOrEmpty(ItemName)
            ? L["Composition.SelectBOM"].ToString()
            : string.Format(L["Composition.SelectBOMWithItem"].ToString(), ItemName);
    }

    private async Task SelectComposition(int compositionId)
    {
        if (OnSelected.HasDelegate)
        {
            await OnSelected.InvokeAsync((compositionId, false));
        }
        await CloseModal();
    }

    private async Task SelectCustomMode()
    {
        if (OnSelected.HasDelegate)
        {
            await OnSelected.InvokeAsync((null, true));
        }
        await CloseModal();
    }

    private async Task CloseModal()
    {
        searchTerm = string.Empty;
        await IsVisibleChanged.InvokeAsync(false);
    }

    private string GetCompositionDisplayInfo(ItemComposition composition)
    {
        var info = new List<string>();

        if (composition.Customer != null)
        {
            info.Add(string.Format(L["Composition.CustomerLabel"].ToString(), composition.Customer.CompanyName));
        }
        if (!string.IsNullOrEmpty(composition.Specification))
        {
            info.Add(string.Format(L["Composition.SpecLabel"].ToString(), composition.Specification));
        }
        if (composition.CompositionCategory != null)
        {
            info.Add(string.Format(L["Composition.CategoryLabel"].ToString(), composition.CompositionCategory.Name));
        }

        return info.Any() ? string.Join(" | ", info) : L["Composition.GeneralFormula"].ToString();
    }

    // ===== IDisposable =====
    public void Dispose()
    {
        // 預留：未來若加入 debounce Timer 可在此清理
    }
}
