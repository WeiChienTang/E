@page "/sales-targets"
@inject ISalesTargetService SalesTargetService
@inject INotificationService NotificationService
@inject IStringLocalizer<SharedResource> L
@rendermode InteractiveServer

@using ERPCore2.Helpers.FieldConfiguration

<GenericIndexPageComponent TEntity="SalesTarget"
                          TService="ISalesTargetService"
                          Service="@SalesTargetService"
                          EntityBasePath="/sales-targets"
                          PageTitle="@L["Page.SalesTargetTitle"]"
                          PageSubtitle="@L["Page.SalesTargetSubtitle"]"
                          EntityName="@L["Entity.SalesTarget"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ServerDataLoader="@ServerLoadSalesTargetsAsync"
                          GetEntityDisplayName="@(t => t.PeriodLabel)"
                          RequiredPermission="@PermissionRegistry.SalesTarget.Read"
                          RequiredModule="Sales"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          DebugPageName="SalesTargetIndex"
                          @ref="indexComponent" />

<SalesTargetEditModalComponent IsVisible="@showEditModal"
                               IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                               SalesTargetId="@editingSalesTargetId"
                               OnSalesTargetSaved="@modalHandler.OnEntitySavedAsync"
                               OnCancel="@modalHandler.OnModalCancelAsync" />

@code {
    private GenericIndexPageComponent<SalesTarget, ISalesTargetService> indexComponent = default!;
    private bool showEditModal = false;
    private int? editingSalesTargetId = null;
    private ModalHandler<SalesTarget, GenericIndexPageComponent<SalesTarget, ISalesTargetService>> modalHandler = default!;
    private SalesTargetFieldConfiguration fieldConfiguration = default!;
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            modalHandler = ModalHelper.CreateModalHandler<SalesTarget, GenericIndexPageComponent<SalesTarget, ISalesTargetService>>(
                id => editingSalesTargetId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            fieldConfiguration = new SalesTargetFieldConfiguration(NotificationService);
            fieldConfiguration.SetLocalizer(L);
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化業績目標頁面失敗");
            await NotificationService.ShowErrorAsync("初始化業績目標頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync() =>
        breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync("銷售管理", "業績目標管理", "#", NotificationService, GetType());

    private Task<(List<SalesTarget> Items, int TotalCount)> ServerLoadSalesTargetsAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return SalesTargetService.GetPagedWithFiltersAsync(
            q =>
            {
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadSalesTargetsAsync), GetType());
                return q;
            },
            page, pageSize);
    }
}
