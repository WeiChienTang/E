    /// <summary>
    /// 從報價單載入明細到訂單明細表
    /// </summary>
    private async Task LoadQuotationDetailsToSalesOrder(int quotationId)
    {
        try
        {
            // 載入報價單資料（含明細和審核狀態）
            var quotation = await QuotationService.GetWithDetailsAsync(quotationId);
            if (quotation == null)
            {
                await NotificationService.ShowWarningAsync("找不到指定的報價單", "載入失敗");
                return;
            }
            
            // 驗證報價單明細
            if (quotation.QuotationDetails == null || !quotation.QuotationDetails.Any())
            {
                await NotificationService.ShowWarningAsync("報價單沒有明細資料", "載入失敗");
                return;
            }
            
            // 使用 SalesOrderTable 的公開方法載入明細
            if (salesOrderDetailManager != null)
            {
                await salesOrderDetailManager.LoadQuotationDetails(
                    quotation.QuotationDetails.ToList(), 
                    quotationId, 
                    quotation.IsApproved
                );
            }
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadQuotationDetailsToSalesOrder), GetType(),
                additionalData: new { QuotationId = quotationId });
            await NotificationService.ShowErrorAsync("載入報價單明細時發生錯誤");
        }
    }
    
    /// <summary>
    /// 從報價單載入資料到訂單
    /// 注意：實際的轉單邏輯由 QuotationEditModalComponent 在儲存時處理
    /// 這裡只是預留參數，實際使用 PrefilledCustomerId
    /// </summary>
    private async Task LoadDataFromQuotation(SalesOrder salesOrder, int quotationId)
    {
        try
        {
            // 載入報價單資料（含明細和審核狀態）
            var quotation = await QuotationService.GetWithDetailsAsync(quotationId);
            if (quotation == null)
            {
                await NotificationService.ShowWarningAsync("找不到指定的報價單", "載入失敗");
                return;
            }

            // 設定報價單篩選ID（虛擬欄位，不儲存至資料庫）
            filterQuotationId = quotationId;

            // 設定客戶ID
            salesOrder.CustomerId = quotation.CustomerId;

            // 設定公司ID
            salesOrder.CompanyId = quotation.CompanyId;

            // 設定業務員ID（從報價單的業務員欄位轉入）
            salesOrder.SalespersonId = quotation.SalespersonId;

            // 設定稅別
            salesOrder.TaxCalculationMethod = quotation.TaxCalculationMethod;

            // 注意：明細的載入將由父組件（QuotationEditModalComponent）的 HandleCreateSalesOrderFromQuotation 處理
            // 這裡不直接處理明細轉換，只設定審核狀態和客戶
            salesOrderDetails.Clear();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadDataFromQuotation), GetType(),
                additionalData: new { QuotationId = quotationId });
        }
    }

    // ===== 審核功能 =====

    private bool ShouldShowApprovalSection()
        => isManualApproval && SalesOrderId.HasValue && SalesOrderId.Value > 0;

    private Func<bool>? GetCanPrintCheck()
        => isManualApproval
            ? () => ApprovalConfigHelper.CanPerformActionRequiringApproval(
                  isManualApproval, editModalComponent?.Entity?.IsApproved ?? false)
            : null;

    private async Task<bool> HandleSalesOrderApprove()
    {
        try
        {
            var entity = editModalComponent?.Entity;
            if (entity == null || !SalesOrderId.HasValue)
            {
                await NotificationService.ShowErrorAsync("找不到銷貨訂單資料");
                return false;
            }

            var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
            if (!userId.HasValue)
            {
                await NotificationService.ShowErrorAsync("無法取得目前使用者資訊");
                return false;
            }

            var updateResult = await SalesOrderService.UpdateAsync(entity);
            if (!updateResult.IsSuccess)
            {
                await NotificationService.ShowErrorAsync(updateResult.ErrorMessage ?? "儲存銷貨訂單失敗");
                return false;
            }

            await SaveSalesOrderDetails(entity.Id, true, await SalesOrderDetailService.GetBySalesOrderIdAsync(entity.Id));
            await SaveSalesOrderCompositionDetails(entity.Id);

            var approveResult = await SalesOrderService.ApproveAsync(entity.Id, userId.Value);
            if (!approveResult.IsSuccess)
            {
                await NotificationService.ShowErrorAsync(approveResult.ErrorMessage ?? "核准失敗");
                return false;
            }

            return true;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleSalesOrderApprove), GetType());
            return false;
        }
    }

    private async Task<bool> HandleSalesOrderRejectWithReason(string rejectReason)
    {
        try
        {
            if (!SalesOrderId.HasValue)
            {
                await NotificationService.ShowErrorAsync("找不到銷貨訂單資料");
                return false;
            }

            var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
            if (!userId.HasValue)
            {
                await NotificationService.ShowErrorAsync("無法取得目前使用者資訊");
                return false;
            }

            var rejectResult = await SalesOrderService.RejectAsync(SalesOrderId.Value, userId.Value, rejectReason);
            if (!rejectResult.IsSuccess)
            {
                await NotificationService.ShowErrorAsync(rejectResult.ErrorMessage ?? "駁回失敗");
                return false;
            }

            return true;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleSalesOrderRejectWithReason), GetType());
            return false;
        }
    }
}
