    private RenderFragment? GetCustomActionButtons() => __builder =>
    {
        @* 轉銷貨出貨單按鈕 - 新增模式需先儲存，編輯模式直接可用，草稿不顯示 *@
        @if (editModalComponent?.Entity != null &&
