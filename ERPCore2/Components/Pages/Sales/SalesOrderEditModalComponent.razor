                {
                    PropertyName = "ApprovalStatusText",
                    Label = L["Approval.Status"],
                    FieldType = FormFieldType.Text,
                    IsReadOnly = true,
                    IsDisabled = true,
                    ContainerCssClass = "col-md-4"
                },
                new FormFieldDefinition()
                {
                    PropertyName = "ApprovedByDisplayName",
                    Label = L["Approval.ApprovedBy"],
                    FieldType = FormFieldType.Text,
                    IsReadOnly = true,
                    IsDisabled = true,
                    ContainerCssClass = "col-md-4"
                },
                new FormFieldDefinition()
                {
                    PropertyName = "ApprovedAtText",
                    Label = L["Approval.ApprovedAt"],
                    FieldType = FormFieldType.Text,
                    IsReadOnly = true,
                    IsDisabled = true,
                    ContainerCssClass = "col-md-4"
                },
                new FormFieldDefinition()
                {
                    PropertyName = nameof(SalesOrder.RejectReason),
