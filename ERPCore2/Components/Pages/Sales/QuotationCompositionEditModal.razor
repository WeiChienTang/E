@* BOM 組合編輯 Modal - 泛用型 BOM 組成編輯器（支援報價單和銷貨訂單） *@
@* 整合配方選擇 + 組件編輯為單一 Modal，提供明確的儲存/取消操作 *@
@typeparam TCompositionDetail where TCompositionDetail : BaseEntity, new()
@using ERPCore2.Components.Shared.UI.Button
@using ERPCore2.Components.Shared.UI.Input
@using ERPCore2.Data.Entities
@inject IProductService ProductService
@inject IUnitService UnitService
@inject IProductCategoryService ProductCategoryService
@inject IProductCompositionService ProductCompositionService
@inject INotificationService NotificationService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L

<BaseModalComponent IsVisible="@IsVisible"
                   IsVisibleChanged="@HandleModalVisibleChanged"
                   Title="@GetModalTitle()"
                   Icon="bi bi-diagram-3"
                   HeaderColor="BaseModalComponent.HeaderVariant.Info"
                   CloseOnBackdropClick="false"
                   CloseOnEscape="true"
                   IsLoading="@isLoading"
                   LoadingMessage="@L["Label.Loading"]"
                   DebugComponentName="QuotationCompositionEditModal">
    <HeaderButtons>
        <div class="w-100 d-flex align-items-center px-2">
            <div class="d-flex gap-2 ms-auto">
                @if (!IsReadOnly)
                {
                    <GenericButtonComponent Text="@L["Button.Save"].ToString()"
                                          Variant="ButtonVariant.Green"
                                          Size="ButtonSize.Small"
                                          OnClick="@HandleSave" />
                }
                <GenericButtonComponent Text="@L["Button.Cancel"].ToString()"
                                      Variant="ButtonVariant.Red"
                                      Size="ButtonSize.Small"
                                      OnClick="@HandleCancel" />
            </div>
        </div>
    </HeaderButtons>
    <BodyContent>
        <div class="container-fluid">
            @* ===== 配方選擇區：三區段 ===== *@
            @if (!IsReadOnly)
            {
                var standardComps = Compositions.Where(c => !c.CustomerId.HasValue).ToList();
                var customerComps = Compositions.Where(c => c.CustomerId.HasValue).ToList();
                var hasAnySection = standardComps.Any() || customerComps.Any();

                @if (hasAnySection || true) @* 自定義區段永遠顯示 *@
                {
                    <div class="composition-sections-container">
                        @* ── 區段 1：快速套用（通用配方） ── *@
                        @if (standardComps.Any())
                        {
                            <div class="composition-section">
                                <div class="composition-section-header section-standard">
                                    <i class="bi bi-lightning-charge composition-section-icon"></i>
                                    <span class="composition-section-title">@L["Composition.SectionStandard"]</span>
                                </div>
                                <div class="composition-section-body">
                                    @foreach (var comp in standardComps)
                                    {
                                        var isActive = selectedCompositionId == comp.Id && !isCustomMode;
                                        var displayName = !string.IsNullOrEmpty(comp.Name) ? comp.Name : comp.Code;
                                        <button type="button"
                                                class="composition-pill @(isActive ? "active" : "")"
                                                title="@comp.Code"
                                                @onclick="() => ApplyComposition(comp.Id)">
                                            <i class="bi bi-diagram-3"></i>
                                            <span class="composition-pill-name">@displayName</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        @* ── 區段 2：客製化（客戶專屬配方） ── *@
                        @if (customerComps.Any())
                        {
                            <div class="composition-section">
                                <div class="composition-section-header section-customer">
                                    <i class="bi bi-person-gear composition-section-icon"></i>
                                    <span class="composition-section-title">@L["Composition.SectionCustomer"]</span>
                                </div>
                                <div class="composition-section-body">
                                    @foreach (var comp in customerComps)
                                    {
                                        var isActive = selectedCompositionId == comp.Id && !isCustomMode;
                                        var isCurrentCustomer = comp.CustomerId == CurrentCustomerId;
                                        var pillVariant = isActive ? "active" : isCurrentCustomer ? "current-customer" : "other-customer";
                                        var iconClass = isCurrentCustomer ? "bi-person-check" : "bi-person-lock";
                                        var displayName = !string.IsNullOrEmpty(comp.Name) ? comp.Name : comp.Code;
                                        <button type="button"
                                                class="composition-pill @pillVariant"
                                                title="@comp.Code"
                                                @onclick="() => ApplyComposition(comp.Id)">
                                            <i class="bi @iconClass"></i>
                                            <span class="composition-pill-name">@displayName</span>
                                            @if (isCurrentCustomer)
                                            {
                                                <span class="composition-pill-tag tag-current">@L["Composition.CurrentCustomer"]</span>
                                            }
                                            else
                                            {
                                                <span class="composition-pill-tag tag-other">@(comp.Customer?.CompanyName ?? L["Composition.OtherCustomer"].ToString())</span>
                                            }
                                        </button>
                                    }
                                </div>
                            </div>
                        }

                        @* ── 區段 3：自定義（空白編輯模式） ── *@
                        <div class="composition-section">
                            <div class="composition-section-header section-custom">
                                <i class="bi bi-stars composition-section-icon"></i>
                                <span class="composition-section-title">@L["Composition.SectionCustom"]</span>
                            </div>
                            <div class="composition-section-body">
                                <button type="button"
                                        class="composition-pill custom-mode @(isCustomMode ? "active" : "")"
                                        @onclick="EnterCustomMode">
                                    <i class="bi bi-pencil-square"></i>
                                    <span class="composition-pill-name">@L["Composition.CustomModeShort"]</span>
                                </button>
                            </div>
                        </div>
                    </div>
                    <hr class="my-2" />
                }
            }

            @* ===== 自定義模式：批量選擇按鈕 ===== *@
            @if (!IsReadOnly && isCustomMode)
            {
                <div class="mb-2">
                    <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                                            Size="ButtonSize.Small"
                                            Text=@L["Composition.BatchSelect"]
                                            OnClick="OpenProductPicker" />
                </div>
            }

            @* ===== 組件明細表格 ===== *@
            <InteractiveTableComponent @ref="tableComponent"
                                      TItem="TCompositionDetail"
                                      Items="@compositionDetails"
                                      ColumnDefinitions="@GetColumnDefinitions()"
                                      IsReadOnly="@IsReadOnly"
                                      ShowHeader="true"
                                      ShowActions="false"
                                      ShowBuiltInActions="true"
                                      ShowBuiltInDeleteButton="true"
                                      ActionsColumnWidth="60px"
                                      OnItemDelete="@HandleItemDelete"
                                      EnableAutoEmptyRow="@(!IsReadOnly)"
                                      CreateEmptyItem="@CreateEmptyItem"
                                      DataLoadCompleted="@_dataLoadCompleted"
                                      IsStriped="true"
                                      IsHoverable="true"
                                      IsBordered="true"
                                      EmptyMessage="@L["Composition.EmptyMsg"]" />
        </div>
    </BodyContent>
</BaseModalComponent>

@* 商品批量選擇器 *@
<ProductPickerModal IsVisible="@_showProductPicker"
                   AvailableProducts="@GetPickerAvailableProducts()"
                   AvailableCategories="@_availableCategories"
                   AvailableUnits="@availableUnits"
                   AlreadyAddedProductIds="@GetAlreadyAddedProductIds()"
                   OnConfirmed="@HandleProductsSelected"
                   OnCancelled="@(() => _showProductPicker = false)" />

@* 空白 BOM 儲存確認對話框 *@
<GenericConfirmModalComponent IsVisible="@_showEmptyConfirm"
                             IsVisibleChanged="@((bool v) => _showEmptyConfirm = v)"
                             Title="@L["Button.Confirm"]"
                             Icon="bi-exclamation-triangle"
                             HeaderColor="BaseModalComponent.HeaderVariant.Warning"
                             Message="@L["Composition.ConfirmSaveEmpty"]"
                             ConfirmButtonText="@L["Button.Confirm"]"
                             CancelButtonText="@L["Button.Cancel"]"
                             OnConfirm="@HandleConfirmSaveEmpty"
                             OnCancel="@(() => _showEmptyConfirm = false)" />

@code {
    // ===== 參數定義 =====
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }
    [Parameter] public int? DetailId { get; set; }  // QuotationDetailId 或 SalesOrderDetailId
    [Parameter] public string ProductName { get; set; } = string.Empty;
    [Parameter] public int? ProductId { get; set; }
    [Parameter] public bool IsReadOnly { get; set; } = false;
    [Parameter] public EventCallback<List<TCompositionDetail>> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public Func<List<TCompositionDetail>?>? OnRequestCachedData { get; set; }
    [Parameter] public int? SelectedCompositionId { get; set; }  // 初始選中的配方 ID
    [Parameter] public EventCallback<int?> SelectedCompositionIdChanged { get; set; }
    [Parameter] public bool IsCustomMode { get; set; } = false;  // 是否為自定義模式
    [Parameter] public EventCallback<bool> IsCustomModeChanged { get; set; }

    /// <summary>可用的配方清單（由父元件傳入，用於頂部 pill 按鈕）</summary>
    [Parameter] public List<ProductComposition> Compositions { get; set; } = new();

    /// <summary>當前客戶 ID（用於標示「當前客戶」配方）</summary>
    [Parameter] public int? CurrentCustomerId { get; set; }
    
    // ===== 泛型服務委派參數 =====
    [Parameter] public Func<int, Task<List<TCompositionDetail>>> GetCompositionsByDetailId { get; set; } = null!;
    [Parameter] public Func<int, int, Task<List<TCompositionDetail>>> CopyFromComposition { get; set; } = null!;

    // ===== 私有欄位 =====
    private bool isLoading = false;
    private bool _dataLoadCompleted = true;
    private bool _previousIsVisible = false;
    private List<TCompositionDetail> compositionDetails = new();
    private List<ERPCore2.Data.Entities.Product> availableProducts = new();
    private List<ERPCore2.Data.Entities.Unit> availableUnits = new();
    private List<ERPCore2.Data.Entities.ProductCategory> _availableCategories = new();
    private InteractiveTableComponent<TCompositionDetail>? tableComponent;
    private bool _showProductPicker = false;
    
    // ===== 配方選擇狀態 =====
    private int? selectedCompositionId;
    private bool isCustomMode;
    
    // 空白 BOM 確認狀態
    private bool _showEmptyConfirm = false;
    private List<TCompositionDetail>? _pendingSaveDetails;

    // ===== 生命週期 =====
    protected override async Task OnParametersSetAsync()
    {
        // 只在 Modal 從隱藏變為顯示時載入資料
        if (IsVisible && !_previousIsVisible)
        {
            selectedCompositionId = SelectedCompositionId;
            isCustomMode = IsCustomMode;
            await LoadDataAsync();
        }
        
        _previousIsVisible = IsVisible;
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        _dataLoadCompleted = false;
        StateHasChanged();

        try
        {
            // 載入可用的商品、單位、商品類別
            availableProducts = await ProductService.GetAllAsync();
            availableUnits = await UnitService.GetAllAsync();
            _availableCategories = await ProductCategoryService.GetAllAsync();

            // 優先從父組件的快取載入
            if (OnRequestCachedData != null)
            {
                var cachedData = OnRequestCachedData();
                if (cachedData?.Any() == true)
                {
                    compositionDetails = cachedData;
                    FillNavigationProperties(compositionDetails);
                    return;
                }
            }

            // 從資料庫載入（DetailId 存在時）
            if (DetailId.HasValue)
            {
                var existingDetails = await GetCompositionsByDetailId(DetailId.Value);
                if (existingDetails.Any())
                {
                    compositionDetails = existingDetails;
                    return;
                }
            }

            // 從指定的配方複製
            if (selectedCompositionId.HasValue && DetailId.HasValue)
            {
                compositionDetails = await CopyFromComposition(DetailId.Value, selectedCompositionId.Value);
                FillNavigationProperties(compositionDetails);
                return;
            }

            // 自定義模式或無配方 → 空表格（使用者透過 AutoEmptyRow 直接在表格新增）
            if (isCustomMode)
            {
                compositionDetails = new List<TCompositionDetail>();
                return;
            }

            // Fallback：從商品預設 BOM 複製
            if (ProductId.HasValue && DetailId.HasValue)
            {
                var defaultCompositions = await ProductCompositionService.GetCompositionsByProductIdAsync(ProductId.Value);
                if (defaultCompositions.Any())
                {
                    var defaultComposition = defaultCompositions.First();
                    compositionDetails = await CopyFromComposition(DetailId.Value, defaultComposition.Id);
                    FillNavigationProperties(compositionDetails);
                    selectedCompositionId = defaultComposition.Id;
                    
                    // 通知父元件 fallback 選擇的配方
                    await SelectedCompositionIdChanged.InvokeAsync(defaultComposition.Id);
                    await IsCustomModeChanged.InvokeAsync(false);
                    return;
                }
            }

            compositionDetails = new List<TCompositionDetail>();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"{ex.Message}");
            compositionDetails = new List<TCompositionDetail>();
        }
        finally
        {
            isLoading = false;
            _dataLoadCompleted = true;
            StateHasChanged();
        }
    }

    /// <summary>
    /// 統一填充導航屬性（消除重複的反射程式碼）
    /// </summary>
    private void FillNavigationProperties(List<TCompositionDetail> details)
    {
        foreach (var detail in details)
        {
            var componentProductIdProp = detail.GetType().GetProperty("ComponentProductId");
            var componentProductProp = detail.GetType().GetProperty("ComponentProduct");
            var unitIdProp = detail.GetType().GetProperty("UnitId");
            var unitProp = detail.GetType().GetProperty("Unit");

            var componentProductId = (int)(componentProductIdProp?.GetValue(detail) ?? 0);
            var componentProduct = componentProductProp?.GetValue(detail);
            var unitId = unitIdProp?.GetValue(detail) as int?;
            var unit = unitProp?.GetValue(detail);

            if (componentProductId > 0 && componentProduct == null)
            {
                var product = availableProducts.FirstOrDefault(p => p.Id == componentProductId);
                componentProductProp?.SetValue(detail, product);
            }
            if (unitId.HasValue && unit == null)
            {
                var foundUnit = availableUnits.FirstOrDefault(u => u.Id == unitId.Value);
                unitProp?.SetValue(detail, foundUnit);
            }
        }
    }
private string GetModalTitle()
    {
        return string.IsNullOrEmpty(ProductName)
            ? L["Composition.EditBOM"].ToString()
            : string.Format(L["Composition.EditBOMWithProduct"].ToString(), ProductName);
    }

    // ===== 配方快速套用 =====
    
    /// <summary>
    /// 一鍵套用配方（pill 按鈕）
    /// </summary>
    private async Task ApplyComposition(int compositionId)
    {
        if (!DetailId.HasValue) return;
        
        isLoading = true;
        _dataLoadCompleted = false;
        StateHasChanged();

        try
        {
            compositionDetails = await CopyFromComposition(DetailId.Value, compositionId);
            FillNavigationProperties(compositionDetails);
            selectedCompositionId = compositionId;
            isCustomMode = false;
            
            // 通知父元件選擇狀態變更
            await SelectedCompositionIdChanged.InvokeAsync(compositionId);
            await IsCustomModeChanged.InvokeAsync(false);
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"{ex.Message}");
        }
        finally
        {
            isLoading = false;
            _dataLoadCompleted = true;
            StateHasChanged();
        }
    }

    /// <summary>
    /// 進入自定義模式（清空表格，讓使用者透過 AutoEmptyRow 直接新增）
    /// </summary>
    private async Task EnterCustomMode()
    {
        compositionDetails = new List<TCompositionDetail>();
        selectedCompositionId = null;
        isCustomMode = true;
        
        // 通知父元件選擇狀態變更
        await SelectedCompositionIdChanged.InvokeAsync(null);
        await IsCustomModeChanged.InvokeAsync(true);
        
        // 先 StateHasChanged + await Task.Yield() 讓 Blazor 完成一次真正的渲染
        // 使子元件 InteractiveTableComponent 的 Items 指向新的空 List
        // 同步方法中多次 StateHasChanged() 會被 Blazor 批次合併，子元件看不到中間態
        StateHasChanged();
        await Task.Yield();
        
        // 渲染完成後，子元件的 Items 已更新，可安全呼叫 RefreshEmptyRow
        tableComponent?.RefreshEmptyRow();
    }

    // ===== 批量選擇器 =====
    
    private void OpenProductPicker() => _showProductPicker = true;

    /// <summary>
    /// 取得批量選擇器的可用商品（排除主商品本身）
    /// </summary>
    private List<Product> GetPickerAvailableProducts()
    {
        if (!ProductId.HasValue) return availableProducts;
        return availableProducts.Where(p => p.Id != ProductId.Value).ToList();
    }

    /// <summary>
    /// 取得已加入的商品 ID 集合（用於選擇器標示「已加入」）
    /// </summary>
    private HashSet<int> GetAlreadyAddedProductIds()
    {
        var ids = new HashSet<int>();
        foreach (var detail in compositionDetails)
        {
            var prop = detail.GetType().GetProperty("ComponentProductId");
            var id = (int)(prop?.GetValue(detail) ?? 0);
            if (id > 0) ids.Add(id);
        }
        return ids;
    }

    /// <summary>
    /// 批量選擇器確認：將選取的商品建立為 TCompositionDetail 加入表格
    /// </summary>
    private async Task HandleProductsSelected(List<Product> selectedProducts)
    {
        _showProductPicker = false;
        if (!selectedProducts.Any()) return;

        _dataLoadCompleted = false;
        StateHasChanged();

        try
        {
            var alreadyAdded = GetAlreadyAddedProductIds();

            foreach (var product in selectedProducts.Where(p => !alreadyAdded.Contains(p.Id)))
            {
                var item = CreateEmptyItem();

                item.GetType().GetProperty("ComponentProductId")?.SetValue(item, product.Id);
                item.GetType().GetProperty("ComponentProduct")?.SetValue(item, product);
                item.GetType().GetProperty("Quantity")?.SetValue(item, 1m);
                item.GetType().GetProperty("UnitId")?.SetValue(item, product.UnitId > 0 ? (int?)product.UnitId : null);

                if (product.UnitId > 0)
                {
                    var unit = availableUnits.FirstOrDefault(u => u.Id == product.UnitId);
                    item.GetType().GetProperty("Unit")?.SetValue(item, unit);
                }

                compositionDetails.Add(item);
            }

            var addedCount = selectedProducts.Count(p => !alreadyAdded.Contains(p.Id));
            if (addedCount > 0)
            {
                await NotificationService.ShowSuccessAsync(
                    string.Format(L["Composition.BatchAddedCount"].ToString(), addedCount));
            }
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"{ex.Message}");
        }
        finally
        {
            _dataLoadCompleted = true;
            StateHasChanged();
        }
    }

    // ===== InteractiveTable 配置 =====
    private List<InteractiveColumnDefinition> GetColumnDefinitions()
    {
        var columns = new List<InteractiveColumnDefinition>();

        // 組件商品
        columns.Add(new InteractiveColumnDefinition
        {
            Title = L["Column.ComponentItem"].ToString(),
            PropertyName = "ComponentProductId",
            EmptyCheckPropertyName = "ComponentProduct",
            ColumnType = InteractiveColumnType.Select,
            Width = "200px",
            Options = availableProducts.Select(p => new InteractiveSelectOption
            {
                Value = p.Id,
                Text = $"[{p.Code}] {p.Name}"
            }).ToList(),
            TriggerEmptyRowOnFilled = true,
            OnSelectionChanged = EventCallback.Factory.Create<(object, object?)>(this, (args) =>
            {
                var (item, value) = args;
                if (item is TCompositionDetail detail && value != null)
                {
                    var productId = Convert.ToInt32(value);
                    var product = availableProducts.FirstOrDefault(p => p.Id == productId);
                    
                    detail.GetType().GetProperty("ComponentProductId")?.SetValue(detail, product?.Id ?? 0);
                    detail.GetType().GetProperty("ComponentProduct")?.SetValue(detail, product);
                    detail.GetType().GetProperty("UnitId")?.SetValue(detail, product?.UnitId);
                    
                    var quantityProp = detail.GetType().GetProperty("Quantity");
                    var currentQuantity = (decimal)(quantityProp?.GetValue(detail) ?? 0m);
                    if (currentQuantity == 0)
                    {
                        quantityProp?.SetValue(detail, 1m);
                    }
                    
                    StateHasChanged();
                }
            })
        });

        // 數量
        columns.Add(new InteractiveColumnDefinition
        {
            Title = L["Column.Quantity"].ToString(),
            PropertyName = "Quantity",
            ColumnType = InteractiveColumnType.Number,
            Width = "150px",
            MinValue = 0.01m,
            NumberFormat = "N2",
            TextAlign = "right",
            ExcludeFromEmptyCheck = true
        });

        // 單位（唯讀顯示，跟隨組件商品的預設單位）
        columns.Add(new InteractiveColumnDefinition
        {
            Title = L["Label.Unit"].ToString(),
            PropertyName = "",
            ColumnType = InteractiveColumnType.Custom,
            Width = "100px",
            CustomTemplate = item =>
            {
                var detail = (TCompositionDetail)item;
                var unitProp = detail.GetType().GetProperty("Unit");
                var unit = unitProp?.GetValue(detail) as Unit;
                var unitName = unit?.Name ?? "";
                return @<span class="text-muted">@unitName</span>;
            }
        });

        // 備註
        columns.Add(new InteractiveColumnDefinition
        {
            Title = L["Label.Remarks"].ToString(),
            PropertyName = "Remarks",
            ColumnType = InteractiveColumnType.Custom,
            Width = "200px",
            Tooltip = L["Composition.RemarksTooltip"].ToString(),
            CustomTemplate = item =>
            {
                var detail = (TCompositionDetail)item;
                var remarksProp = detail.GetType().GetProperty("Remarks");
                var remarks = remarksProp?.GetValue(detail) as string ?? "";
                
                if (IsReadOnly)
                {
                    var displayText = string.IsNullOrEmpty(remarks) ? L["Label.NoRemarks"].ToString() : remarks;
                    return @<div class="d-flex align-items-center" style="min-height: 31px;">
                        <span class="text-muted">@displayText</span>
                    </div>;
                }
                
                return @<input type="text" class="form-control" 
                               value="@remarks"
                               @oninput="(e) => OnRemarksInput(detail, e.Value?.ToString())"/>;
            }
        });

        return columns;
    }

    private TCompositionDetail CreateEmptyItem()
    {
        var item = new TCompositionDetail();
        
        var detailIdProp = typeof(TCompositionDetail).GetProperty("QuotationDetailId") 
                           ?? typeof(TCompositionDetail).GetProperty("SalesOrderDetailId");
        detailIdProp?.SetValue(item, DetailId ?? 0);
        
        return item;
    }

    // ===== 事件處理 =====
    private void HandleItemDelete(TCompositionDetail item)
    {
        compositionDetails.Remove(item);
        StateHasChanged();
    }
    
    private void OnRemarksInput(TCompositionDetail item, string? value)
    {
        var remarksProp = item.GetType().GetProperty("Remarks");
        remarksProp?.SetValue(item, value ?? string.Empty);
        StateHasChanged();
    }

    /// <summary>
    /// 處理 Modal 可見性變更（攔截 ESC/背景點擊的關閉事件）
    /// </summary>
    private async Task HandleModalVisibleChanged(bool visible)
    {
        if (!visible)
        {
            // 使用者按 ESC 關閉 → 等同取消
            await HandleCancel();
            return;
        }
        await IsVisibleChanged.InvokeAsync(visible);
    }

    /// <summary>
    /// 明確的儲存操作
    /// </summary>
    private async Task HandleSave()
    {
        try
        {
            // 過濾掉空行
            var validDetails = compositionDetails
                .Where(x => {
                    var componentProductIdProp = x.GetType().GetProperty("ComponentProductId");
                    var quantityProp = x.GetType().GetProperty("Quantity");
                    var componentProductId = (int)(componentProductIdProp?.GetValue(x) ?? 0);
                    var quantity = (decimal)(quantityProp?.GetValue(x) ?? 0m);
                    return componentProductId > 0 && quantity > 0;
                })
                .ToList();

            // 空白 BOM 處理
            if (!validDetails.Any())
            {
                if (isCustomMode)
                {
                    // 自定義模式：不允許空白，直接提示
                    await NotificationService.ShowWarningAsync(L["Composition.CustomModeEmptyError"].ToString());
                    return;
                }
                
                // 非自定義模式：透過 GenericConfirmModalComponent 讓使用者確認
                _pendingSaveDetails = validDetails;
                _showEmptyConfirm = true;
                return;
            }

            // 有明細資料，直接執行儲存
            await ExecuteSave(validDetails);
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"{ex.Message}");
        }
    }

    private async Task HandleCancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
        await IsVisibleChanged.InvokeAsync(false);
    }
    
    /// <summary>
    /// 使用者確認儲存空白 BOM
    /// </summary>
    private async Task HandleConfirmSaveEmpty()
    {
        _showEmptyConfirm = false;
        if (_pendingSaveDetails != null)
        {
            await ExecuteSave(_pendingSaveDetails);
            _pendingSaveDetails = null;
        }
    }
    
    /// <summary>
    /// 執行實際儲存（重複檢查 + 呼叫 OnSave）
    /// </summary>
    private async Task ExecuteSave(List<TCompositionDetail> validDetails)
    {
        try
        {
            // 檢查重複組件
            if (validDetails.Any())
            {
                var duplicates = validDetails
                    .GroupBy(x => {
                        var prop = x.GetType().GetProperty("ComponentProductId");
                        return (int)(prop?.GetValue(x) ?? 0);
                    })
                    .Where(g => g.Count() > 1)
                    .Select(g => {
                        var first = g.First();
                        var productProp = first.GetType().GetProperty("ComponentProduct");
                        var product = productProp?.GetValue(first) as Product;
                        return product?.Name ?? L["Label.Unknown"].ToString();
                    })
                    .ToList();

                if (duplicates.Any())
                {
                    await NotificationService.ShowWarningAsync(
                        string.Format(L["Message.DuplicateComponent"].ToString(), string.Join(", ", duplicates)));
                    return;
                }
            }

            if (OnSave.HasDelegate)
            {
                await OnSave.InvokeAsync(validDetails);
            }
            
            await IsVisibleChanged.InvokeAsync(false);
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"{ex.Message}");
        }
    }
}
