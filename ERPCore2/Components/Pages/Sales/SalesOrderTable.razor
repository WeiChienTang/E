    /// <summary>
    /// 格式化報價單明細顯示文字（用於下拉選單 - 兩行顯示）
    /// 第一行：報價單號 + 待轉數量（小字藍色）
    /// 第二行：商品編號 商品名稱
    /// </summary>
    private string FormatQuotationDetailDropdownText(QuotationDetail detail)
    {
        if (detail?.Product == null) return "";
        
        var product = detail.Product;
        var quotationCode = detail.Quotation?.Code ?? "N/A";
        var pendingQty = detail.PendingQuantity;
        
        var productDisplay = !string.IsNullOrEmpty(product.Code) && !string.IsNullOrEmpty(product.Name)
            ? $"{product.Code} {product.Name}"
            : (!string.IsNullOrEmpty(product.Code) ? product.Code : product.Name ?? "");
        
        // 兩行顯示：報價單號在上（小字藍色），商品資訊在下
        return $"<div style='line-height: 1.3;'>" +
               $"<small class='text-primary'>報價: {quotationCode} (待轉: {pendingQty:G29})</small><br/>" +
               $"<span>{productDisplay}</span></div>";
    }
    
    /// <summary>
    /// 格式化報價單明細顯示文字（用於輸入框顯示 - 單行簡潔格式）
    /// </summary>
    private string FormatQuotationDetailDisplayText(QuotationDetail detail)
    {
        if (detail?.Product == null) return "";
        
        var product = detail.Product;
        var quotationCode = detail.Quotation?.Code ?? "N/A";
        
        var productDisplay = !string.IsNullOrEmpty(product.Code) && !string.IsNullOrEmpty(product.Name)
            ? $"{product.Code} {product.Name}"
            : (!string.IsNullOrEmpty(product.Code) ? product.Code : product.Name ?? "");
        
        // 輸入框顯示：簡潔的單行格式
        return $"{quotationCode} | {productDisplay}";
    }
    
    /// <summary>
    /// 格式化商品顯示文字（用於下拉選單 - 兩行顯示）
    /// 第一行：商品類別（小字灰色）
    /// 第二行：商品編號 商品名稱
    /// </summary>
    private string FormatProductDropdownText(Product product)
