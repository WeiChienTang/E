    /// <summary>
    /// 選擇項目（報價單明細或一般商品）
    /// </summary>
    private async Task OnItemSelectItem(SalesItem item, object? selectedItem)
    {
        if (selectedItem is QuotationDetail detail)
        {
            // 選擇報價單明細
            item.SelectedQuotationDetail = detail;
            item.SelectedProduct = detail.Product;
            item.ProductSearchValue = FormatQuotationDetailDisplayText(detail);
            item.OrderQuantity = detail.PendingQuantity; // 預設填入待轉數量
            item.UnitPrice = detail.UnitPrice;
            item.DiscountPercentage = detail.DiscountPercentage;
            item.TaxRate = detail.TaxRate ?? detail.Product?.TaxRate ?? await SystemParameterService.GetTaxRateAsync();
            item.SourceQuotationId = detail.QuotationId;
            item.SourceQuotationDetailId = detail.Id;
            item.IsQuotationApproved = detail.Quotation?.IsApproved ?? false;
            item.CalculateSubtotal();
        }
        else if (selectedItem is Product product)
        {
            // 選擇一般商品
            item.SelectedQuotationDetail = null;
            item.SelectedProduct = product;
            item.ProductSearchValue = FormatProductDisplayText(product);
            item.OrderQuantity = 0;
            item.UnitPrice = 0; // 需手動輸入單價
            item.DiscountPercentage = 0;
            item.TaxRate = product.TaxRate ?? await SystemParameterService.GetTaxRateAsync();
            item.SourceQuotationId = null;
            item.SourceQuotationDetailId = null;
            item.IsQuotationApproved = null;
        }
        else
        {
            item.SelectedQuotationDetail = null;
            item.SelectedProduct = null;
            item.ProductSearchValue = string.Empty;
        }
        
        item.ShowProductDropdown = false;
        item.ProductSelectedIndex = -1;
        await NotifyDetailsChangedAsync();
        StateHasChanged();
    }
    
