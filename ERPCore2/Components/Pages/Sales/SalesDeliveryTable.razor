    // ===== 事件處理方法 =====
    
    private async Task OnWarehouseLocationChanged(DeliveryItem item, object? value)
    {
        if (value == null || !int.TryParse(value.ToString(), out int detailId))
        {
            item.WarehouseId = null;
            item.WarehouseLocationId = null;
            item.InventoryStockDetailId = null;
            item.CurrentStockQuantity = null;
        }
        else
        {
            // 從選擇的庫存明細中取得倉庫和庫位資訊
            var selectedDetail = item.AvailableWarehouseLocations.FirstOrDefault(d => d.Id == detailId);
            if (selectedDetail != null)
            {
                item.WarehouseId = selectedDetail.WarehouseId;
                item.WarehouseLocationId = selectedDetail.WarehouseLocationId;
                item.InventoryStockDetailId = detailId;
                // 編輯模式：若選回原始倉庫位置，加回原始出貨量；選新倉庫則用原始 AvailableStock
                item.CurrentStockQuantity = selectedDetail.AvailableStock + item.GetOriginalQuantityBonus(detailId);
            }
        }
        
        await NotifyDetailsChangedAsync();
        StateHasChanged();
    }

    /// <summary>
    /// 載入指定項目的庫存量
    /// </summary>
    private async Task LoadStockQuantityAsync(DeliveryItem item)
    {
        try
        {
            if (item.ProductId <= 0)
            {
                item.AvailableWarehouseLocations.Clear();
                item.CurrentStockQuantity = null;
                return;
            }

            // 載入該商品的庫存（包含明細）
            var inventoryStocks = await InventoryStockService.GetByProductIdAsync(item.ProductId);
            
            // 從庫存主檔中提取所有庫存明細
            // 修正：保留有庫存的位置 + 編輯模式下原始選擇的位置（即使庫存已被扣完）
            var allStockDetails = inventoryStocks
                .SelectMany(s => s.InventoryStockDetails ?? new List<InventoryStockDetail>())
                .ToList();
            
            var stockDetails = allStockDetails
                .Where(d => d.AvailableStock > 0 || 
                            (item.OriginalInventoryStockDetailId.HasValue && d.Id == item.OriginalInventoryStockDetailId.Value))
                .OrderByDescending(d => d.AvailableStock)
                .ToList();
            
            item.AvailableWarehouseLocations = stockDetails;

            // 🔑 關鍵修正：根據不同情況設置庫存量（編輯模式下加回原始出貨量）
            if (item.InventoryStockDetailId.HasValue)
            {
                // 情況1: 已選擇庫存明細ID（編輯模式下有倉庫和庫位）
                var selectedDetail = item.AvailableWarehouseLocations
                    .FirstOrDefault(d => d.Id == item.InventoryStockDetailId.Value);
                if (selectedDetail != null)
                {
                    // 編輯模式：若是原始倉庫位置，加回原始出貨量
                    item.CurrentStockQuantity = selectedDetail.AvailableStock + item.GetOriginalQuantityBonus();
                }
                else
                {
                    item.CurrentStockQuantity = null;
                }
            }
            else if (item.WarehouseId.HasValue && item.WarehouseId.Value > 0)
            {
                // 情況2: 有倉庫ID，嘗試根據倉庫ID和庫位ID找到對應的庫存明細
                // 修正：搜尋範圍改為包含原始位置的 allStockDetails
                InventoryStockDetail? matchingDetail = null;
                
                if (item.WarehouseLocationId.HasValue && item.WarehouseLocationId.Value > 0)
                {
                    // 有庫位ID，精確匹配倉庫+庫位
                    matchingDetail = allStockDetails.FirstOrDefault(d => 
                        d.WarehouseId == item.WarehouseId.Value && 
                        d.WarehouseLocationId == item.WarehouseLocationId.Value);
                }
                else
                {
                    // 沒有庫位ID，只匹配倉庫（取第一個符合的）
                    matchingDetail = allStockDetails.FirstOrDefault(d => 
                        d.WarehouseId == item.WarehouseId.Value);
                }
                
                if (matchingDetail != null)
                {
                    // 找到匹配的庫存明細，設定 InventoryStockDetailId 讓下拉選單能正確顯示
                    item.InventoryStockDetailId = matchingDetail.Id;
                    // 編輯模式：若是原始倉庫位置，加回原始出貨量
                    item.CurrentStockQuantity = matchingDetail.AvailableStock + item.GetOriginalQuantityBonus(matchingDetail.Id);
                    
                    // 確保此位置在下拉選單中（可能 AvailableStock 為 0 但是原始位置）
                    if (!stockDetails.Any(d => d.Id == matchingDetail.Id))
                    {
                        stockDetails.Add(matchingDetail);
                        item.AvailableWarehouseLocations = stockDetails;
                    }
                }
                else
                {
                    // 找不到匹配的庫存明細（可能庫存已用完），顯示為 0
                    item.CurrentStockQuantity = 0;
                }
            }
            else
            {
                // 情況3: 都沒選擇（新增明細）
                item.CurrentStockQuantity = null;
            }
        }
        catch (Exception)
        {
            // 忽略錯誤，庫存量載入失敗不影響主要流程
            item.AvailableWarehouseLocations.Clear();
            item.CurrentStockQuantity = null;
        }
    }

