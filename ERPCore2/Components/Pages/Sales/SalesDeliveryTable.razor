    // ===== 內部方法 =====
    private async Task LoadAvailableProductsAsync()
    {
        try
        {
            if (SelectedCustomerId.HasValue && SelectedCustomerId.Value > 0)
            {
                // 載入該客戶的未出貨訂單明細
                AvailableSalesDetails = await SalesOrderService.GetDeliveryDetailsByCustomerAsync(
                    SelectedCustomerId.Value, 
                    includeCompleted: false,
                    checkApproval: false);
                
                // 載入所有啟用的商品，只顯示商品類別標記為可販售的商品
                var allProducts = await ProductService.GetActiveProductsAsync();
                AvailableProducts = allProducts
                    .Where(p => p.ProductCategory != null && p.ProductCategory.IsSaleable)
                    .ToList();
            }
            else
            {
                AvailableProducts = new List<Product>();
                AvailableSalesDetails = new List<SalesOrderDetail>();
            }
        }
        catch
        {
            AvailableProducts = new List<Product>();
            AvailableSalesDetails = new List<SalesOrderDetail>();
        }
    }

    /// <summary>
    /// 取得可用的訂單明細清單
    /// 會根據 SelectedSalesOrderId 和 FilterProductId 過濾指定條件的明細
    /// </summary>
    private List<SalesOrderDetail> GetAvailableSalesDetails()
    {
        if (!SelectedCustomerId.HasValue || SelectedCustomerId.Value <= 0)
        {
            return new List<SalesOrderDetail>();
        }
        
        var filteredDetails = AvailableSalesDetails.AsEnumerable();
        
        //  關鍵修正：如果指定了訂單ID，只載入該訂單的明細
        if (SelectedSalesOrderId.HasValue && SelectedSalesOrderId.Value > 0)
        {
            filteredDetails = filteredDetails.Where(sd => sd.SalesOrderId == SelectedSalesOrderId.Value);
        }
        
        // 如果指定了商品ID，只載入該商品的明細
        if (FilterProductId.HasValue && FilterProductId.Value > 0)
        {
            filteredDetails = filteredDetails.Where(sd => sd.ProductId == FilterProductId.Value);
        }
        
        return filteredDetails.ToList();
    }

    /// <summary>
    /// 檢查項目是否可以刪除 - 使用 DetailLockHelper 統一處理
    /// 銷貨出貨明細需檢查：
    /// 1. TotalReceivedAmount > 0：已有收款記錄
    /// 2. 已有退貨記錄（透過 ReturnedQuantities）
    /// </summary>
    /// <param name="item">要檢查的項目</param>
    /// <param name="reason">不可刪除的原因（輸出參數）</param>
    /// <returns>true 表示可以刪除，false 表示不可刪除</returns>
    private bool CanDeleteItem(DeliveryItem item, out string reason)
    {
        return DetailLockHelper.CanDeleteItem(
            item.ExistingDetailEntity,
            out reason,
            checkReturn: true,
            checkPayment: true,
            returnedQuantities: ReturnedQuantities
        );
    }
    
