    /// <summary>
    /// 選擇商品項目（支援訂單明細或一般商品）
    /// </summary>
    private async Task OnProductSelect(DeliveryItem item, object? selectedItem)
    {
        if (selectedItem is SalesOrderDetail detail)
        {
            // 選擇訂單明細
            item.SelectedSalesDetail = detail;
            item.SelectedProduct = detail.Product;
            item.ProductId = detail.ProductId;
            item.ProductSearchValue = FormatSalesDetailDisplayText(detail);
            item.UnitPrice = detail.UnitPrice;
            item.DeliveryQuantity = detail.OrderQuantity - detail.DeliveredQuantity; // 未出貨數量
            item.DiscountPercentage = detail.DiscountPercentage;
            item.WarehouseId = detail.WarehouseId;
            item.TaxRate = detail.TaxRate ?? detail.Product?.TaxRate ?? currentTaxRate;
        }
        else if (selectedItem is Product product)
        {
            // 選擇一般商品
            item.SelectedSalesDetail = null;
            item.SelectedProduct = product;
            item.ProductId = product.Id;
            item.ProductSearchValue = FormatProductDisplayText(product);
            item.UnitPrice = null; // 需手動輸入單價
            item.DeliveryQuantity = null; // 需手動輸入數量
            item.DiscountPercentage = 0; // 預設無折扣
            item.TaxRate = product.TaxRate ?? currentTaxRate;
        }
        else
        {
            item.SelectedSalesDetail = null;
            item.SelectedProduct = null;
            item.ProductId = 0;
            item.ProductSearchValue = string.Empty;
        }
        
        item.ShowDropdown = false;
        item.SelectedIndex = -1;
        
        // 載入該商品的庫存資訊
        if (item.SelectedProduct != null)
        {
            await LoadStockQuantityAsync(item);
        }
        
        await NotifyDetailsChangedAsync();
        StateHasChanged();
    }

    /// <summary>
    /// 格式化訂單明細顯示文字（用於下拉選單 - 兩行顯示）
    /// 第一行：訂單號（小字灰色）
    /// 第二行：商品編號 商品名稱
    /// </summary>
    private string FormatSalesDetailDropdownText(SalesOrderDetail detail)
    {
        if (detail?.Product == null) return "";
        
        var product = detail.Product;
        var salesOrderNumber = detail.SalesOrder?.Code ?? "N/A";
        var remainingQty = detail.OrderQuantity - detail.DeliveredQuantity;
        
        var productDisplay = !string.IsNullOrEmpty(product.Code) && !string.IsNullOrEmpty(product.Name)
            ? $"{product.Code} {product.Name}"
            : (!string.IsNullOrEmpty(product.Code) ? product.Code : product.Name ?? "");
        
        // 兩行顯示：訂單號在上（小字藍色），商品資訊在下
        return $"<div style='line-height: 1.3;'>" +
               $"<small class='text-primary'>訂單: {salesOrderNumber} (未出: {remainingQty:G29})</small><br/>" +
               $"<span>{productDisplay}</span></div>";
    }
    
    /// <summary>
    /// 格式化訂單明細顯示文字（用於輸入框顯示 - 單行簡潔格式）
    /// </summary>
    private string FormatSalesDetailDisplayText(SalesOrderDetail detail)
    {
        if (detail?.Product == null) return "";
        
        var product = detail.Product;
        var salesOrderNumber = detail.SalesOrder?.Code ?? "N/A";
        
        var productDisplay = !string.IsNullOrEmpty(product.Code) && !string.IsNullOrEmpty(product.Name)
            ? $"{product.Code} {product.Name}"
            : (!string.IsNullOrEmpty(product.Code) ? product.Code : product.Name ?? "");
        
        // 輸入框顯示：簡潔的單行格式
        return $"{salesOrderNumber} | {productDisplay}";
    }
    
    /// <summary>
    /// 格式化一般商品顯示文字（用於下拉選單 - 兩行顯示）
    /// </summary>
    private string FormatProductDropdownText(Product product)
    {
        if (product == null) return "";
        
        var productDisplay = !string.IsNullOrEmpty(product.Code) && !string.IsNullOrEmpty(product.Name)
            ? $"{product.Code} {product.Name}"
            : (!string.IsNullOrEmpty(product.Code) ? product.Code : product.Name ?? "");
        
        // 一般商品：單行顯示，但加上標示區分
        return $"<div style='line-height: 1.3;'>" +
               $"<small class='text-muted'>一般商品</small><br/>" +
               $"<span>{productDisplay}</span></div>";
    }
    
    /// <summary>
    /// 格式化一般商品顯示文字（用於輸入框顯示 - 單行簡潔格式）
    /// </summary>
    private string FormatProductDisplayText(Product product)
    {
        if (product == null) return "";
        
        if (!string.IsNullOrEmpty(product.Code) && !string.IsNullOrEmpty(product.Name))
            return $"{product.Code} {product.Name}";
        
        return product.Code ?? product.Name ?? "";
    }

    private List<InteractiveSelectOption> GetWarehouseOptions()
    {
        var options = new List<InteractiveSelectOption>
        {
            new InteractiveSelectOption { Text = "-- 請選擇倉庫 --", Value = 0 }
        };
        
        options.AddRange(Warehouses.Select(w => new InteractiveSelectOption
        {
            Text = w.Name,
            Value = w.Id
        }));
        
        return options;
    }

    private decimal GetTotalAmount()
    {
        return Items
            .Where(item => item.ProductId > 0)
            .Sum(item => item.SubtotalAmount);
    }

    // ===== 明細清除方法 =====
    /// <summary>
    /// 清除明細（只移除未鎖定的明細，保留已鎖定的）
    /// </summary>
    private async Task ClearAllDetails()
    {
        var nonEmptyItems = Items.Where(item => item.ProductId > 0).ToList();

        if (!nonEmptyItems.Any())
        {
            await NotificationService.ShowWarningAsync("沒有可清除的明細項目", "提示");
            return;
        }

        // 區分可刪除和被鎖定的明細
        var unlocked = nonEmptyItems.Where(item => CanDeleteItem(item, out _)).ToList();
        var locked = nonEmptyItems.Where(item => !CanDeleteItem(item, out _)).ToList();

        if (!unlocked.Any())
        {
            await NotificationService.ShowWarningAsync(
                "所有明細都已有退貨記錄，無法移除",
                "操作限制");
            return;
        }

        // 記錄所有要刪除的現有明細 ID
        foreach (var item in unlocked.Where(item => item.ExistingDetailEntity != null))
        {
            var entityId = item.ExistingDetailEntity!.Id;
            if (entityId > 0 && !_deletedDetailIds.Contains(entityId))
            {
                _deletedDetailIds.Add(entityId);
            }
        }

        // 從列表中移除未鎖定的項目，保留已鎖定的項目
        foreach (var item in unlocked)
        {
            Items.Remove(item);
        }
        
        await NotifyDetailsChangedAsync();
        await NotifyDeletedDetailsChanged();
        
        var message = $"已清除 {unlocked.Count} 項明細";
        if (locked.Any())
        {
            message += $"\n（已保留 {locked.Count} 項已鎖定的明細）";
        }
        await NotificationService.ShowSuccessAsync(message);
    }
    
    // ===== 智能下單功能 =====
    
    /// <summary>
    /// 智能下單 - 載入該客戶最近一次完整的銷貨出貨明細
    /// </summary>
    private async Task LoadSmartDeliveryItems()
    {
        if (IsReadOnly || !SelectedCustomerId.HasValue) return;
        
        // 檢查是否有現有資料
        var hasExistingData = Items.Any(item => item.ProductId > 0);
        
        if (hasExistingData)
        {
            if (!await ShowConfirmationAsync("載入智能下單", "此操作將覆蓋現有的出貨明細，是否繼續？"))
            {
                return;
            }
        }

        // 從服務獲取客戶的最近一次完整出貨
        var lastDeliveryDetails = await SalesDeliveryDetailService.GetLastCompleteDeliveryAsync(SelectedCustomerId.Value);
        
        if (!lastDeliveryDetails.Any())
        {
            await NotificationService.ShowInfoAsync("該客戶沒有銷貨出貨歷史紀錄可參考", "智能下單");
            return;
        }

        // 清空現有項目
        Items.Clear();
        _deletedDetailIds.Clear();

        // 將歷史出貨轉換為新的出貨項目
        foreach (var detail in lastDeliveryDetails)
        {
            var deliveryItem = new DeliveryItem
            {
                SelectedProduct = detail.Product,
                ProductId = detail.ProductId,
                DeliveryQuantity = detail.DeliveryQuantity,
                UnitPrice = detail.UnitPrice,
                DiscountPercentage = detail.DiscountPercentage,
                TaxRate = detail.TaxRate ?? detail.Product?.TaxRate ?? currentTaxRate,
                Remarks = detail.Remarks ?? "",
                WarehouseId = detail.WarehouseId
            };

            // 初始化 ProductSearchValue
            if (deliveryItem.SelectedProduct != null)
            {
                deliveryItem.ProductSearchValue = FormatProductDisplayText(deliveryItem.SelectedProduct);
            }

            // 載入庫存資訊（非同步）
            _ = Task.Run(async () =>
            {
                await LoadStockQuantityAsync(deliveryItem);
                await InvokeAsync(StateHasChanged);
            });

            Items.Add(deliveryItem);
        }
        
        await NotifyDetailsChangedAsync();
        await NotificationService.ShowSuccessAsync($"已載入 {lastDeliveryDetails.Count} 項商品作為參考", "智能下單完成");
        
        StateHasChanged();
    }
    
    /// <summary>
    /// 顯示確認對話框
    /// </summary>
    private async Task<bool> ShowConfirmationAsync(string title, string message)
    {
        // 暫時使用簡單的通知，等待確認後執行
        // 在實際專案中可能會使用更精美的對話框組件
        try 
        {
            await NotificationService.ShowInfoAsync(message, title);
            return true;
        }
        catch
        {
            return false;
        }
    }

    // ===== 載入訂單方法 =====
    
    /// <summary>
    /// 顯示載入確認 Modal - 收集載入條件並顯示給使用者確認
    /// </summary>
    private async Task ShowLoadConfirmModal()
    {
        try
        {
            // 檢查是否已選擇客戶
            if (!SelectedCustomerId.HasValue || SelectedCustomerId.Value <= 0)
            {
                await NotificationService.ShowWarningAsync("請先選擇客戶");
                return;
            }
            
            // 建立載入條件清單
            _loadConditions = new List<string>();
            
            // 條件1：客戶
            var customerName = !string.IsNullOrWhiteSpace(SelectedCustomerName) 
                ? SelectedCustomerName 
                : $"客戶 ID: {SelectedCustomerId.Value}";
            _loadConditions.Add($"客戶：{customerName}");
            
            // 條件2：訂單（如有選擇）
            if (SelectedSalesOrderId.HasValue && SelectedSalesOrderId.Value > 0)
            {
                var orderCode = !string.IsNullOrWhiteSpace(SelectedSalesOrderCode)
                    ? SelectedSalesOrderCode
                    : $"訂單 ID: {SelectedSalesOrderId.Value}";
                _loadConditions.Add($"訂單：{orderCode}");
            }
            else
            {
                _loadConditions.Add("訂單：全部未出貨訂單");
            }
            
            // 條件3：商品篩選（如有選擇）
            if (FilterProductId.HasValue && FilterProductId.Value > 0)
            {
                var productName = !string.IsNullOrWhiteSpace(FilterProductName)
                    ? FilterProductName
                    : $"商品 ID: {FilterProductId.Value}";
                _loadConditions.Add($"商品篩選：{productName}");
            }
            
            // 計算符合條件的明細數量
            var availableDetails = GetAvailableSalesDetails();
            int matchingCount = availableDetails.Count;
            
            if (matchingCount == 0)
            {
                await NotificationService.ShowInfoAsync("目前沒有符合條件的未出貨訂單明細");
                return;
            }
            
            _loadSummaryMessage = $"共 {matchingCount} 筆，是否確定載入？";
            
            // 顯示確認 Modal
            _showLoadConfirmModal = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"準備載入資料時發生錯誤：{ex.Message}");
        }
    }

    /// <summary>
    /// 執行載入所有未出貨訂單 - 使用者確認後執行
    /// </summary>
    private async Task ExecuteLoadAllUndeliveredItems()
    {
        try
        {
            var availableDetails = GetAvailableSalesDetails();
            
            if (!availableDetails.Any())
            {
                await NotificationService.ShowWarningAsync("沒有可載入的未出貨訂單明細", "提示");
                return;
            }
            
            await LoadUndeliveredItemsInternal(availableDetails);
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入未出貨訂單時發生錯誤：{ex.Message}");
        }
    }

    /// <summary>
    /// 載入所有未出貨訂單的主要方法（公開方法，供父組件調用）
    /// </summary>
    public async Task LoadAllUndeliveredItems()
    {
        await ExecuteLoadAllUndeliveredItems();
    }

    /// <summary>
    /// 內部方法：載入未出貨項目
    /// </summary>
    private async Task LoadUndeliveredItemsInternal(List<SalesOrderDetail> details)
    {
        try
        {
            // 清空現有項目
            Items.Clear();

            // 載入所有未出貨項目
            foreach (var detail in details)
            {
                var deliveryItem = new DeliveryItem
                {
                    // 關鍵：設定 SelectedSalesDetail 和 SelectedProduct
                    SelectedSalesDetail = detail,
                    SelectedProduct = detail.Product,
                    ProductId = detail.ProductId,
                    ProductSearchValue = FormatSalesDetailDisplayText(detail),
                    DeliveryQuantity = detail.OrderQuantity - detail.DeliveredQuantity, // 未出貨數量
                    UnitPrice = detail.UnitPrice,
                    TaxRate = detail.TaxRate ?? detail.Product?.TaxRate ?? currentTaxRate,
                    WarehouseId = detail.WarehouseId,
                    Remarks = string.Empty
                };

                // 載入庫存資訊（非同步）
                _ = Task.Run(async () =>
                {
                    await LoadStockQuantityAsync(deliveryItem);
                    await InvokeAsync(StateHasChanged);
                });

                Items.Add(deliveryItem);
            }

            // 通知變更
            await NotifyDetailsChangedAsync();

            StateHasChanged();
            
            await NotificationService.ShowSuccessAsync(
                $"成功載入 {details.Count} 項未出貨訂單"
            );
        }
        catch (Exception ex)
        {
            await NotificationService.ShowErrorAsync($"載入未出貨訂單失敗：{ex.Message}");
        }
    }

    public async Task<bool> ValidateAsync()
    {
        var nonEmptyItems = Items.Where(item => item.ProductId > 0).ToList();
        
        if (!nonEmptyItems.Any())
        {
            await NotificationService.ShowWarningAsync("請至少新增一筆出貨明細");
            return false;
        }

        foreach (var item in nonEmptyItems)
        {
            if (item.ProductId <= 0)
            {
                await NotificationService.ShowWarningAsync("請選擇商品");
                return false;
            }

            if (!item.DeliveryQuantity.HasValue || item.DeliveryQuantity.Value <= 0)
            {
                await NotificationService.ShowWarningAsync("數量必須大於 0");
                return false;
            }

            if (!item.UnitPrice.HasValue || item.UnitPrice.Value < 0)
            {
                await NotificationService.ShowWarningAsync("單價不能為負數");
                return false;
            }

            //  檢查是否已選擇倉庫
            if (!item.WarehouseId.HasValue || item.WarehouseId.Value <= 0)
            {
                var product = AvailableProducts.FirstOrDefault(p => p.Id == item.ProductId);
                var productName = product?.Name ?? $"商品ID: {item.ProductId}";
                await NotificationService.ShowWarningAsync($"商品「{productName}」尚未選擇倉庫，請選擇出貨倉庫");
                return false;
            }

            //  檢查庫存數量是否足夠
            if (!item.CurrentStockQuantity.HasValue)
            {
                var product = AvailableProducts.FirstOrDefault(p => p.Id == item.ProductId);
                var productName = product?.Name ?? $"商品ID: {item.ProductId}";
                await NotificationService.ShowWarningAsync($"商品「{productName}」的庫存資料載入中，請稍後再試");
                return false;
            }

            // 編輯模式庫存驗證：CurrentStockQuantity 已在載入和切換倉庫時計算好有效可用庫存
            // （原始倉庫位置 = AvailableStock + OriginalDeliveryQuantity，新倉庫位置 = AvailableStock）
            if (item.CurrentStockQuantity.Value < item.DeliveryQuantity.Value)
            {
                var product = AvailableProducts.FirstOrDefault(p => p.Id == item.ProductId);
                var productName = product?.Name ?? $"商品ID: {item.ProductId}";
                var warehouse = Warehouses.FirstOrDefault(w => w.Id == item.WarehouseId);
                var warehouseName = warehouse?.Name ?? "選定倉庫";
                
                await NotificationService.ShowWarningAsync(
                    $"商品「{productName}」在「{warehouseName}」的庫存不足！\n" +
                    $"目前可用庫存: {item.CurrentStockQuantity.Value:N0}，" +
                    $"出貨數量: {item.DeliveryQuantity.Value:N0}");
                return false;
            }
        }

        return true;
    }

    public class DeliveryItem
    {
        /// <summary>
        /// 商品ID（用於 Select 綁定）
        /// </summary>
        public int ProductId { get; set; }
        
        /// <summary>
        /// 選擇的商品物件（用於空行檢查）
        /// </summary>
        public Product? SelectedProduct { get; set; }
        
        // === 訂單明細相關屬性 ===
        public SalesOrderDetail? SelectedSalesDetail { get; set; }
        
        // === SearchableSelect 支援屬性（通用：支援 SalesOrderDetail 和 Product）===
        public string ProductSearchValue { get; set; } = string.Empty;
        public List<object> FilteredItems { get; set; } = new();
        public bool ShowDropdown { get; set; } = false;
        public int SelectedIndex { get; set; } = -1;
        
        /// <summary>
        /// 數量（nullable，預設 null）
        /// </summary>
        public decimal? DeliveryQuantity { get; set; }
        
        /// <summary>
        /// 累計退貨數量
        /// </summary>
        public decimal TotalReturnedQuantity { get; set; } = 0;
        
        /// <summary>
        /// 單價（nullable，預設 null）
        /// </summary>
        public decimal? UnitPrice { get; set; }
        
        /// <summary>
        /// 折扣百分比（0-100，預設 0）
        /// </summary>
        public decimal DiscountPercentage { get; set; } = 0;
        
        /// <summary>
        /// 稅率（nullable，預設 null）
        /// </summary>
        public decimal? TaxRate { get; set; }
        
        public string Remarks { get; set; } = string.Empty;
        public int? WarehouseId { get; set; }
        public int? WarehouseLocationId { get; set; }
        
        /// <summary>
        /// 小計金額（計算屬性）
        /// </summary>
        public decimal SubtotalAmount => (DeliveryQuantity ?? 0) * (UnitPrice ?? 0);
        
        public SalesDeliveryDetail? ExistingDetailEntity { get; set; }
        
        /// <summary>
        /// 即時庫存量（不儲存到資料庫）
        /// </summary>
        public decimal? CurrentStockQuantity { get; set; }
        
        /// <summary>
        /// 庫存明細ID（用於選擇倉庫-庫位）
        /// </summary>
        public int? InventoryStockDetailId { get; set; }
        
        /// <summary>
        /// 可用的倉庫位置清單（僅顯示有庫存的位置）
        /// </summary>
        public List<InventoryStockDetail> AvailableWarehouseLocations { get; set; } = new();
        
        // ===== 編輯模式庫存追蹤欄位 =====
        
        /// <summary>
        /// 原始出貨數量（編輯模式下從 ExistingDetailEntity 載入時記錄）
        /// 用於計算編輯模式下的實際可用庫存
        /// </summary>
        public decimal? OriginalDeliveryQuantity { get; set; }
        
        /// <summary>
        /// 原始庫存明細ID（編輯模式下記錄原始選擇的倉庫-庫位組合）
        /// 用於判斷使用者是否更換了倉庫/庫位
        /// </summary>
        public int? OriginalInventoryStockDetailId { get; set; }
        
        /// <summary>
        /// 判斷倉庫/庫位是否已被更改（相對於原始值）
        /// </summary>
        public bool IsWarehouseChanged => 
            OriginalInventoryStockDetailId.HasValue && 
            InventoryStockDetailId != OriginalInventoryStockDetailId;
        
        /// <summary>
        /// 取得該庫存明細位置在編輯模式下應加回的原始出貨量
        /// 只有在未更換倉庫且有原始出貨量時才加回
        /// </summary>
        public decimal GetOriginalQuantityBonus(int? stockDetailId = null)
        {
            var checkId = stockDetailId ?? InventoryStockDetailId;
            if (OriginalDeliveryQuantity.HasValue && 
                OriginalInventoryStockDetailId.HasValue &&
                checkId == OriginalInventoryStockDetailId)
            {
                return OriginalDeliveryQuantity.Value;
            }
            return 0;
        }
    }
}
