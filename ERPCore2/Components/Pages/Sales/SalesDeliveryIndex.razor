@page "/salesDeliveries"
@using ERPCore2.Models.Reports
@inject ISalesDeliveryService SalesDeliveryService
@inject ICustomerService CustomerService
@inject ISalesOrderService SalesOrderService
@inject IEmployeeService EmployeeService
@inject IWarehouseService WarehouseService
@inject ISystemParameterService SystemParameterService
@inject INotificationService NotificationService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISalesDeliveryReportService SalesDeliveryReportService
@rendermode InteractiveServer

<GenericIndexPageComponent TEntity="SalesDelivery"
                          TService="ISalesDeliveryService"
                          Service="@SalesDeliveryService"
                          EntityBasePath="/sales-deliveries"
                          PageTitle="@L["Page.SalesDeliveryTitle"]"
                          PageSubtitle="@L["Page.SalesDeliverySubtitle"]"
                          EntityName="@L["Entity.SalesDeliveryDoc"]"
                          BreadcrumbItems="@breadcrumbItems"
                          FilterDefinitions="@filterDefinitions"
                          ColumnDefinitions="@columnDefinitions"
                          ShowDraftTab="true"
                          ServerDataLoader="@ServerLoadSalesDeliveriesAsync"
                          GetEntityDisplayName="@(delivery => delivery.Code)"
                          RequiredPermission="@PermissionRegistry.SalesDelivery.Read"
                          RequiredModule="Sales"
                          ShowBatchPrintButton="false"
                          OnBatchPrintClick="@HandleBatchPrintAsync"
                          ShowBatchApprovalButton="@isManualApproval"
                          OnBatchApprovalClick="@HandleBatchApprovalAsync"
                          OnAddClick="@modalHandler.ShowAddModalAsync"
                          OnRowClick="@modalHandler.ShowEditModalAsync"
                          DebugPageName="SalesDeliveryIndex"
                          RowPrintService="@SalesDeliveryReportService"
                          RowPrintReportId="@ReportIds.SalesDelivery"
                          @ref="indexComponent" />

@* 銷貨單編輯 Modal *@
<SalesDeliveryEditModalComponent IsVisible="@showEditModal"
                                IsVisibleChanged="@((bool visible) => showEditModal = visible)"
                                SalesDeliveryId="@editingSalesDeliveryId"
                                OnSalesDeliverySaved="@modalHandler.OnEntitySavedAsync"
                                OnCancel="@modalHandler.OnModalCancelAsync" />

@* 批次審核 Modal *@
<BatchApprovalModalComponent TEntity="SalesDelivery"
                            IsVisible="@showBatchApprovalModal"
                            IsVisibleChanged="@((bool visible) => showBatchApprovalModal = visible)"
                            Title="出貨單批次審核"
                            EntityName="@L["Entity.SalesDeliveryDoc"]"
                            LoadPendingItems="@LoadPendingSalesDeliveriesAsync"
                            OnApproveItem="@ApproveSingleSalesDeliveryAsync"
                            OnApproveAll="@ApproveAllSalesDeliveriesAsync"
                            OnViewClick="@HandleApprovalViewClick"
                            OnApprovalCompleted="@HandleApprovalCompleted" />

@* 批次列印篩選 Modal - 使用 GenericReportFilterModalComponent 統一架構 *@
<GenericReportFilterModalComponent IsVisible="@showBatchPrintModal"
                                  IsVisibleChanged="@((bool visible) => showBatchPrintModal = visible)"
                                  ReportId="@ReportIds.SalesDelivery"
                                  OnPrintSuccess="@HandleBatchPrintSuccess" />

@code {
    // 組件參考
    private GenericIndexPageComponent<SalesDelivery, ISalesDeliveryService> indexComponent = default!;

    // Modal 相關狀態
    private bool showEditModal = false;
    private int? editingSalesDeliveryId = null;
    
    // 審核相關狀態
    private bool isManualApproval = false;
    private bool showBatchApprovalModal = false;

    // 批次列印 Modal 相關狀態
    private bool showBatchPrintModal = false;

    // 從 URL 直接開啟指定單據的 Edit Modal（由 CustomerTransactionTable 導航時使用）
    [Parameter, SupplyParameterFromQuery(Name = "editId")]
    public int? EditId { get; set; }

    // Modal 處理器
    private ModalHandler<SalesDelivery, GenericIndexPageComponent<SalesDelivery, ISalesDeliveryService>> modalHandler = default!;

    // 選項清單
    private List<Customer> customers = new();
    private List<SalesOrder> salesOrders = new();
    private List<Employee> employees = new();
    private List<Warehouse> warehouses = new();

    // 欄位配置
    private SalesDeliveryFieldConfiguration fieldConfiguration = default!;

    // 配置相關
    private List<SearchFilterDefinition> filterDefinitions = new();
    private List<TableColumnDefinition> columnDefinitions = new();
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && EditId.HasValue)
        {
            editingSalesDeliveryId = EditId.Value;
            showEditModal = true;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 初始化 Modal 處理器
            modalHandler = ModalHelper.CreateModalHandler<SalesDelivery, GenericIndexPageComponent<SalesDelivery, ISalesDeliveryService>>(
                id => editingSalesDeliveryId = id,
                visible => showEditModal = visible,
                () => indexComponent,
                StateHasChanged,
                GetType());

            await InitializeBreadcrumbsAsync();

            // 載入相關資料
            await LoadCustomersAsync();
            await LoadSalesOrdersAsync();
            await LoadEmployeesAsync();
            await LoadWarehousesAsync();

            // 建立欄位配置(在載入相關資料後,並傳遞 NotificationService)
            isManualApproval = await SystemParameterService.IsSalesDeliveryManualApprovalAsync();
            fieldConfiguration = new SalesDeliveryFieldConfiguration(
                customers,
                salesOrders,
                employees,
                warehouses,
                isManualApproval,
                NotificationService);
            fieldConfiguration.SetLocalizer(L);

            // 使用欄位配置建立篩選器和表格欄位
            filterDefinitions = fieldConfiguration.BuildFilters();
            columnDefinitions = fieldConfiguration.BuildColumns();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(OnInitializedAsync), GetType(), additionalData: "初始化銷貨單頁面失敗");
            await NotificationService.ShowErrorAsync("初始化銷貨單頁面失敗");
        }
    }

    private async Task InitializeBreadcrumbsAsync()
    {
        breadcrumbItems = await BreadcrumbHelper.CreateThreeLevelAsync(
            "銷貨管理",
            "銷貨單",
            null,
            NotificationService,
            GetType());
    }

    private async Task LoadCustomersAsync()
    {
        customers = await DataLoaderHelper.LoadAsync(
            () => CustomerService.GetAllAsync(),
            "客戶",
            NotificationService,
            GetType(),
            nameof(LoadCustomersAsync));
    }

    private async Task LoadSalesOrdersAsync()
    {
        salesOrders = await DataLoaderHelper.LoadAsync(
            () => SalesOrderService.GetAllAsync(),
            "銷售訂單",
            NotificationService,
            GetType(),
            nameof(LoadSalesOrdersAsync));
    }

    private async Task LoadEmployeesAsync()
    {
        employees = await DataLoaderHelper.LoadAsync(
            () => EmployeeService.GetAllAsync(),
            "員工",
            NotificationService,
            GetType(),
            nameof(LoadEmployeesAsync));
    }

    private async Task LoadWarehousesAsync()
    {
        warehouses = await DataLoaderHelper.LoadAsync(
            () => WarehouseService.GetAllAsync(),
            "倉庫",
            NotificationService,
            GetType(),
            nameof(LoadWarehousesAsync));
    }

    // 伺服器端分頁載入
    private Task<(List<SalesDelivery> Items, int TotalCount)> ServerLoadSalesDeliveriesAsync(
        SearchFilterModel filter, int page, int pageSize)
    {
        return SalesDeliveryService.GetPagedWithFiltersAsync(
            q =>
            {
                q = q.Where(sd => sd.IsDraft == (filter.ShowDrafts ?? false));
                if (fieldConfiguration != null)
                    q = fieldConfiguration.ApplyFilters(filter, q, nameof(ServerLoadSalesDeliveriesAsync), GetType());
                return q;
            },
            page, pageSize);
    }

    // 多筆列印處理方法
    private async Task HandleBatchPrintAsync()
    {
        try
        {
            // 顯示批次列印篩選 Modal
            showBatchPrintModal = true;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleBatchPrintAsync), GetType(), additionalData: "開啟多筆列印視窗失敗");
            await NotificationService.ShowErrorAsync("開啟多筆列印視窗失敗");
        }
    }

    // 處理批次列印成功
    private void HandleBatchPrintSuccess()
    {
        showBatchPrintModal = false;
        StateHasChanged();
    }

    // ===== 批次審核相關方法 =====

    private async Task HandleBatchApprovalAsync()
    {
        try
        {
            showBatchApprovalModal = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleBatchApprovalAsync), GetType(), additionalData: "開啟批次審核視窗失敗");
            await NotificationService.ShowErrorAsync("開啟批次審核視窗失敗");
        }
    }

    private async Task<List<SalesDelivery>> LoadPendingSalesDeliveriesAsync()
    {
        try
        {
            var all = await SalesDeliveryService.GetAllAsync();
            return all.Where(sd => !sd.IsApproved).ToList();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadPendingSalesDeliveriesAsync), GetType(), additionalData: "載入待審核出貨單失敗");
            await NotificationService.ShowErrorAsync("載入待審核出貨單失敗");
            return new List<SalesDelivery>();
        }
    }

    private async Task<bool> ApproveSingleSalesDeliveryAsync(SalesDelivery entity)
    {
        try
        {
            var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
            if (!userId.HasValue) return false;
            var result = await SalesDeliveryService.ApproveAsync(entity.Id, userId.Value);
            return result.IsSuccess;
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(ApproveSingleSalesDeliveryAsync), GetType(), additionalData: new { EntityId = entity.Id });
            return false;
        }
    }

    private async Task<(int successCount, int failCount)> ApproveAllSalesDeliveriesAsync(List<SalesDelivery> items)
    {
        int successCount = 0, failCount = 0;
        var userId = await CurrentUserHelper.GetCurrentEmployeeIdAsync(AuthenticationStateProvider);
        if (!userId.HasValue) return (0, items.Count);
        foreach (var item in items)
        {
            try
            {
                var result = await SalesDeliveryService.ApproveAsync(item.Id, userId.Value);
                if (result.IsSuccess) successCount++; else failCount++;
            }
            catch (Exception ex)
            {
                failCount++;
                await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(ApproveAllSalesDeliveriesAsync), GetType(), additionalData: new { EntityId = item.Id });
            }
        }
        return (successCount, failCount);
    }

    private async Task HandleApprovalViewClick(SalesDelivery entity)
    {
        try
        {
            await modalHandler.ShowEditModalAsync(entity);
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleApprovalViewClick), GetType(), additionalData: new { EntityId = entity.Id });
            await NotificationService.ShowErrorAsync("開啟查看視窗失敗");
        }
    }

    private async Task HandleApprovalCompleted()
    {
        try
        {
            if (indexComponent != null)
                await indexComponent.Refresh();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(HandleApprovalCompleted), GetType(), additionalData: "刷新列表失敗");
        }
    }
}

