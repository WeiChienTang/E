@* 通用會計資訊 Tab — 支援客戶、廠商、品項；顯示對應子科目，並可立即建立 *@
@using ERPCore2.Models.Enums
@using Microsoft.Extensions.Localization
@inject ISubAccountService SubAccountService
@inject INotificationService NotificationService
@inject AuthenticationStateProvider AuthStateProvider
@inject IStringLocalizer<SharedResource> L

@if (_entityId <= 0)
{
    <div class="text-muted py-3 px-2">
        <i class="bi bi-info-circle me-2"></i>@L["Accounting.SaveFirst"]
    </div>
}
else if (_isLoading)
{
    <div class="text-muted py-3 px-2">
        <i class="bi bi-hourglass-split me-2"></i>@L["Label.Loading"]
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2 px-1">
        <div class="d-flex gap-2">
            @if (_rows.Any(r => r.Item == null))
            {
                <GenericButtonComponent Variant="ButtonVariant.DarkBlue"
                                       Size="ButtonSize.Small"
                                       Text="@L["Accounting.CreateSubAccount"].ToString()"
                                       OnClick="HandleCreateAsync"
                                       IsLoading="@_isCreating"
                                       IsDisabled="@_isCreating"
                                       Title="@L["Accounting.CreateSubAccountTitle"].ToString()" />
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-hover mb-3">
            <thead class="accounting-thead">
                <tr>
                    <th style="width:160px">@L["Accounting.SubAccountType"]</th>
                    <th style="width:140px">@L["Accounting.AccountCode"]</th>
                    <th>@L["Accounting.AccountName"]</th>
                    <th style="width:90px">@L["Field.Status"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _rows)
                {
                    <tr>
                        <td>@row.Label</td>
                        <td class="font-monospace small">@(row.Item?.Code ?? "—")</td>
                        <td class="small">@(row.Item?.Name ?? "—")</td>
                        <td>
                            @if (row.Item != null)
                            {
                                <span class="text-success small"><i class="bi bi-check-circle me-1"></i>@L["Accounting.Created"]</span>
                            }
                            else
                            {
                                <span class="text-warning small"><i class="bi bi-exclamation-circle me-1"></i>@L["Accounting.NotCreated"]</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter] public AccountingEntityType EntityType { get; set; }
    [Parameter] public int? EntityId { get; set; }

    private int _entityId;
    private int _lastLoadedId;
    private bool _isLoading;
    private bool _isCreating;
    private List<(string Label, AccountItem? Item)> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        var newId = EntityId ?? 0;
        if (newId > 0 && newId != _lastLoadedId)
        {
            await LoadAsync(newId);
        }
        else if (newId <= 0 && _lastLoadedId > 0)
        {
            Clear();
        }
    }

    public async Task LoadAsync(int entityId)
    {
        _entityId = entityId;
        _lastLoadedId = entityId;
        await RefreshAsync();
        StateHasChanged();
    }

    public void Clear()
    {
        _entityId = 0;
        _lastLoadedId = 0;
        _rows = new();
        StateHasChanged();
    }

    private async Task RefreshAsync()
    {
        if (_entityId <= 0) return;

        _isLoading = true;
        StateHasChanged();

        _rows = EntityType switch
        {
            AccountingEntityType.Customer => await BuildCustomerRowsAsync(),
            AccountingEntityType.Supplier => await BuildSupplierRowsAsync(),
            AccountingEntityType.Product  => await BuildProductRowsAsync(),
            _ => new()
        };

        _isLoading = false;
    }

    private async Task<List<(string, AccountItem?)>> BuildCustomerRowsAsync()
    {
        var all = await SubAccountService.GetAllSubAccountsForCustomerAsync(_entityId);

        AccountItem? Find(SubAccountLinkType type) =>
            all.FirstOrDefault(a =>
                a.SubAccountLinkType == type ||
                (type == SubAccountLinkType.ReceivablePayable && a.SubAccountLinkType == null));

        return new()
        {
            (L["Accounting.AccountsReceivable"].ToString(), Find(SubAccountLinkType.ReceivablePayable)),
            (L["Accounting.NoteReceivable"].ToString(),     Find(SubAccountLinkType.NoteReceivablePayable)),
            (L["Accounting.SalesReturn"].ToString(),        Find(SubAccountLinkType.SalesPurchaseReturn)),
            (L["Accounting.AdvanceReceipt"].ToString(),     Find(SubAccountLinkType.AdvanceReceiptPayment)),
        };
    }

    private async Task<List<(string, AccountItem?)>> BuildSupplierRowsAsync()
    {
        var all = await SubAccountService.GetAllSubAccountsForSupplierAsync(_entityId);

        AccountItem? Find(SubAccountLinkType type) =>
            all.FirstOrDefault(a =>
                a.SubAccountLinkType == type ||
                (type == SubAccountLinkType.ReceivablePayable && a.SubAccountLinkType == null));

        return new()
        {
            (L["Accounting.AccountsPayable"].ToString(), Find(SubAccountLinkType.ReceivablePayable)),
            (L["Accounting.NotePayable"].ToString(),     Find(SubAccountLinkType.NoteReceivablePayable)),
            (L["Accounting.PurchaseReturn"].ToString(),  Find(SubAccountLinkType.SalesPurchaseReturn)),
            (L["Accounting.AdvancePayment"].ToString(),  Find(SubAccountLinkType.AdvanceReceiptPayment)),
        };
    }

    private async Task<List<(string, AccountItem?)>> BuildProductRowsAsync()
    {
        var item = await SubAccountService.GetSubAccountForProductAsync(_entityId);
        return new()
        {
            (L["Accounting.Inventory"].ToString(), item),
        };
    }

    private async Task HandleCreateAsync()
    {
        try
        {
            _isCreating = true;
            StateHasChanged();

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var createdBy = authState.User.Identity?.Name ?? "system";

            _ = EntityType switch
            {
                AccountingEntityType.Customer => await SubAccountService.GetOrCreateCustomerSubAccountAsync(_entityId, createdBy),
                AccountingEntityType.Supplier => await SubAccountService.GetOrCreateSupplierSubAccountAsync(_entityId, createdBy),
                AccountingEntityType.Product  => await SubAccountService.GetOrCreateProductSubAccountAsync(_entityId, createdBy),
                _ => null
            };

            await RefreshAsync();
        }
        catch (Exception)
        {
            await NotificationService.ShowErrorAsync(L["Accounting.CreateError"].ToString());
        }
        finally
        {
            _isCreating = false;
            StateHasChanged();
        }
    }
}
