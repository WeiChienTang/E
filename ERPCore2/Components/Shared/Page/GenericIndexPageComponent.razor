@* 泛型Index頁面基底組件 *@
@attribute [Authorize]
@typeparam TEntity where TEntity : BaseEntity
@typeparam TService where TService : IGenericManagementService<TEntity>
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject INotificationService NotificationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ICompanyModuleService CompanyModuleService
@inject INavigationPermissionService NavigationPermissionService
@inject IUserPreferenceContext UserPreferenceContext
@inject IStringLocalizer<SharedResource> L

@using ERPCore2.Models.Enums
@using ERPCore2.Components.Shared.UI.Form
@using ERPCore2.Services
@using Microsoft.Extensions.Localization

@* 設置瀏覽器標題 *@
<PageTitle>@PageTitle</PageTitle>

@{
    // 權限檢查 - 如果沒有設定權限，預設拒絕存取
    string requiredPermission = RequiredPermission;
    if (string.IsNullOrWhiteSpace(requiredPermission))
    {
        // 安全起見，如果沒有設定權限，設定為一個不存在的權限以確保拒絕存取
        requiredPermission = "System.RequiredPermissionNotSet";
    }
}

@* 公司層級模組檢查 - 模組未啟用時顯示拒絕畫面 *@
@if (!string.IsNullOrWhiteSpace(RequiredModule) && !_isModuleEnabled)
{
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
        <i class="bi bi-lock-fill text-secondary" style="font-size: 4rem;"></i>
        <h4 class="mt-3 text-secondary">@L["Module.NotAvailable"]</h4>
        <p class="text-muted">@L["Module.DisabledMessage"]</p>
    </div>
}
else
{

<PagePermissionCheck RequiredPermission="@requiredPermission">

@* 頁面標題 *@
<GenericHeaderComponent Title="@PageTitle"
                       Subtitle="@PageSubtitle"
                       HeadingLevel="h1"
                       BreadcrumbItems="@BreadcrumbItems"
                       IsLoading="@IsLoading"
                       LoadingText="@L["Label.Loading"]"
                       ShowDivider="true">
    <ActionButtons>
        @if (ShowDefaultActions && CustomActionButtons == null)
        {
            <IndexActionButtonsComponent 
                AddButtonText="@GetAddButtonText()"
                AddButtonTitle="@GetAddButtonTitle()"
                ShowAddButton="@ShowAddButton"
                OnAddClick="@HandleAddClick"
                OnRefreshClick="@Refresh"
                ShowExportExcelButton="@ShowExportExcelButton"
                OnExportExcelClick="@HandleExportExcelClick"
                ShowExportPdfButton="@ShowExportPdfButton"
                OnExportPdfClick="@HandleExportPdfClick"
                ShowBatchPrintButton="@ShowBatchPrintButton"
                OnBatchPrintClick="@HandleBatchPrintClick"
                ShowBarcodePrintButton="@ShowBarcodePrintButton"
                OnBarcodePrintClick="@HandleBarcodePrintClick"
                ShowBatchApprovalButton="@ShowBatchApprovalButton"
                OnBatchApprovalClick="@HandleBatchApprovalClick"
                ShowImportScheduleButton="@ShowImportScheduleButton"
                OnImportScheduleClick="@HandleImportScheduleClick"
                ShowBatchDeleteButton="@ShowBatchDeleteButton"
                IsBatchDeleteDisabled="@IsBatchDeleteDisabled"
                OnBatchDeleteClick="@HandleBatchDeleteClick"
                IsLoading="@IsLoading"
                LoadingOnRefresh="true"
                CustomButtons="@CustomIndexButtons" />
        }
        else if (CustomActionButtons != null)
        {
            @CustomActionButtons
        }
    </ActionButtons>
</GenericHeaderComponent>

@* 統計卡片區域 - 條件顯示 *@
@if (ShowStatisticsCards && StatisticsCardConfigs != null && StatisticsCardConfigs.Any())
{
    <div class="row mb-4">
        <div class="col-12">
            <GenericStatisticsCards CardConfigs="@StatisticsCardConfigs"
                                   Statistics="@_statisticsData" />
        </div>
    </div>
}

@* 主要內容區域 *@
<div class="row">
    <div class="col-12">
        <div class="card section-card">
            <div class="card-header section-header-primary">                
                <h5 class="card-title mb-0">
                    <i class="bi bi-search me-2"></i>
                    @GetSearchSectionTitle()
                </h5>
            </div>
            <div class="card-body">                
                @* 搜尋篩選區域 *@
                <GenericSearchFilterComponent TModel="SearchFilterModel"
                                             FilterDefinitions="@_cachedFilterDefinitions"
                                             FilterModel="@SearchModel"
                                             OnSearch="@HandleSearch"
                                             OnFilterChanged="@HandleFilterChanged"
                                             AutoSearch="@AutoSearch"
                                             ShowSearchButton="@ShowSearchButton"
                                             SearchDelayMs="@SearchDelayMs" />

                @* 草稿/正式資料切換按鈕（僅在 ShowDraftTab 時顯示） *@
                @if (ShowDraftTab)
                {
                    <div class="index-draft-tab-btn-group pt-3">
                        <button type="button"
                                class="index-draft-tab-btn @(!_showingDrafts ? "active" : "")"
                                @onclick="@(() => SwitchDraftTab(false))">
                            <i class="bi bi-check-circle me-1"></i>
                            @L["Label.Official"]
                        </button>
                        <button type="button"
                                class="index-draft-tab-btn @(_showingDrafts ? "active" : "")"
                                @onclick="@(() => SwitchDraftTab(true))">
                            <i class="bi bi-pencil-square me-1"></i>
                            @L["Label.Draft"]
                            @if (_draftCount > 0)
                            {
                                <span class="badge bg-danger ms-1">@_draftCount</span>
                            }
                        </button>
                    </div>
                }

                @* 列表表格 *@
                <div class="pt-3">
                    @* 多選操作列（選取任一項目後顯示） *@
                    @if (EnableMultiSelect && _selectedItems.Count > 0)
                    {
                        <div class="d-flex align-items-center gap-2 mb-2 px-3 py-2 rounded border"
                             style="background: var(--bs-primary-bg-subtle); border-color: var(--bs-primary) !important;">
                            <span class="fw-semibold" style="color: var(--bs-primary);">
                                <i class="bi bi-check2-square me-1"></i>
                                @string.Format(L["Label.SelectedCount"], _selectedItems.Count)
                            </span>
                            <GenericButtonComponent Variant="ButtonVariant.Red"
                                                   IconClass="bi bi-trash"
                                                   Text="@L["Button.Delete"]"
                                                   OnClick="@(() => _showMultiDeleteModal = true)"
                                                   Title="@L["Button.Delete"]" />
                            <GenericButtonComponent Variant="ButtonVariant.Gray"
                                                   Text="@L["Button.ClearSelection"]"
                                                   OnClick="@(() => { _selectedItems.Clear(); StateHasChanged(); })"
                                                   Title="@L["Button.ClearSelection"]" />
                        </div>
                    }
                    <GenericTableComponent TItem="TEntity"
                                          Items="@PagedItems"
                                          ColumnDefinitions="@_cachedColumnDefinitions"
                                          EnableRowClick="@EnableRowClick"
                                          OnRowClick="@HandleRowClick"
                                          EnableSorting="@EnableSorting"
                                          IsStriped="@IsStriped"
                                          IsHoverable="@IsHoverable"
                                          IsBordered="@IsBordered"
                                          Size="@TableSize"
                                          EmptyMessage="@GetEmptyMessage()"
                                          ContextMenuItems="@_cachedEffectiveContextMenuItems"
                                          ShowSelectColumn="@EnableMultiSelect"
                                          AllowMultipleSelection="true"
                                          SelectedItems="@_selectedItems"
                                          OnSelectionChanged="HandleSelectionChanged"
                                          IsItemSelectable="@(EnableMultiSelect ? (IsMultiSelectItemSelectable ?? (Func<TEntity, bool>?)IsEntityDeletable) : null)">
                    </GenericTableComponent>

                    @* 分頁組件 - 獨立於表格之外 *@
                    @if (EnablePagination)
                    {
                        <GenericPaginationComponent CurrentPage="@CurrentPage"
                                                   PageSize="@PageSize"
                                                   TotalItems="@TotalItems"
                                                   OnPageChanged="@HandlePageChanged"
                                                   OnPageSizeChanged="@HandlePageSizeChanged"
                                                   ShowPageSizeSelector="@ShowPageSizeSelector" />
                    }
                </div>
            </div>
        </div>
    </div>
</div>
</PagePermissionCheck>

@* ===== Debug Badge (僅 SuperAdmin 可見) ===== *@
@if (_isSuperAdmin && !string.IsNullOrEmpty(DebugPageName))
{
    <div style="position:fixed; bottom:1rem; left:50%; transform:translateX(-50%); z-index:999;
                background:#1a1a2e; color:#7ec8e3; font-size:0.7rem;
                font-family:monospace; padding:0.25rem 0.6rem;
                border-radius:4px; border:1px solid #30363d;
                cursor:pointer; letter-spacing:0.03em; opacity:0.85; user-select:text;
                white-space:nowrap;"
         title="點擊複製頁面名稱"
         @onclick="CopyDebugPageNameAsync">
        🔧 <strong style="color:#f8c8a0;">SuperAdmin</strong> | @DebugPageName
        @if (_debugQueryMs >= 0)
        {
            <span style="color:#8b949e;"> | </span>
            <span style="color:@(_debugMode == "server" ? "#3fb950" : "#d29922");">@_debugMode</span>
            <span style="color:#8b949e;"> </span>
            <span style="color:#e6edf3;">@_debugPageCount/@_debugTotalCount 筆</span>
            <span style="color:#8b949e;"> | </span>
            <span style="color:@(_debugQueryMs < 500 ? "#3fb950" : _debugQueryMs < 2000 ? "#d29922" : "#f85149");">@_debugQueryMs ms</span>
        }
    </div>
}

@* 多選批次刪除確認 Modal *@
@if (_showMultiDeleteModal && _selectedItems.Count > 0)
{
    <GenericConfirmModalComponent
        IsVisible="@_showMultiDeleteModal"
        IsVisibleChanged="@((bool v) => _showMultiDeleteModal = v)"
        Title="@L["Button.ConfirmDelete"]"
        Icon="bi-trash"
        HeaderColor="BaseModalComponent.HeaderVariant.Danger"
        Message="@string.Format(L["Message.ConfirmBatchDelete"], _selectedItems.Count, EntityName)"
        ConfirmButtonText="@L["Button.Delete"]"
        ConfirmButtonVariant="ButtonVariant.Red"
        CancelButtonText="@L["Button.Cancel"]"
        OnConfirm="ExecuteMultiDeleteAsync" />
}

@* 右鍵選單刪除確認 Modal *@
@if (_showContextMenuDeleteModal && _contextMenuDeleteTarget != null)
{
    <GenericConfirmModalComponent
        IsVisible="@_showContextMenuDeleteModal"
        IsVisibleChanged="@((bool v) => { _showContextMenuDeleteModal = v; if (!v) _contextMenuDeleteTarget = null; })"
        Title="@L["Button.ConfirmDelete"]"
        Icon="bi-trash"
        HeaderColor="BaseModalComponent.HeaderVariant.Danger"
        Message="@GetDeleteConfirmMessage(GetEntityDisplayName(_contextMenuDeleteTarget))"
        ConfirmButtonText="@L["Button.Delete"]"
        ConfirmButtonVariant="ButtonVariant.Red"
        CancelButtonText="@L["Button.Cancel"]"
        OnConfirm="ExecuteContextMenuDeleteAsync" />
}

@* 操作欄刪除確認 Modal *@
@if (_showActionDeleteModal && _actionDeleteTarget != null)
{
    <GenericConfirmModalComponent
        IsVisible="@_showActionDeleteModal"
        IsVisibleChanged="@((bool v) => { _showActionDeleteModal = v; if (!v) _actionDeleteTarget = null; })"
        Title="@L["Button.ConfirmDelete"]"
        Icon="bi-trash"
        HeaderColor="BaseModalComponent.HeaderVariant.Danger"
        Message="@GetDeleteConfirmMessage(GetEntityDisplayName(_actionDeleteTarget))"
        ConfirmButtonText="@L["Button.Delete"]"
        ConfirmButtonVariant="ButtonVariant.Red"
        CancelButtonText="@L["Button.Cancel"]"
        OnConfirm="ExecuteActionDeleteAsync" />
}

@* 內建批次刪除 Modal *@
@if (BatchDeleteColumnDefinitions != null)
{
    <BatchDeleteConfirmModalComponent TItem="TEntity"
                                      IsVisible="@_showInternalBatchDeleteModal"
                                      IsVisibleChanged="@((bool v) => _showInternalBatchDeleteModal = v)"
                                      Title="@GetBatchDeleteTitle()"
                                      Items="@(ServerDataLoader != null ? pagedItems : filteredItems)"
                                      ColumnDefinitions="@BatchDeleteColumnDefinitions"
                                      IsDeleting="@_isInternalBatchDeleting"
                                      OnConfirmDelete="@HandleInternalBatchDeleteAsync"
                                      OnCancel="@(() => _showInternalBatchDeleteModal = false)" />
}

@* 右鍵列印預覽 Modal（由 RowPrintService 驅動） *@
@if (_showRowPrintModal)
{
    <ReportPreviewModalComponent IsVisible="@_showRowPrintModal"
                                 IsVisibleChanged="@((bool v) => _showRowPrintModal = v)"
                                 Title="@_rowPrintTitle"
                                 PreviewImages="@_rowPrintImages"
                                 FormattedDocument="@_rowPrintDocument"
                                 ReportId="@RowPrintReportId"
                                 DocumentName="@_rowPrintTitle"
                                 OnCancel="@(() => _showRowPrintModal = false)" />
}

} @* end else (module enabled) *@

@code {
    /// <summary>取得標準操作按鈕範本（含自訂範本與刪除按鈕）</summary>
    public RenderFragment<TEntity> GetStandardActionsTemplate()
    {
        return entity =>
            @<div>
                @if (CustomActionsTemplate != null)
                {
                    @CustomActionsTemplate(entity)
                }
                @if (ShowDeleteButton && IsEntityDeletable(entity))
                {
                    <GenericButtonComponent
                        Variant="ButtonVariant.Red"
                        IconClass="bi bi-trash text-white"
                        Title="@L["Button.Delete"]"
                        OnClick="@(() => { _actionDeleteTarget = entity; _showActionDeleteModal = true; StateHasChanged(); })"
                        StopPropagation="true"
                        CssClass="btn-square" />
                }
            </div>;
    }

    /// <summary>取得最終操作欄範本（優先使用外部 ActionsTemplate，其次標準範本）</summary>
    private RenderFragment<TEntity> GetFinalActionsTemplate()
    {
        if (ActionsTemplate != null)
            return ActionsTemplate;

        if (EnableStandardActions)
            return GetStandardActionsTemplate();

        return entity => @<div></div>;
    }
}
