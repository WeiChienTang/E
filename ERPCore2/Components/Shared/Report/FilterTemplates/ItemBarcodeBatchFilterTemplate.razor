@* 
    品項條碼批次列印篩選模板
    實作 IFilterTemplateComponent 介面，提供品項條碼批次列印的篩選 UI
    設計原則：緊湊式佈局，整合品項選擇表格與列印設定
*@

@using ERPCore2.Models
@using ERPCore2.Models.Barcode
@using ERPCore2.Models.Reports.FilterCriteria
@using ERPCore2.Models.Reports.FilterTemplates
@implements IFilterTemplateComponent
@inject IItemService ItemService
@inject INotificationService NotificationService
@inject IStringLocalizer<ERPCore2.SharedResource> L

<FilterSectionGroup>
    <FilterSectionColumn Title="@L["Report.BarcodeSettings"]" Icon="bi bi-upc-scan">
    @* 品項選擇表格 *@
    <div class="mb-3">
        <div class="d-flex gap-2 align-items-center flex-wrap justify-content-end mb-2">
            <GenericButtonComponent Text="@L["Label.SelectAll"]"
                                    Variant="ButtonVariant.Green"
                                    OnClick="SelectAll" />
            <GenericButtonComponent Text="@L["Button.DeselectAll"]"
                                    Variant="ButtonVariant.Red"
                                    OnClick="DeselectAll" />
        </div>

        @if (barcodeItems == null || !barcodeItems.Any())
        {
            <div class="alert alert-info py-2">
                <i class="bi bi-info-circle me-2"></i>
                @L["Message.NoBarcodeItems"]
            </div>
        }
        else
        {
            <div style="max-height: 300px; overflow-y: auto;">
                <ItemBarcodePrintTable Items="@barcodeItems"
                                        SelectedItems="@selectedItems"
                                        OnSelectionChanged="@HandleSelectionChanged"
                                        OnPrintQuantityChanged="@HandlePrintQuantityChanged"
                                        GetRowCssClass="@GetRowCssClass" />
            </div>
        }
    </div>
    
    @* 列印設定區 *@
    <div class="card print-settings-card">
        <div class="card-header print-settings-header py-2">
            <h6 class="mb-0 small">
                <i class="bi bi-gear me-2"></i>
                @L["Report.PrintSettings"]
            </h6>
        </div>
        <div class="card-body py-2">
            <div class="d-flex align-items-center gap-4 flex-wrap">
                <div>
                    <span class="fw-bold small">58mm × 28mm</span>
                </div>

                <div class="form-check">
                    <input class="form-check-input" type="checkbox"
                           @bind="showItemName"
                           id="showItemName">
                    <label class="form-check-label" for="showItemName">
                        @L["Label.ShowItemName"]
                    </label>
                </div>

                <div class="form-check">
                    <input class="form-check-input" type="checkbox"
                           @bind="showItemCode"
                           id="showItemCode">
                    <label class="form-check-label" for="showItemCode">
                        @L["Label.ShowItemCode"]
                    </label>
                </div>
            </div>
        </div>
    </div>
    </FilterSectionColumn>
</FilterSectionGroup>

@code {
    // ===== 內部狀態 =====
    
    private List<ItemBarcodeItem> barcodeItems = new();
    private HashSet<ItemBarcodeItem> selectedItems = new();
    private bool showItemName = true;
    private bool showItemCode = true;
    
    // ===== 生命週期方法 =====
    
    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }
    
    private async Task LoadDataAsync()
    {
        try
        {
            var allItems = await ItemService.GetAllAsync();
            
            if (allItems == null || !allItems.Any())
            {
                barcodeItems = new();
                return;
            }
            
            barcodeItems = allItems
                .Where(p => !string.IsNullOrWhiteSpace(p.Barcode))
                .Select(p => new ItemBarcodeItem
                {
                    ItemId = p.Id,
                    Code = p.Code ?? "",
                    Name = p.Name ?? "",
                    Barcode = p.Barcode ?? "",
                    PrintQuantity = 1
                })
                .ToList();
        }
        catch (Exception ex)
        {
            await ErrorHandlingHelper.HandlePageErrorAsync(ex, nameof(LoadDataAsync), GetType());
            await NotificationService.ShowErrorAsync(L["Message.LoadItemsFailed"]);
            barcodeItems = new();
        }
    }
    
    // ===== 事件處理方法 =====
    
    private void HandleSelectionChanged(HashSet<ItemBarcodeItem> items)
    {
        selectedItems = items;
        StateHasChanged();
    }
    
    private string GetRowCssClass(ItemBarcodeItem item, int index)
    {
        return selectedItems.Contains(item) ? "table-row-selected" : "";
    }
    
    private void HandlePrintQuantityChanged((ItemBarcodeItem item, string? value) args)
    {
        // 數值已經在 Table 元件中更新
        StateHasChanged();
    }
    
    private void SelectAll()
    {
        selectedItems = barcodeItems.ToHashSet();
        StateHasChanged();
    }
    
    private void DeselectAll()
    {
        selectedItems.Clear();
        StateHasChanged();
    }
    
    private int GetTotalPrintQuantity()
    {
        return selectedItems.Sum(x => x.PrintQuantity);
    }
    
    // ===== IFilterTemplateComponent 實作 =====
    
    /// <summary>
    /// 取得目前的篩選條件
    /// </summary>
    public IReportFilterCriteria GetCriteria()
    {
        return new ItemBarcodeBatchPrintCriteria
        {
            ItemIds = selectedItems.Select(x => x.ItemId).ToList(),
            BarcodeSize = BarcodeSize.Large,
            BarcodesPerPage = 24,
            ShowItemName = showItemName,
            ShowItemCode = showItemCode,
            OnlyWithBarcode = true,
            PrintQuantities = selectedItems.ToDictionary(x => x.ItemId, x => x.PrintQuantity)
        };
    }
    
    /// <summary>
    /// 重置篩選條件為預設值
    /// </summary>
    public void Reset()
    {
        selectedItems.Clear();
        showItemName = true;
        showItemCode = true;
        
        // 重置每個品項的列印數量為 1
        foreach (var item in barcodeItems)
        {
            item.PrintQuantity = 1;
        }
        
        StateHasChanged();
    }
}
