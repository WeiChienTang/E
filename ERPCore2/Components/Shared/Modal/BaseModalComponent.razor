@*
    基礎 Modal 模板組件
    提供統一的 Modal 外觀和行為，包含：
    1. 標準化的 Header（標題 + 圖示）
    2. 可自訂的按鈕區（Header 右側）
    3. 完全自訂的內容區
    4. 可選的 Footer（顯示審計資訊）
    5. 內建 ESC 鍵關閉功能
    6. 點擊背景關閉功能
*@
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization
@using ERPCore2.Models.FeatureGuides
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L
@inject INavigationPermissionService NavigationPermissionService
@implements IDisposable

@if (IsVisible)
{
    <div class="modal fade show"
         tabindex="-1"
         style="display: block; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: @GetModalZIndex(); overflow: hidden; cursor: pointer;"
         @onclick="@HandleBackdropClick">
        
        <div class="modal-dialog @GetModalSizeClass()"
             style="@GetModalDialogStyle()"
             @onclick:stopPropagation="true">
            <div class="modal-content shadow-lg" @onclick="DismissPopups">
                
                @* ===== Modal Header ===== *@
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">
                        @if (!string.IsNullOrEmpty(Icon))
                        {
                            <i class="@Icon me-2"></i>
                        }
                        @Title
                    </h5>

                    @* 右上角按鈕群組（全景 + 關閉） *@
                    <div class="d-flex align-items-center gap-1 ms-auto">
                        @if (AllowFullscreen)
                        {
                            <button type="button"
                                    class="btn btn-sm btn-link text-secondary p-0"
                                    @onclick="ToggleModalFullscreen"
                                    title="@(_isModalFullscreen ? "還原視窗" : "全螢幕")"
                                    style="font-size: 1.1rem; line-height: 1; opacity: 0.8; text-decoration: none;">
                                <i class="bi @(_isModalFullscreen ? "bi-fullscreen-exit" : "bi-fullscreen")"></i>
                            </button>
                        }
                        @if (ShowCloseButton)
                        {
                            <button type="button"
                                    class="btn-close"
                                    @onclick="HandleClose"
                                    title="@L["Button.Close"]"
                                    aria-label="@L["Button.Close"]"></button>
                        }
                    </div>
                </div>

                @* ===== Modal Actions (按鈕區) ===== *@
                @if (HeaderButtons != null)
                {
                    <div class="modal-action-bar border-bottom px-3 py-2 mb-2">
                        @HeaderButtons
                    </div>
                }

                @* ===== Modal Body ===== *@
                <div class="modal-body @BodyCssClass">
                    @if (IsLoading)
                    {
                        <div class="d-flex justify-content-center align-items-center py-5">
                            <div class="spinner-border text-primary me-2" style="width: 1.2rem; height: 1.2rem; border-width: 0.15em;" role="status">
                                <span class="visually-hidden">@L["Label.Loading"]</span>
                            </div>
                            <span class="fs-6">@LoadingMessage</span>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <h6 class="alert-heading">
                                <i class="fas fa-exclamation-circle me-2"></i>
                                @L["Modal.ErrorHeading"]
                            </h6>
                            @ErrorMessage
                        </div>
                    }
                    else if (BodyContent != null)
                    {
                        @BodyContent
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-inbox fs-1 d-block mb-3"></i>
                            <p class="mb-0">@L["Modal.NoContent"]</p>
                        </div>
                    }
                </div>

                @* ===== Modal Footer (Custom Content) ===== *@
                @if (ShowFooter && FooterContent != null)
                {
                    <div class="modal-footer border-top">
                        @FooterContent
                    </div>
                }
                
                @* ===== Modal 底部浮動按鈕群組 ===== *@
                @{
                    bool hasAuditBtn = ShowFooter && AuditInfo != null;
                    bool hasGuideBtn = FeatureGuide != null;
                }
                @if (hasAuditBtn || hasGuideBtn)
                {
                    <div class="audit-info-float-container" @onclick:stopPropagation="true">
                        @* 功能說明按鈕（新增 / 編輯模式皆可見） *@
                        @if (hasGuideBtn)
                        {
                            <button class="audit-info-toggle-btn"
                                    @onclick="ToggleFeatureGuide"
                                    title="@(_showFeatureGuide ? L["Modal.HideFeatureGuide"] : L["Modal.ShowFeatureGuide"])">
                                <i class="bi bi-question-circle"></i>
                            </button>
                        }
                        @* 審計資訊按鈕（僅編輯模式，有 Footer 時顯示） *@
                        @if (hasAuditBtn)
                        {
                            <button class="audit-info-toggle-btn"
                                    @onclick="@(() => _showAuditInfo = !_showAuditInfo)"
                                    title="@(_showAuditInfo ? L["Modal.HideAuditInfo"] : L["Modal.ShowAuditInfo"])">
                                <i class="bi bi-clock-history"></i>
                            </button>
                        }
                        @if (_showAuditInfo && AuditInfo != null)
                        {
                            <div class="audit-info-popup">
                                @if (AuditInfo.CreatedAt.HasValue)
                                {
                                    <div class="audit-info-row">
                                        <span class="audit-info-label">@L["Modal.CreatedAt"]</span>
                                        <span class="audit-info-value">@AuditInfo.CreatedAt.Value.ToString("yyyy/MM/dd HH:mm:ss")</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(AuditInfo.CreatedBy))
                                {
                                    <div class="audit-info-row">
                                        <span class="audit-info-label">@L["Modal.CreatedBy"]</span>
                                        <span class="audit-info-value">@AuditInfo.CreatedBy</span>
                                    </div>
                                }
                                @if (AuditInfo.UpdatedAt.HasValue)
                                {
                                    <div class="audit-info-row">
                                        <span class="audit-info-label">@L["Modal.UpdatedAt"]</span>
                                        <span class="audit-info-value">@AuditInfo.UpdatedAt.Value.ToString("yyyy/MM/dd HH:mm:ss")</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(AuditInfo.UpdatedBy))
                                {
                                    <div class="audit-info-row">
                                        <span class="audit-info-label">@L["Modal.UpdatedBy"]</span>
                                        <span class="audit-info-value">@AuditInfo.UpdatedBy</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                @* ===== Feature Guide Side Drawer（右側滑出操作說明面板） ===== *@
                @if (FeatureGuide != null)
                {
                    @* 點擊外部關閉用的透明遮罩 *@
                    @if (_showFeatureGuide)
                    {
                        <div class="feature-guide-overlay" @onclick="CloseFeatureGuide"></div>
                    }

                    <div class="feature-guide-drawer @(_showFeatureGuide ? "open" : "")">
                        @* 左側書籤標籤（從 Sections 自動產生） *@
                        @if (FeatureGuide.Sections.Count > 0)
                        {
                            <div class="feature-guide-bookmarks">
                                @foreach (var sec in FeatureGuide.Sections)
                                {
                                    <button class="feature-guide-bookmark @(_activeBookmarkId == sec.Id ? "active" : "")"
                                            style="--bookmark-color: @sec.BookmarkColor;"
                                            title="@sec.BookmarkLabel"
                                            @onclick="@(() => ScrollToBookmark(sec.Id))">
                                        <span class="feature-guide-bookmark-text">@sec.BookmarkLabel</span>
                                    </button>
                                }
                            </div>
                        }

                        <div class="feature-guide-main">
                            <div class="feature-guide-header">
                                <h6 class="feature-guide-title">
                                    <i class="bi bi-book me-2"></i>@L["Modal.FeatureGuideTitle"]
                                </h6>
                                <button class="feature-guide-close-btn"
                                        @onclick="CloseFeatureGuide"
                                        title="@L["Button.Close"]">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                            <div class="feature-guide-body" @ref="_guideBodyRef">
                                <FeatureGuideRenderer Definition="@FeatureGuide" ActiveSectionId="@_activeBookmarkId" />
                            </div>

                            @* Debug Bar：顯示定義檔路徑（僅 SuperAdmin） *@
                            @if (_isSuperAdmin && !string.IsNullOrEmpty(FeatureGuide.SourceFile))
                            {
                                var fileName = System.IO.Path.GetFileName(FeatureGuide.SourceFile);
                                <div class="feature-guide-debug"
                                     title="@FeatureGuide.SourceFile"
                                     @onclick="() => CopyTextAsync(fileName!)"
                                     @onclick:stopPropagation="true">
                                    🔧 @fileName
                                </div>
                            }
                        </div>
                    </div>
                }

                @* ===== Debug Info (僅 SuperAdmin 可見) ===== *@
                @if (_isSuperAdmin && !string.IsNullOrEmpty(DebugComponentName))
                {
                    var debugParts = DebugComponentName.Split(" > ", StringSplitOptions.RemoveEmptyEntries);
                    <div class="px-3 py-1 border-top d-flex align-items-center gap-1"
                         style="background:#1a1a2e; font-size:1rem; font-family:monospace; letter-spacing:0.03em; user-select:text;">
                        🔧 <strong style="color:#f8c8a0;">SuperAdmin</strong>
                        @for (int i = 0; i < debugParts.Length; i++)
                        {
                            var part = debugParts[i];
                            if (i > 0)
                            {
                                <span style="color:#555; margin:0 2px;">›</span>
                            }
                            <span style="color:#7ec8e3; cursor:pointer;"
                                  title="點擊複製：@part"
                                  @onclick="() => CopyTextAsync(part)"
                                  @onclick:stopPropagation="true">@part</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    
    @* Modal Backdrop *@
    <div class="modal-backdrop fade show" style="z-index: @GetBackdropZIndex();"></div>
}

@code {
    // ===== 參數定義 =====
    
    /// <summary>
    /// Modal 是否顯示
    /// </summary>
    [Parameter]
    public bool IsVisible { get; set; }
    
    /// <summary>
    /// Modal 顯示狀態變更事件
    /// </summary>
    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }
    
    /// <summary>
    /// Modal 標題
    /// </summary>
    [Parameter]
    public string Title { get; set; } = string.Empty;
    
    /// <summary>
    /// 標題圖示 (Bootstrap Icons 或 Font Awesome)
    /// 例如: "bi bi-pencil" 或 "fas fa-edit"
    /// </summary>
    [Parameter]
    public string Icon { get; set; } = string.Empty;
    
    /// <summary>
    /// Modal 尺寸
    /// </summary>
    [Parameter]
    public ModalSize Size { get; set; } = ModalSize.Desktop;
    
    /// <summary>
    /// 是否顯示關閉按鈕
    /// </summary>
    [Parameter]
    public bool ShowCloseButton { get; set; } = true;
    
    /// <summary>
    /// 點擊背景是否關閉 Modal
    /// </summary>
    [Parameter]
    public bool CloseOnBackdropClick { get; set; } = true;
    
    /// <summary>
    /// 按下 ESC 鍵是否關閉 Modal
    /// </summary>
    [Parameter]
    public bool CloseOnEscape { get; set; } = true;
    
    /// <summary>
    /// 是否顯示載入中狀態
    /// </summary>
    [Parameter]
    public bool IsLoading { get; set; } = false;
    
    /// <summary>
    /// 載入中訊息
    /// </summary>
    [Parameter]
    public string LoadingMessage { get; set; } = "載入中...";
    
    /// <summary>
    /// 錯誤訊息（如果有值會顯示錯誤畫面）
    /// </summary>
    [Parameter]
    public string ErrorMessage { get; set; } = string.Empty;
    
    /// <summary>
    /// 是否顯示 Footer
    /// </summary>
    [Parameter]
    public bool ShowFooter { get; set; } = false;
    
    /// <summary>
    /// Body 額外 CSS 類別
    /// </summary>
    [Parameter]
    public string BodyCssClass { get; set; } = string.Empty;
    
    /// <summary>
    /// 審計資訊（用於 Footer 顯示）
    /// </summary>
    [Parameter]
    public ModalAuditInfo? AuditInfo { get; set; }

    /// <summary>
    /// 組件名稱（僅 SuperAdmin 可見，用於快速定位 .razor 檔案）
    /// 建議傳入 nameof 或直接寫字串，例如：DebugComponentName="PurchaseOrderEditModalComponent"
    /// </summary>
    [Parameter]
    public string? DebugComponentName { get; set; }

    /// <summary>
    /// 是否顯示全景模式切換按鈕（Modal 內展開至視窗全螢幕）
    /// </summary>
    [Parameter]
    public bool AllowFullscreen { get; set; } = false;

    /// <summary>
    /// 是否啟用 Body 捲動（Bootstrap modal-dialog-scrollable）
    /// </summary>
    [Parameter]
    public bool ScrollableBody { get; set; } = false;

    // ===== RenderFragment 參數 =====
    
    /// <summary>
    /// Header 自訂按鈕區（顯示在標題右側、關閉按鈕左側）
    /// </summary>
    [Parameter]
    public RenderFragment? HeaderButtons { get; set; }
    
    /// <summary>
    /// Modal 主要內容區（必填）
    /// </summary>
    [Parameter]
    public RenderFragment? BodyContent { get; set; }
    
    /// <summary>
    /// Footer 自訂內容（優先於 AuditInfo）
    /// </summary>
    [Parameter]
    public RenderFragment? FooterContent { get; set; }

    /// <summary>
    /// 功能說明定義（數據驅動，自動渲染操作說明面板）
    /// 傳入 FeatureGuideDefinition 即可自動產生右側滑出面板、左側書籤
    /// </summary>
    [Parameter]
    public FeatureGuideDefinition? FeatureGuide { get; set; }
    
    // ===== 事件回呼 =====
    
    /// <summary>
    /// Modal 關閉事件
    /// </summary>
    [Parameter]
    public EventCallback OnClose { get; set; }
    
    /// <summary>
    /// Modal 開啟前事件
    /// </summary>
    [Parameter]
    public EventCallback OnOpening { get; set; }
    
    /// <summary>
    /// Modal 開啟後事件
    /// </summary>
    [Parameter]
    public EventCallback OnOpened { get; set; }
    
    // ===== 私有欄位 =====
    
    private bool _lastVisible = false;
    private bool _isSuperAdmin = false;
    private bool _isModalFullscreen = false;
    private bool _showAuditInfo = false;
    private bool _showFeatureGuide = false;
    private string? _activeBookmarkId = null;
    private ElementReference _guideBodyRef;
    private DotNetObjectReference<BaseModalComponent>? _escKeyDotNetRef;
    private bool _isEscKeyListenerActive = false;
    private bool _isDisposed = false;
    private readonly object _escKeyLock = new object();
    
    // z-index 管理（靜態變數，所有 Modal 共享）
    private static int _currentZIndexBase = 1050;
    private static readonly object _zIndexLock = new object();
    private int _myZIndex = 1050;
    
    // ===== 生命週期方法 =====
    
    protected override async Task OnParametersSetAsync()
    {
        // Modal 剛打開
        if (IsVisible && !_lastVisible)
        {
            _lastVisible = true;

            // 分配新的 z-index
            lock (_zIndexLock)
            {
                _currentZIndexBase += 10; // 每個新 Modal 增加 10，留出空間給 backdrop
                _myZIndex = _currentZIndexBase;
            }

            // 查詢 SuperAdmin 狀態（有快取，效能無虞）
            if (!string.IsNullOrEmpty(DebugComponentName))
            {
                _isSuperAdmin = await NavigationPermissionService.IsCurrentEmployeeSuperAdminAsync();
            }

            if (OnOpening.HasDelegate)
            {
                await OnOpening.InvokeAsync();
            }
        }
        // Modal 剛關閉
        else if (!IsVisible && _lastVisible)
        {
            _lastVisible = false;
            _isModalFullscreen = false;
            _showFeatureGuide = false;

            // 釋放 z-index（遞減回去）
            lock (_zIndexLock)
            {
                _currentZIndexBase -= 10;
                // 確保不會低於基礎值
                if (_currentZIndexBase < 1050)
                {
                    _currentZIndexBase = 1050;
                }
            }
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsVisible)
        {
            // 設置 ESC 鍵監聽器
            if (CloseOnEscape)
            {
                bool shouldSetup;
                lock (_escKeyLock)
                {
                    shouldSetup = !_isEscKeyListenerActive;
                }
                
                if (shouldSetup)
                {
                    await SetupEscKeyListenerAsync();
                }
            }
            
            // 觸發開啟後事件
            if (firstRender && OnOpened.HasDelegate)
            {
                await OnOpened.InvokeAsync();
            }
        }
        else
        {
            // 清理 ESC 鍵監聽器
            bool shouldCleanup;
            lock (_escKeyLock)
            {
                shouldCleanup = _isEscKeyListenerActive;
            }
            
            if (shouldCleanup)
            {
                await CleanupEscKeyListenerAsync();
            }
        }
    }
    
    // ===== 事件處理方法 =====
    
    /// <summary>
    /// 處理關閉按鈕點擊
    /// </summary>
    private async Task HandleClose()
    {
        await CloseModal();
    }
    
    /// <summary>
    /// 處理背景點擊
    /// </summary>
    private async Task HandleBackdropClick()
    {
        if (CloseOnBackdropClick)
        {
            await CloseModal();
        }
    }
    
    /// <summary>
    /// 關閉 Modal
    /// </summary>
    private async Task CloseModal()
    {
        try
        {
            if (_isDisposed)
            {
                return;
            }
            
            if (OnClose.HasDelegate)
            {
                await OnClose.InvokeAsync();
            }
            
            if (IsVisibleChanged.HasDelegate)
            {
                await IsVisibleChanged.InvokeAsync(false);
            }
        }
        catch (ObjectDisposedException)
        {
            // 忽略已釋放物件的錯誤
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"CloseModal Error: {ex.Message}");
        }
    }
    
    // ===== ESC 鍵處理 =====
    
    /// <summary>
    /// 設置 ESC 鍵監聽器
    /// </summary>
    private async Task SetupEscKeyListenerAsync()
    {
        try
        {
            lock (_escKeyLock)
            {
                if (_isEscKeyListenerActive && _escKeyDotNetRef != null)
                {
                    return;
                }
                
                _isEscKeyListenerActive = true;
            }
            
            lock (_escKeyLock)
            {
                _escKeyDotNetRef = DotNetObjectReference.Create(this);
            }
            
            await JSRuntime.InvokeVoidAsync("setupEscKeyListener", _escKeyDotNetRef);
        }
        catch (Exception ex)
        {
            lock (_escKeyLock)
            {
                _isEscKeyListenerActive = false;
            }
            LogError("SetupEscKeyListener", ex);
        }
    }
    
    /// <summary>
    /// 清理 ESC 鍵事件監聽器
    /// </summary>
    private async Task CleanupEscKeyListenerAsync()
    {
        DotNetObjectReference<BaseModalComponent>? refToDispose = null;
        
        lock (_escKeyLock)
        {
            if (!_isEscKeyListenerActive)
            {
                return;
            }
            
            _isEscKeyListenerActive = false;
            refToDispose = _escKeyDotNetRef;
            _escKeyDotNetRef = null;
        }
        
        try
        {
            await JSRuntime.InvokeVoidAsync("cleanupEscKeyListener");
            await Task.Delay(200);
            
            if (refToDispose != null)
            {
                try
                {
                    refToDispose.Dispose();
                }
                catch (ObjectDisposedException)
                {
                    // 對象已被釋放，這是正常的
                }
                catch (Exception ex)
                {
                    LogError($"DotNetObjectReference dispose warning (safe to ignore): {ex.Message}", ex);
                }
            }
        }
        catch (JSDisconnectedException)
        {
            // Blazor 連接已斷開，這是正常的
        }
        catch (TaskCanceledException)
        {
            // 任務被取消，這是正常的
        }
        catch (Exception ex)
        {
            LogError("CleanupEscKeyListener", ex);
        }
    }
    
    /// <summary>
    /// 處理 ESC 鍵按下事件（由 JavaScript 調用）
    /// </summary>
    [JSInvokable]
    public async Task HandleEscapeKey()
    {
        try
        {
            if (_isDisposed)
            {
                return;
            }
            
            if (IsVisible && CloseOnEscape)
            {
                if (_showFeatureGuide)
                {
                    CloseFeatureGuide();
                    StateHasChanged();
                }
                else
                {
                    await HandleClose();
                }
            }
        }
        catch (ObjectDisposedException)
        {
            // 忽略已釋放物件的錯誤
        }
        catch (InvalidOperationException)
        {
            // 忽略無效操作錯誤
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"ESC Error: {ex.Message}");
        }
    }
    
    // ===== 輔助方法 =====
    
    /// <summary>
    /// 取得 Modal 的 z-index
    /// </summary>
    private int GetModalZIndex()
    {
        return _myZIndex;
    }
    
    /// <summary>
    /// 取得 Backdrop 的 z-index（比 Modal 少 1）
    /// </summary>
    private int GetBackdropZIndex()
    {
        return _myZIndex - 1;
    }
    
    /// <summary>
    /// 取得 Modal 尺寸 CSS 類別
    /// </summary>
    private string GetModalSizeClass()
    {
        if (_isModalFullscreen)
            return "modal-fullscreen";

        var sizeClass = Size switch
        {
            ModalSize.Small => "modal-sm",
            ModalSize.Default => "",
            ModalSize.Large => "modal-lg",
            ModalSize.ExtraLarge => "modal-xl",
            ModalSize.Desktop => "modal-xl modal-desktop",
            _ => "modal-lg"
        };

        return ScrollableBody ? $"{sizeClass} modal-dialog-scrollable" : sizeClass;
    }

    /// <summary>
    /// 取得 Modal Dialog 的 inline style（全景模式時清空，讓 Bootstrap modal-fullscreen 接管）
    /// </summary>
    private string GetModalDialogStyle()
    {
        if (_isModalFullscreen)
            return string.Empty;
        return "position: relative; margin: 1.5rem auto;";
    }

    /// <summary>
    /// 切換 Modal 全景模式
    /// </summary>
    private void ToggleModalFullscreen()
    {
        _isModalFullscreen = !_isModalFullscreen;
    }
    
    
    /// <summary>
    /// 點擊 modal-content 時關閉所有彈出元素（審計 popup 等）
    /// </summary>
    private void DismissPopups()
    {
        if (_showAuditInfo)
        {
            _showAuditInfo = false;
        }
    }

    /// <summary>
    /// 切換功能說明面板（打開時自動選中第一個書籤）
    /// </summary>
    private void ToggleFeatureGuide()
    {
        _showFeatureGuide = !_showFeatureGuide;
        if (_showFeatureGuide && FeatureGuide?.Sections.Count > 0)
        {
            _activeBookmarkId ??= FeatureGuide.Sections[0].Id;
        }
        else if (!_showFeatureGuide)
        {
            _activeBookmarkId = null;
        }
    }

    /// <summary>
    /// 關閉功能說明面板並重置書籤狀態
    /// </summary>
    private void CloseFeatureGuide()
    {
        _showFeatureGuide = false;
        _activeBookmarkId = null;
    }

    /// <summary>
    /// 滾動到指定書籤章節
    /// </summary>
    private async Task ScrollToBookmark(string targetId)
    {
        _activeBookmarkId = targetId;
        try
        {
            await JSRuntime.InvokeVoidAsync("eval",
                $"document.getElementById('{targetId}')?.scrollIntoView({{ behavior: 'smooth', block: 'start' }})");
        }
        catch
        {
            // 忽略 JS 錯誤
        }
    }

    /// <summary>
    /// 複製指定文字到剪貼簿（方式一：點擊 Debug Bar 各分段）
    /// </summary>
    private async Task CopyTextAsync(string text)
    {
        if (!string.IsNullOrEmpty(text))
            await JSRuntime.InvokeVoidAsync("DebugHelper.copyText", text);
    }

    /// <summary>
    /// 記錄錯誤
    /// </summary>
    private void LogError(string method, Exception ex)
    {
        System.Diagnostics.Debug.WriteLine($"[BaseModalComponent.{method}] 錯誤：{ex.Message}");
    }
    
    // ===== 資源清理 =====
    
    public void Dispose()
    {
        try
        {
            bool wasListenerActive;
            DotNetObjectReference<BaseModalComponent>? refToDispose = null;
            
            lock (_escKeyLock)
            {
                _isDisposed = true;
                wasListenerActive = _isEscKeyListenerActive;
                _isEscKeyListenerActive = false;
                refToDispose = _escKeyDotNetRef;
                _escKeyDotNetRef = null;
            }
            
            // 關鍵修復：如果 ESC 監聽器仍在活動中，需要通知 JS 清理堆疊
            // 之前的 bug：先設 _isEscKeyListenerActive=false 再呼叫 CleanupEscKeyListenerAsync，
            // 但 CleanupEscKeyListenerAsync 檢查到 flag 為 false 就直接 return，
            // 導致 JS escKeyDotNetHelpers 堆疊殘留失效的引用，後續 ESC 全部失效。
            if (wasListenerActive)
            {
                _ = Task.Run(async () =>
                {
                    try
                    {
                        await JSRuntime.InvokeVoidAsync("cleanupEscKeyListener");
                        await Task.Delay(200);
                    }
                    catch
                    {
                        // Blazor 連接可能已斷開，忽略錯誤
                    }
                });
            }
            
            // 延遲釋放 DotNetObjectReference，讓 JS 端先完成清理
            if (refToDispose != null)
            {
                _ = Task.Run(async () =>
                {
                    try
                    {
                        await Task.Delay(300);
                        refToDispose.Dispose();
                    }
                    catch
                    {
                        // 忽略釋放過程中的錯誤
                    }
                });
            }
        }
        catch
        {
            // 忽略清理過程中的錯誤
        }
    }
    
