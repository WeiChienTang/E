@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode())
@using Microsoft.AspNetCore.Components.Authorization
@using ERPCore2.Components.Shared
@using ERPCore2.Components.Shared.UI.Auth
@using ERPCore2.Data.Navigation
@using ERPCore2.Services
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject INavigationPermissionService PermissionService
@inject ICompanyModuleService CompanyModuleService
@inject IEmployeePreferenceService EmployeePreferenceService
@inject IEmployeeService EmployeeService
@inject ERPCore2.Services.CustomTables.ICustomTableDefinitionService CustomTableDefinitionService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> L
@implements IDisposable

<CascadingValue Value="@this" Name="NavMenuInstance">
<div class="nav-menu-container">
    @* 選單切換用 Checkbox（透明，由 label 觸發）*@
    <input type="checkbox" title="Navigation menu" class="navbar-toggler" id="nav-toggle" />

    @* 手機版固定頂部列（漢堡按鈕列） *@
    <div class="top-row">
        <label for="nav-toggle" class="navbar-toggler-label" title="@L["Nav.ToggleNav"]">
            <i class="bi bi-list"></i>
        </label>
    </div>

    @* 手機版半透明遮罩（點擊可關閉抽屜） *@
    <div class="nav-backdrop" @onclick="HandleBackdropClick"></div>

    <div class="nav-scrollable">
        @* 使用者資訊區 - 固定在頂部 *@
        <AuthorizeView>
            <Authorized>
                @{
                    var userName = context.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
                        ?? context.User.Identity?.Name
                        ?? L["Nav.DefaultUser"].ToString();
                    var userInitial = !string.IsNullOrEmpty(userName) ? userName[0].ToString().ToUpper() : "U";
                }
                <div class="nav-user-section">
                    <div class="nav-user-toggle" @onclick="ToggleUserMenu">
                        @if (!string.IsNullOrEmpty(_currentUserPhotoPath))
                        {
                            <img src="@_currentUserPhotoPath" class="nav-user-avatar nav-user-avatar-photo" alt="@userName" />
                        }
                        else
                        {
                            <div class="nav-user-avatar">@userInitial</div>
                        }
                        <span class="nav-user-name">@userName</span>
                        <i class="bi bi-chevron-down nav-user-chevron @(isUserMenuOpen ? "open" : "")"></i>
                    </div>
                    <div class="nav-user-dropdown @(isUserMenuOpen ? "show" : "")">
                        <div class="nav-user-dropdown-item" @onclick="HandlePersonalPreference">
                            <i class="bi bi-person"></i>
                            <span>@L["Nav.PersonalData"]</span>
                        </div>
                        <a class="nav-user-dropdown-item" href="/auth/signout" @onclick="CloseUserMenu">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>@L["Nav.SignOut"]</span>
                        </a>
                    </div>
                </div>
            </Authorized>
            <NotAuthorized>
                <NavMenuItem Text="@L["Nav.SignIn"]"
                            IconClass="bi bi-box-arrow-in-right"
                            Url="/auth/login" />
            </NotAuthorized>
        </AuthorizeView>

        <nav class="nav flex-column">
            @if (isInitialized)
            {
                @foreach (var menuItem in filteredMenuGroups)
                {
                    var isModuleDisabled = !string.IsNullOrEmpty(menuItem.ModuleKey) && _disabledModuleKeys.Contains(menuItem.ModuleKey);
                    var itemDisplayName = menuItem.NameKey != null ? L[menuItem.NameKey].ToString() : menuItem.Name;

                    @if (isModuleDisabled)
                    {
                        <!-- 模組已停用：灰色鎖定顯示 -->
                        <div class="nav-item px-3 nav-module-disabled" title="@L["Nav.ModuleDisabled"]">
                            <div class="nav-menu-dropdown-toggle-btn">
                                <span class="@menuItem.IconClass" aria-hidden="true"></span>
                                <span class="nav-menu-item-text">@itemDisplayName</span>
                                <span class="nav-module-disabled-badge">
                                    <span class="bi bi-lock-fill"></span>
                                </span>
                            </div>
                        </div>
                    }
                    else if (menuItem.IsParent && menuItem.Children.Any())
                    {
                        <!-- 有子選單的項目 -->
                        <NavMenuItem Text="@itemDisplayName"
                                    IconClass="@menuItem.IconClass"
                                    MenuKey="@menuItem.MenuKey"
                                    AutoDetectPermissions="false">
                            <DropdownItems>
                                @foreach (var child in menuItem.Children)
                                {
                                    <NavDropdownItem Text="@(child.NameKey != null ? L[child.NameKey].ToString() : child.Name)"
                                                   Url="@child.Route"
                                                   ItemType="@child.ItemType"
                                                   ActionId="@child.ActionId"
                                                   RequiredPermission="@child.RequiredPermission"
                                                   ParentMenuKey="@menuItem.MenuKey"
                                                   IconClass="@child.IconClass"
                                                   IconColorClass="@child.IconColorClass"
                                                   IsDivider="@child.IsDivider" />
                                }
                            </DropdownItems>
                        </NavMenuItem>
                    }
                    else
                    {
                        <!-- 單一連結項目 -->
                        <NavMenuItem Text="@itemDisplayName"
                                    IconClass="@menuItem.IconClass"
                                    Url="@menuItem.Route"
                                    AutoDetectPermissions="false" />
                    }
                }
            }
        </nav>

    </div>
</div>
</CascadingValue>

@code {
    // ===== 參數 =====

    /// <summary>
    /// 動作觸發事件
    /// </summary>
    [Parameter]
    public EventCallback<string> OnActionTriggered { get; set; }

    // ===== 使用者選單狀態 =====

    private bool isUserMenuOpen = false;

    private void ToggleUserMenu() => isUserMenuOpen = !isUserMenuOpen;

    private void CloseUserMenu() => isUserMenuOpen = false;

    private async Task HandlePersonalPreference()
    {
        isUserMenuOpen = false;
        await TriggerActionAsync("OpenPersonalPreference");
        // 手機模式下收合導航選單
        await JSRuntime.InvokeVoidAsync("navMenuMobile.hideNavMenu");
    }

    private async Task HandleBackdropClick()
    {
        await JSRuntime.InvokeVoidAsync("navMenuMobile.hideNavMenu");
    }

    // ===== 私有欄位 =====

    private bool isInitialized = false;
    private List<NavigationItem> filteredMenuGroups = new();
    private HashSet<string> _disabledModuleKeys = new();
    private bool _showDisabledModules = false;
    private string? _currentUserPhotoPath = null;

    // ===== 生命週期方法 =====

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        // 在初始化時過濾出有權限的選單項目
        await FilterMenuGroupsAsync();
        isInitialized = true;
    }

    /// <summary>
    /// 過濾選單群組，只保留使用者有權限訪問的項目
    /// </summary>
    private async Task FilterMenuGroupsAsync()
    {
        var allMenuGroups = NavigationConfig.GetMenuGroups();
        filteredMenuGroups = new List<NavigationItem>();

        // 取得當前員工ID
        var currentEmployeeId = await PermissionService.GetCurrentEmployeeIdAsync();

        // 檢查是否為系統管理員
        bool isAdmin = await PermissionService.CanAccessAsync("System.Admin");

        // 載入使用者照片
        if (currentEmployeeId > 0)
        {
            var emp = await EmployeeService.GetByIdAsync(currentEmployeeId);
            _currentUserPhotoPath = emp?.PhotoPath;
        }

        // 載入停用模組清單（SuperAdmin 略過，因為對他們全部啟用）
        if (!isAdmin)
        {
            var allModules = await CompanyModuleService.GetAllAsync();
            _disabledModuleKeys = allModules
                .Where(m => !m.IsEnabled)
                .Select(m => m.ModuleKey)
                .ToHashSet();

            // 載入使用者偏好：是否顯示停用模組
            if (currentEmployeeId > 0)
            {
                var pref = await EmployeePreferenceService.GetByEmployeeIdAsync(currentEmployeeId);
                _showDisabledModules = pref.ShowDisabledModules;
            }
        }

        foreach (var menuGroup in allMenuGroups)
        {
            if (menuGroup.IsParent && menuGroup.Children.Any())
            {
                // 父選單有 ModuleKey 且模組已停用
                bool isModuleDisabled = !string.IsNullOrEmpty(menuGroup.ModuleKey)
                    && _disabledModuleKeys.Contains(menuGroup.ModuleKey);

                if (isModuleDisabled)
                {
                    if (_showDisabledModules)
                    {
                        // 顯示為停用狀態（不過濾子項目，無論如何都不可點）
                        filteredMenuGroups.Add(menuGroup);
                    }
                    // else: 完全隱藏，跳過
                    continue;
                }

                // 過濾子項目
                var filteredChildren = new List<NavigationItem>();

                foreach (var child in menuGroup.Children)
                {
                    // 如果是分隔線，先暫存
                    if (child.IsDivider)
                    {
                        filteredChildren.Add(child);
                        continue;
                    }

                    // 檢查權限
                    bool hasPermission = false;

                    if (isAdmin)
                    {
                        hasPermission = true;
                    }
                    else if (string.IsNullOrEmpty(child.RequiredPermission))
                    {
                        // 沒有權限要求的項目，所有人都可訪問
                        hasPermission = true;
                    }
                    else
                    {
                        // 檢查是否有特定權限
                        hasPermission = await PermissionService.CanAccessAsync(child.RequiredPermission);
                    }

                    if (hasPermission)
                    {
                        filteredChildren.Add(child);
                    }
                }

                // 移除開頭和結尾的分隔線，以及連續的分隔線
                filteredChildren = CleanDividers(filteredChildren);

                // 如果有子項目（不包含只有分隔線的情況），則加入父選單
                if (filteredChildren.Any(c => !c.IsDivider))
                {
                    var filteredMenuGroup = new NavigationItem
                    {
                        Name = menuGroup.Name,
                        NameKey = menuGroup.NameKey,
                        IconClass = menuGroup.IconClass,
                        IsParent = menuGroup.IsParent,
                        MenuKey = menuGroup.MenuKey,
                        ModuleKey = menuGroup.ModuleKey,
                        Route = menuGroup.Route,
                        Children = filteredChildren
                    };

                    filteredMenuGroups.Add(filteredMenuGroup);
                }
            }
            else
            {
                // 單一項目，檢查權限
                bool hasPermission = false;

                if (isAdmin)
                {
                    hasPermission = true;
                }
                else if (string.IsNullOrEmpty(menuGroup.RequiredPermission))
                {
                    // 沒有權限要求的項目，所有人都可訪問（如首頁）
                    hasPermission = true;
                }
                else
                {
                    // 檢查是否有特定權限
                    hasPermission = await PermissionService.CanAccessAsync(menuGroup.RequiredPermission);
                }

                if (hasPermission)
                {
                    filteredMenuGroups.Add(menuGroup);
                }
            }
        }

        // ── 動態注入自訂資料表到導航群組 ──────────────────────
        bool canSeeCustomTables = isAdmin ||
            await PermissionService.CanAccessAsync(PermissionRegistry.System.CustomTable);

        if (canSeeCustomTables)
        {
            var allCustomTables = await CustomTableDefinitionService.GetAllAsync();
            var navTables = allCustomTables
                .Where(t => t.Status == ERPCore2.Models.Enums.EntityStatus.Active
                         && !string.IsNullOrEmpty(t.NavigationGroupKey))
                .ToList();

            foreach (var table in navTables)
            {
                var parentGroup = filteredMenuGroups
                    .FirstOrDefault(g => g.MenuKey == table.NavigationGroupKey && g.IsParent);

                if (parentGroup?.Children == null) continue;

                // 加分隔線（若最後一個項目不是分隔線）
                if (parentGroup.Children.Any() && !parentGroup.Children.Last().IsDivider)
                    parentGroup.Children.Add(new NavigationItem { IsDivider = true });

                parentGroup.Children.Add(new NavigationItem
                {
                    Name = table.TableName,
                    Route = $"/custom-tables/{table.Id}",
                    IconClass = table.IconClass ?? "bi bi-table",
                    ItemType = NavigationItemType.Route,
                    RequiredPermission = PermissionRegistry.System.CustomTable,
                    Category = parentGroup.Category ?? string.Empty
                });
            }
        }
    }

    /// <summary>
    /// 清理分隔線：移除開頭、結尾和連續的分隔線
    /// </summary>
    private List<NavigationItem> CleanDividers(List<NavigationItem> items)
    {
        if (!items.Any()) return items;

        var result = new List<NavigationItem>();
        bool lastWasDivider = true; // 初始化為 true 以移除開頭的分隔線

        foreach (var item in items)
        {
            if (item.IsDivider)
            {
                if (!lastWasDivider)
                {
                    result.Add(item);
                    lastWasDivider = true;
                }
            }
            else
            {
                result.Add(item);
                lastWasDivider = false;
            }
        }

        // 移除結尾的分隔線
        while (result.Any() && result.Last().IsDivider)
        {
            result.RemoveAt(result.Count - 1);
        }

        return result;
    }

    // ===== 事件處理 =====

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        isUserMenuOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    /// <summary>
    /// 觸發導航動作
    /// </summary>
    public async Task TriggerActionAsync(string actionId)
    {
        if (OnActionTriggered.HasDelegate)
        {
            await OnActionTriggered.InvokeAsync(actionId);
        }
    }

    /// <summary>
    /// 重新載入當前使用者照片並更新頭像，供 MainLayout 在照片變更後呼叫
    /// </summary>
    public async Task RefreshAvatarAsync()
    {
        var currentEmployeeId = await PermissionService.GetCurrentEmployeeIdAsync();
        if (currentEmployeeId > 0)
        {
            var emp = await EmployeeService.GetByIdAsync(currentEmployeeId);
            _currentUserPhotoPath = emp?.PhotoPath;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ShowUnderConstructionMessage()
    {
        await JSRuntime.InvokeVoidAsync("alert", L["Nav.UnderConstruction"].ToString());
    }
}
