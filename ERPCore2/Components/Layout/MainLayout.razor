    /// <summary>
    /// 開啟便條貼面板（與行事曆互斥）
    /// </summary>
    [JSInvokable]
    public void OpenStickyNotes()
    {
        try
        {
            showCalendar = false;
            showStickyNotes = !showStickyNotes;
            StateHasChanged();
        }
        catch
        {
            // 忽略開啟便條貼失敗
        }
    }

    /// <summary>
    /// 開啟行事曆面板（與便條貼互斥）
    /// </summary>
    [JSInvokable]
    public void OpenCalendar()
    {
        try
        {
            showStickyNotes = false;
            showCalendar = !showCalendar;
            StateHasChanged();
        }
        catch
