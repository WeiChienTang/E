    /// <summary>
    /// 處理報表中心選擇的報表
    /// 當使用者在報表中心點擊列印按鈕時觸發
    /// </summary>
    private async Task HandleReportSelected(string actionId)
    {
        // 從 ActionId 查找對應的 ReportDefinition
        var reportDef = Data.ReportRegistry.GetAllReports()
            .FirstOrDefault(r => r.ActionId == actionId);

        if (reportDef == null)
            return;

        // 若報表有 ModuleKey，檢查公司層級模組是否啟用（IsSuperAdmin 自動繞過）
        if (!string.IsNullOrEmpty(reportDef.ModuleKey))
        {
            var moduleEnabled = await NavigationPermissionService.IsModuleEnabledAsync(reportDef.ModuleKey);
            if (!moduleEnabled)
            {
                _showModuleDisabledModal = true;
                StateHasChanged();
                return;
            }
        }

        // 若報表有 RequiredPermission，檢查使用者是否有對應權限（SuperAdmin 自動繞過）
        if (!string.IsNullOrEmpty(reportDef.RequiredPermission))
        {
            var hasPermission = await NavigationPermissionService.CanAccessAsync(reportDef.RequiredPermission);
            if (!hasPermission)
                return;
        }

        // 檢查是否有對應的篩選模板配置
        if (Models.Reports.FilterTemplates.FilterTemplateRegistry.HasConfig(reportDef.Id))
        {
            // 使用新的通用篩選 Modal
            currentFilterReportId = reportDef.Id;
            StateHasChanged();
            return;
        }

        // 沒有篩選配置，使用舊的 ActionHandlerRegistry 執行
        actionRegistry?.Execute(actionId);
    }
    
    /// <summary>
    /// 處理篩選 Modal 列印成功事件
    /// </summary>
    private void HandleFilterPrintSuccess()
    {
        currentFilterReportId = string.Empty;
        StateHasChanged();
    }
    
    // ===== 搜尋函數 =====
    
    /// <summary>
    /// 搜尋導航項目（頁面搜尋用）
    /// </summary>
    private List<ISearchableItem> SearchNavigationItems(string searchTerm)
    {
        return NavigationSearchService.SearchNavigationItems(searchTerm)
            .Where(item => !item.IsParent && 
                (item.ItemType == NavigationItemType.Action || 
                 (!string.IsNullOrEmpty(item.Route) && item.Route != "#")))
            .Cast<ISearchableItem>()
            .ToList();
    }
    
    /// <summary>
    /// 搜尋報表（報表搜尋用）
    /// </summary>
    private List<ISearchableItem> SearchReports(string searchTerm)
    {
        return ReportSearchService.SearchReports(searchTerm, onlyEnabled: true)
            .Where(r => _allowedReportIds.Contains(r.ActionId ?? ""))
            .Cast<ISearchableItem>()
            .ToList();
    }
    
    // ===== 全域搜尋列處理 =====

    private void HandleSearchBarPageSelected(ISearchableItem item)
    {
        if (!string.IsNullOrEmpty(item.ActionId))
        {
            HandleNavigationAction(item.ActionId);
        }
    }

    private async Task HandleSearchBarReportSelected(ISearchableItem item)
    {
        if (!string.IsNullOrEmpty(item.ActionId))
        {
            await HandleReportSelected(item.ActionId);
        }
    }

    /// <summary>
    /// 處理導航動作觸發
    /// 執行前依序檢查：模組是否啟用、使用者是否有所需權限（SuperAdmin 自動繞過）
    /// </summary>
    private async void HandleNavigationAction(string actionId)
    {
        try
        {
            // 從扁平化導航清單中找到對應的 Action 項目
            var navItem = NavigationConfig.GetFlattenedNavigationItems()
                .FirstOrDefault(item => item.ItemType == NavigationItemType.Action && item.ActionId == actionId);

            // 若有 ModuleKey，檢查公司層級模組是否啟用（IsModuleEnabledAsync 內部已處理 SuperAdmin 繞過）
            // 注意：此處故意使用 IsModuleEnabledAsync 而非 CanAccessModuleAsync，
            //       ModuleKey 只做公司層級開關，用戶層級存取由下方 RequiredPermission 負責
            if (!string.IsNullOrEmpty(navItem?.ModuleKey))
            {
                var moduleEnabled = await NavigationPermissionService.IsModuleEnabledAsync(navItem.ModuleKey);
                if (!moduleEnabled)
                {
                    _showModuleDisabledModal = true;
                    StateHasChanged();
                    return;
                }
            }

            // 若有 RequiredPermission，檢查使用者是否有對應權限（CanAccessAsync 內部已處理 SuperAdmin 繞過）
            if (!string.IsNullOrEmpty(navItem?.RequiredPermission))
            {
                var hasPermission = await NavigationPermissionService.CanAccessAsync(navItem.RequiredPermission);
                if (!hasPermission)
                    return;
            }

            // 使用 ActionHandlerRegistry 執行 Action
            actionRegistry?.Execute(actionId);
        }
        catch
        {
            // 忽略執行失敗，避免影響 UI
        }
    }

    // ===== 通知 Timer 方法 =====

    /// <summary>
    /// 每分鐘檢查到期提醒（純記憶體，不查 DB）
    /// </summary>
    private async Task RunNotificationTimerAsync()
    {
        // 立即做一次檢查，不等第一分鐘
        try
        {
            var initialDue = await NotificationService.GetDueRemindersAsync();
            if (initialDue.Any())
            {
                foreach (var ev in initialDue)
                {
                    if (!_dueReminders.Any(r => r.Id == ev.Id))
                        _dueReminders.Add(ev);
                }
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { }

        _notificationTimer = new PeriodicTimer(TimeSpan.FromMinutes(1));
        try
        {
            while (await _notificationTimer.WaitForNextTickAsync(_timerCts.Token))
            {
                var due = await NotificationService.GetDueRemindersAsync();
                if (due.Any())
                {
                    foreach (var ev in due)
                    {
                        if (!_dueReminders.Any(r => r.Id == ev.Id))
                            _dueReminders.Add(ev);
                    }
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Timer 被取消，正常結束
        }
        catch
        {
            // 忽略其他 Timer 錯誤
        }
    }

    /// <summary>
    /// 通知服務快取變更時（CRUD 後）由此更新 UI
    /// </summary>
    private void HandleNotificationChanged()
    {
        _ = InvokeAsync(async () =>
        {
            // 強制刷新快取（RefreshIfNeededAsync 會看到 dirty flag 並查 DB）
            try { await NotificationService.GetDueRemindersAsync(); } catch { }
            StateHasChanged();
        });
    }

    /// <summary>
    /// 關閉單筆提醒 Toast
    /// </summary>
    private void DismissReminder(int eventId)
    {
        _dueReminders.RemoveAll(r => r.Id == eventId);
    }

    /// <summary>
    /// 清理資源
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        // 停止通知 Timer
        try
        {
            _timerCts.Cancel();
            _notificationTimer?.Dispose();
            NotificationService.OnChanged -= HandleNotificationChanged;
        }
        catch
        {
            // 忽略 Timer 清理錯誤
        }

        try
        {
            // 清理 JavaScript 快捷鍵監聽器
            await JSRuntime.InvokeVoidAsync("KeyboardShortcuts.dispose");
        }
        catch
        {
            // 忽略清理錯誤
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("cleanupFullscreenChangeListener");
        }
        catch
        {
            // 忽略清理錯誤
        }
        _dotNetRef?.Dispose();
    }
